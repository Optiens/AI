        extrasList.innerHTML = '';
        var extras = data.extracted_extras || {};
        var extraKeys = Object.keys(extras).filter(function(k) { return extras[k] && String(extras[k]).trim(); });
        if (extraKeys.length === 0) {
          extrasWrap.hidden = true;
        } else {
          extraKeys.forEach(function(k) {
            var dt = document.createElement('dt');
            dt.textContent = EXTRAS_LABELS[k] || k;
            var dd = document.createElement('dd');
            dd.textContent = extras[k];
            extrasList.appendChild(dt);
            extrasList.appendChild(dd);
          });
          extrasWrap.hidden = false;
        }
      }
      factWrap.hidden = false;
    }

    function applyFields(data) {
      var fields = data.fields || {};
      var setIf = function(id, val) {
        if (val) {
          var el = document.getElementById(id);
          if (el) {
            el.value = val;
            el.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
      };
      // 基本
      setIf('company_name', fields.company_name);
      setIf('person_name', fields.person_name);
      setIf('email', fields.email);
      setIf('industry', fields.industry);
      setIf('employee_count', fields.employee_count);
      setIf('business_description', fields.business_description);
      setIf('daily_tasks', fields.daily_tasks);
      setIf('current_tools', fields.current_tools);
      // 詳細レポート向け追加項目
      setIf('business_age', fields.business_age);
      setIf('service_area', fields.service_area);
      setIf('target_customer', fields.target_customer);
      setIf('annual_revenue_range', fields.annual_revenue_range);
      setIf('decision_timeline', fields.decision_timeline);
      setIf('past_it_experience', fields.past_it_experience);

      var filledCount = 0;
      Object.keys(fields).forEach(function(k) {
        if (fields[k] && String(fields[k]).trim()) filledCount++;
      });

      var msg;
      if (data.mock) {
        msg = 'モック応答（APIキー未設定）です。本番環境では実データから抽出されます。' + filledCount + '項目を反映しました。';
      } else if (filledCount === 0) {
        msg = '読み取り結果が空でした。情報源を変更して再度お試しください。';
      } else {
        msg = filledCount + '項目をフォームに反映しました。下記の確認内容と合わせてご確認・修正をお願いします。';
      }
      setStatus(msg, filledCount === 0 ? 'error' : 'info');

      // ファクトチェック表示
      renderFactCheck(data);
    }

    function postExtract(payload, btn, runningMsg) {
      if (extractUsed) {
        setStatus('自動読取は1回の申込につき画像1点またはURL1件までです。追加資料がある場合は、要点をフォームの自由記述に追記してください。', 'error');
        return;
      }
      var turnstileToken = requireTurnstileToken();
      if (turnstileToken === null) return;
      if (turnstileToken) payload.turnstileToken = turnstileToken;

      btn.disabled = true;
      setStatus(runningMsg, 'info');
      fetch('/api/file-extract', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.error) {
            setStatus(data.error, 'error');
          } else {
            extractUsed = true;
            applyFields(data);
          }
          resetTurnstileWidget();
          btn.disabled = false;
        })
        .catch(function(err) {
          console.error('[file-extract] fetch error:', err);
          setStatus('通信エラーが発生しました。時間をおいて再度お試しください。', 'error');
          resetTurnstileWidget();
          btn.disabled = false;
        });
    }

    // タブ切替
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var mode = tab.getAttribute('data-mode');
        tabs.forEach(function(t) {
          var on = t === tab;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        panels.forEach(function(p) {
          p.hidden = p.getAttribute('data-panel') !== mode;
        });
      });
    });

    // ファイル選択時のラベル更新
    if (fileUpload && fileNameLabel) {
      fileUpload.addEventListener('change', function() {
        var file = fileUpload.files && fileUpload.files[0];
        fileNameLabel.textContent = file ? file.name : 'ファイルを選択';
      });
    }

    // ファイル → 抽出
    if (extractFileBtn && fileUpload) {
      extractFileBtn.addEventListener('click', function() {
        var file = fileUpload.files && fileUpload.files[0];
        if (!file) {
          setStatus('ファイルを選択してください。', 'error');
          return;
        }
        if (file.size > 5 * 1024 * 1024) {
          setStatus('ファイルサイズが上限（5MB）を超えています。', 'error');
          return;
        }
        var reader = new FileReader();
        reader.onload = function() {
          var dataUrl = String(reader.result || '');
          var match = dataUrl.match(/^data:([^;]+);base64,(.+)$/);
          if (!match) {
            setStatus('ファイルの読み込みに失敗しました。', 'error');
            return;
          }
          postExtract(
            { fileBase64: match[2], mediaType: match[1], fileName: file.name },
            extractFileBtn,
            'AIが書類を読み取り中… 通常10〜30秒かかります。'
          );
        };
        reader.onerror = function() {
          setStatus('ファイルの読み込みに失敗しました。', 'error');
        };
        reader.readAsDataURL(file);
      });
    }

    // URL → 抽出
    if (extractUrlBtn && urlInput) {
      extractUrlBtn.addEventListener('click', function() {
        var url = urlInput.value.trim();
        if (!url) {
          setStatus('URLを入力してください。', 'error');
          return;
        }
        if (!/^https?:\/\//i.test(url)) {
          setStatus('http:// または https:// で始まるURLを入力してください。', 'error');
          return;
        }
        postExtract(
          { url: url },
          extractUrlBtn,
          'ページを読み取り中… 通常10〜30秒かかります。'
        );
      });
    }
  })();

</script>

