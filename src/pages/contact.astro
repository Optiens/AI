---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="お問い合わせ | Optiens（全国オンライン対応）"
  description="合同会社Optiensへのお問い合わせフォーム。AI業務自動化に関するご質問・ご相談を全国オンライン対応で承ります。"
  canonical="https://optiens.com/contact"
>
  <main class="contact-page light-section">
    <!-- 背景: アイソメトリック3Dグリッド（全ページ統一） -->

    <div class="container" style="position:relative;z-index:1;">
      <h1 class="reveal">お問い合わせ</h1>
      <p class="reveal">ご質問、ご意見、ご要望など、お気軽にお問い合わせください。</p>

      <p class="contact-tip reveal">
        ※「業務にAIが使えるか診断してほしい」場合は、<a href="/free-diagnosis">【簡易版】AI活用診断</a>のフォームをご利用いただくと、より具体的なレポートをお届けできます。
      </p>
      <p class="contact-intent-note reveal" id="contact-intent-note" hidden></p>

      <form action="/api/contact" method="POST" class="contact-form reveal" id="contact-form">
        <!-- いたずら防止: ハニーポット -->
        <div style="position:absolute;left:-9999px;" aria-hidden="true">
          <label for="website">ウェブサイト</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
        </div>
        <!-- いたずら防止: タイムスタンプ -->
        <input type="hidden" name="_t" id="_t">

        <div class="form-row">
          <div class="form-group">
            <label for="company_name">会社・団体名</label>
            <input type="text" id="company_name" name="company_name" placeholder="例: 株式会社〇〇">
          </div>
          <div class="form-group">
            <label for="person_name">お名前 <span class="req">*</span></label>
            <input type="text" id="person_name" name="person_name" required placeholder="例: 山田 太郎">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="email">メールアドレス <span class="req">*</span></label>
            <input type="email" id="email" name="email" required placeholder="example@company.com">
          </div>
          <div class="form-group">
            <label for="phone">電話番号</label>
            <input type="tel" id="phone" name="phone" placeholder="例: 090-1234-5678">
          </div>
        </div>

        <div class="form-group">
          <label for="inquiry_type">お問い合わせ種別</label>
          <select id="inquiry_type" name="inquiry_type">
            <option value="">選択してください</option>
            <option value="free-diagnosis-waitlist">【簡易版】AI活用診断の無料枠案内を受け取りたい</option>
            <option value="consult-ticket">AI活用レビュー面談・有償要件定義を相談したい</option>
            <option value="spot-ticket-urgent-payment">スポット相談チケットの入金確認を急ぎたい</option>
            <option value="ai-consult">AI支援事業について</option>
            <option value="press">取材・メディア掲載</option>
            <option value="partner">業務提携・パートナーシップ</option>
            <option value="other">その他</option>
          </select>
        </div>

        <div class="form-group">
          <label for="subject">件名 <span class="req">*</span></label>
          <input type="text" id="subject" name="subject" required>
        </div>

        <div class="form-group">
          <label for="message">内容 <span class="req">*</span></label>
          <textarea id="message" name="message" rows="8" required></textarea>
        </div>

        <p class="form-note">
          ご入力いただいた情報はお問い合わせ対応のみに使用します。<a href="/privacy-policy">プライバシーポリシー</a>をご確認ください。
        </p>

        <button type="submit" class="btn-primary contact-submit-btn" id="contact-submit">送信</button>
      </form>
    </div>
  </main>
</Layout>

<script is:inline>
// タイムスタンプ設定（いたずら防止）
(function() {
  const t = document.getElementById('_t');
  if (t) t.value = String(Date.now());
})();

// URLパラメータから問い合わせ意図を反映
(function() {
  const params = new URLSearchParams(window.location.search);
  const topic = params.get('topic');
  const presets = {
    'free-diagnosis-waitlist': {
      type: 'free-diagnosis-waitlist',
      subject: '【簡易版】AI活用診断の無料枠案内を希望',
      message: '【簡易版】AI活用診断の無料枠が再開した際に案内を希望します。',
      note: '【簡易版】AI活用診断の無料枠案内として受付します。'
    },
    'consult-ticket': {
      type: 'consult-ticket',
      subject: 'AI活用レビュー面談・有償要件定義の相談',
      message: 'AI活用レビュー面談または有償要件定義について相談したいです。',
      note: 'AI活用レビュー面談・有償要件定義のご相談として受付します。'
    },
    'detail-diagnosis': {
      type: 'consult-ticket',
      subject: '詳細診断・AI活用レビュー面談の相談',
      message: '詳細診断またはAI活用レビュー面談の案内を希望します。',
      note: '詳細診断・AI活用レビュー面談のご相談として受付します。'
    },
    'spot-ticket-urgent-payment': {
      type: 'spot-ticket-urgent-payment',
      subject: 'スポット相談チケットの入金確認について',
      message: 'スポット相談チケットの入金確認について、早めの確認を希望します。\n\n申込番号:\n振込人名義:\n振込日時:\n振込金額:\n補足:',
      note: 'スポット相談チケットの入金確認に関するお問い合わせとして受付します。申込番号・振込人名義・振込日時が分かると確認がスムーズです。'
    }
  };
  const preset = presets[topic || ''];
  if (!preset) return;

  const inquiryType = document.getElementById('inquiry_type');
  const subject = document.getElementById('subject');
  const message = document.getElementById('message');
  const note = document.getElementById('contact-intent-note');

  if (inquiryType) inquiryType.value = preset.type;
  if (subject && !subject.value) subject.value = preset.subject;
  if (message && !message.value) message.value = preset.message;
  if (note) {
    note.textContent = preset.note;
    note.hidden = false;
  }
})();

// 二重送信防止
(function() {
  const form = document.getElementById('contact-form');
  if (!form) return;
  form.addEventListener('submit', function() {
    const btn = document.getElementById('contact-submit');
    if (btn) {
      btn.disabled = true;
      btn.textContent = '送信中…';
    }
  });
})();
</script>

<style>
  .contact-page {
    position: relative;
    padding: 120px 0 60px;
    overflow: hidden;
  }
  .contact-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .contact-page h1 {
    text-align: center;
    margin-bottom: 20px;
    color: var(--heading);
  }
  .contact-page > .container > p {
    text-align: center;
    margin-bottom: 40px;
    color: var(--muted);
  }
  .contact-form {
    max-width: 720px;
    margin: 0 auto;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 32px;
    border-radius: var(--radius);
    position: relative;
  }
  .contact-tip {
    max-width: 720px;
    margin: -10px auto 28px !important;
    padding: 12px 18px;
    background: rgba(31, 58, 147, .06);
    border-left: 3px solid var(--brand);
    border-radius: 4px;
    font-size: .88rem !important;
    line-height: 1.7;
    text-align: left !important;
    color: var(--text) !important;
  }
  .contact-tip a {
    color: var(--brand);
    font-weight: 700;
  }
  .contact-intent-note {
    max-width: 720px;
    margin: -14px auto 22px !important;
    padding: 10px 14px;
    background: rgba(228, 138, 149, .08);
    border: 1px solid rgba(228, 138, 149, .28);
    border-radius: 6px;
    color: var(--heading) !important;
    font-size: .88rem !important;
    line-height: 1.6;
    text-align: left !important;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; gap: 0; }
  }
  .req {
    color: #F24E1E;
    font-weight: 700;
  }
  .form-note {
    font-size: .82rem !important;
    color: var(--muted) !important;
    line-height: 1.7;
    margin: 0 0 16px !important;
    text-align: left !important;
  }
  .form-note a {
    color: var(--brand);
    text-decoration: underline;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    font-size: .9rem;
    color: var(--heading);
  }
  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 1em;
    color: var(--text);
    transition: border-color .2s ease;
  }
  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(31, 58, 147, .15);
  }
  .form-group textarea {
    resize: vertical;
  }
  .contact-submit-btn {
    width: 100%;
    padding: 15px 20px;
    font-size: 1.1em;
    margin-top: 10px;
  }
</style>
