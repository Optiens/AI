---
import Layout from '../layouts/Layout.astro';

const mode = Astro.url.searchParams.get('mode') === 'redeem' ? 'redeem' : 'purchase';
const title = mode === 'redeem'
  ? '利用申請を受け付けました'
  : '購入申込を受け付けました';
const message = mode === 'redeem'
  ? 'チケット番号と依頼内容を確認し、日程候補または次の確認事項をご連絡します。'
  : '1〜3枚の購入申込には、振込先・請求情報・振込完了通知URLを記載した自動返信メールをお送りします。入金確認後にチケット番号を発行します。急ぎの場合は、振込後に申込番号・振込人名義・振込日時を添えてお問い合わせください。';
---

<Layout
  title={`${title} | Optiens`}
  description="スポット相談チケットの申込受付完了ページです。"
  canonical="https://optiens.com/spot-ticket-success"
>
  <main class="spot-success-page light-section">
    <div class="container">
      <div class="spot-success-inner">
        <p class="spot-success-mark" aria-hidden="true"><i class="fa-solid fa-check"></i></p>
        <h1>{title}</h1>
        <p>{message}</p>
        <div class="spot-success-actions">
          <a href="/spot-ticket" class="btn-primary">スポット相談チケットへ戻る</a>
          {mode === 'purchase' && (
            <a href="/contact?topic=spot-ticket-urgent-payment" class="btn-secondary">急ぎの入金確認を相談</a>
          )}
          <a href="/service" class="btn-secondary">サービスを見る</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .spot-success-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: 120px 0 80px;
  }
  .spot-success-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .spot-success-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    margin: 0 0 24px;
    border-radius: 50%;
    color: #fff;
    background: var(--brand);
    font-size: 1.8rem;
  }
  .spot-success-inner h1 {
    margin: 0 0 18px;
    color: var(--heading);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
  }
  .spot-success-inner p {
    color: var(--text);
    line-height: 1.9;
  }
  .spot-success-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }
  .spot-success-actions .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 14px 30px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--brand);
    background: #fff;
    font-weight: 700;
    letter-spacing: .04em;
  }
  @media (max-width: 600px) {
    .spot-success-actions a {
      width: 100%;
      justify-content: center;
    }
  }
</style>
