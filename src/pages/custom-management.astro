<script is:inline>
(function() {
  // ロール切替
  const roleBtns = document.querySelectorAll('.role-btn');
  const root = document.querySelector('.cm-app');

  function setRole(role) {
    roleBtns.forEach((b) => {
      const active = b.dataset.role === role;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    if (!root) return;
    root.dataset.role = role;
  }
  roleBtns.forEach((b) => b.addEventListener('click', () => setRole(b.dataset.role)));
  setRole('executive');

  // ステージ切替
  const navItems = document.querySelectorAll('.cm-nav-item');
  const stagePanels = document.querySelectorAll('[data-stage-panel]');

  function setStage(stage) {
    navItems.forEach((n) => n.classList.toggle('is-active', n.dataset.stage === stage));
    stagePanels.forEach((p) => p.classList.toggle('hidden', p.dataset.stagePanel !== stage));
  }
  navItems.forEach((n) => n.addEventListener('click', () => setStage(n.dataset.stage)));

  // AI 提案モーダル
  const modal = document.getElementById('ai-modal');
  const modalBody = document.getElementById('ai-modal-body');
  const modalClose = modal?.querySelector('.cm-modal-close');

  const aiSuggestions = {
    leads: `
      <p><strong>提案 1: 八ヶ岳ペンション 八ヶ岳</strong> ── 過去 3 件の宿泊業案件はすべて 14 日以内の MTG 設定で受注しています。<strong>5/15 MTG を必ず確保</strong>してください。</p>
      <p><strong>提案 2: 甲府税理士事務所</strong> ── セミナー経由のリードは平均受注金額が他経路の 1.4 倍。<strong>個別フォロー優先度を高に維持</strong>してください。</p>
      <p><strong>提案 3: 風と森ガイド</strong> ── SNS 経由の小規模案件。リソースが逼迫している場合、<strong>無料診断レポート送付で自走を促す</strong>選択肢もあります。</p>
      <p class="ai-source"><i class="fa-solid fa-quote-right"></i> 根拠: 過去 24 ヶ月の経路別受注率データ + 業種別 LTV 集計</p>
    `,
    opportunities: `
      <p><strong>提案 1: 八ヶ岳ペンション AI 受付</strong> ── 確度 90%、見積書未送付。<strong>本日中の送付推奨</strong>。送付遅延が 3 日続くと過去データでは確度が 20% 低下。</p>
      <p><strong>提案 2: 甲府税理士事務所</strong> ── 契約書最終確認段階。<strong>受注後の保守プラン提案を同時提示</strong>することで、過去 5 件中 4 件が即契約。</p>
      <p><strong>提案 3: 北杜ベーカリー</strong> ── 確度 35% のまま 7 日経過。<strong>ステージダウンの判断時期</strong>。リソースを高確度案件に集中する判断も。</p>
      <p class="ai-source"><i class="fa-solid fa-quote-right"></i> 根拠: 商談ステージ別の経過日数と受注率の相関分析</p>
    `,
  };

  document.querySelectorAll('[data-ai]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.ai;
      if (modal && modalBody && aiSuggestions[key]) {
        modalBody.innerHTML = aiSuggestions[key];
        modal.hidden = false;
      }
    });
  });
  modalClose?.addEventListener('click', () => { if (modal) modal.hidden = true; });
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.hidden = true; });
})();
</script>

