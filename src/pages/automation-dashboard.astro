---
import Layout from '../layouts/Layout.astro';

// モック稼働データ
const workflows = [
  {
    id: 'wf-invoice',
    name: '請求書 OCR → 会計連携',
    status: 'active',
    lastRunAt: '3 分前',
    runs24h: 47,
    errors24h: 0,
    costMonth: '¥1,820',
    runtimeMs: 1240,
    icon: 'fa-file-invoice-dollar',
  },
  {
    id: 'wf-inquiry',
    name: '問い合わせ振り分け',
    status: 'active',
    lastRunAt: '10 分前',
    runs24h: 128,
    errors24h: 2,
    costMonth: '¥3,450',
    runtimeMs: 820,
    icon: 'fa-bell',
  },
  {
    id: 'wf-summary',
    name: '日次売上サマリー生成',
    status: 'active',
    lastRunAt: '1 時間前',
    runs24h: 1,
    errors24h: 0,
    costMonth: '¥420',
    runtimeMs: 4100,
    icon: 'fa-chart-line',
  },
  {
    id: 'wf-followup',
    name: 'リード フォローアップ メール下書き',
    status: 'warning',
    lastRunAt: '5 時間前',
    runs24h: 12,
    errors24h: 1,
    costMonth: '¥980',
    runtimeMs: 2300,
    icon: 'fa-envelope-open-text',
  },
  {
    id: 'wf-monitor',
    name: '補助金 公募モニタリング',
    status: 'active',
    lastRunAt: '12 時間前',
    runs24h: 1,
    errors24h: 0,
    costMonth: '¥260',
    runtimeMs: 5800,
    icon: 'fa-magnifying-glass-chart',
  },
];

const recentEvents = [
  { time: '10:42', level: 'info', wf: '問い合わせ振り分け', message: '宿泊予約問い合わせを「予約担当」に振り分け（信頼度 0.94）' },
  { time: '10:31', level: 'warn', wf: '問い合わせ振り分け', message: '振り分け先が判定不能のため、一次回答を保留（人手判断待ち）' },
  { time: '09:58', level: 'info', wf: '請求書 OCR → 会計連携', message: '5 件の請求書を処理、freee 会計に登録完了' },
  { time: '08:00', level: 'info', wf: '日次売上サマリー生成', message: '前日売上サマリーを Slack に投稿' },
  { time: '06:12', level: 'warn', wf: 'リード フォローアップ メール下書き', message: 'メール下書きの生成で 1 件タイムアウト（再試行で成功）' },
  { time: '昨日 22:15', level: 'info', wf: '補助金 公募モニタリング', message: '中小企業庁の新規公募 1 件を検出、Notion に登録' },
];

const totalRuns24h = workflows.reduce((s, w) => s + w.runs24h, 0);
const totalErrors24h = workflows.reduce((s, w) => s + w.errors24h, 0);
const totalCostMonth = workflows.reduce((s, w) => s + parseInt(w.costMonth.replace(/[^\d]/g, ''), 10), 0);
---

<Layout
  title="稼働状況ダッシュボード（デモ） | Optiens"
  description="AI 自動化の稼働状況を可視化するダッシュボードのデモ。直近の処理件数・エラー・コストを一画面で把握。Optiens 社内で運用中の構成を簡略化したサンプル表示です。"
  noindex={true}
>
  <main class="ad-main">
    <section class="ad-hero">
      <div class="container">
        <h1 class="ad-title">稼働状況ダッシュボード</h1>
        <p class="ad-lede">AI 自動化が「ちゃんと動いているか」をひと目で把握できる画面です。<br class="pc-only">本デモは表示用のモックデータで動作しています。</p>
      </div>
    </section>

    <section class="ad-section">
      <div class="container">

        <!-- フィルタ -->
        <div class="ad-filters">
          <div class="ad-filter-row">
            <div class="ad-filter-group">
              <span class="ad-filter-label">期間</span>
              <div class="ad-pills" data-filter-group="period">
                <button class="ad-pill" data-value="7">過去 7 日</button>
                <button class="ad-pill is-active" data-value="30">過去 30 日</button>
                <button class="ad-pill" data-value="90">過去 90 日</button>
              </div>
            </div>
            <div class="ad-filter-group">
              <span class="ad-filter-label">ワークフロー</span>
              <div class="ad-pills ad-pills--multi" data-filter-group="workflow">
                <button class="ad-pill is-active" data-value="all">すべて</button>
                {workflows.map((w) => (
                  <button class="ad-pill" data-value={w.id}>{w.name}</button>
                ))}
              </div>
            </div>
            <div class="ad-filter-group">
              <span class="ad-filter-label">レベル</span>
              <div class="ad-pills ad-pills--multi" data-filter-group="level">
                <button class="ad-pill is-active" data-value="all">すべて</button>
                <button class="ad-pill" data-value="info">正常</button>
                <button class="ad-pill" data-value="warn">警告</button>
                <button class="ad-pill" data-value="error">エラー</button>
              </div>
            </div>
            <button class="ad-pill ad-pill--reset" type="button" id="ad-reset">
              <i class="fa-solid fa-rotate-left"></i> リセット
            </button>
          </div>
        </div>

        <!-- KPI カード -->
        <div class="kpi-grid">
          <div class="kpi-card">
            <div class="kpi-label">期間内 処理件数</div>
            <div class="kpi-value" id="kpi-runs">{totalRuns24h.toLocaleString()}<span class="kpi-unit">件</span></div>
            <div class="kpi-sub" id="kpi-runs-sub">前期比 +12%</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">期間内 エラー件数</div>
            <div class="kpi-value" id="kpi-errors">{totalErrors24h}<span class="kpi-unit">件</span></div>
            <div class="kpi-sub kpi-sub--ok" id="kpi-errors-sub">エラー率 {((totalErrors24h / totalRuns24h) * 100).toFixed(1)}%</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">期間内 AI 利用コスト</div>
            <div class="kpi-value" id="kpi-cost">¥{totalCostMonth.toLocaleString()}</div>
            <div class="kpi-sub" id="kpi-cost-sub">予算 ¥10,000 内</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">対象ワークフロー</div>
            <div class="kpi-value" id="kpi-wfcount">{workflows.length}<span class="kpi-unit">本</span></div>
            <div class="kpi-sub" id="kpi-wfcount-sub">{workflows.filter(w => w.status === 'active').length} 本 正常</div>
          </div>
        </div>

        <!-- チャートグリッド -->
        <div class="ad-charts-grid">
          <div class="ad-chart-card ad-chart-card--wide">
            <div class="trend-head">
              <h2 class="trend-title">累積処理件数推移（ワークフロー別 積み上げ）</h2>
              <div class="trend-legend">期間内の合計をワークフロー別に積み上げ表示</div>
            </div>
            <div class="ad-chart-canvas-wrap">
              <canvas id="ad-chart-timeline"></canvas>
            </div>
          </div>
          <div class="ad-chart-card">
            <div class="trend-head">
              <h2 class="trend-title">ワークフロー別 処理件数</h2>
              <div class="trend-legend">バーをクリックで絞込</div>
            </div>
            <div class="ad-chart-canvas-wrap">
              <canvas id="ad-chart-workflow"></canvas>
            </div>
          </div>
          <div class="ad-chart-card">
            <div class="trend-head">
              <h2 class="trend-title">レベル別 イベント分布</h2>
              <div class="trend-legend">スライスをクリックで絞込</div>
            </div>
            <div class="ad-chart-canvas-wrap ad-chart-canvas-wrap--doughnut">
              <canvas id="ad-chart-level"></canvas>
            </div>
          </div>
        </div>

        <!-- ワークフロー一覧 -->
        <div class="wf-card">
          <h2 class="wf-title">ワークフロー一覧 <span class="wf-count" id="wf-count">（全 {workflows.length} 本）</span></h2>
          <div class="wf-list" id="wf-list">
            {workflows.map((w) => (
              <article class={`wf-item wf-status-${w.status}`} data-wf-id={w.id}>
                <div class="wf-icon"><i class={`fa-solid ${w.icon}`}></i></div>
                <div class="wf-body">
                  <h3 class="wf-name">{w.name}</h3>
                  <div class="wf-meta">
                    <span class={`wf-badge wf-badge-${w.status}`}>{w.status === 'active' ? '稼働中' : w.status === 'warning' ? '要確認' : '停止中'}</span>
                    <span class="wf-meta-item">最終実行: {w.lastRunAt}</span>
                    <span class="wf-meta-item">平均処理: {w.runtimeMs}ms</span>
                  </div>
                </div>
                <div class="wf-stats">
                  <div class="wf-stat">
                    <div class="wf-stat-label">期間内 処理</div>
                    <div class="wf-stat-value" data-wf-runs={w.id}>{w.runs24h}</div>
                  </div>
                  <div class="wf-stat">
                    <div class="wf-stat-label">期間内 エラー</div>
                    <div class={`wf-stat-value ${w.errors24h > 0 ? 'wf-stat-warn' : ''}`} data-wf-errors={w.id}>{w.errors24h}</div>
                  </div>
                  <div class="wf-stat">
                    <div class="wf-stat-label">期間内 コスト</div>
                    <div class="wf-stat-value" data-wf-cost={w.id}>{w.costMonth}</div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- 最近のイベント -->
        <div class="events-card">
          <h2 class="events-title">最近のイベント <span class="events-count" id="events-count">（直近 {recentEvents.length} 件）</span></h2>
          <ul class="events-list" id="events-list"></ul>
        </div>

        <!-- 注記 + 戻る -->
        <div class="ad-footnote">
          <p><strong>このデモについて</strong>: 表示している数値・イベントはすべてサンプルデータです。実際のお客様向けには、業務に合わせて KPI 項目・グラフ・通知ルールをカスタマイズして納品します。</p>
          <p><strong>弊社での運用</strong>: 同型のダッシュボードを Optiens 社内で運用し、IoT 水耕栽培の稼働監視と AI ワークフローの状態把握に使っています。保守プラン契約者向けに標準提供します。</p>
          <a href="/ai-examples#case-06" class="ad-back">← 共通AI事例集に戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
<script is:inline define:vars={{ workflows, recentEvents }}>
(function() {
  if (typeof Chart === 'undefined') return;

  // ===== モックデータ生成（過去90日 × 各ワークフロー） =====
  let _seed = 73;
  function rand() { _seed = (_seed * 9301 + 49297) % 233280; return _seed / 233280; }

  const today = new Date('2026-05-11T11:00:00');
  const RUNS = []; // 個別実行レコード

  workflows.forEach((w) => {
    // ワークフローごとに 1 日の実行頻度プロファイル
    let dailyBase;
    if (w.id === 'wf-inquiry') dailyBase = 110;       // 問い合わせ振り分け（高頻度）
    else if (w.id === 'wf-invoice') dailyBase = 40;    // 請求書OCR（中頻度）
    else if (w.id === 'wf-followup') dailyBase = 12;   // フォローアップ（低頻度）
    else dailyBase = 1;                                 // 日次バッチ系

    for (let dayOffset = 90; dayOffset >= 0; dayOffset--) {
      const date = new Date(today);
      date.setDate(date.getDate() - dayOffset);
      // 直近30日にかけて緩やかに増加
      const growthFactor = 1 + (90 - dayOffset) / 90 * 0.4;
      const dailyCount = Math.max(1, Math.round(dailyBase * growthFactor * (0.7 + rand() * 0.6)));
      // エラー率：warning ステータスのものは 8%、それ以外は 1.5%
      const errorRate = w.status === 'warning' ? 0.08 : 0.015;
      for (let i = 0; i < dailyCount; i++) {
        const isError = rand() < errorRate;
        const isWarn = !isError && rand() < 0.05;
        RUNS.push({
          dateStr: date.toISOString().slice(0, 10),
          wfId: w.id,
          wfName: w.name,
          level: isError ? 'error' : isWarn ? 'warn' : 'info',
          runtimeMs: w.runtimeMs + Math.round((rand() - 0.5) * w.runtimeMs * 0.3),
          costJpy: Math.max(1, Math.round((w.runtimeMs / 1000) * (5 + rand() * 5))),
        });
      }
    }
  });

  // 期間内の代表的なイベントメッセージサンプル
  const SAMPLE_MESSAGES = {
    'wf-invoice': [
      '請求書 OCR を実行、freee 会計に登録完了',
      'PDF 解析中に金額欄が判定不能、人手判断にエスカレーション',
      '5 件の請求書を一括処理、全件登録成功',
    ],
    'wf-inquiry': [
      '宿泊予約問い合わせを「予約担当」に振り分け（信頼度 0.94）',
      '振り分け先が判定不能のため、一次回答を保留（人手判断待ち）',
      'FAQ から自動回答を生成、お客様へ送信完了',
      '不明な問い合わせのため、メールを CEO に転送',
    ],
    'wf-summary': [
      '前日売上サマリーを Slack に投稿',
      'KPI 値が前日比 +15%、要因分析コメントを添付',
    ],
    'wf-followup': [
      'リード 12 件のフォローアップメール下書きを生成',
      '生成中にタイムアウト（再試行で成功）',
      '送信前確認待ちのドラフトを CEO に通知',
    ],
    'wf-monitor': [
      '中小企業庁の新規公募 1 件を検出、Notion に登録',
      '農水省サイト更新を検出、要約を作成',
    ],
  };

  // ===== フィルタ状態 =====
  const filters = {
    period: 30,
    workflow: new Set(['all']),
    level: new Set(['all']),
  };

  function applyFilters() {
    const cutoff = new Date(today);
    cutoff.setDate(cutoff.getDate() - filters.period);
    const cutoffStr = cutoff.toISOString().slice(0, 10);
    return RUNS.filter(r => {
      if (r.dateStr < cutoffStr) return false;
      if (!filters.workflow.has('all') && !filters.workflow.has(r.wfId)) return false;
      if (!filters.level.has('all') && !filters.level.has(r.level)) return false;
      return true;
    });
  }

  // ===== Chart.js =====
  const BRAND = '#1F3A93';
  const COLORS = ['#1F3A93', '#6B85C9', '#9CA8D9', '#2E7D4F', '#B08825', '#7B4FA0', '#D45D5D', '#C0632B'];
  const LEVEL_COLORS = { info: '#1F3A93', warn: '#E48A95', error: '#DC2626' };
  const LEVEL_LABELS = { info: '正常', warn: '警告', error: 'エラー' };

  Chart.defaults.font.family = 'system-ui, -apple-system, "Segoe UI", "Hiragino Sans", "Yu Gothic", sans-serif';
  Chart.defaults.color = '#475569';

  const tlCtx = document.getElementById('ad-chart-timeline');

  // ワークフローごとの色割当
  function wfColor(idx, alpha = 1) {
    const palette = [
      [31, 58, 147],   // BRAND
      [107, 133, 201], // BRAND_LIGHT
      [46, 125, 79],   // green
      [176, 136, 37],  // gold
      [123, 79, 160],  // purple
      [212, 93, 93],   // red
      [192, 99, 43],   // orange
    ];
    const [r, g, b] = palette[idx % palette.length];
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  const timelineChart = new Chart(tlCtx, {
    type: 'line',
    data: { labels: [], datasets: [] },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { padding: 10, font: { size: 11 }, boxWidth: 12 } },
        tooltip: {
          mode: 'index', intersect: false,
          callbacks: {
            footer: (items) => {
              const total = items.reduce((s, i) => s + i.parsed.y, 0);
              return '累積合計: ' + total.toLocaleString() + ' 件';
            },
          },
        },
      },
      scales: {
        x: { grid: { display: false }, ticks: { maxTicksLimit: 8 }, stacked: true },
        y: {
          beginAtZero: true,
          stacked: true,
          grid: { color: 'rgba(0,0,0,0.05)' },
          ticks: { precision: 0 },
          title: { display: true, text: '累積処理件数（ワークフロー別積み上げ）', font: { size: 11 } },
        },
      },
      interaction: { mode: 'nearest', axis: 'x', intersect: false },
    },
  });

  const wfCtx = document.getElementById('ad-chart-workflow');
  const workflowChart = new Chart(wfCtx, {
    type: 'bar',
    data: { labels: [], datasets: [{ label: '処理件数', data: [], backgroundColor: COLORS, borderRadius: 6 }] },
    options: {
      responsive: true, maintainAspectRatio: false, indexAxis: 'y',
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: 'rgba(0,0,0,0.05)' }, beginAtZero: true },
        y: { grid: { display: false } },
      },
      onClick: (e, elems) => {
        if (elems.length === 0) return;
        const wfName = workflowChart.data.labels[elems[0].index];
        const wf = workflows.find(w => w.name === wfName);
        if (wf) toggleFilter('workflow', wf.id);
      },
    },
  });

  const lvCtx = document.getElementById('ad-chart-level');
  const levelChart = new Chart(lvCtx, {
    type: 'doughnut',
    data: { labels: [], datasets: [{ data: [], backgroundColor: [], borderWidth: 2, borderColor: '#fff' }] },
    options: {
      responsive: true, maintainAspectRatio: false, cutout: '60%',
      plugins: {
        legend: { position: 'bottom', labels: { padding: 12, font: { size: 12 } } },
        tooltip: { callbacks: { label: (c) => c.label + ': ' + c.raw + ' 件' } },
      },
      onClick: (e, elems) => {
        if (elems.length === 0) return;
        const label = levelChart.data.labels[elems[0].index];
        const key = Object.keys(LEVEL_LABELS).find(k => LEVEL_LABELS[k] === label);
        if (key) toggleFilter('level', key);
      },
    },
  });

  // ===== 更新 =====
  function updateAll() {
    const filtered = applyFilters();

    // 時系列：日付ラベル生成
    const labels = [];
    const dateStrs = [];
    for (let i = filters.period; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const ds = d.toISOString().slice(0, 10);
      dateStrs.push(ds);
      labels.push(ds.slice(5).replace('-', '/'));
    }

    // ワークフロー × 日付の累積件数を計算
    const wfsInFilter = new Set(filtered.map(r => r.wfId));
    const wfList = workflows.filter(w => wfsInFilter.has(w.id));

    const datasets = wfList.map((w, idx) => {
      // 各日の件数（その日新規）
      const dailyCounts = dateStrs.map(ds =>
        filtered.filter(r => r.wfId === w.id && r.dateStr === ds).length
      );
      // 累積化
      const cumulative = [];
      let running = 0;
      dailyCounts.forEach(v => { running += v; cumulative.push(running); });

      return {
        label: w.name,
        data: cumulative,
        borderColor: wfColor(idx, 1),
        backgroundColor: wfColor(idx, 0.35),
        borderWidth: 1.5,
        tension: 0.25,
        fill: true,
        pointRadius: 0,
        pointHoverRadius: 4,
      };
    });

    timelineChart.data.labels = labels;
    timelineChart.data.datasets = datasets;
    timelineChart.update();

    // ワークフロー別
    const wfMap = new Map();
    filtered.forEach(r => wfMap.set(r.wfName, (wfMap.get(r.wfName) || 0) + 1));
    const sortedWfs = Array.from(wfMap.entries()).sort((a, b) => b[1] - a[1]);
    workflowChart.data.labels = sortedWfs.map(e => e[0]);
    workflowChart.data.datasets[0].data = sortedWfs.map(e => e[1]);
    workflowChart.update();

    // レベル別
    const lvMap = new Map();
    filtered.forEach(r => lvMap.set(r.level, (lvMap.get(r.level) || 0) + 1));
    const lvOrder = ['info', 'warn', 'error'].filter(k => lvMap.has(k));
    levelChart.data.labels = lvOrder.map(k => LEVEL_LABELS[k]);
    levelChart.data.datasets[0].data = lvOrder.map(k => lvMap.get(k));
    levelChart.data.datasets[0].backgroundColor = lvOrder.map(k => LEVEL_COLORS[k]);
    levelChart.update();

    // KPI
    const totalRuns = filtered.length;
    const totalErrors = filtered.filter(r => r.level === 'error').length;
    const totalCost = filtered.reduce((s, r) => s + r.costJpy, 0);
    const wfsInScope = new Set(filtered.map(r => r.wfId));

    document.getElementById('kpi-runs').innerHTML = totalRuns.toLocaleString() + '<span class="kpi-unit">件</span>';
    document.getElementById('kpi-errors').innerHTML = totalErrors.toLocaleString() + '<span class="kpi-unit">件</span>';
    document.getElementById('kpi-errors-sub').textContent = 'エラー率 ' + (totalRuns > 0 ? ((totalErrors / totalRuns) * 100).toFixed(2) : '0.00') + '%';
    document.getElementById('kpi-cost').textContent = '¥' + totalCost.toLocaleString();
    document.getElementById('kpi-cost-sub').textContent = filters.period + ' 日間累計';
    document.getElementById('kpi-wfcount').innerHTML = wfsInScope.size + '<span class="kpi-unit">本</span>';
    document.getElementById('kpi-wfcount-sub').textContent = '全 ' + workflows.length + ' 本中';

    // ワークフロー個別の数値更新 + 表示/非表示
    let visibleWfCount = 0;
    workflows.forEach((w) => {
      const wfRuns = filtered.filter(r => r.wfId === w.id);
      const wfErrors = wfRuns.filter(r => r.level === 'error').length;
      const wfCost = wfRuns.reduce((s, r) => s + r.costJpy, 0);

      const runsEl = document.querySelector(`[data-wf-runs="${w.id}"]`);
      const errEl = document.querySelector(`[data-wf-errors="${w.id}"]`);
      const costEl = document.querySelector(`[data-wf-cost="${w.id}"]`);
      if (runsEl) runsEl.textContent = wfRuns.length.toLocaleString();
      if (errEl) {
        errEl.textContent = wfErrors.toLocaleString();
        errEl.classList.toggle('wf-stat-warn', wfErrors > 0);
      }
      if (costEl) costEl.textContent = '¥' + wfCost.toLocaleString();

      // ワークフローフィルタ未選択でも、件数0なら非表示
      const wfPanel = document.querySelector(`[data-wf-id="${w.id}"]`);
      if (wfPanel) {
        const wfFiltered = !filters.workflow.has('all') && !filters.workflow.has(w.id);
        const noRuns = wfRuns.length === 0;
        wfPanel.style.display = (wfFiltered || noRuns) ? 'none' : '';
        if (!wfFiltered && !noRuns) visibleWfCount++;
      }
    });
    document.getElementById('wf-count').textContent = `（表示中 ${visibleWfCount} / 全 ${workflows.length} 本）`;

    // イベント一覧（フィルタ済みから直近 8 件をサンプル生成）
    const eventsList = document.getElementById('events-list');
    const recentRuns = filtered.slice().reverse().slice(0, 8);
    eventsList.innerHTML = recentRuns.map((r) => {
      const messages = SAMPLE_MESSAGES[r.wfId] || ['処理を実行'];
      const msg = messages[Math.floor(Math.abs(r.runtimeMs * 7) % messages.length)];
      const timeStr = r.dateStr.slice(5).replace('-', '/');
      return `
        <li class="event-item event-${r.level}">
          <span class="event-time">${timeStr}</span>
          <span class="event-level event-level--${r.level}">${LEVEL_LABELS[r.level]}</span>
          <span class="event-wf">${r.wfName}</span>
          <span class="event-msg">${msg}</span>
        </li>
      `;
    }).join('') || '<li style="text-align:center;padding:20px;color:#94a3b8;">該当するイベントがありません</li>';
    document.getElementById('events-count').textContent = `（全 ${filtered.length} 件中 直近 ${recentRuns.length} 件を表示）`;
  }

  // ===== フィルタ操作 =====
  function toggleFilter(group, value) {
    if (group === 'period') {
      filters.period = parseInt(value, 10);
      document.querySelectorAll('[data-filter-group="period"] .ad-pill').forEach(p => {
        p.classList.toggle('is-active', parseInt(p.dataset.value, 10) === filters.period);
      });
      updateAll();
      return;
    }
    if (value === 'all') {
      filters[group].clear();
      filters[group].add('all');
    } else {
      filters[group].delete('all');
      if (filters[group].has(value)) {
        filters[group].delete(value);
        if (filters[group].size === 0) filters[group].add('all');
      } else {
        filters[group].add(value);
      }
    }
    document.querySelectorAll(`[data-filter-group="${group}"] .ad-pill`).forEach(p => {
      p.classList.toggle('is-active', filters[group].has(p.dataset.value));
    });
    updateAll();
  }

  document.querySelectorAll('[data-filter-group] .ad-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      const group = pill.closest('[data-filter-group]').dataset.filterGroup;
      toggleFilter(group, pill.dataset.value);
    });
  });

  document.getElementById('ad-reset')?.addEventListener('click', () => {
    filters.period = 30;
    filters.workflow = new Set(['all']);
    filters.level = new Set(['all']);
    document.querySelectorAll('[data-filter-group="period"] .ad-pill').forEach(p => {
      p.classList.toggle('is-active', p.dataset.value === '30');
    });
    ['workflow', 'level'].forEach(g => {
      document.querySelectorAll(`[data-filter-group="${g}"] .ad-pill`).forEach(p => {
        p.classList.toggle('is-active', p.dataset.value === 'all');
      });
    });
    updateAll();
  });

  updateAll();
})();
</script>

