---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="書類添削AI（デモ）| Optiens"
  description="経営者向けの書類添削AIデモ。社内文書サンプルを選んで、AIエージェントによる添削を体験できます。"
  canonical="https://optiens.com/document-editor"
>
  <main class="ed-main light-section">
    <!-- ヒーロー -->
    <section class="ed-hero">
      <div class="container text-center">
        <p class="hero-eyebrow">DEMO</p>
        <h1>書類添削AI（デモ）</h1>
        <p class="hero-sub">
          社内文書サンプルを選んで、AIエージェントによる添削を体験いただけます。<br />
          推敲ツールの業務版として、本文と添削メモを並列に確認できます。
        </p>
      </div>
    </section>

    <!-- ツール本体 -->
    <section class="ed-tool-section">
      <div class="container">
        <!-- ツールバー -->
        <div class="toolbar">
          <div class="toolbar-left">
            <span class="toolbar-title">書類添削ツール</span>
            <select id="doc-select">
              <option value="">社内文書を選択</option>
            </select>
          </div>
          <div class="toolbar-right">
            <span id="status" class="status"></span>
            <button type="button" id="ai-edit-btn" class="action-btn primary" disabled>
              <i class="fa-solid fa-wand-magic-sparkles"></i> AIで添削
            </button>
            <button type="button" id="clear-btn" class="action-btn danger" disabled>クリア</button>
          </div>
        </div>

        <!-- 空状態 -->
        <div id="empty-state" class="empty-state">
          <p>左上のメニューから書類を選択してください。</p>
          <p class="empty-hint">サンプルは社内文書を想定したダミーデータです。本番環境では御社のDBから直接選択する仕組みを構築できます。</p>
        </div>

        <!-- エディタ -->
        <div id="editor" class="editor" style="display:none;">
          <div class="editor-header">
            <div class="col-header col-header-num">#</div>
            <div class="col-header col-header-text">本文</div>
            <div class="col-header col-header-note">添削メモ</div>
          </div>
          <div id="editor-body" class="editor-body"></div>
        </div>

        <!-- 凡例（メモあり時のみ表示） -->
        <div id="legend" class="legend" style="display:none;">
          <span class="legend-item"><span class="dot dot-high"></span>重要</span>
          <span class="legend-item"><span class="dot dot-medium"></span>中</span>
          <span class="legend-item"><span class="dot dot-low"></span>軽微</span>
        </div>

        <!-- 注意書き -->
        <p class="disclaimer">
          ※AIによる添削は1時間あたり10回までご利用いただけます。送信内容は添削処理にのみ使用します。<br />
          ※御社専用版では、社内テンプレート参照・過去文書からの整合チェック・部門別ルール適用などの拡張が可能です。
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="ed-cta-section">
      <div class="container text-center">
        <h2>御社業務に合わせたカスタム版もご相談いただけます</h2>
        <p>
          社内テンプレート参照・過去文書からの整合チェック・部門別ルール適用など、<br />
          御社の業務フローに沿った書類添削の仕組みを構築します。
        </p>
        <div class="cta-buttons">
          <a href="/free-diagnosis" class="btn-primary">無料AI診断を受ける（0円）</a>
          <a href="/service" class="btn-ghost">サービスメニューを見る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  type Severity = 'high' | 'medium' | 'low';
  interface EditNote {
    severity: Severity;
    location: string;
    comment: string;
  }
  interface SampleDoc {
    id: string;
    title: string;
    category: string;
    text: string;
  }

  const docSelect = document.getElementById('doc-select') as HTMLSelectElement;
  const aiEditBtn = document.getElementById('ai-edit-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('status') as HTMLSpanElement;
  const emptyState = document.getElementById('empty-state') as HTMLDivElement;
  const editor = document.getElementById('editor') as HTMLDivElement;
  const editorBody = document.getElementById('editor-body') as HTMLDivElement;
  const legend = document.getElementById('legend') as HTMLDivElement;

  let samples: SampleDoc[] = [];
  let currentLines: string[] = [];

  // --- サンプル読み込み ---
  async function loadSamples() {
    try {
      const res = await fetch('/samples/document-editor.json');
      samples = await res.json();
      docSelect.innerHTML = '<option value="">社内文書を選択</option>';
      // カテゴリでグループ化
      const byCategory: Record<string, SampleDoc[]> = {};
      for (const s of samples) {
        if (!byCategory[s.category]) byCategory[s.category] = [];
        byCategory[s.category].push(s);
      }
      for (const [category, docs] of Object.entries(byCategory)) {
        const group = document.createElement('optgroup');
        group.label = category;
        for (const doc of docs) {
          const o = document.createElement('option');
          o.value = doc.id;
          o.textContent = doc.title;
          group.appendChild(o);
        }
        docSelect.appendChild(group);
      }
    } catch (e) {
      statusEl.textContent = 'サンプルの読み込みに失敗しました';
    }
  }

  // --- 書類選択 ---
  docSelect.addEventListener('change', () => {
    const id = docSelect.value;
    if (!id) {
      showEmptyState();
      return;
    }
    const doc = samples.find(s => s.id === id);
    if (!doc) return;
    renderRows(doc.text);
  });

  // --- 行レンダリング ---
  function renderRows(text: string) {
    const lines = text.split('\n');
    currentLines = lines;
    editorBody.innerHTML = '';

    lines.forEach((line, i) => {
      const row = document.createElement('div');
      row.className = 'row';
      row.dataset.lineIndex = String(i);

      const num = document.createElement('div');
      num.className = 'row-num';
      num.textContent = String(i + 1);

      const text = document.createElement('div');
      text.className = 'row-text';
      if (line.trim() === '') {
        text.innerHTML = '<span class="row-text-empty">（空行）</span>';
      } else {
        text.textContent = line;
      }

      const noteCell = document.createElement('div');
      noteCell.className = 'row-note';
      noteCell.innerHTML = '<span class="row-note-empty">—</span>';

      row.appendChild(num);
      row.appendChild(text);
      row.appendChild(noteCell);
      editorBody.appendChild(row);
    });

    emptyState.style.display = 'none';
    editor.style.display = 'block';
    aiEditBtn.disabled = false;
    clearBtn.disabled = false;
    legend.style.display = 'none';
    statusEl.textContent = `${lines.length}行`;
  }

  // --- AI添削 ---
  aiEditBtn.addEventListener('click', async () => {
    const id = docSelect.value;
    const doc = samples.find(s => s.id === id);
    if (!doc) return;

    aiEditBtn.disabled = true;
    statusEl.textContent = 'AI添削中...';

    try {
      const res = await fetch('/api/document-edit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: doc.text }),
      });
      const data = await res.json();
      if (data.error) {
        statusEl.textContent = data.error;
        aiEditBtn.disabled = false;
        return;
      }
      placeNotes(data.notes || []);
      statusEl.textContent = `${data.notes?.length || 0}件の添削メモを生成${data.mock ? '（モック）' : ''}`;
    } catch (e) {
      statusEl.textContent = '添削に失敗しました';
    }
    aiEditBtn.disabled = false;
  });

  // --- AI添削メモを行にマッピング ---
  function placeNotes(notes: EditNote[]) {
    // クリア
    editorBody.querySelectorAll('.row').forEach(row => {
      row.classList.remove('has-note', 'note-high', 'note-medium', 'note-low');
      const noteCell = row.querySelector('.row-note') as HTMLDivElement;
      noteCell.innerHTML = '<span class="row-note-empty">—</span>';
    });

    // 各noteを最も該当する行にマッピング
    let assignedCount = 0;
    notes.forEach((note) => {
      const targetIdx = findBestMatchLine(note);
      const row = editorBody.querySelector(`.row[data-line-index="${targetIdx}"]`);
      if (!row) return;
      assignNoteToRow(row as HTMLDivElement, note);
      assignedCount++;
    });

    if (assignedCount > 0) {
      legend.style.display = 'flex';
    }
  }

  function findBestMatchLine(note: EditNote): number {
    // location文字列に「N行目」「行N」等が含まれる場合はその行
    const lineMatch = note.location.match(/(\d+)\s*行/);
    if (lineMatch) {
      const idx = parseInt(lineMatch[1]) - 1;
      if (idx >= 0 && idx < currentLines.length) return idx;
    }

    // location文字列が本文のいずれかの行に含まれているか探す
    const loc = note.location.replace(/^[「『]|[」』]$/g, '').trim();
    if (loc.length >= 2) {
      // 完全一致 or 部分一致
      for (let i = 0; i < currentLines.length; i++) {
        if (currentLines[i].includes(loc)) return i;
      }
      // 短いキーワード抽出 (2-4文字の連続するJP文字)
      const keywords = loc.match(/[一-龯ぁ-ゔァ-ヴ]{2,4}/g) || [];
      for (const kw of keywords) {
        for (let i = 0; i < currentLines.length; i++) {
          if (currentLines[i].includes(kw)) return i;
        }
      }
    }

    // フォールバック: 最初の非空行
    for (let i = 0; i < currentLines.length; i++) {
      if (currentLines[i].trim()) return i;
    }
    return 0;
  }

  function assignNoteToRow(row: HTMLDivElement, note: EditNote) {
    row.classList.add('has-note', `note-${note.severity}`);
    const noteCell = row.querySelector('.row-note') as HTMLDivElement;
    const dot = document.createElement('span');
    dot.className = `dot dot-${note.severity}`;
    const text = document.createElement('span');
    text.className = 'row-note-text';
    text.textContent = note.comment;
    noteCell.innerHTML = '';
    noteCell.appendChild(dot);
    noteCell.appendChild(text);
  }

  // --- クリア ---
  clearBtn.addEventListener('click', () => {
    docSelect.value = '';
    showEmptyState();
  });

  function showEmptyState() {
    emptyState.style.display = 'block';
    editor.style.display = 'none';
    legend.style.display = 'none';
    aiEditBtn.disabled = true;
    clearBtn.disabled = true;
    statusEl.textContent = '';
    currentLines = [];
  }

  loadSamples();
</script>

<style>
  .ed-main {
    padding-top: 80px;
  }

  /* ヒーロー */
  .ed-hero {
    padding: clamp(40px, 6vw, 64px) 0 clamp(24px, 4vw, 40px);
    background: var(--surface);
  }
  .hero-eyebrow {
    font-size: clamp(11px, 1.2vw, 13px);
    font-weight: 600;
    letter-spacing: .25em;
    color: var(--brand);
    margin: 0 0 12px;
    text-transform: uppercase;
  }
  .ed-hero h1 {
    color: var(--heading);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    margin: 0 0 16px;
  }
  .ed-hero .hero-sub {
    color: var(--muted);
    font-size: clamp(.9rem, 1.6vw, 1.05rem);
    line-height: 1.85;
    margin: 0 auto;
    max-width: 720px;
  }

  /* ツール本体 */
  .ed-tool-section {
    padding: clamp(32px, 5vw, 48px) 0 clamp(48px, 6vw, 72px);
    background: var(--surface-2);
  }

  /* ツールバー */
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 16px;
  }
  .toolbar-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--heading);
    white-space: nowrap;
  }
  .toolbar-left, .toolbar-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .toolbar select {
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.88rem;
    background: var(--surface);
    color: var(--text);
    min-width: 220px;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border: 1px solid transparent;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .2s, transform .2s;
  }
  .action-btn:hover { opacity: .85; transform: translateY(-1px); }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
  .action-btn.primary {
    background: var(--brand);
    color: #fff;
  }
  .action-btn.danger {
    background: transparent;
    color: var(--muted);
    border-color: var(--border);
  }
  .status {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
  }

  /* 空状態 */
  .empty-state {
    text-align: center;
    padding: 64px 20px;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 10px;
    color: var(--muted);
  }
  .empty-state p { margin: 0; }
  .empty-hint {
    font-size: 0.85rem;
    margin-top: 12px !important;
    line-height: 1.7;
  }

  /* エディタ */
  .editor {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .editor-header {
    display: grid;
    grid-template-columns: 48px 1fr 1fr;
    background: var(--brand);
    color: #fff;
  }
  .col-header {
    padding: 10px 14px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .col-header-num { text-align: center; }
  .col-header-note { border-left: 1px solid rgba(255, 255, 255, 0.2); }

  /* 行 */
  .row {
    display: grid;
    grid-template-columns: 48px 1fr 1fr;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s ease;
  }
  .row:last-child { border-bottom: none; }
  .row:hover { background: rgba(162, 89, 255, 0.04); }
  .row.has-note { background: rgba(162, 89, 255, 0.04); }
  .row.has-note.note-high { background: rgba(242, 78, 30, 0.05); }
  .row.has-note.note-high .row-num { color: #F24E1E; font-weight: 700; }
  .row.has-note.note-medium .row-num { color: #F24E1E; opacity: 0.7; }
  .row.has-note.note-low .row-num { color: var(--brand); opacity: 0.7; }

  .row-num {
    padding: 10px 4px;
    font-size: 0.72rem;
    color: var(--muted);
    text-align: center;
    user-select: none;
    border-right: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12px;
    font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
  }
  .row-text {
    padding: 10px 14px;
    font-size: 0.92rem;
    line-height: 1.85;
    word-break: break-word;
    border-right: 1px solid var(--border);
    color: var(--text);
    white-space: pre-wrap;
  }
  .row-text-empty {
    color: var(--muted);
    font-size: 0.78rem;
    opacity: 0.6;
  }
  .row-note {
    padding: 10px 14px;
    font-size: 0.85rem;
    line-height: 1.75;
    color: var(--text);
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .row-note-empty {
    color: var(--muted);
    opacity: 0.4;
  }
  .row-note-text {
    flex: 1;
  }

  /* Severityドット */
  .dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 7px;
  }
  .dot-high { background: #F24E1E; }
  .dot-medium { background: #F2A93E; }
  .dot-low { background: var(--brand); }

  /* 凡例 */
  .legend {
    display: flex;
    gap: 18px;
    margin-top: 16px;
    padding: 10px 16px;
    font-size: 0.78rem;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .legend-item .dot { margin-top: 0; }

  /* 注意書き */
  .disclaimer {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.85;
    margin: 24px 0 0;
    padding: 14px 18px;
    background: var(--surface);
    border-left: 3px solid var(--brand);
    border-radius: 0 6px 6px 0;
  }

  /* CTA */
  .ed-cta-section {
    padding: clamp(48px, 7vw, 80px) 0;
    background: var(--surface);
  }
  .ed-cta-section h2 {
    color: var(--heading);
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    margin: 0 0 16px;
  }
  .ed-cta-section p {
    color: var(--muted);
    font-size: clamp(.9rem, 1.5vw, 1rem);
    line-height: 1.85;
    margin: 0 0 28px;
  }
  .cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* スマホ */
  @media (max-width: 768px) {
    .toolbar {
      padding: 12px 14px;
    }
    .toolbar-left, .toolbar-right {
      width: 100%;
    }
    .toolbar-right { justify-content: flex-end; }
    .toolbar select { min-width: 0; flex: 1; }
    .action-btn { padding: 7px 12px; font-size: 0.8rem; }

    .editor-header { grid-template-columns: 36px 1fr 1fr; }
    .row { grid-template-columns: 36px 1fr 1fr; }
    .row-num { font-size: 0.68rem; padding-top: 10px; }
    .row-text { font-size: 0.85rem; padding: 8px 10px; }
    .row-note { font-size: 0.78rem; padding: 8px 10px; }
  }
  @media (max-width: 480px) {
    .editor-header { grid-template-columns: 30px 1fr 1fr; }
    .row { grid-template-columns: 30px 1fr 1fr; }
    .row-text { font-size: 0.8rem; padding: 6px 8px; }
    .row-note { font-size: 0.74rem; padding: 6px 8px; }
  }
</style>
