<script is:inline>
  (() => {
    const form = document.getElementById('diag-form');
    if (!form) return;

    const toast = document.getElementById('diag-toast');
    const toastTitle = document.getElementById('diag-toast-title');
    const toastMessage = document.getElementById('diag-toast-message');
    const toastClose = document.getElementById('diag-toast-close');
    let hideTimer = null;

    function showToast(message, opts = {}) {
      if (!toast || !toastMessage) return;
      const isSuccess = !!opts.success;
      toast.classList.toggle('is-success', isSuccess);
      toast.querySelector('.diag-toast__icon').textContent = isSuccess ? '✓' : '⚠';
      toastTitle.textContent = opts.title || (isSuccess ? '送信しました' : '送信できませんでした');
      toastMessage.textContent = message;
      toast.hidden = false;
      // 次フレームで遷移クラス付与
      requestAnimationFrame(() => toast.classList.add('is-visible'));
      if (hideTimer) clearTimeout(hideTimer);
      const autoHideMs = opts.persistent ? 0 : (isSuccess ? 5000 : 10000);
      if (autoHideMs > 0) {
        hideTimer = setTimeout(hideToast, autoHideMs);
      }
    }

    function hideToast() {
      if (!toast) return;
      toast.classList.remove('is-visible');
      // CSS の transition 終了後に hidden
      setTimeout(() => { toast.hidden = true; }, 280);
    }

    toastClose && toastClose.addEventListener('click', hideToast);

    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      // Turnstile 必須エラーなど、ブラウザ標準のバリデーションは通常フローに任せる
      if (!form.checkValidity()) return;

      e.preventDefault();

      hideToast();

      const originalLabel = submitBtn ? submitBtn.innerHTML : '';
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.dataset.busy = '1';
        const planField = document.getElementById('plan-field');
        const plan = planField && planField.value === 'paid' ? 'paid' : 'free';
        submitBtn.textContent = plan === 'paid' ? 'お申込中…' : '送信中…';
      }

      try {
        const formData = new FormData(form);
        var submitUrl = form.action || '/api/free-diagnosis';
        const res = await fetch(submitUrl, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' },
        });

        let data = null;
        try { data = await res.json(); } catch { /* JSON 以外 */ }

        if (res.ok && data && data.redirect) {
          window.location.assign(data.redirect);
          return;
        }

        // エラーパターン
        const errMsg = (data && data.error) || `送信に失敗しました (${res.status})`;
        let title = '送信できませんでした';
        if (res.status === 429) {
          title = '送信制限にかかっています';
        } else if (res.status >= 500) {
          title = 'サーバー側でエラーが発生しました';
        } else if (res.status === 400) {
          title = '入力内容を確認してください';
        }
        showToast(errMsg, { title });

        // Turnstile の再描画（CAPTCHA は1度の検証で消費されるため）
        if (window.turnstile && typeof window.turnstile.reset === 'function') {
          try { window.turnstile.reset(); } catch {}
        }
      } catch (err) {
        showToast('通信に失敗しました。電波状況をご確認のうえ、再度お試しください。', {
          title: 'ネットワークエラー',
        });
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          delete submitBtn.dataset.busy;
          submitBtn.innerHTML = originalLabel;
        }
      }
    });
  })();
</script>

