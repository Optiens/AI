---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '~/styles/global.css'; // ルートエイリアスでバンドル

export interface Props {
  title: string;
  description?: string;
  canonical?: string;                 // 例: https://optiens.com/solutions
  ogImage?: string;                   // 例: https://optiens.com/ogp.png (public 推奨)
  noindex?: boolean;                  // true のとき robots を noindex に
  structuredData?: Record<string, any> | Array<Record<string, any>>;  // ページ固有のJSON-LD
}

const SITE_URL = 'https://optiens.com';
const DEFAULT_OG = SITE_URL + '/images/og-default.png';

const {
  title,
  description = '合同会社Optiens（オプティエンス）はAIエージェントによる業務自動化で、中小企業・小規模事業者の業務効率化を全国オンライン対応でサポートします。',
  canonical,
  ogImage = DEFAULT_OG,
  noindex = false,
  structuredData,
} = Astro.props;

// 全ページ共通の Organization スキーマ
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '合同会社Optiens',
  alternateName: 'Optiens LLC',
  url: SITE_URL,
  logo: SITE_URL + '/images/optiens-logo.png',
  email: 'info@optiens.com',
  foundingDate: '2026-04-06',
  description: 'AIエージェントによる業務自動化支援を全国の中小企業・小規模事業者に提供する合同会社。',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '高根町清里3545番地2483',
    addressLocality: '北杜市',
    addressRegion: '山梨県',
    postalCode: '407-0301',
    addressCountry: 'JP',
  },
  founder: {
    '@type': 'Person',
    name: '髙橋 大地',
  },
  sameAs: [
    'https://kakuyomu.jp/users/optiens-novel',
  ],
  taxID: '9090003003025',
};

// LocalBusiness スキーマ（地域SEO + 全国対応の補強）
const localBizSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: '合同会社Optiens',
  url: SITE_URL,
  image: SITE_URL + '/images/optiens-logo.png',
  email: 'info@optiens.com',
  areaServed: { '@type': 'Country', name: '日本' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '高根町清里3545番地2483',
    addressLocality: '北杜市',
    addressRegion: '山梨県',
    postalCode: '407-0301',
    addressCountry: 'JP',
  },
  priceRange: '¥¥',
  serviceType: ['AI業務自動化支援', 'AI活用診断', 'AIエージェント導入支援'],
};

const allSchemas = [orgSchema, localBizSchema];
if (structuredData) {
  if (Array.isArray(structuredData)) {
    allSchemas.push(...structuredData);
  } else {
    allSchemas.push(structuredData);
  }
}
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />

    {/* Canonical */}
    {canonical && <link rel="canonical" href={canonical} />}

    {/* Favicon / PWA 基本（v13-02 シンボル単体・ラピスB） */}
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/optiens-symbol-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/optiens-symbol-180-bg.png" />
    {/* (ある場合) */}
    {/* <link rel="manifest" href="/site.webmanifest" /> */}
    <meta name="theme-color" content="#1F3A93" />

    {/* OGP / Twitter */}
    <meta property="og:site_name" content="Optiens" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Optiens — Make AI native to your business." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* JSON-LD: 構造化データ（Organization + LocalBusiness + ページ固有） */}
    <script type="application/ld+json" set:html={JSON.stringify(allSchemas)} />

    {/* Fonts: Inter weight を絞り込み（5→2）、display=swap で render-blocking 抑制 */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Noto+Sans+JP:wght@400;700&display=swap"
      rel="stylesheet"
    />

    {/* Icons: 非同期ロードで render-blocking を解消 */}
    <link
      rel="preload"
      as="style"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
      />
    </noscript>

    {/* 任意: Safari等の電話番号自動リンクを抑止したい場合 */}
    {/* <meta name="format-detection" content="telephone=no" /> */}
  </head>
  <body>
    {/* スキップリンク（キーボード利用者向け） */}
    <a href="#main" class="skip-link">本文へスキップ</a>

    {/* Ambient floating blobs — visible through all pages */}
    <div class="ambient-wrap" aria-hidden="true">
      <div class="ambient-blob ambient-blob--1"></div>
      <div class="ambient-blob ambient-blob--2"></div>
      <div class="ambient-blob ambient-blob--3"></div>
    </div>

    <Header />
    <div id="main" class="site-main">
      <slot />
    </div>
    <Footer />

    {/* Scroll Reveal Observer */}
    <script is:inline>
      (function() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  /* アクセシビリティ: スキップリンクをフォーカス時だけ表示 */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    z-index: 1000;
    background: #0B2A4A;
    color: #fff;
    padding: 8px 12px;
    border-radius: 6px;
    text-decoration: none;
    transition: top .2s ease;
  }
  .skip-link:focus { top: 8px; }
</style>
