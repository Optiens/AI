---
import Layout from '../layouts/Layout.astro';

// ===== データ定義 =====
type CommonCase = {
  id: string;
  num: string;
  icon: string;
  title: string;
  summary: string;
  desc: string;
  tags: string[];
  self: string;
  demo?: { label: string; href: string };
};

type Industry = {
  id: string;
  image: string;
  title: string;
  shortTitle: string;
  summary: string;
  metric: string;
  href: string;
};

type Role = {
  id: string;
  tag: string;
  title: string;
  shortTitle: string;
  summary: string;
  metric: string;
  href: string;
  comingSoon?: boolean;
  icon?: string;
};

const commonCases: CommonCase[] = [
  {
    id: 'case-01',
    num: '01',
    icon: 'fa-file-arrow-up',
    title: '書類自動読み取り機能',
    summary: '手元の資料を投げ込むだけで、AI が要点を整理して台帳に記録',
    desc: '見積書・契約書・請求書・議事録・写真——日々たまっていく書類をフォームにアップロードすると、AIが自動で内容を読み取り、必要な情報だけ抜き出して台帳に整理します。手入力の転記時間がそのまま削減され、読み取り結果は人間が最終確認できる画面で表示するため、AI任せの誤りも防げます。請求書の金額・支払期日抽出、議事録からのToDo抽出、現場写真からの作業報告書下書きなど、紙とPDFが混じる現場ほど効果が出ます。',
    tags: ['工務店', '士業', '製造業', '宿泊業', '自治体'],
    self: '補助金公募要領のPDFを取り込み、要件を自動抽出する仕組みを社内で運用しています。',
    demo: { label: '実際に動くデモを試す（書類レビュー AI）', href: '/document-review' },
  },
  {
    id: 'case-02',
    num: '02',
    icon: 'fa-table-columns',
    title: 'カスタム業務管理画面',
    summary: '既製の SaaS ではなく、御社の業務に合わせた専用画面を構築',
    desc: '市販の業務管理システムは多くがSaaS(Software as a Service：複数の利用企業で同じ画面・機能を共有するクラウド型サービス)として提供されており、汎用的に作られているため御社の業務フローには完全には合いません。「項目が多すぎて使われない」「複数サービスを行き来して二重入力」が発生しがちです。弊社はシングルテナント構成(御社専用の環境で動作する構成)で管理画面を構築します。リード管理から成約・納品・保守までを1画面で追える設計、外注先や営業パートナーが見るべき情報だけを共有する画面、現場スマホ用の入力に絞った画面——用途別に最適化できます。月額ライセンス料は発生せず、データは御社の資産として残ります。',
    tags: ['工務店', '士業', 'EC', '製造業', 'サービス業', '農業'],
    self: '弊社の CRM と承認ワークフローツールは、まさにこの構成で社内運用しています。',
  },
  {
    id: 'case-03',
    num: '03',
    icon: 'fa-comments',
    title: '自然言語データ検索',
    summary: '「先月、何件あった？」と話しかけるだけで AI がデータから答える',
    desc: '社内に蓄積されたデータ（顧客リスト・売上・在庫・問い合わせ履歴等）に、自然な日本語で質問できる仕組みです。「先月の新規問い合わせを業種別に教えて」「リピート率が高い顧客の共通点は？」といった問いに、AIがデータを読み取って答えを返します。表計算ソフトでの集計やデータベースの専門知識は不要で、経営判断に必要な数字をその場で取り出せます。回答の根拠となったデータも併せて表示するため、AIの誤答を確認しながら使えます。',
    tags: ['小売', 'EC', '士業', '宿泊業', '自治体', '全業種'],
    self: '水耕栽培の収穫データ・電力消費データに対して、同じ仕組みで対話分析しています。',
  },
  {
    id: 'case-04',
    num: '04',
    icon: 'fa-bell',
    title: '24 時間 問い合わせ自動監視',
    summary: '営業時間外の問い合わせも、AI が取りこぼさず一次対応',
    desc: 'メール・Webフォーム・LINE公式・SNS——複数の窓口に届く問い合わせを、AIエージェントが24時間監視します。内容を分類し、定型的なものには自動で一次回答を返し、判断が必要なものだけ通知します。夜間や休日にも一次対応が動くため、機会損失を減らせます。同時に、問い合わせ内容は自動でデータ化され、傾向分析や次の改善に使えます。完全自動化ではなく「人が判断すべきものは人に渡す」設計が前提です。',
    tags: ['宿泊業', 'EC', '士業', 'サービス業', '自治体'],
    self: '弊社では補助金情報や市場ニュースを定期的にモニタリングする仕組みを社内運用しています。',
  },
  {
    id: 'case-05',
    num: '05',
    icon: 'fa-people-group',
    title: 'マルチエージェント分業',
    summary: '役割を持った複数の AI が、並行してタスクを処理',
    desc: 'ひとつの大きなAIに何でも頼むのではなく、役割ごとに専門のAIエージェントを用意し、それぞれを連携させて業務を回します。たとえば「市場調査担当」「文章編集担当」「数値チェック担当」のように分業させると、1人の経営者が複数の専門スタッフを抱える体制に近い動き方をAIで実現できます。各エージェントには得意分野・参照資料・判断基準を仕込んでおけるため、汎用AIに毎回ゼロから指示する必要がありません。少人数の事業者ほど、この分業設計の効果が大きく出ます。',
    tags: ['一人事業主', '少人数チーム', '全業種'],
    self: 'COO・CRO・CMO・CFO・CSO・CTOといった役割別エージェントを社内で運用しており、本ページの設計もこの体制で進めました。',
  },
  {
    id: 'case-06',
    num: '06',
    icon: 'fa-gauge-high',
    title: '稼働状況ダッシュボード',
    summary: '動いている自動化を可視化、いつでも経営者が把握できる',
    desc: 'AI自動化を導入した後、「ちゃんと動いているのか」「どこで止まったのか」が見えないと不安が残ります。弊社は自動化ワークフローごとに稼働状況を可視化するダッシュボードを納品します。直近の処理件数、エラー発生箇所、AIが判断に迷った件数、月次のコスト——必要な数字だけをひと目で確認できます。何かあれば通知が届き、ない日は見なくて済む設計です。導入したまま放置にならず、改善のサイクルが回ります。',
    tags: ['保守契約', '全業種'],
    self: '保守プラン契約者向けに、このダッシュボードを標準で提供します。',
  },
];

const industries: Industry[] = [
  { id: 'ind-legal', image: '/images/industries/legal.png', title: '士業（税理士・行政書士）', shortTitle: '士業', summary: '月次報告自動生成・期限管理・FAQ対応', metric: '月30時間削減', href: '/service/sample-legal' },
  { id: 'ind-pension', image: '/images/industries/pension.png', title: 'ペンション・宿泊業', shortTitle: 'ペンション・宿泊', summary: '多言語対応・口コミ返信・SNS投稿の自動化', metric: '月25時間削減', href: '/service/sample-pension' },
  { id: 'ind-restaurant', image: '/images/industries/restaurant.png', title: 'カフェ＆レストラン', shortTitle: 'カフェ・レストラン', summary: 'SNS毎日投稿・LINE配信・予約一元化', metric: '月18時間削減＋売上増', href: '/service/sample-restaurant' },
  { id: 'ind-ec', image: '/images/industries/ec.png', title: 'EC事業者・ネットショップ', shortTitle: 'EC・ネットショップ', summary: '商品登録・受注対応・SNS運用の自動化', metric: '月25時間削減', href: '/service/sample-ec' },
  { id: 'ind-construction', image: '/images/industries/construction.png', title: '工務店・建設業', shortTitle: '工務店・建設', summary: '見積自動生成・報告書効率化・別荘管理', metric: '月35時間削減', href: '/service/sample-construction' },
  { id: 'ind-winery', image: '/images/industries/winery.png', title: 'ワイナリー・醸造所', shortTitle: 'ワイナリー', summary: '醸造記録デジタル化・DtoC販売・卸先提案書', metric: '月30時間削減', href: '/service/sample-winery' },
  { id: 'ind-outdoor', image: '/images/industries/outdoor.png', title: 'アウトドアガイド', shortTitle: 'アウトドアガイド', summary: '予約一元管理・天候判断・SNS集客', metric: '月20時間削減', href: '/service/sample-outdoor' },
  { id: 'ind-bakery', image: '/images/industries/bakery.png', title: 'パン屋・ベーカリー', shortTitle: 'ベーカリー', summary: '仕込み計画AI最適化・SNS集客・売上分析', metric: '月22時間削減', href: '/service/sample-bakery' },
  { id: 'ind-farmer', image: '/images/industries/farmer.png', title: '個人農家', shortTitle: '個人農家', summary: '出荷管理・SNS直販AI活用＋IoTハウス環境監視', metric: '月25時間削減', href: '/service/sample-farmer' },
  { id: 'ind-dairy', image: '/images/industries/dairy.png', title: '酪農・畜産業', shortTitle: '酪農・畜産', summary: '飼養記録AI分析＋IoT牛舎環境モニタリング', metric: '月28時間削減', href: '/service/sample-dairy' },
  { id: 'ind-municipality', image: '/images/industries/municipality.png', title: '自治体・市役所', shortTitle: '自治体', summary: '観光SNS・議事録・多言語対応の効率化', metric: '月40時間削減', href: '/service/sample-municipality' },
];

const roles: Role[] = [
  { id: 'role-executive', tag: 'FOR EXECUTIVES', title: '経営者・代表者向けAIブリーフィング', shortTitle: '経営者・代表者向け', summary: '朝10分で事業全体が見える、本来の時間が戻る仕組み', metric: '事業状況把握 5時間 → 30分', href: '/service/sample-executive', icon: 'fa-user-tie' },
  { id: 'role-board', tag: 'FOR BOARD MEMBERS', title: '取締役・役員向けAI意思決定支援', shortTitle: '取締役・役員向け', summary: '取締役会・経営会議の論点整理と数値ブリーフィングをAIで自動化', metric: '会議準備 3時間 → 20分', href: '/service/sample-board', comingSoon: true, icon: 'fa-chess-king' },
  { id: 'role-manager', tag: 'FOR MANAGERS', title: '管理職・マネージャー向けAI業務支援', shortTitle: '管理職向け', summary: 'メンバー稼働把握・週次レポート・1on1準備をAIエージェントに委譲', metric: 'マネジメント工数 月15時間削減', href: '/service/sample-manager', comingSoon: true, icon: 'fa-users-gear' },
  { id: 'role-staff', tag: 'FOR STAFF', title: '一般社員・実務担当者向けAI業務効率化', shortTitle: '一般社員・担当者向け', summary: '日々の繰り返し業務をAIに任せ、本来集中すべき業務に時間を取り戻す', metric: '定型業務 月20時間削減', href: '/service/sample-staff', comingSoon: true, icon: 'fa-user-gear' },
  { id: 'role-backoffice', tag: 'FOR BACK-OFFICE', title: 'バックオフィス（経理・労務・総務）向けAI業務自動化', shortTitle: 'バックオフィス向け', summary: '請求書処理・経費精算・勤怠集計・社内問い合わせ対応をAIで一気通貫化', metric: '月次締め作業 50% 削減', href: '/service/sample-backoffice', comingSoon: true, icon: 'fa-building-columns' },
];

const totalCount = commonCases.length + industries.length + roles.length;
---

<Layout
  title="AI活用事例集 | 業種別11業種 + 共通6パターン | Optiens（中小企業向けAI業務自動化）"
  description="中小企業・小規模事業者のAI活用事例集。士業・宿泊業・飲食・EC・建設・ワイナリー・アウトドア・ベーカリー・農家・酪農・自治体の11業種別レポートと、業種を問わず効く6つの共通AI自動化パターン、小規模事業者の経営者向けAIブリーフィング。御社に近い業種・課題からご覧ください。"
  canonical="https://optiens.com/ai-examples"
>
  <main>
    <!-- 事例エクスプローラ（ヒーローは削除し直接表示） -->
    <section class="ax-explorer light-section">
      <div class="container">
        <!-- カテゴリタブ -->
        <div class="ax-tabs reveal" role="tablist" aria-label="事例カテゴリ">
          <button class="ax-tab active" data-cat="common" role="tab" aria-selected="true">
            <span class="ax-tab-label">共通</span>
            <span class="ax-tab-count">{commonCases.length}</span>
          </button>
          <button class="ax-tab" data-cat="industry" role="tab" aria-selected="false">
            <span class="ax-tab-label">業種別</span>
            <span class="ax-tab-count">{industries.length}</span>
          </button>
          <button class="ax-tab" data-cat="role" role="tab" aria-selected="false">
            <span class="ax-tab-label">対象者別</span>
            <span class="ax-tab-count">{roles.length}</span>
          </button>
        </div>

        <!-- セレクタ + 詳細 -->
        <div class="ax-explorer-grid">
          <!-- 左：セレクタリスト -->
          <aside class="ax-selector" aria-label="事例選択リスト">
            <!-- 共通事例 -->
            <ul class="ax-selector-group" data-cat-group="common">
              {commonCases.map((c, idx) => (
                <li>
                  <button class={`ax-sel-item ${idx === 0 ? 'active' : ''}`} data-id={c.id}>
                    <span class="ax-sel-num">{c.num}</span>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">{c.title}</span>
                      <span class="ax-sel-summary">{c.summary}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
            <!-- 業種別 -->
            <ul class="ax-selector-group hidden" data-cat-group="industry">
              {industries.map((i) => (
                <li>
                  <button class="ax-sel-item ax-sel-item--industry" data-id={i.id}>
                    <span class="ax-sel-thumb">
                      <img src={i.image} alt="" loading="lazy" />
                    </span>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">{i.shortTitle}</span>
                      <span class="ax-sel-summary">{i.metric}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
            <!-- 対象者別 -->
            <ul class="ax-selector-group hidden" data-cat-group="role">
              {roles.map((r) => (
                <li>
                  <button class="ax-sel-item ax-sel-item--role" data-id={r.id}>
                    <span class="ax-sel-role-icon">
                      <i class={`fa-solid ${r.icon ?? 'fa-user-tie'}`}></i>
                    </span>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">
                        {r.shortTitle}
                        {r.comingSoon && <span class="ax-coming-soon">近日公開</span>}
                      </span>
                      <span class="ax-sel-summary">{r.metric}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
          </aside>

          <!-- 右：詳細パネル -->
          <div class="ax-detail" aria-live="polite">
            <!-- 共通事例の詳細 -->
            {commonCases.map((c, idx) => (
              <article class={`ax-detail-card ${idx === 0 ? 'active' : ''}`} data-id={c.id} data-cat="common">
                <header class="ax-detail-head">
                  <span class="ax-detail-eyebrow">共通 / {c.num}</span>
                  <div class="ax-detail-icon"><i class={`fa-solid ${c.icon}`}></i></div>
                  <h2 class="ax-detail-title">{c.title}</h2>
                </header>
                <p class="ax-detail-desc">{c.desc}</p>
                <div class="ax-detail-tags">
                  <span class="ax-detail-tags-label">適用業種：</span>
                  {c.tags.map((t: string) => <span class="ax-tag">{t}</span>)}
                </div>
                <div class="ax-detail-self">
                  <i class="fa-solid fa-flask"></i>
                  <p><strong>弊社での運用</strong>: {c.self}</p>
                </div>
                {c.demo ? (
                  <a href={c.demo.href} class="btn-primary ax-detail-cta">
                    <i class="fa-solid fa-circle-play"></i>
                    {c.demo.label}
                    <i class="fa-solid fa-arrow-right"></i>
                  </a>
                ) : null}
              </article>
            ))}
            <!-- 業種別の詳細 -->
            {industries.map((i) => (
              <article class="ax-detail-card" data-id={i.id} data-cat="industry">
                <header class="ax-detail-head">
                  <span class="ax-detail-eyebrow">業種別事例</span>
                  <div class="ax-detail-thumb-wrap">
                    <img src={i.image} alt={i.title} loading="lazy" />
                  </div>
                  <h2 class="ax-detail-title">{i.title}</h2>
                </header>
                <p class="ax-detail-desc">{i.summary}を含む業務全体を、御社の現場に合わせて再設計します。具体的な業務プロセスごとの自動化提案・想定削減時間・導入ロードマップは、サンプルレポートでご覧いただけます。</p>
                <div class="ax-detail-metric">
                  <span class="ax-metric-label">想定削減時間</span>
                  <span class="ax-metric-value">{i.metric}</span>
                </div>
                <a href={i.href} class="btn-primary ax-detail-cta">
                  サンプルレポートを見る
                  <i class="fa-solid fa-arrow-right"></i>
                </a>
              </article>
            ))}
            <!-- 対象者別の詳細 -->
            {roles.map((r) => (
              <article class="ax-detail-card" data-id={r.id} data-cat="role">
                <header class="ax-detail-head">
                  <span class="ax-detail-eyebrow">
                    {r.tag}
                    {r.comingSoon && <span class="ax-coming-soon ax-coming-soon--inline">近日公開</span>}
                  </span>
                  <div class="ax-detail-icon ax-detail-icon--role"><i class={`fa-solid ${r.icon ?? 'fa-user-tie'}`}></i></div>
                  <h2 class="ax-detail-title">{r.title}</h2>
                </header>
                <p class="ax-detail-desc">{r.summary}。具体的な運用イメージ・導入ロードマップ・ROI試算はサンプルページでご覧いただけます。</p>
                <div class="ax-detail-metric">
                  <span class="ax-metric-label">想定効果</span>
                  <span class="ax-metric-value">{r.metric}</span>
                </div>
                {r.comingSoon ? (
                  <a href="/free-diagnosis" class="btn-secondary ax-detail-cta">
                    サンプル準備中 — まずは無料診断で個別提案
                    <i class="fa-solid fa-arrow-right"></i>
                  </a>
                ) : (
                  <a href={r.href} class="btn-primary ax-detail-cta">
                    サンプルページを見る
                    <i class="fa-solid fa-arrow-right"></i>
                  </a>
                )}
              </article>
            ))}
          </div>
        </div>

        <p class="ax-bridge-note reveal">
          記載のない業種でも対応可能です。サービス内容は <a href="/service">AI支援ページ</a> をご確認ください。
        </p>
      </div>
    </section>

    <!-- ファイナルCTA -->
    <section class="ax-cta-section">
      <div class="container text-center">
        <h2 class="reveal">貴社の業務に当てはめた、具体例をご提示します</h2>
        <p class="reveal">
          上記の型のうち、どれが御社で効きやすいか。<br />
          無料活用診断レポートで数値とともにご提案します。
        </p>
        <div class="cta-buttons reveal">
          <a href="/free-diagnosis" class="btn-primary">無料活用診断を受ける</a>
          <a href="/service" class="btn-secondary">サービス内容を見る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
(function() {
  const tabs = document.querySelectorAll('.ax-tab');
  const groups = document.querySelectorAll('.ax-selector-group');
  const detailCards = document.querySelectorAll('.ax-detail-card');
  const selItems = document.querySelectorAll('.ax-sel-item');

  function selectCategory(cat) {
    // タブ更新
    tabs.forEach((t) => {
      const isActive = t.dataset.cat === cat;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    // セレクタグループ更新
    groups.forEach((g) => {
      g.classList.toggle('hidden', g.dataset.catGroup !== cat);
    });
    // そのカテゴリの最初の項目を選択
    const firstItem = document.querySelector(`.ax-selector-group[data-cat-group="${cat}"] .ax-sel-item`);
    if (firstItem) selectItem(firstItem.dataset.id);
  }

  function selectItem(id) {
    if (!id) return;
    selItems.forEach((b) => b.classList.toggle('active', b.dataset.id === id));
    detailCards.forEach((c) => c.classList.toggle('active', c.dataset.id === id));
    // 詳細パネルへスクロール（モバイル対応）
    if (window.innerWidth <= 900) {
      const target = document.querySelector(`.ax-detail-card.active`);
      if (target) {
        const offset = target.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: offset, behavior: 'smooth' });
      }
    }
    // URLハッシュ更新
    if (history.replaceState) history.replaceState(null, '', '#' + id);
  }

  tabs.forEach((t) => {
    t.addEventListener('click', () => selectCategory(t.dataset.cat));
  });
  selItems.forEach((b) => {
    b.addEventListener('click', () => selectItem(b.dataset.id));
  });

  // 初期表示：URLハッシュがあればそれを選択
  const hash = window.location.hash.replace('#', '');
  if (hash) {
    const target = document.querySelector(`.ax-sel-item[data-id="${hash}"]`);
    if (target) {
      const cat = target.closest('.ax-selector-group')?.dataset.catGroup;
      if (cat) {
        selectCategory(cat);
        selectItem(hash);
      }
    }
  }
})();
</script>

