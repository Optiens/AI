            {lane.leads.length > 6 && <p class="lane-more">他 {lane.leads.length - 6}件</p>}
          </div>
        </article>
      ))}
    </div>

    <div class="status-distribution">
      {statusRows.filter((row) => row.count > 0).map((row) => (
        <div class="status-row">
          <span class="status-pill" style={`--pill:${row.color}`}>{row.shortLabel}</span>
          <i><b style={`width:${(row.count / maxStatusCount) * 100}%; background:${row.color}`}></b></i>
          <strong>{row.count}</strong>
        </div>
      ))}
    </div>
  </section>

  <section class="panel table-panel">
    <div class="panel-head panel-head--table">
      <div>
        <span class="section-kicker">Lead Table</span>
        <h3>リード一覧</h3>
      </div>
      <span class="panel-count"><span id="visible-count">{total}</span> / {total}件</span>
    </div>

    <div class="lead-toolbar">
      <label class="search-box">
        <i class="fas fa-search"></i>
        <input id="lead-search" type="search" placeholder="企業名、担当者、メール、申込番号で検索" />
      </label>
