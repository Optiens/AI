---
import Layout from '../layouts/Layout.astro';

type DemoService = {
  id: string;
  title: string;
  shortTitle: string;
  icon: string;
  href: string;
  cta: string;
  outcome: string;
  summary: string;
  bestFor: string[];
  automations: string[];
  proof: string;
  humanCheck: string;
  delivery: string;
  priority: 'core' | 'strong' | 'niche';
};

type ScenarioLink = {
  title: string;
  href: string;
  note: string;
};

const demoServices: DemoService[] = [
  {
    id: 'service-inquiry',
    title: '問い合わせ自動振り分け・一次返信下書き',
    shortTitle: '問い合わせ振り分け',
    icon: 'fa-route',
    href: '/inquiry-routing',
    cta: 'デモを試す',
    outcome: '初動対応を数分に短縮',
    summary:
      'Webフォームやメールで届いた問い合わせを、内容別に分類し、優先度・担当者・一次返信案まで生成します。夜間や休日の取りこぼしを減らし、対応が必要な案件だけ人に渡せます。',
    bestFor: ['宿泊業', 'EC', '士業', 'BtoBサービス'],
    automations: ['内容分類', '優先度判定', '担当者振り分け', '返信下書き'],
    proof: 'サンプル問い合わせを入力すると、業種分類・優先度・推奨対応者・返信テンプレートがその場で表示されます。',
    humanCheck: '送信前の最終確認と例外対応は人が行います。',
    delivery: 'フォーム、メール、チャット通知、CRM登録まで接続可能',
    priority: 'core',
  },
  {
    id: 'service-quote',
    title: '見積書ドラフト自動生成',
    shortTitle: '見積書作成',
    icon: 'fa-file-signature',
    href: '/quote-generator',
    cta: '見積書を作る',
    outcome: '見積初稿の作成時間を短縮',
    summary:
      '顧客名・案件概要・金額・納期を入力すると、見積書の下書きを自動生成します。御社専用版では過去案件、標準価格表、承認フローまでつなげられます。',
    bestFor: ['工務店', '制作会社', '士業', '導入支援会社'],
    automations: ['案件情報の整理', '内訳案の生成', '条件文の挿入', 'テキスト出力'],
    proof: '入力内容を反映した見積書ドラフトを生成し、その場で編集・コピー・ダウンロードできます。',
    humanCheck: '金額、契約条件、送付可否は担当者が確認します。',
    delivery: '標準価格表、CRM、承認ワークフロー、PDF出力に接続可能',
    priority: 'core',
  },
  {
    id: 'service-search',
    title: '社内データ・社内ドキュメント検索',
    shortTitle: 'データ検索',
    icon: 'fa-magnifying-glass-chart',
    href: '/data-search',
    cta: '検索デモを試す',
    outcome: '数字探しと社内質問を減らす',
    summary:
      '売上・顧客・問い合わせ履歴などの数値データと、規程・マニュアル・連絡網などの社内文書を、自然な日本語で検索できます。回答には根拠データや引用元を添えます。',
    bestFor: ['全業種', '管理部門', '営業', '新人教育'],
    automations: ['自然言語検索', '集計回答', '引用元表示', '質問履歴化'],
    proof: '販売データ検索と社内ドキュメント検索をタブで切り替え、サンプル質問に対する回答と根拠を確認できます。',
    humanCheck: '重要判断に使う数値は、根拠行と元資料を確認できます。',
    delivery: 'CSV、スプレッドシート、Supabase、社内文書DBに接続可能',
    priority: 'core',
  },
  {
    id: 'service-approval',
    title: '承認ワークフロー',
    shortTitle: '承認WF',
    icon: 'fa-clipboard-check',
    href: '/approval-workflow',
    cta: '申請と承認を試す',
    outcome: '申請、承認、差戻しを画面で完結',
    summary:
      '経費精算・休暇申請・稟議・発注承認を、申請者ビューと承認者ビューに分けて管理します。金額や種類に応じた承認ルートの自動切替にも対応できます。',
    bestFor: ['管理部門', '建設業', '製造業', '複数拠点'],
    automations: ['申請登録', '承認者絞り込み', 'ステータス管理', '処理履歴'],
    proof: '申請者として新規申請を出し、承認者に切り替えて承認・却下できます。',
    humanCheck: '承認判断は権限を持つ人が行い、履歴が残ります。',
    delivery: 'freee、kintone、スプレッドシート、チャット通知に接続可能',
    priority: 'strong',
  },
  {
    id: 'service-management',
    title: '御社専用の業務管理画面',
    shortTitle: '業務管理画面',
    icon: 'fa-table-columns',
    href: '/custom-management',
    cta: '管理画面を見る',
    outcome: 'リードから保守まで一画面で把握',
    summary:
      '汎用ツールの項目過多や二重入力を避け、御社の業務フローに合わせた専用画面を作ります。経営者、営業パートナー、現場担当で見える情報を切り替えられます。',
    bestFor: ['小規模事業者', '営業組織', '外注先管理', '保守運用'],
    automations: ['案件管理', 'ロール別表示', 'KPI集計', 'AI提案'],
    proof: 'ロール別ビューを切り替え、リード・商談・進行案件・保守契約を確認できます。',
    humanCheck: '案件更新や最終判断は担当者が行います。',
    delivery: '御社専用DB、権限管理、スマホ入力画面、月次レポートに接続可能',
    priority: 'strong',
  },
  {
    id: 'service-review',
    title: '口コミ監視・返信下書き',
    shortTitle: '口コミ監視',
    icon: 'fa-star-half-stroke',
    href: '/review-monitor',
    cta: '口コミ監視を見る',
    outcome: '低評価を当日中に把握',
    summary:
      'Googleマップ、食べログ、SNSなどの新着口コミを監視し、低評価をアラート化します。内容を分類し、店舗の言葉に合わせた返信下書きを用意します。',
    bestFor: ['飲食店', '宿泊業', '観光事業', '店舗運営'],
    automations: ['新着監視', '低評価検知', '要因分類', '返信下書き'],
    proof: 'サンプル口コミ一覧から低評価を抽出し、返信下書きと改善ポイントを確認できます。',
    humanCheck: '公開返信は店舗責任者が確認して送信します。',
    delivery: '店舗別ルール、通知、週次レポート、SNS投稿案に接続可能',
    priority: 'strong',
  },
  {
    id: 'service-document',
    title: '契約書・社内文書レビュー支援',
    shortTitle: '文書レビュー',
    icon: 'fa-file-circle-check',
    href: '/document-review',
    cta: '文書レビューを見る',
    outcome: 'レビュー観点の抜け漏れを減らす',
    summary:
      'メール、契約書、提案書、社内文書を読み、重要度付きの指摘メモを表示します。御社専用版では表現チェック、記載漏れ、期限・金額・責任範囲の確認に使えます。',
    bestFor: ['士業', '管理部門', '営業', '経営者'],
    automations: ['重要度分類', '指摘メモ表示', '修正観点整理', 'レビュー履歴化'],
    proof: 'サンプル文書を選ぶと、本文の行ごとにAI添削メモが表示されます。',
    humanCheck: '法的判断や最終提出は専門家・責任者が確認します。',
    delivery: '社内テンプレート、承認ワークフロー、履歴DB、AI事前レビューに接続可能',
    priority: 'niche',
  },
];

const scenarioLinks: ScenarioLink[] = [
  { title: '士業', href: '/service/sample-legal', note: '期限管理、顧客対応、書類作成' },
  { title: '宿泊業', href: '/service/sample-pension', note: '予約対応、口コミ返信、多言語対応' },
  { title: '飲食店', href: '/service/sample-restaurant', note: 'SNS、口コミ、LINE配信' },
  { title: 'EC', href: '/service/sample-ec', note: '商品登録、問い合わせ、受注対応' },
  { title: '工務店', href: '/service/sample-construction', note: '見積、報告書、別荘管理' },
  { title: 'ワイナリー', href: '/service/sample-winery', note: '記録管理、提案書、在庫管理' },
];

const coreCount = demoServices.filter((d) => d.priority === 'core').length;
const strongCount = demoServices.filter((d) => d.priority === 'strong').length;
const nicheCount = demoServices.filter((d) => d.priority === 'niche').length;
---

<Layout
  title="AI業務自動化デモ | 実際に触れる業務サービス集 | Optiens"
  description="中小企業・小規模事業者向けに、問い合わせ振り分け、見積書作成、社内データ検索、承認ワークフロー、業務管理画面など、実際に触れるAI業務自動化デモを公開しています。"
  canonical="https://optiens.com/ai-examples"
>
  <main class="demo-main">
    <section class="demo-hero">
      <div class="container demo-hero-grid">
        <div class="demo-hero-copy">
          <p class="demo-eyebrow">AI AUTOMATION DEMOS</p>
          <h1>業務で使うところまで想像できる、AI自動化デモだけを残しました。</h1>
          <p class="demo-lede">
            「AIで何ができるか」ではなく、「明日どの業務に入れられるか」で選べるように、実際に操作できるデモを中心に整理しました。
            それぞれ、入力、判定、出力、人間の確認ポイントまで確認できます。
          </p>
          <div class="demo-hero-actions">
            <a href="#demo-services" class="btn-primary">デモ一覧を見る</a>
            <a href="/free-diagnosis" class="btn-secondary">自社向けに診断する</a>
          </div>
        </div>
        <div class="demo-hero-panel" aria-label="掲載デモの内訳">
          <div class="panel-row">
            <span class="panel-label">すぐ試せる中核デモ</span>
            <strong>{coreCount}</strong>
          </div>
          <div class="panel-row">
            <span class="panel-label">業務フロー型デモ</span>
            <strong>{strongCount}</strong>
          </div>
          <div class="panel-row">
            <span class="panel-label">用途限定の補助デモ</span>
            <strong>{nicheCount}</strong>
          </div>
          <div class="panel-automation">
            <span>公開基準</span>
            <ul>
              <li>顧客が画面上で操作できる</li>
              <li>日常業務の頻度が高い</li>
              <li>人間の確認ポイントが明確</li>
              <li>導入後の接続先まで説明できる</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="demo-policy-section">
      <div class="container policy-grid">
        <article>
          <span class="policy-num">01</span>
          <h2>触れるものを優先</h2>
          <p>単なるアイデア集ではなく、入力や切替操作で結果が見えるデモを優先して掲載しています。</p>
        </article>
        <article>
          <span class="policy-num">02</span>
          <h2>現場頻度で選定</h2>
          <p>問い合わせ、見積、検索、承認、案件管理など、毎週または毎日発生する業務を中心にしています。</p>
        </article>
        <article>
          <span class="policy-num">03</span>
          <h2>完全自動にしすぎない</h2>
          <p>送信、承認、契約判断など、責任が発生する箇所は人間が確認する設計を前提にしています。</p>
        </article>
      </div>
    </section>

    <section class="demo-services-section" id="demo-services">
      <div class="container">
        <div class="section-head">
          <p class="demo-eyebrow">AVAILABLE DEMOS</p>
          <h2>公開中の業務自動化デモ</h2>
          <p>商談で説明しやすく、顧客が自社業務に置き換えやすいものに絞っています。</p>
        </div>

        <div class="demo-grid">
          {demoServices.map((demo) => (
            <article class={`demo-card demo-card--${demo.priority}`} id={demo.id}>
              <header class="demo-card-head">
                <span class="demo-icon"><i class={`fa-solid ${demo.icon}`}></i></span>
                <div>
                  <span class="demo-priority">
                    {demo.priority === 'core' ? '優先提案' : demo.priority === 'strong' ? '業務フロー型' : '用途限定'}
                  </span>
                  <h3>{demo.title}</h3>
                </div>
              </header>

              <p class="demo-outcome">{demo.outcome}</p>
              <p class="demo-summary">{demo.summary}</p>

              <div class="demo-meta-row">
                <div>
                  <span class="demo-meta-label">向いている業務</span>
                  <div class="demo-tags">
                    {demo.bestFor.map((tag) => <span>{tag}</span>)}
                  </div>
                </div>
                <div>
                  <span class="demo-meta-label">自動化する処理</span>
                  <ul class="demo-mini-list">
                    {demo.automations.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </div>

              <div class="demo-proof">
                <div>
                  <span>デモで確認できること</span>
                  <p>{demo.proof}</p>
                </div>
                <div>
                  <span>人が確認すること</span>
                  <p>{demo.humanCheck}</p>
                </div>
              </div>

              <div class="demo-delivery">
                <i class="fa-solid fa-plug-circle-bolt"></i>
                <span>{demo.delivery}</span>
              </div>

              <a href={demo.href} class="demo-card-link">
                {demo.cta}
                <i class="fa-solid fa-arrow-right"></i>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="scenario-section">
      <div class="container scenario-grid">
        <div class="scenario-copy">
          <p class="demo-eyebrow">INDUSTRY ENTRY</p>
          <h2>業種別ページは、デモの前後に読む補足資料として残します。</h2>
          <p>
            業種別シナリオは「その業界なら何から始めるか」を掴むための資料です。
            実際の導入可否は、無料診断で業務量、既存ツール、運用体制を見てから判断します。
          </p>
          <a href="/free-diagnosis" class="btn-primary">無料AI診断を受ける</a>
        </div>
        <div class="scenario-list">
          {scenarioLinks.map((scenario) => (
            <a href={scenario.href} class="scenario-link">
              <strong>{scenario.title}</strong>
              <span>{scenario.note}</span>
              <i class="fa-solid fa-arrow-right"></i>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="demo-cta-section">
      <div class="container cta-box">
        <p class="demo-eyebrow">NEXT STEP</p>
        <h2>御社で使うなら、どのデモから着手すべきかを診断します。</h2>
        <p>
          既存の業務フロー、利用中のツール、月間件数を確認し、効果が出やすい順に導入候補を整理します。
          まずは無料診断で、過剰な自動化を避けた現実的な構成をご提案します。
        </p>
        <div class="cta-actions">
          <a href="/free-diagnosis" class="btn-primary">無料AI診断を受ける</a>
          <a href="/implementation" class="btn-secondary">導入支援を見る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .demo-main {
    --text: #293b35;
    --heading: #18362f;
    --muted: #5b6c66;
    --brand: #2e574c;
    --brand-dim: #24463d;
    background: #f7faf8;
    color: var(--text);
  }

  .demo-main .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 24px;
    border-radius: 999px;
    background: #2e574c;
    color: #ffffff;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(46, 87, 76, 0.18);
  }

  .demo-main .btn-primary:hover {
    background: #24463d;
    color: #ffffff;
  }

  .demo-hero {
    background:
      linear-gradient(135deg, rgba(46, 87, 76, 0.08), rgba(94, 168, 154, 0.06)),
      #ffffff;
    padding: 72px 0 48px;
  }

  .demo-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 32px;
    align-items: center;
  }

  .demo-eyebrow {
    margin: 0 0 12px;
    color: #2e574c;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .demo-hero h1 {
    margin: 0;
    color: var(--heading);
    font-size: 2.2rem;
    line-height: 1.45;
  }

  .demo-lede {
    margin: 20px 0 0;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.9;
    max-width: 760px;
  }

  .demo-hero-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 24px;
    border-radius: 999px;
    border: 1px solid #2e574c;
    color: #2e574c;
    background: #ffffff;
    font-weight: 700;
    text-decoration: none;
  }

  .btn-secondary:hover {
    background: #2e574c;
    color: #ffffff;
  }

  .demo-hero-panel {
    border: 1px solid rgba(46, 87, 76, 0.18);
    background: #ffffff;
    border-radius: 8px;
    padding: 22px;
    box-shadow: 0 16px 40px rgba(29, 51, 45, 0.08);
  }

  .panel-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(46, 87, 76, 0.12);
  }

  .panel-row strong {
    color: #2e574c;
    font-size: 2rem;
  }

  .panel-label {
    color: var(--text);
    font-weight: 700;
  }

  .panel-automation {
    margin-top: 18px;
  }

  .panel-automation span {
    display: block;
    color: var(--heading);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .panel-automation ul,
  .demo-mini-list {
    margin: 0;
    padding-left: 18px;
    color: var(--muted);
    line-height: 1.8;
  }

  .demo-policy-section,
  .demo-services-section,
  .scenario-section,
  .demo-cta-section {
    padding: 56px 0;
  }

  .policy-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .policy-grid article {
    background: #ffffff;
    border: 1px solid rgba(46, 87, 76, 0.14);
    border-radius: 8px;
    padding: 22px;
  }

  .policy-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(94, 168, 154, 0.16);
    color: #2e574c;
    font-weight: 700;
    margin-bottom: 14px;
  }

  .policy-grid h2 {
    margin: 0 0 10px;
    color: var(--heading);
    font-size: 1.12rem;
  }

  .policy-grid p,
  .section-head p,
  .scenario-copy p,
  .cta-box p {
    color: var(--muted);
    line-height: 1.8;
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .section-head h2,
  .scenario-copy h2,
  .cta-box h2 {
    margin: 0 0 12px;
    color: var(--heading);
    font-size: 1.8rem;
    line-height: 1.5;
  }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .demo-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    background: #ffffff;
    border: 1px solid rgba(46, 87, 76, 0.16);
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 12px 30px rgba(29, 51, 45, 0.06);
  }

  .demo-card--core {
    border-top: 4px solid #2e574c;
  }

  .demo-card--strong {
    border-top: 4px solid #5ea89a;
  }

  .demo-card--niche {
    border-top: 4px solid #c58b28;
  }

  .demo-card-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 14px;
  }

  .demo-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 8px;
    background: rgba(94, 168, 154, 0.14);
    color: #2e574c;
