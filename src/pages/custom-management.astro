<script is:inline>
(function() {
  // ロール切替
  const roleBtns = document.querySelectorAll('.role-btn');
  const root = document.querySelector('.cm-app');

  function setRole(role) {
    roleBtns.forEach((b) => {
      const active = b.dataset.role === role;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    if (!root) return;
    root.dataset.role = role;
  }
  roleBtns.forEach((b) => b.addEventListener('click', () => setRole(b.dataset.role)));
  setRole('executive');

  // ステージ切替
  const navItems = document.querySelectorAll('.cm-nav-item');
  const stagePanels = document.querySelectorAll('[data-stage-panel]');

  function setStage(stage) {
    navItems.forEach((n) => n.classList.toggle('is-active', n.dataset.stage === stage));
    stagePanels.forEach((p) => p.classList.toggle('hidden', p.dataset.stagePanel !== stage));
  }
  navItems.forEach((n) => n.addEventListener('click', () => setStage(n.dataset.stage)));

  // AI 提案モーダル
  const modal = document.getElementById('ai-modal');
  const modalBody = document.getElementById('ai-modal-body');
  const modalClose = modal?.querySelector('.cm-modal-close');

  const aiSuggestions = {
    leads: `
      <p><strong>提案 1: 八ヶ岳ペンション 八ヶ岳</strong> ── 過去 3 件の宿泊業案件はすべて 14 日以内の MTG 設定で受注しています。<strong>5/15 MTG を必ず確保</strong>してください。</p>
      <p><strong>提案 2: 甲府税理士事務所</strong> ── セミナー経由のリードは平均受注金額が他経路の 1.4 倍。<strong>個別フォロー優先度を高に維持</strong>してください。</p>
      <p><strong>提案 3: 風と森ガイド</strong> ── SNS 経由の小規模案件。リソースが逼迫している場合、<strong>無料診断レポート送付で自走を促す</strong>選択肢もあります。</p>
      <p class="ai-source"><i class="fa-solid fa-quote-right"></i> 根拠: 過去 24 ヶ月の経路別受注率データ + 業種別 LTV 集計</p>
    `,
    opportunities: `
      <p><strong>提案 1: 八ヶ岳ペンション AI 受付</strong> ── 確度 90%、見積書未送付。<strong>本日中の送付推奨</strong>。送付遅延が 3 日続くと過去データでは確度が 20% 低下。</p>
      <p><strong>提案 2: 甲府税理士事務所</strong> ── 契約書最終確認段階。<strong>受注後の保守プラン提案を同時提示</strong>することで、過去 5 件中 4 件が即契約。</p>
      <p><strong>提案 3: 北杜ベーカリー</strong> ── 確度 35% のまま 7 日経過。<strong>ステージダウンの判断時期</strong>。リソースを高確度案件に集中する判断も。</p>
      <p class="ai-source"><i class="fa-solid fa-quote-right"></i> 根拠: 商談ステージ別の経過日数と受注率の相関分析</p>
    `,
  };

  document.querySelectorAll('[data-ai]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.ai;
      if (modal && modalBody && aiSuggestions[key]) {
        modalBody.innerHTML = aiSuggestions[key];
        modal.hidden = false;
      }
    });
  });
  modalClose?.addEventListener('click', () => { if (modal) modal.hidden = true; });
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.hidden = true; });
})();
</script>

<!-- ===== 動的ダッシュボード ===== -->
<script is:inline>
(function() {
  if (typeof Chart === 'undefined') {
    console.warn('[dashboard] Chart.js not loaded');
    return;
  }

  // ===== モックデータ生成 =====
  const INDUSTRIES = ['宿泊業', '士業', 'EC', '工務店', '飲食業', '農業'];
  const ASSIGNEES = ['代表', '田中', '佐藤', '鈴木'];
  const STATUSES = ['リード', '商談中', '進行中', '完了'];
  const COMPANIES = {
    '宿泊業': ['八ヶ岳ペンション', '清里リゾート', '高根山荘', '富士見ホテル', '小淵沢民宿'],
    '士業': ['甲府税理士', '長坂行政書士', '北杜社労士', '八ヶ岳法律事務所'],
    'EC': ['北杜マルシェ', '山梨セレクト', 'ヴィンヤードEC', 'クラフトギフト'],
    '工務店': ['南アルプス工務店', '清里建設', '八ヶ岳ホーム'],
    '飲食業': ['白州ベーカリー', '北杜カフェ', 'ワイナリーレストラン', '清里食堂'],
    '農業': ['北杜野菜', '八ヶ岳ハーブ農園', '清里林檎', '甲斐畜産'],
  };
  const STATUS_AMOUNT = {
    'リード': () => 0,
    '商談中': () => Math.floor((Math.random() * 1500 + 500)) * 1000,
    '進行中': () => Math.floor((Math.random() * 2500 + 1000)) * 1000,
    '完了': () => Math.floor((Math.random() * 3000 + 800)) * 1000,
  };

  // 過去 90 日分の案件データを生成（決定的にseed）
  let _seed = 42;
  function rand() { _seed = (_seed * 9301 + 49297) % 233280; return _seed / 233280; }
  function pick(arr) { return arr[Math.floor(rand() * arr.length)]; }

  const today = new Date('2026-05-11');
  const RECORDS = [];
  for (let dayOffset = 90; dayOffset >= 0; dayOffset--) {
    const date = new Date(today);
    date.setDate(date.getDate() - dayOffset);
    // 1 日あたり 2〜6 件
    const dailyCount = Math.floor(rand() * 5) + 2;
    for (let i = 0; i < dailyCount; i++) {
      const industry = pick(INDUSTRIES);
      const company = pick(COMPANIES[industry]);
      const assignee = pick(ASSIGNEES);
      // ステータス分布：古いほど完了寄り、最近はリード寄り
      const ageRatio = dayOffset / 90;
      let status;
      const r = rand();
      if (ageRatio > 0.6) status = r < 0.7 ? '完了' : (r < 0.9 ? '進行中' : '商談中');
      else if (ageRatio > 0.3) status = r < 0.4 ? '完了' : (r < 0.7 ? '進行中' : '商談中');
      else status = r < 0.5 ? 'リード' : (r < 0.85 ? '商談中' : '進行中');
      RECORDS.push({
        date: date.toISOString().slice(0, 10),
        company,
        industry,
        assignee,
        status,
        amount: STATUS_AMOUNT[status](),
      });
    }
  }

  // ===== フィルタ状態 =====
  const filters = {
    period: 30,
    industry: new Set(['all']),
    assignee: new Set(['all']),
    status: new Set(['all']),
  };

  // フィルタ適用
  function applyFilters() {
    const cutoff = new Date(today);
    cutoff.setDate(cutoff.getDate() - filters.period);
    const cutoffStr = cutoff.toISOString().slice(0, 10);

    return RECORDS.filter(r => {
      if (r.date < cutoffStr) return false;
      if (!filters.industry.has('all') && !filters.industry.has(r.industry)) return false;
      if (!filters.assignee.has('all') && !filters.assignee.has(r.assignee)) return false;
      if (!filters.status.has('all') && !filters.status.has(r.status)) return false;
      return true;
    });
  }

  // ===== Chart.js 初期化 =====
  const BRAND = '#1F3A93';
  const BRAND_LIGHT = '#6B85C9';
  const COLORS = ['#1F3A93', '#6B85C9', '#9CA8D9', '#2E7D4F', '#B08825', '#7B4FA0', '#D45D5D', '#C0632B'];

  Chart.defaults.font.family = 'system-ui, -apple-system, "Segoe UI", "Hiragino Sans", "Yu Gothic", sans-serif';
  Chart.defaults.color = '#475569';

  // 時系列ライン
  const timelineCtx = document.getElementById('chart-timeline');
  const timelineGradient = timelineCtx.getContext('2d').createLinearGradient(0, 0, 0, 220);
  timelineGradient.addColorStop(0, 'rgba(31, 58, 147, 0.35)');
  timelineGradient.addColorStop(1, 'rgba(31, 58, 147, 0)');

  const timelineChart = new Chart(timelineCtx, {
    type: 'line',
    data: { labels: [], datasets: [{
      label: '日別件数',
      data: [],
      borderColor: BRAND,
      backgroundColor: timelineGradient,
      borderWidth: 2,
      tension: 0.35,
      fill: true,
      pointRadius: 0,
      pointHoverRadius: 5,
      pointHoverBackgroundColor: BRAND,
    }]},
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },
      scales: {
        x: { grid: { display: false }, ticks: { maxTicksLimit: 8 } },
        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { precision: 0 } },
      },
    },
  });

  // 業種別棒
  const industryCtx = document.getElementById('chart-industry');
  const industryChart = new Chart(industryCtx, {
    type: 'bar',
    data: { labels: [], datasets: [{
      label: '受注金額（千円）',
      data: [],
      backgroundColor: COLORS,
      borderRadius: 6,
    }]},
    options: {
      responsive: true,
      maintainAspectRatio: false,
      indexAxis: 'y',
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: (c) => '¥' + (c.raw * 1000).toLocaleString() } },
      },
      scales: {
        x: { grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { callback: (v) => '¥' + (v * 1000).toLocaleString().slice(0, -4) + '万' } },
        y: { grid: { display: false } },
      },
      onClick: (e, elements) => {
        if (elements.length === 0) return;
        const label = industryChart.data.labels[elements[0].index];
        toggleFilter('industry', label);
      },
    },
  });

  // 担当者別ドーナツ
  const assigneeCtx = document.getElementById('chart-assignee');
  const assigneeChart = new Chart(assigneeCtx, {
    type: 'doughnut',
    data: { labels: [], datasets: [{
      data: [],
      backgroundColor: COLORS,
      borderWidth: 2,
      borderColor: '#fff',
    }]},
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '60%',
      plugins: {
        legend: { position: 'bottom', labels: { padding: 12, font: { size: 12 } } },
        tooltip: { callbacks: { label: (c) => c.label + ': ' + c.raw + ' 件' } },
      },
      onClick: (e, elements) => {
        if (elements.length === 0) return;
        const label = assigneeChart.data.labels[elements[0].index];
        toggleFilter('assignee', label);
      },
    },
  });

  // ===== チャート更新 =====
  function updateAll() {
    const filtered = applyFilters();

    // 時系列：日別集計
    const dailyMap = new Map();
    filtered.forEach(r => dailyMap.set(r.date, (dailyMap.get(r.date) || 0) + 1));
    const cutoff = new Date(today);
    cutoff.setDate(cutoff.getDate() - filters.period);
    const labels = [];
    const data = [];
    for (let i = filters.period; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const ds = d.toISOString().slice(0, 10);
      labels.push(ds.slice(5).replace('-', '/'));
      data.push(dailyMap.get(ds) || 0);
    }
    timelineChart.data.labels = labels;
    timelineChart.data.datasets[0].data = data;
    timelineChart.update();

    // 業種別：金額集計
    const industryMap = new Map();
    filtered.forEach(r => industryMap.set(r.industry, (industryMap.get(r.industry) || 0) + r.amount));
    const sortedIndustries = Array.from(industryMap.entries()).sort((a, b) => b[1] - a[1]);
    industryChart.data.labels = sortedIndustries.map(e => e[0]);
    industryChart.data.datasets[0].data = sortedIndustries.map(e => Math.round(e[1] / 1000));
    industryChart.update();

    // 担当者別：件数集計
    const assigneeMap = new Map();
    filtered.forEach(r => assigneeMap.set(r.assignee, (assigneeMap.get(r.assignee) || 0) + 1));
    const sortedAssignees = Array.from(assigneeMap.entries()).sort((a, b) => b[1] - a[1]);
    assigneeChart.data.labels = sortedAssignees.map(e => e[0]);
    assigneeChart.data.datasets[0].data = sortedAssignees.map(e => e[1]);
    assigneeChart.update();

    // サマリ
    const totalAmount = filtered.reduce((s, r) => s + r.amount, 0);
    const doneCount = filtered.filter(r => r.status === '完了').length;
    document.getElementById('sum-count').textContent = filtered.length.toLocaleString() + ' 件';
    document.getElementById('sum-amount').textContent = '¥' + totalAmount.toLocaleString();
    document.getElementById('sum-avg').textContent = filtered.length > 0
      ? '¥' + Math.round(totalAmount / filtered.length).toLocaleString()
      : '¥0';
    document.getElementById('sum-done').textContent = filtered.length > 0
      ? Math.round(doneCount / filtered.length * 100) + '%'
      : '0%';

    // テーブル（最新 8 件）
    const tbody = document.getElementById('dash-table-body');
    const tableMeta = document.getElementById('dash-table-meta');
    const recent = filtered.slice().reverse().slice(0, 8);
    tbody.innerHTML = recent.map(r => `
      <tr>
        <td>${r.date.replace(/-/g, '/').slice(5)}</td>
        <td><strong>${r.company}</strong></td>
        <td>${r.industry}</td>
        <td>${r.assignee}</td>
        <td><span class="cm-badge cm-badge--${r.status === '完了' ? 'ok' : 'source'}">${r.status}</span></td>
        <td>${r.amount > 0 ? '¥' + r.amount.toLocaleString() : '—'}</td>
      </tr>
    `).join('') || '<tr><td colspan="6" style="text-align:center;color:#94a3b8;padding:24px;">該当する案件がありません</td></tr>';
    tableMeta.textContent = `全 ${filtered.length} 件中 直近 ${recent.length} 件を表示`;
  }

  // ===== フィルタ操作 =====
  function setActive(group, value) {
    const root = document.querySelector(`[data-filter-group="${group}"]`);
    if (!root) return;
    root.querySelectorAll('.cm-pill').forEach(p => {
      p.classList.toggle('is-active', filters[group].has(p.dataset.value));
    });
  }

  function toggleFilter(group, value) {
    const isMulti = group !== 'period';
    if (!isMulti) {
      filters[group] = parseInt(value, 10);
      document.querySelectorAll(`[data-filter-group="${group}"] .cm-pill`).forEach(p => {
        p.classList.toggle('is-active', parseInt(p.dataset.value, 10) === filters[group]);
      });
      updateAll();
      return;
    }

    if (value === 'all') {
      filters[group].clear();
      filters[group].add('all');
    } else {
      filters[group].delete('all');
      if (filters[group].has(value)) {
        filters[group].delete(value);
        if (filters[group].size === 0) filters[group].add('all');
      } else {
        filters[group].add(value);
      }
    }
    setActive(group, value);
    updateAll();
  }

  // フィルタピルにイベント
  document.querySelectorAll('[data-filter-group] .cm-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      const group = pill.closest('[data-filter-group]').dataset.filterGroup;
      toggleFilter(group, pill.dataset.value);
    });
  });

  // リセット
  document.getElementById('dash-reset')?.addEventListener('click', () => {
    filters.period = 30;
    filters.industry = new Set(['all']);
    filters.assignee = new Set(['all']);
    filters.status = new Set(['all']);
    document.querySelectorAll('[data-filter-group="period"] .cm-pill').forEach(p => {
      p.classList.toggle('is-active', p.dataset.value === '30');
    });
    ['industry', 'assignee', 'status'].forEach(g => {
      document.querySelectorAll(`[data-filter-group="${g}"] .cm-pill`).forEach(p => {
        p.classList.toggle('is-active', p.dataset.value === 'all');
      });
    });
    updateAll();
  });

  // 初期描画
  updateAll();
})();
</script>

