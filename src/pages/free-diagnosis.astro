  // 二重送信防止＆送信中表示はページ末尾の fetch ベースハンドラ側に統合

  // ===== 業務資料・URLからの自動入力 =====
  (function() {
    var fileUpload = document.getElementById('file-upload');
    var fileNameLabel = document.getElementById('upload-file-name');
    var extractFileBtn = document.getElementById('extract-file-btn');
    var extractUrlBtn = document.getElementById('extract-url-btn');
