          suggestion: '廃止・減額・継続の結論、適用月、対象者を明記します。',
          owner: '人事 + 経理',
          replacement: '現行の在宅勤務手当（月額5,000円）は、2026年6月支給分をもって終了します。ただし、会社都合により週3日以上の在宅勤務を指示する社員は対象外とします。',
        },
        {
          line: 15,
          severity: 'high',
          category: 'operation',
          title: '開始時期が確定していない',
          risk: '現場の勤務計画、交通費精算、会議設定が準備できません。',
          suggestion: '具体日と移行期間を示します。',
          owner: '人事',
          replacement: '2026年6月1日（月）より新制度へ移行します。5月中は移行期間とし、各部門で出社曜日を調整してください。',
        },
        {
          line: 17,
          severity: 'medium',
          category: 'operation',
          title: '問い合わせ方法が不足',
          risk: '人事担当へ個別連絡が集中し、同じ質問に何度も対応することになります。',
          suggestion: 'フォーム、締切、FAQ公開日を明記します。',
          owner: '人事',
          replacement: '質問は5月20日までに社内フォームへ入力してください。回答は5月24日にFAQとして全社公開します。',
        },
        {
          line: 19,
          severity: 'low',
          category: 'customer',
          title: '協力依頼だけで納得材料がない',
          risk: '制度変更の背景が見えないと、社員はコスト削減だけが目的だと受け止めます。',
          suggestion: '目的を1文追加します。',
          owner: '経営 + 人事',
          replacement: '今回の見直しは、若手育成、部門間連携、顧客対応品質の向上を目的としています。',
        },
      ],
    },
  ];

  const documentSelect = document.getElementById('document-select') as HTMLSelectElement;
  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-btn'));
  const editorBody = document.getElementById('editor-body')!;

  const docType = document.getElementById('doc-type')!;
  const docTitle = document.getElementById('doc-title')!;
  const docSubtitle = document.getElementById('doc-subtitle')!;
  const docGoal = document.getElementById('doc-goal')!;
  const docAudience = document.getElementById('doc-audience')!;
  const docStage = document.getElementById('doc-stage')!;
  const reviewPoints = document.getElementById('review-points')!;
  const nextActions = document.getElementById('next-actions')!;
  const countHigh = document.getElementById('count-high')!;
  const countMedium = document.getElementById('count-medium')!;
  const countLow = document.getElementById('count-low')!;

  let currentDocument = SAMPLE_DOCUMENTS[0];
  let currentFilter = 'all';

  for (const doc of SAMPLE_DOCUMENTS) {
    const option = document.createElement('option');
    option.value = doc.id;
    option.textContent = doc.title;
    documentSelect.appendChild(option);
  }

  documentSelect.value = currentDocument.id;
  render(currentDocument);

  documentSelect.addEventListener('change', () => {
    currentDocument = SAMPLE_DOCUMENTS.find((doc) => doc.id === documentSelect.value) || SAMPLE_DOCUMENTS[0];
    render(currentDocument);
  });

  for (const button of filterButtons) {
    button.addEventListener('click', () => {
      currentFilter = button.dataset.filter || 'all';
      filterButtons.forEach((btn) => btn.classList.toggle('active', btn === button));
      render(currentDocument);
    });
  }

  function noteMatches(note: ReviewNote) {
    if (currentFilter === 'all') return true;
    if (currentFilter === 'high') return note.severity === 'high';
    return note.category === currentFilter;
  }

  function render(doc: SampleDocument) {
    docType.textContent = doc.type;
    docTitle.textContent = doc.title;
    docSubtitle.textContent = doc.subtitle;
    docGoal.textContent = doc.goal;
    docAudience.textContent = doc.audience;
    docStage.textContent = doc.stage;

    countHigh.textContent = String(doc.notes.filter((note) => note.severity === 'high').length);
    countMedium.textContent = String(doc.notes.filter((note) => note.severity === 'medium').length);
    countLow.textContent = String(doc.notes.filter((note) => note.severity === 'low').length);

    reviewPoints.innerHTML = '';
    for (const point of doc.reviewPoints) {
      const li = document.createElement('li');
      li.textContent = point;
      reviewPoints.appendChild(li);
    }

    nextActions.innerHTML = '';
    for (const action of doc.nextActions) {
      const li = document.createElement('li');
      li.textContent = action;
      nextActions.appendChild(li);
    }

    const notesByLine = new Map<number, ReviewNote[]>();
    for (const note of doc.notes) {
      if (!notesByLine.has(note.line)) notesByLine.set(note.line, []);
      notesByLine.get(note.line)!.push(note);
    }

    editorBody.innerHTML = '';
    const lines = doc.content.split('\n');

    lines.forEach((line, index) => {
      const lineNumber = index + 1;
      const allNotes = notesByLine.get(lineNumber) || [];
      const visibleNotes = allNotes.filter(noteMatches);

      const row = document.createElement('div');
      row.className = 'review-row';
      if (allNotes.length > 0) row.classList.add('has-note');
      if (visibleNotes.length > 0) row.classList.add('has-visible-note');

      const number = document.createElement('div');
      number.className = 'line-number';
      number.textContent = String(lineNumber);

      const text = document.createElement('div');
      text.className = 'line-text';
      text.textContent = line || ' ';

      const noteColumn = document.createElement('div');
      noteColumn.className = 'note-column';

      if (visibleNotes.length === 0 && allNotes.length > 0) {
        const muted = document.createElement('p');
        muted.className = 'filtered-note';
        muted.textContent = '現在のフィルタでは非表示';
        noteColumn.appendChild(muted);
      }

      for (const note of visibleNotes) {
        noteColumn.appendChild(createNoteCard(note));
      }

      row.appendChild(number);
      row.appendChild(text);
      row.appendChild(noteColumn);
      editorBody.appendChild(row);
    });
  }

  function createNoteCard(note: ReviewNote) {
    const card = document.createElement('article');
    card.className = `note-card note-${note.severity}`;

    const header = document.createElement('header');
    header.className = 'note-header';

    const severity = document.createElement('span');
    severity.className = `severity severity-${note.severity}`;
    severity.textContent = severityLabel[note.severity];

    const category = document.createElement('span');
    category.className = 'category';
    category.textContent = categoryLabel[note.category];

    const title = document.createElement('h3');
    title.textContent = note.title;

    header.appendChild(severity);
    header.appendChild(category);
    header.appendChild(title);

    const risk = document.createElement('p');
    risk.className = 'note-risk';
    risk.innerHTML = `<strong>業務影響</strong>${escapeHtml(note.risk)}`;

    const suggestion = document.createElement('p');
    suggestion.className = 'note-suggestion';
    suggestion.innerHTML = `<strong>修正方針</strong>${escapeHtml(note.suggestion)}`;

    const owner = document.createElement('p');
    owner.className = 'note-owner';
    owner.innerHTML = `<strong>確認先</strong>${escapeHtml(note.owner)}`;

    card.appendChild(header);
    card.appendChild(risk);
    card.appendChild(suggestion);
    card.appendChild(owner);

    if (note.replacement) {
      const replacement = document.createElement('pre');
      replacement.className = 'replacement';
      replacement.textContent = note.replacement;
      card.appendChild(replacement);
    }

    return card;
  }

  function escapeHtml(value: string) {
    return value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }
</script>

