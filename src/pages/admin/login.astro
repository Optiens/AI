---
import { makeToken, COOKIE_NAME, getAdminPassword } from '../../middleware'

const ADMIN_PASSWORD = getAdminPassword()
let error = ''

// クエリ ?config=missing が来た場合でも、実際に env が空のときだけエラー表示する
// （古いリダイレクト URL が履歴に残っていても誤表示しないため）
if (Astro.url.searchParams.get('config') === 'missing' && !ADMIN_PASSWORD) {
  error = 'ADMIN_PASSWORD が未設定です（Vercel 環境変数を確認してください）'
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const password = String(form.get('password') || '')

  if (!ADMIN_PASSWORD) {
    error = 'ADMIN_PASSWORD が未設定です（Vercel 環境変数を確認してください）'
  } else if (password === ADMIN_PASSWORD) {
    Astro.cookies.set(COOKIE_NAME, makeToken(ADMIN_PASSWORD), {
      // path: '/' にすることで /admin/* と /api/admin/* の両方にクッキー送信される
      path: '/',
      httpOnly: true,
      // localhost (http) では secure クッキーが送信されないため開発時は false
      secure: import.meta.env.PROD,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24 * 7, // 7 days
    })
    return Astro.redirect('/admin/leads')
  } else {
    error = 'パスワードが違います'
  }
}
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin Login | Optiens</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --admin-primary: #1F3A93;
      --admin-primary-dark: #152870;
      --admin-secondary: #6B85C9;
      --admin-accent: #E48A95;
      --admin-accent-soft: #FFCED0;
      --admin-bg: #0B1434;
      --admin-surface: #111D49;
      --admin-border: rgba(107, 133, 201, 0.32);
      --admin-text: #F7F9FF;
      --admin-muted: #B9C6EA;
    }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--admin-bg);
      color: var(--admin-text);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100svh;
    }
    .login-card {
      background: var(--admin-surface);
      border: 1px solid var(--admin-border);
      border-radius: 12px;
      padding: 40px;
      width: min(400px, 90vw);
    }
    .login-card h1 {
      font-size: 1.5rem;
      margin-bottom: 8px;
      color: #fff;
    }
    .login-card p {
      font-size: 0.85rem;
      color: var(--admin-muted);
      margin-bottom: 24px;
    }
    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--admin-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }
    input[type="password"] {
      width: 100%;
      padding: 10px 14px;
      background: var(--admin-bg);
      border: 1px solid var(--admin-border);
      border-radius: 8px;
      color: var(--admin-text);
      font-size: 1rem;
      outline: none;
      transition: border-color 0.2s;
    }
    input[type="password"]:focus {
      border-color: var(--admin-secondary);
    }
    button {
      width: 100%;
      margin-top: 20px;
      padding: 10px;
      background: var(--admin-primary);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    button:hover { background: var(--admin-primary-dark); }
    .error {
      margin-top: 12px;
      padding: 8px 12px;
      background: rgba(228, 138, 149, 0.16);
      border: 1px solid rgba(228, 138, 149, 0.34);
      border-radius: 6px;
      color: var(--admin-accent-soft);
      font-size: 0.85rem;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>Optiens Admin</h1>
    <p>管理画面にアクセスするにはパスワードを入力してください。</p>
    <form method="POST">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" autofocus required />
      <button type="submit">ログイン</button>
    </form>
    {error && <div class="error">{error}</div>}
  </div>
</body>
</html>
