---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { getBusinessTaskSummary } from '../../lib/google-tasks';
import { buildTodayActions } from '../../lib/ops-today';
import {
  evaluateAdminAlerts,
  getAdminSettings,
  getAlertRulesWithDefaults,
  listCustomersWithProjects,
  listKnowledgeGaps,
} from '../../lib/admin-ops';
import { knowledgeDocs } from '../../lib/optiens-knowledge';

type Lead = {
  id: string | number;
  created_at: string;
  updated_at?: string | null;
  plan?: string | null;
  status?: string | null;
  amount_jpy?: number | null;
  paid_at?: string | null;
  company_name?: string | null;
  industry?: string | null;
  application_id?: string | null;
  person_name?: string | null;
  last_error?: string | null;
};

type AiApiEvent = {
  id: number;
  created_at: string;
  workflow?: string | null;
  provider?: string | null;
  model?: string | null;
  operation?: string | null;
  status?: string | null;
  input_tokens?: number | null;
  output_tokens?: number | null;
  total_tokens?: number | null;
  latency_ms?: number | null;
  error_type?: string | null;
  error_message?: string | null;
};

let leads: Lead[] = [];
let events: AiApiEvent[] = [];
let dbError = '';
let eventsError = '';
const runtimeEnv = import.meta.env as Record<string, string | undefined>;
const taskSummary = await getBusinessTaskSummary(new Date(), 7);
const { values: adminSettings } = await getAdminSettings();
const [customerResult, gapResult, alertRuleResult] = await Promise.all([
  listCustomersWithProjects(),
  listKnowledgeGaps(),
  getAlertRulesWithDefaults(),
]);

if (supabase) {
  const { data, error } = await supabase
    .from('diagnosis_leads')
    .select('*')
    .order('created_at', { ascending: false });
  if (error) {
    dbError = error.message;
  } else {
    leads = (data as Lead[]) || [];
  }

  const { data: eventData, error: eventError } = await supabase
    .from('ai_api_events')
    .select('*')
    .order('created_at', { ascending: false })
    .limit(500);
  if (eventError) {
    eventsError = eventError.message;
  } else {
    events = (eventData as AiApiEvent[]) || [];
  }
} else {
  dbError = 'Supabase が設定されていません';
}

const now = Date.now();
const ms24h = 24 * 60 * 60 * 1000;
const ms30d = 30 * ms24h;
const oneHour = 60 * 60 * 1000;
const yen = new Intl.NumberFormat('ja-JP');

const total = leads.length;
const last24h = leads.filter(l => new Date(l.created_at).getTime() > now - ms24h).length;
const last30d = leads.filter(l => new Date(l.created_at).getTime() > now - ms30d).length;

const freeCount = leads.filter(l => (l.plan ?? 'free') === 'free').length;
const paidCount = leads.filter(l => l.plan === 'paid').length;

const completedCount = leads.filter(l => ['completed', 'mtg_scheduled'].includes(l.status || '')).length;
const reportSentCount = leads.filter(l => ['report_sent', 'sent'].includes(l.status || '')).length;
const inProgressCount = leads.filter(l => ['new', 'report_created'].includes(l.status || '')).length;
const pendingPaymentCount = leads.filter(l => l.status === 'pending_payment').length;
const paidStatusCount = leads.filter(l => l.status === 'paid').length;
const manualReviewCount = leads.filter(l => l.status === 'manual_review').length;
const cancelledCount = leads.filter(l => l.status === 'cancelled').length;

const totalRevenuePaid = leads
  .filter(l => l.paid_at && (l.amount_jpy || 0) > 0)
  .reduce((s, l) => s + (l.amount_jpy || 0), 0);
const pendingRevenue = leads
  .filter(l => l.status === 'pending_payment')
  .reduce((s, l) => s + (l.amount_jpy || 0), 0);
const reportBacklog = leads.filter(l => ['paid', 'report_created'].includes(l.status || ''));
const followupBacklog = leads.filter(l => ['sent', 'report_sent'].includes(l.status || ''));
const todayActions = buildTodayActions({ leads, events, tasks: taskSummary, now: new Date() });
const criticalActions = todayActions.filter(action => action.tone === 'critical');
const highActions = todayActions.filter(action => action.tone === 'high');
const apiIssues24h = events.filter(event => parseTime(event.created_at) > now - ms24h && ['error', 'retry'].includes(event.status || ''));
const customerProjects = customerResult.customers.flatMap(customer => customer.projects || []);
const openCustomerProjects = customerProjects.filter(project => !['done', 'cancelled'].includes(project.status));
const activeCustomers = customerResult.customers.filter(customer => customer.status === 'active').length;
const customerMrr = openCustomerProjects.reduce((sum, project) => sum + (project.monthly_amount_jpy || 0), 0);
const openKnowledgeGaps = gapResult.gaps.filter(gap => gap.status === 'open');
const evaluatedAlerts = evaluateAdminAlerts({
  leads,
  events,
  tasks: taskSummary,
  settings: adminSettings,
  rules: alertRuleResult.rules,
  projects: customerProjects,
  knowledgeGaps: gapResult.gaps,
  todayActionCount: todayActions.length,
});
const triggeredAlerts = evaluatedAlerts.filter(alert => alert.triggered);

const adminColors = {
  primary: '#1F3A93',
  secondary: '#6B85C9',
  accent: '#E48A95',
  accentSoft: '#FFCED0',
  muted: '#94a3b8',
};

function parseTime(iso?: string | null) {
  if (!iso) return 0;
  const t = new Date(iso).getTime();
  return Number.isFinite(t) ? t : 0;
}

function ageHours(iso?: string | null) {
  const t = parseTime(iso);
  return t ? Math.max(0, Math.floor((now - t) / oneHour)) : 0;
}

function ageDays(iso?: string | null) {
  const t = parseTime(iso);
  return t ? Math.max(0, Math.floor((now - t) / ms24h)) : 0;
}

function envNumber(name: string) {
  const value = Number(runtimeEnv[name] || '0');
  return Number.isFinite(value) ? value : 0;
}

function settingNumber(key: string, envName?: string) {
  const settingValue = Number(adminSettings[key] || 0);
  if (Number.isFinite(settingValue) && settingValue > 0) return settingValue;
  return envName ? envNumber(envName) : 0;
}

const tokyoMonthKeyFormatter = new Intl.DateTimeFormat('sv-SE', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: '2-digit',
});
function tokyoMonthKey(date: Date) {
  return tokyoMonthKeyFormatter.format(date);
}

const currentMonthKey = tokyoMonthKey(new Date());
const monthEvents = events.filter(event => {
  const created = parseTime(event.created_at);
  return created > 0 && tokyoMonthKey(new Date(created)) === currentMonthKey;
});
const openAiInputUsdPer1M = settingNumber('openai_input_usd_per_1m', 'OPENAI_INPUT_USD_PER_1M');
const openAiOutputUsdPer1M = settingNumber('openai_output_usd_per_1m', 'OPENAI_OUTPUT_USD_PER_1M');
const anthropicInputUsdPer1M = settingNumber('anthropic_input_usd_per_1m', 'ANTHROPIC_INPUT_USD_PER_1M');
const anthropicOutputUsdPer1M = settingNumber('anthropic_output_usd_per_1m', 'ANTHROPIC_OUTPUT_USD_PER_1M');
const usdJpyRate = settingNumber('usd_jpy_rate', 'USD_JPY_RATE');
const pricingConfigured = Boolean(
  usdJpyRate
  && (openAiInputUsdPer1M || openAiOutputUsdPer1M || anthropicInputUsdPer1M || anthropicOutputUsdPer1M)
);
function estimateEventCostUsd(event: AiApiEvent) {
  const input = event.input_tokens || 0;
  const output = event.output_tokens || 0;
  if (event.provider === 'openai') {
    return (input / 1_000_000) * openAiInputUsdPer1M + (output / 1_000_000) * openAiOutputUsdPer1M;
  }
  if (event.provider === 'anthropic') {
    return (input / 1_000_000) * anthropicInputUsdPer1M + (output / 1_000_000) * anthropicOutputUsdPer1M;
  }
  return 0;
}
const estimatedApiCostJpy = pricingConfigured
  ? Math.round(monthEvents.reduce((usd, event) => usd + estimateEventCostUsd(event), 0) * usdJpyRate)
  : null;

const aiProcessingSlaHours = settingNumber('sla_ai_processing_hours') || 2;
const paidReportSlaDays = settingNumber('sla_paid_report_business_days') || 5;
const workloadWarnCount = settingNumber('alert_workload_warn_count') || 6;
const workloadCriticalCount = settingNumber('alert_workload_critical_count') || 12;

const slaRisks = leads.filter(l => {
  const status = l.status || 'new';
  const hours = ageHours(l.updated_at || l.created_at);
  const days = ageDays(l.paid_at || l.updated_at || l.created_at);
  return (['verified', 'processing'].includes(status) && hours >= aiProcessingSlaHours)
    || (status === 'paid' && days >= Math.max(1, paidReportSlaDays - 2))
    || status === 'report_created'
    || (['sent', 'report_sent'].includes(status) && ageDays(l.updated_at || l.created_at) >= 2);
});

const knowledgeTotal = knowledgeDocs.length;
const knowledgeDemoSafe = knowledgeDocs.filter(doc => doc.visibility === 'demo-safe').length;
const knowledgeDemoReady = knowledgeDocs.filter(doc => doc.maturity === 'demo-ready').length;
const knowledgeSeed = knowledgeDocs.filter(doc => doc.maturity === 'seed').length;
const knowledgeStale = knowledgeDocs.filter(doc => ageDays(doc.updatedAt) >= 30).length;
const openTaskCount = taskSummary.overdue.length + taskSummary.today.length + taskSummary.upcoming.length;
const workloadScore = todayActions.length + reportBacklog.length + taskSummary.overdue.length + taskSummary.today.length;
const commandTone = criticalActions.length || apiIssues24h.some(event => event.status === 'error')
  ? 'bad'
  : highActions.length || slaRisks.length || taskSummary.overdue.length
    ? 'warn'
    : 'ok';
const commandLabel = commandTone === 'bad' ? '要対応' : commandTone === 'warn' ? '確認あり' : '安定';
const commandDetail = commandTone === 'bad'
  ? '今日の赤信号があります。上から順に処理してください。'
  : commandTone === 'warn'
    ? '期限・納品・フォローに確認対象があります。'
    : '通常運用の範囲です。';

const commandMetrics = [
  { label: '異常/要対応', value: `${criticalActions.length + apiIssues24h.length + triggeredAlerts.length}件`, detail: 'API・手動確認・アラート', tone: criticalActions.length + apiIssues24h.length + triggeredAlerts.length ? 'bad' : 'ok' },
  { label: 'SLAリスク', value: `${slaRisks.length}件`, detail: '納品・返信・MTG案内', tone: slaRisks.length ? 'warn' : 'ok' },
  { label: '入金待ち', value: `¥${yen.format(pendingRevenue)}`, detail: `${pendingPaymentCount}件`, tone: pendingPaymentCount ? 'warn' : 'ok' },
  { label: '代表稼働', value: `${workloadScore}件`, detail: '今日/期限/納品待ち', tone: workloadScore >= workloadCriticalCount ? 'bad' : workloadScore >= workloadWarnCount ? 'warn' : 'ok' },
  { label: '顧客案件', value: `${openCustomerProjects.length}件`, detail: `継続顧客 ${activeCustomers} / 月¥${yen.format(customerMrr)}`, tone: openCustomerProjects.length ? 'ok' : 'low' },
  { label: 'ナレッジ不足', value: `${openKnowledgeGaps.length}件`, detail: '回答不能・未整備', tone: openKnowledgeGaps.length ? 'warn' : 'ok' },
];

const alertInboxRows = [
  ...triggeredAlerts.map(alert => ({
    title: alert.title,
    detail: alert.detail,
    meta: `${alert.area} / ${alert.severity}`,
    tone: alert.severity === 'critical' ? 'critical' : alert.severity === 'warn' ? 'high' : 'medium',
    href: alert.target_href || '/admin/alerts',
  })),
  ...todayActions.map(action => ({
    title: action.title,
    detail: action.detail,
    meta: `${action.due} / ${action.owner}`,
    tone: action.tone,
    href: action.href || '/admin/reports',
  })),
].slice(0, 8);

const deliveryRows = [
  { label: 'AI診断生成停滞', value: `${leads.filter(l => ['verified', 'processing'].includes(l.status || '') && ageHours(l.updated_at || l.created_at) >= aiProcessingSlaHours).length}件`, detail: `${aiProcessingSlaHours}時間以上更新なし`, tone: 'warn' },
  { label: '詳細レポート作成待ち', value: `${leads.filter(l => l.status === 'paid').length}件`, detail: '入金確認済', tone: leads.some(l => l.status === 'paid') ? 'warn' : 'ok' },
  { label: 'レポート送付待ち', value: `${leads.filter(l => l.status === 'report_created').length}件`, detail: 'Slides URL納品', tone: leads.some(l => l.status === 'report_created') ? 'warn' : 'ok' },
  { label: 'レビュー面談フォロー', value: `${followupBacklog.length}件`, detail: '送付済リード', tone: followupBacklog.length ? 'low' : 'ok' },
];

const financeRows = [
  { label: '入金済売上', value: `¥${yen.format(totalRevenuePaid)}`, detail: 'paid_atあり', tone: 'ok' },
  { label: '入金待ち', value: `¥${yen.format(pendingRevenue)}`, detail: `${pendingPaymentCount}件`, tone: pendingPaymentCount ? 'warn' : 'ok' },
  { label: '当月API費用', value: estimatedApiCostJpy === null ? '未設定' : `約¥${yen.format(estimatedApiCostJpy)}`, detail: `${yen.format(monthEvents.reduce((s, e) => s + (e.total_tokens || 0), 0))} tokens`, tone: estimatedApiCostJpy === null ? 'low' : 'ok' },
  { label: '有償化候補', value: `${paidCount + pendingPaymentCount + reportBacklog.length}件`, detail: 'paid系リード', tone: 'ok' },
];

const knowledgeRows = [
  { label: '登録ナレッジ', value: `${knowledgeTotal}件`, detail: '社内DBの種', tone: 'ok' },
  { label: 'demo-safe', value: `${knowledgeDemoSafe}件`, detail: '将来デモ公開候補', tone: knowledgeDemoSafe ? 'ok' : 'warn' },
  { label: 'demo-ready', value: `${knowledgeDemoReady}件`, detail: '営業デモ即利用', tone: knowledgeDemoReady ? 'ok' : 'low' },
  { label: '不足キュー', value: `${openKnowledgeGaps.length}件`, detail: '質問から追加候補化', tone: openKnowledgeGaps.length ? 'warn' : 'ok' },
];

const customerRows = [
  { label: '登録顧客', value: `${customerResult.customers.length}件`, detail: `継続中 ${activeCustomers}件`, tone: customerResult.customers.length ? 'ok' : 'low' },
  { label: '進行案件', value: `${openCustomerProjects.length}件`, detail: '完了・中止以外', tone: openCustomerProjects.length ? 'ok' : 'low' },
  { label: '月額見込み', value: `¥${yen.format(customerMrr)}`, detail: '保守・継続支援', tone: customerMrr ? 'ok' : 'low' },
  { label: '期限案件', value: `${openCustomerProjects.filter(project => project.due_date && project.due_date <= new Date().toISOString().slice(0, 10)).length}件`, detail: '今日以前の次アクション', tone: openCustomerProjects.some(project => project.due_date && project.due_date <= new Date().toISOString().slice(0, 10)) ? 'warn' : 'ok' },
];

const capacityRows = [
  { label: '今日の対応', value: `${todayActions.length}件`, detail: '優先順で処理', tone: todayActions.length ? 'warn' : 'ok' },
  { label: '期限タスク', value: `${openTaskCount}件`, detail: `超過 ${taskSummary.overdue.length} / 今日 ${taskSummary.today.length}`, tone: taskSummary.overdue.length ? 'bad' : openTaskCount ? 'warn' : 'ok' },
  { label: '納品待ち', value: `${reportBacklog.length}件`, detail: 'paid / report_created', tone: reportBacklog.length ? 'warn' : 'ok' },
  { label: '期限なしタスク', value: `${taskSummary.noDue.length}件`, detail: '棚卸対象', tone: taskSummary.noDue.length >= 8 ? 'warn' : 'low' },
];

const stageRows = [
  { label: '新規受付', count: leads.filter(l => l.status === 'new').length, color: adminColors.secondary },
  { label: '入金待ち', count: pendingPaymentCount, color: adminColors.accent },
  { label: '入金確認済', count: paidStatusCount, color: adminColors.secondary },
  { label: 'レポート作成済', count: leads.filter(l => l.status === 'report_created').length, color: adminColors.primary },
  { label: '送付済', count: reportSentCount, color: adminColors.accentSoft },
  { label: '面談 / 完了', count: completedCount, color: adminColors.secondary },
  { label: '手動確認', count: manualReviewCount, color: adminColors.accent },
  { label: 'キャンセル', count: cancelledCount, color: adminColors.muted },
];
const stageMax = Math.max(1, ...stageRows.map(s => s.count));

// 過去30日の日次申込数（古い → 新しい）
const trend: { day: string; count: number }[] = [];
for (let i = 29; i >= 0; i--) {
  const d = new Date(now - i * ms24h);
  const dayKey = d.toISOString().slice(0, 10);
  const count = leads.filter(l => l.created_at?.slice(0, 10) === dayKey).length;
  trend.push({ day: dayKey, count });
}
const trendMax = Math.max(1, ...trend.map(t => t.count));
const trendW = 600;
const trendH = 140;
const trendStep = trendW / (trend.length - 1);
const trendPath = trend
  .map((t, i) => `${i === 0 ? 'M' : 'L'} ${(i * trendStep).toFixed(1)} ${(trendH - (t.count / trendMax) * (trendH - 12) - 4).toFixed(1)}`)
  .join(' ');
const trendArea = `${trendPath} L ${trendW} ${trendH} L 0 ${trendH} Z`;

const recentLeads = leads.slice(0, 10);

function fmtDateTime(iso?: string | null) {
  if (!iso) return '';
  const d = new Date(iso);
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  const hh = String(d.getHours()).padStart(2, '0');
  const mi = String(d.getMinutes()).padStart(2, '0');
  return `${mm}/${dd} ${hh}:${mi}`;
}

function statusBadge(s?: string | null) {
  const map: Record<string, { label: string; cls: string }> = {
    new: { label: '新規', cls: 'badge-blue' },
    pending_payment: { label: '入金待ち', cls: 'badge-amber' },
    paid: { label: '入金確認済', cls: 'badge-cyan' },
    report_created: { label: 'レポート作成済', cls: 'badge-purple' },
    report_sent: { label: '送付済', cls: 'badge-yellow' },
    sent: { label: '送付済', cls: 'badge-yellow' },
    mtg_scheduled: { label: 'MTG予定', cls: 'badge-green' },
    completed: { label: '完了', cls: 'badge-green' },
    manual_review: { label: '手動確認', cls: 'badge-red' },
    cancelled: { label: 'キャンセル', cls: 'badge-gray' },
  };
  const v = map[s || 'new'] || { label: s || '-', cls: 'badge-gray' };
  return v;
}
---

<AdminLayout title="ダッシュボード" active="dashboard">
  <div class="dash-grid">

    {(dbError || eventsError || taskSummary.error || customerResult.error || gapResult.error || alertRuleResult.error) && (
      <div class="dash-error">
        <i class="fas fa-circle-exclamation"></i>
        <span>{dbError || eventsError || taskSummary.error || customerResult.error || gapResult.error || alertRuleResult.error}</span>
      </div>
    )}

    <!-- Command center -->
    <section class={`command-panel command-panel--${commandTone}`}>
      <div>
        <span>Command Center</span>
        <h2>管理トップは、今日まず見る司令塔です</h2>
        <p>{commandDetail}</p>
      </div>
      <strong>
        {commandLabel}
        <small>{criticalActions.length}件の最優先 / {highActions.length}件の高優先</small>
      </strong>
    </section>

    <section class="command-metrics">
      {commandMetrics.map((metric) => (
        <article class={`command-card command-card--${metric.tone}`}>
          <span>{metric.label}</span>
          <strong>{metric.value}</strong>
          <small>{metric.detail}</small>
        </article>
      ))}
    </section>

    <section class="ops-grid">
      <article class="panel alert-inbox">
        <div class="panel-head">
          <h2 class="panel-title">異常検知インボックス</h2>
          <a href="/admin/reports" class="panel-link">今日の対応へ →</a>
        </div>
        {alertInboxRows.length === 0 ? (
          <p class="panel-empty">今すぐ処理すべき赤信号はありません。</p>
        ) : (
          <div class="alert-list">
            {alertInboxRows.map((row) => (
              <a class={`alert-item alert-item--${row.tone}`} href={row.href}>
                <div>
                  <strong>{row.title}</strong>
                  <p>{row.detail}</p>
                </div>
                <small>{row.meta}</small>
              </a>
            ))}
          </div>
        )}
      </article>

      <article class="panel">
        <div class="panel-head">
          <h2 class="panel-title">納品SLA・顧客待ち</h2>
          <a href="/admin/leads" class="panel-link">リード管理 →</a>
        </div>
        <div class="ops-list">
          {deliveryRows.map((row) => (
            <div class={`ops-row ops-row--${row.tone}`}>
              <span>{row.label}</span>
              <strong>{row.value}</strong>
              <small>{row.detail}</small>
            </div>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-head">
          <h2 class="panel-title">売上・キャッシュ要約</h2>
          <a href="/admin/funnel" class="panel-link">営業ファネル →</a>
        </div>
        <div class="ops-list">
          {financeRows.map((row) => (
            <div class={`ops-row ops-row--${row.tone}`}>
              <span>{row.label}</span>
              <strong>{row.value}</strong>
              <small>{row.detail}</small>
            </div>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-head">
          <h2 class="panel-title">顧客・案件管理</h2>
          <a href="/admin/customers" class="panel-link">顧客・案件 →</a>
        </div>
        <div class="ops-list">
          {customerRows.map((row) => (
            <div class={`ops-row ops-row--${row.tone}`}>
              <span>{row.label}</span>
              <strong>{row.value}</strong>
              <small>{row.detail}</small>
            </div>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-head">
          <h2 class="panel-title">ナレッジDB成長</h2>
          <a href="/admin/knowledge-gaps" class="panel-link">不足キュー →</a>
        </div>
        <div class="ops-list">
          {knowledgeRows.map((row) => (
            <div class={`ops-row ops-row--${row.tone}`}>
              <span>{row.label}</span>
              <strong>{row.value}</strong>
              <small>{row.detail}</small>
            </div>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-head">
          <h2 class="panel-title">代表稼働・ボトルネック</h2>
          <a href="/admin/reports#task-deadlines" class="panel-link">期限を見る →</a>
        </div>
        <div class="ops-list">
          {capacityRows.map((row) => (
            <div class={`ops-row ops-row--${row.tone}`}>
              <span>{row.label}</span>
              <strong>{row.value}</strong>
              <small>{row.detail}</small>
            </div>
          ))}
        </div>
      </article>
    </section>

    <!-- KPI -->
    <section class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-label">過去 24h 申込</div>
        <div class="kpi-value">{last24h}<span class="kpi-unit">件</span></div>
        <div class="kpi-sub">直近 30 日: {last30d} 件</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">累計申込</div>
        <div class="kpi-value">{total}<span class="kpi-unit">件</span></div>
        <div class="kpi-sub">無料 {freeCount} / 有償 {paidCount}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">入金待ち</div>
        <div class={`kpi-value ${pendingPaymentCount > 0 ? 'kpi-warn' : ''}`}>{pendingPaymentCount}<span class="kpi-unit">件</span></div>
        <div class="kpi-sub">手動確認: {manualReviewCount} 件</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">有償 累計売上（入金済）</div>
        <div class="kpi-value">¥{totalRevenuePaid.toLocaleString()}</div>
        <div class="kpi-sub">入金確認済の合計</div>
      </div>
    </section>

    <!-- 申込推移 -->
    <section class="panel">
      <div class="panel-head">
        <h2 class="panel-title">過去 30 日 申込推移</h2>
        <span class="panel-legend"><span class="dot dot-brand"></span>1 日あたりの申込件数</span>
      </div>
      {trend.every(t => t.count === 0) ? (
        <p class="panel-empty">この期間にはまだ申込がありません。</p>
      ) : (
        <div class="trend-chart">
          <svg viewBox={`0 0 ${trendW} ${trendH}`} preserveAspectRatio="none" aria-label="申込推移">
            <defs>
              <linearGradient id="trendGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#6B85C9" stop-opacity="0.35" />
                <stop offset="100%" stop-color="#6B85C9" stop-opacity="0" />
              </linearGradient>
            </defs>
            <path d={trendArea} fill="url(#trendGrad)" />
            <path d={trendPath} fill="none" stroke="#6B85C9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
      )}
    </section>

    <!-- パイプライン -->
    <section class="panel">
      <div class="panel-head">
        <h2 class="panel-title">パイプライン分布</h2>
        <a href="/admin/leads" class="panel-link">リード管理を開く →</a>
      </div>
      {stageRows.every(s => s.count === 0) ? (
        <p class="panel-empty">該当するリードがありません。</p>
      ) : (
        <ul class="stage-list">
          {stageRows.map((s) => (
            <li class="stage-row">
              <span class="stage-label">{s.label}</span>
              <span class="stage-bar-wrap">
                <span class="stage-bar" style={`width: ${(s.count / stageMax) * 100}%; background: ${s.color};`}></span>
              </span>
              <span class="stage-count">{s.count}</span>
            </li>
          ))}
        </ul>
      )}
    </section>

    <!-- 直近申込 -->
    <section class="panel">
      <div class="panel-head">
        <h2 class="panel-title">直近の申込（最新 10 件）</h2>
      </div>
      {recentLeads.length === 0 ? (
        <p class="panel-empty">申込データがまだありません。</p>
      ) : (
        <div class="table-wrap">
          <table class="dash-table">
            <thead>
              <tr>
                <th>日時</th>
                <th>申込番号</th>
                <th>会社</th>
                <th>業種</th>
                <th>プラン</th>
                <th>状態</th>
                <th>詳細</th>
              </tr>
            </thead>
            <tbody>
              {recentLeads.map((l) => {
                const sb = statusBadge(l.status);
                return (
                  <tr>
                    <td class="td-meta">{fmtDateTime(l.created_at)}</td>
                    <td class="td-id">{l.application_id || '-'}</td>
                    <td>{l.company_name || '-'}</td>
                    <td class="td-meta">{l.industry || '-'}</td>
                    <td>
                      <span class={`badge ${l.plan === 'paid' ? 'badge-cyan' : 'badge-gray'}`}>
                        {l.plan === 'paid' ? '有償' : '無料'}
                      </span>
                    </td>
                    <td><span class={`badge ${sb.cls}`}>{sb.label}</span></td>
                    <td><a href={`/admin/leads/${l.id}`} class="row-link">開く</a></td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- 注記 -->
    <section class="panel panel-note">
      <p>
        <i class="fas fa-circle-info"></i>
        現在のデータソースは <code>diagnosis_leads</code> テーブルです。
        AI/API の実行ログは <code>ai_api_events</code> に集約し、<a href="/admin/api-status">API稼働状況</a> と
        <a href="/admin/reports">レポート</a> で確認できます。
      </p>
    </section>
  </div>
</AdminLayout>

