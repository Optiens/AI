---
import Layout from '../../layouts/Layout.astro';
import { createClient } from 'microcms-js-sdk';
import { format } from 'date-fns';
import { stripHtmlTags } from '../../utils/string';
import type { News, MicroCMSQueries, MicroCMSListResponse } from '../../types/microcms.d.ts';

// ヒーロー背景画像（assetsからimport）
import bgUrl from '~/assets/ai-nature-city.webp?url';

const client = createClient({
  serviceDomain: import.meta.env.MICROCMS_SERVICE_DOMAIN,
  apiKey: import.meta.env.MICROCMS_API_KEY,
});

const limit = 5;
const currentPage = Number(Astro.url.searchParams.get('page') ?? 1);
const offset = (currentPage - 1) * limit;

const queries: MicroCMSQueries = { orders: '-publishedAt', limit, offset };

const { contents: news, totalCount } = await client.get<MicroCMSListResponse<News>>({
  endpoint: 'news',
  queries,
});

const totalPages = Math.ceil(totalCount / limit);
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
---

<Layout title="ニュース | Optiens">
  <main>
    <!-- 共通 Hero セクション -->
    <section class="hero-section news-list-hero-section" style={`--hero-bg: url(${bgUrl});`}>
      <div class="container text-center">
        <h1>ニュース</h1>
      </div>
    </section>

    <!-- ニュース記事一覧 -->
    <section class="news-articles-section">
      <div class="container news-list-container">
        {totalCount > 0 ? (
          news.map((item) => (
            <a href={`/news/${item.slug}`} class="news-item-long-link" aria-label={`${item.title} の詳細`}>
              <article class="card news-item-long">
                <div class="card-content news-content-long">
                  <p class="news-date">
                    {item.publishedAt ? format(new Date(item.publishedAt), 'yyyy.MM.dd') : ''}
                  </p>
                  <h2 class="card-title">{item.title}</h2>
                  <p class="card-text">{stripHtmlTags(item.body).slice(0, 100)}…</p>
                </div>
                <span class="card-icon-container" aria-hidden="true">
                  <i class="fa-solid fa-arrow-up-right-from-square"></i>
                </span>
              </article>
            </a>
          ))
        ) : (
          <p class="text-center">現在、ニュースはありません。</p>
        )}
      </div>
    </section>

    {totalPages > 1 && (
      <nav class="pagination-container" aria-label="ニュースページネーション">
        <ul class="pagination">
          {hasPrev ? (
            <li class="pagination-item">
              <a href={`?page=${currentPage - 1}`} class="pagination-link">前へ</a>
            </li>
          ) : (
            <li class="pagination-item disabled">
              <span class="pagination-link">前へ</span>
            </li>
          )}
          <li class="pagination-item current">
            <span class="pagination-link">{currentPage} / {totalPages}</span>
          </li>
          {hasNext ? (
            <li class="pagination-item">
              <a href={`?page=${currentPage + 1}`} class="pagination-link">次へ</a>
            </li>
          ) : (
            <li class="pagination-item disabled">
              <span class="pagination-link">次へ</span>
            </li>
          )}
        </ul>
      </nav>
    )}
  </main>
</Layout>

<style>
  /* ========== Hero Section（ソリューションと統一） ========== */
  .hero-section {
    background-image: var(--hero-bg), var(--brand-gradient, linear-gradient(135deg,#2e574c,#5ea89a));
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    padding: clamp(40px, 7vw, 80px) 0;
    text-align: center;
    color: #fff;
    text-shadow: 0 2px 10px rgba(0,0,0,.35);
    position: relative;
    overflow: hidden;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 0;
  }
  .hero-section .container {
    position: relative;
    z-index: 1;
  }
  .hero-section h1 {
    font-size: clamp(26px, 4vw, 36px);
    margin: 0;
  }

  /* ========== News List ========== */
  .news-articles-section {
    padding: clamp(32px, 6vw, 60px) 0;
  }
  .news-list-container {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .news-item-long-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .news-item-long {
    display: flex;
    flex-direction: column;
  }
  .news-content-long {
    /* 共通カードに上書きする調整用 */
    gap: 8px;
  }
  .news-date {
    font-size: .9em;
    color: var(--muted);
    margin: 0;
  }

  /* ========== Pagination ========== */
  .pagination-container {
    display: flex;
    justify-content: center;
    padding: 30px 0;
  }
  .pagination {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid #ddd;
    border-radius: 5px;
  }
  .pagination-link {
    display: block;
    padding: 10px 15px;
    text-decoration: none;
    color: var(--text);
    transition: background-color .2s;
    font-weight: bold;
  }
  .pagination-link:hover {
    background-color: var(--surface-2);
  }
  .pagination-item.disabled .pagination-link {
    color: #ccc;
    cursor: not-allowed;
    background: transparent;
  }
  .pagination-item.current .pagination-link {
    background: var(--brand);
    color: #fff;
  }
</style>
