{
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://optiens.com/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "ensotechlab.com"
        }
      ]
    },
    {
      "source": "/:path*",
      "destination": "https://optiens.com/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.ensotechlab.com"
        }
      ]
    },
    {
      "source": "/ai-consulting",
      "destination": "/service",
      "permanent": true
    },
    {
      "source": "/ai-consulting/:slug*",
      "destination": "/service/:slug*",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/",
      "permanent": true
    }
  ]
}
