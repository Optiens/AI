---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="お問い合わせ | Optiens（全国オンライン対応）"
  description="合同会社Optiensへのお問い合わせフォーム。AI業務自動化に関するご質問・ご相談を全国オンライン対応で承ります。"
  canonical="https://optiens.com/contact"
>
  <main class="contact-page light-section">
    <!-- パーティクルネットワーク背景 -->
    <canvas id="contact-net" class="contact-canvas"></canvas>

    <div class="container" style="position:relative;z-index:1;">
      <h1 class="reveal">お問い合わせ</h1>
      <p class="reveal">ご質問、ご意見、ご要望など、お気軽にお問い合わせください。</p>

      <p class="contact-tip reveal">
        ※「業務にAIが使えるか診断してほしい」場合は、<a href="/free-diagnosis">無料AI診断</a>のフォームをご利用いただくと、より具体的なレポートをお届けできます。
      </p>

      <form action="/api/contact" method="POST" class="contact-form reveal" id="contact-form">
        <!-- いたずら防止: ハニーポット -->
        <div style="position:absolute;left:-9999px;" aria-hidden="true">
          <label for="website">ウェブサイト</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
        </div>
        <!-- いたずら防止: タイムスタンプ -->
        <input type="hidden" name="_t" id="_t">

        <div class="form-row">
          <div class="form-group">
            <label for="company_name">会社・団体名</label>
            <input type="text" id="company_name" name="company_name" placeholder="例: 株式会社〇〇">
          </div>
          <div class="form-group">
            <label for="person_name">お名前 <span class="req">*</span></label>
            <input type="text" id="person_name" name="person_name" required placeholder="例: 山田 太郎">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="email">メールアドレス <span class="req">*</span></label>
            <input type="email" id="email" name="email" required placeholder="example@company.com">
          </div>
          <div class="form-group">
            <label for="phone">電話番号</label>
            <input type="tel" id="phone" name="phone" placeholder="例: 090-1234-5678">
          </div>
        </div>

        <div class="form-group">
          <label for="inquiry_type">お問い合わせ種別</label>
          <select id="inquiry_type" name="inquiry_type">
            <option value="">選択してください</option>
            <option value="ai-consult">AI支援事業について</option>
            <option value="studio">Studio Optiens（創作）について</option>
            <option value="hydroponics">IoT水耕栽培事業について</option>
            <option value="press">取材・メディア掲載</option>
            <option value="partner">業務提携・パートナーシップ</option>
            <option value="other">その他</option>
          </select>
        </div>

        <div class="form-group">
          <label for="subject">件名 <span class="req">*</span></label>
          <input type="text" id="subject" name="subject" required>
        </div>

        <div class="form-group">
          <label for="message">内容 <span class="req">*</span></label>
          <textarea id="message" name="message" rows="8" required></textarea>
        </div>

        <p class="form-note">
          ご入力いただいた情報はお問い合わせ対応のみに使用します。<a href="/privacy-policy">プライバシーポリシー</a>をご確認ください。
        </p>

        <button type="submit" class="btn-primary contact-submit-btn" id="contact-submit">送信</button>
      </form>
    </div>
  </main>
</Layout>

<script is:inline>
(function() {
  const canvas = document.getElementById('contact-net');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let w, h, particles, animId;
  const CONNECT_DIST = 140;
  const PARTICLE_COUNT = 80;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = rect.width;
    h = rect.height;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  // Modern Vibrant パレット（Figma 4色：紫・青・緑・オレンジ）
  const COLORS = [
    'rgba(162,89,255,',   // #A259FF Figma purple
    'rgba(26,188,254,',   // #1ABCFE Figma blue
    'rgba(10,207,131,',   // #0ACF83 Figma green
    'rgba(242,78,30,',    // #F24E1E Figma orange
  ];

  function createParticles() {
    particles = [];
    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 1.5 + 0.5,
        color: COLORS[i % COLORS.length],
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, w, h);

    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          const alpha = (1 - dist / CONNECT_DIST) * 0.15;
          ctx.strokeStyle = 'rgba(162,89,255,' + alpha + ')';
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }

    for (const p of particles) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.color + '0.5)';
      ctx.fill();
    }

    if (!reducedMotion) {
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;
      }
    }

    animId = requestAnimationFrame(draw);
  }

  function init() {
    resize();
    createParticles();
    draw();
  }

  window.addEventListener('resize', () => { resize(); });
  init();
})();

// タイムスタンプ設定（いたずら防止）
(function() {
  const t = document.getElementById('_t');
  if (t) t.value = String(Date.now());
})();

// 二重送信防止
(function() {
  const form = document.getElementById('contact-form');
  if (!form) return;
  form.addEventListener('submit', function() {
    const btn = document.getElementById('contact-submit');
    if (btn) {
      btn.disabled = true;
      btn.textContent = '送信中…';
    }
  });
})();
</script>

<style>
  .contact-page {
    position: relative;
    padding: 120px 0 60px;
    overflow: hidden;
  }
  .contact-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .contact-page h1 {
    text-align: center;
    margin-bottom: 20px;
    color: var(--heading);
  }
  .contact-page > .container > p {
    text-align: center;
    margin-bottom: 40px;
    color: var(--muted);
  }
  .contact-form {
    max-width: 720px;
    margin: 0 auto;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 32px;
    border-radius: var(--radius);
    position: relative;
  }
  .contact-tip {
    max-width: 720px;
    margin: -10px auto 28px !important;
    padding: 12px 18px;
    background: rgba(162, 89, 255, .06);
    border-left: 3px solid var(--brand);
    border-radius: 4px;
    font-size: .88rem !important;
    line-height: 1.7;
    text-align: left !important;
    color: var(--text) !important;
  }
  .contact-tip a {
    color: var(--brand);
    font-weight: 700;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; gap: 0; }
  }
  .req {
    color: #F24E1E;
    font-weight: 700;
  }
  .form-note {
    font-size: .82rem !important;
    color: var(--muted) !important;
    line-height: 1.7;
    margin: 0 0 16px !important;
    text-align: left !important;
  }
  .form-note a {
    color: var(--brand);
    text-decoration: underline;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    font-size: .9rem;
    color: var(--heading);
  }
  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 1em;
    color: var(--text);
    transition: border-color .2s ease;
  }
  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(162, 89, 255, .15);
  }
  .form-group textarea {
    resize: vertical;
  }
  .contact-submit-btn {
    width: 100%;
    padding: 15px 20px;
    font-size: 1.1em;
    margin-top: 10px;
  }
</style>
