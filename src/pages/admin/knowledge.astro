---
import { getCollection } from 'astro:content';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { knowledgeDocs } from '../../lib/optiens-knowledge';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => String(b.data.date).localeCompare(String(a.data.date)));

const categoryLabels: Record<string, string> = {
  AI: 'AI支援',
  business: '経営',
  technology: '技術',
  agriculture: '水耕栽培',
  welfare: '福祉',
  social: '社会',
  announcement: 'お知らせ',
};

const categoryRows = Object.entries(
  posts.reduce<Record<string, number>>((acc, post) => {
    const key = post.data.category || 'unknown';
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  }, {})
)
  .map(([id, count]) => ({ id, label: categoryLabels[id] || id, count }))
  .sort((a, b) => b.count - a.count);

const latestPosts = posts.slice(0, 12);

const knowledgeSources = [
  {
    title: 'AI支援事業の案件運用',
    status: '稼働中',
    owner: 'CEO / COO',
    source: 'diagnosis_leads, ai_api_events',
    action: '案件、API障害、日次アラートへ接続済み',
  },
  {
    title: '無料診断・詳細診断のSOP',
    status: '整備中',
    owner: 'CMO / CSO',
    source: 'executive/ai-consulting, scripts/generate-*',
    action: '見積、納品、メール文面、レポート生成手順をSOP化',
  },
  {
    title: 'ブログ/公開ナレッジ',
    status: '素材あり',
    owner: 'CMO',
    source: 'src/content/blog',
    action: '業種別・論点別に営業資料へ再利用',
  },
  {
    title: '水耕栽培H1/H2判断材料',
    status: '未統合',
    owner: 'CFO / CRO',
    source: 'unit economics, sensor_data, cycles',
    action: '1株コスト、CV、kWh/kgを別ダッシュボード化',
  },
  {
    title: '補助金・期限・会計',
    status: '未統合',
    owner: 'CFO',
    source: 'Google Tasks, freee, executive/research',
    action: '月次/期限レポートとして日次メールに接続',
  },
];

const buildItems = [
  '質問して答えが不足した内容は、SOPまたはナレッジ本文へ追記する',
  '顧客別の提案・MTGメモ・次回アクションは、リード詳細から紐づける',
  '価格、ターゲット、禁止方針、Phase移行条件は決定ログとして残す',
  'プロンプト、メール、Slides、提案書テンプレはバージョンと変更理由を管理する',
  'ナレッジごとに責任者、最終更新日、次回見直し日を持たせる',
];

const categoryDocRows = Object.entries(
  knowledgeDocs.reduce<Record<string, number>>((acc, doc) => {
    acc[doc.category] = (acc[doc.category] || 0) + 1;
    return acc;
  }, {})
).map(([category, count]) => ({ category, count })).sort((a, b) => b.count - a.count);

const demoSafeCount = knowledgeDocs.filter((doc) => doc.visibility === 'demo-safe').length;
const demoReadyCount = knowledgeDocs.filter((doc) => doc.maturity === 'demo-ready').length;

function visibilityLabel(value: string) {
  return value === 'demo-safe' ? 'デモ可' : '社内限定';
}

function maturityLabel(value: string) {
  if (value === 'demo-ready') return 'デモ準備済み';
  if (value === 'operational') return '運用中';
  return '追加中';
}
---

<AdminLayout title="ナレッジ" active="knowledge">
  <section class="hero-panel">
    <div>
      <span>Optiens Knowledge Base</span>
      <h2>人が入った時に、Optiensの仕事を質問できる社内ナレッジにする</h2>
      <p>事業方針、営業SOP、AI/API運用、毎朝の確認、水耕栽培KPI、禁止表現を同じ棚に置き、質問欄から回答できる形にします。</p>
    </div>
    <strong>{knowledgeDocs.length}<small>社内ナレッジ</small></strong>
  </section>

  <section class="panel ask-panel">
    <div class="panel-head">
      <div>
        <span>Ask Optiens</span>
        <h3>業務について質問する</h3>
      </div>
    </div>
    <div class="ask-grid">
      <label>
        <span>質問</span>
        <textarea id="knowledge-question" rows="4" placeholder="例: 詳細レポートの入金後は何をすればいいですか？"></textarea>
      </label>
      <div class="ask-actions">
        <button type="button" id="knowledge-ask-button"><i class="fas fa-message"></i> 質問する</button>
        <small>回答は社内ナレッジを根拠に生成します。不足が出た内容はナレッジ化候補です。</small>
      </div>
    </div>
    <div class="answer-box" id="knowledge-answer">まだ質問していません。</div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Internal DB</span>
        <h3>Optiens標準業務ナレッジ</h3>
      </div>
    </div>
    <div class="knowledge-stats">
      <div>
        <b>{knowledgeDocs.length}</b>
        <span>登録ナレッジ</span>
      </div>
      <div>
        <b>{demoSafeCount}</b>
        <span>デモ公開候補</span>
      </div>
      <div>
        <b>{demoReadyCount}</b>
        <span>デモ準備済み</span>
      </div>
    </div>
    <div class="doc-grid">
      {knowledgeDocs.map((doc) => (
        <article class="doc-card">
          <div class="doc-badges">
            <span>{doc.category}</span>
            <span class={doc.visibility === 'demo-safe' ? 'badge-ok' : 'badge-warn'}>{visibilityLabel(doc.visibility)}</span>
          </div>
          <strong>{doc.title}</strong>
          <p>{doc.summary}</p>
          <small>{doc.owner} / {doc.updatedAt} / {maturityLabel(doc.maturity)}</small>
        </article>
      ))}
    </div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Sales Demo</span>
        <h3>販売デモ化の方針</h3>
      </div>
    </div>
    <div class="demo-roadmap">
      <article>
        <strong>1. 社内で使う</strong>
        <p>毎日の質問、引き継ぎ、手順確認に使い、不足した回答をナレッジ化します。</p>
      </article>
      <article>
        <strong>2. 公開可能な形へ分離する</strong>
        <p>顧客情報、APIキー、未公開財務、内部メモを除き、業務SOPと判断基準だけをデモ候補にします。</p>
      </article>
      <article>
        <strong>3. 主力販売ツールにする</strong>
        <p>「質問すると会社の標準回答が返る」体験を、属人化解消・新人教育・問い合わせ対応の提案に使います。</p>
      </article>
    </div>
  </section>

  <div class="grid">
    <section class="panel panel-wide">
      <div class="panel-head">
        <div>
          <span>Inventory</span>
          <h3>ナレッジ資産の現在地</h3>
        </div>
      </div>
      <div class="source-list">
        {knowledgeSources.map((source) => (
          <article class="source-row">
            <div>
              <strong>{source.title}</strong>
              <p>{source.source}</p>
            </div>
            <span>{source.status}</span>
            <small>{source.owner}</small>
            <em>{source.action}</em>
          </article>
        ))}
      </div>
    </section>

    <section class="panel">
      <div class="panel-head">
        <div>
          <span>Categories</span>
          <h3>公開ナレッジ分類</h3>
        </div>
      </div>
      <ul class="bar-list">
        {categoryDocRows.map((row) => (
          <li>
            <span>{row.category}</span>
            <b>{row.count}</b>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Next Build</span>
        <h3>実装すべきナレッジ機能</h3>
      </div>
    </div>
    <div class="build-list">
      {buildItems.map((item, index) => (
        <div class="build-item">
          <b>{index + 1}</b>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Recent</span>
        <h3>最近の公開記事</h3>
      </div>
      <a href="/blog" class="panel-link">サイト側で見る</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => (
        <a class="post-card" href={`/blog/${post.slug}`}>
          <span>{categoryLabels[post.data.category] || post.data.category}</span>
          <strong>{post.data.title}</strong>
          <p>{post.data.excerpt}</p>
          <small>{post.data.date}</small>
        </a>
      ))}
    </div>
  </section>
</AdminLayout>

<script is:inline>
  (function() {
    const textarea = document.getElementById('knowledge-question');
    const button = document.getElementById('knowledge-ask-button');
    const answer = document.getElementById('knowledge-answer');

    button?.addEventListener('click', async () => {
      if (!textarea || !answer || !button) return;
      const question = textarea.value.trim();
      if (!question) {
        answer.textContent = '質問を入力してください。';
        return;
      }

      button.disabled = true;
      answer.textContent = 'ナレッジを検索して回答を生成しています...';
      try {
        const res = await fetch('/api/admin/knowledge-query', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
        const sourceText = (data.sources || []).map((source) => `・${source.title}`).join('\n');
        answer.textContent = `${data.answer || '回答がありませんでした。'}${sourceText ? `\n\n参照:\n${sourceText}` : ''}`;
      } catch (error) {
        answer.textContent = error instanceof Error ? error.message : '回答生成に失敗しました。';
      } finally {
        button.disabled = false;
      }
    });
  })();
</script>

<style>
  .hero-panel,
  .panel,
  .doc-card {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
  }

  .hero-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 150px;
    gap: 18px;
    align-items: center;
    padding: 22px 24px;
    margin-bottom: 18px;
  }

  .hero-panel span,
  .panel-head span {
    color: var(--admin-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-panel h2,
  .panel-head h3 {
    color: #fff;
    letter-spacing: 0;
  }

  .hero-panel h2 {
    margin: 8px 0;
    font-size: 1.2rem;
  }

  .hero-panel p {
    margin: 0;
    color: var(--admin-muted);
    font-size: 0.9rem;
  }

  .ask-panel {
    margin-bottom: 18px;
  }

  .ask-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 14px;
    align-items: end;
  }

  .ask-grid label span {
    display: block;
    margin-bottom: 6px;
    color: var(--admin-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .ask-grid textarea {
    width: 100%;
    resize: vertical;
    min-height: 110px;
    padding: 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
    color: var(--admin-text);
    font: inherit;
  }

  .ask-actions {
    display: grid;
    gap: 8px;
  }

  .ask-actions button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 40px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-primary);
    color: #fff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .ask-actions button:disabled {
    cursor: wait;
    opacity: 0.68;
  }

  .ask-actions small,
  .answer-box,
  .doc-card p,
  .doc-card small {
    color: var(--admin-muted);
    font-size: 0.82rem;
  }

  .answer-box {
    margin-top: 14px;
    padding: 14px;
    min-height: 92px;
    white-space: pre-wrap;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .knowledge-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 14px;
  }

  .knowledge-stats div {
    padding: 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .knowledge-stats b {
    display: block;
    color: #fff;
    font-size: 1.35rem;
  }

  .knowledge-stats span {
    color: var(--admin-muted);
    font-size: 0.76rem;
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .doc-card {
    padding: 14px;
  }

  .doc-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .doc-card span {
    display: inline-flex;
    min-height: 22px;
    align-items: center;
    padding: 0 7px;
    border-radius: 999px;
    background: rgba(107, 133, 201, 0.16);
    color: var(--admin-accent-soft);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .doc-card span.badge-warn {
    background: rgba(228, 138, 149, 0.16);
  }

  .doc-card span.badge-ok {
    background: rgba(107, 133, 201, 0.22);
  }

  .doc-card strong {
    display: block;
    margin: 8px 0 6px;
    color: #fff;
  }

  .demo-roadmap {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .demo-roadmap article {
    padding: 14px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .demo-roadmap strong {
    color: #fff;
  }

  .demo-roadmap p {
    margin: 7px 0 0;
    color: var(--admin-muted);
    font-size: 0.84rem;
  }

  .hero-panel strong {
    display: grid;
    place-items: center;
    min-height: 110px;
    border-radius: 8px;
    background: var(--admin-surface-2);
    color: #fff;
    font-size: 2rem;
  }

  .hero-panel small {
    display: block;
    color: var(--admin-muted);
    font-size: 0.72rem;
  }

  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.6fr);
    gap: 18px;
    margin-bottom: 18px;
  }

  .panel {
    padding: 18px;
    margin-bottom: 18px;
  }

  .panel-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 14px;
  }

  .panel-head h3 {
    margin: 3px 0 0;
    font-size: 1rem;
  }

  .panel-link {
    color: var(--admin-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .source-list,
  .build-list {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .source-row {
    display: grid;
    grid-template-columns: minmax(180px, 1fr) 82px 90px;
    gap: 10px;
    align-items: center;
    padding: 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .source-row strong,
  .post-card strong {
    color: #fff;
  }

  .source-row p,
  .source-row small,
  .source-row em,
  .post-card p,
  .post-card small {
    color: var(--admin-muted);
    font-size: 0.74rem;
  }

  .source-row p {
    margin: 4px 0 0;
  }

  .source-row span {
    display: inline-flex;
    justify-content: center;
    padding: 3px 8px;
    border-radius: 999px;
    color: var(--admin-accent-soft);
    background: rgba(107, 133, 201, 0.18);
    font-size: 0.7rem;
    font-weight: 700;
  }

  .source-row em {
    grid-column: 1 / -1;
    font-style: normal;
  }

  .bar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin: 0;
    padding: 0;
  }

  .bar-list li {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 10px;
    border-radius: 7px;
    background: var(--admin-bg);
    color: var(--admin-text);
    font-size: 0.84rem;
  }

  .bar-list b {
    color: #fff;
  }

  .build-item {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    padding: 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .build-item b {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: #1F3A93;
    color: #fff;
  }

  .build-item p {
    margin: 0;
    color: var(--admin-text);
    font-size: 0.86rem;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
  }

  .post-card {
    display: block;
    min-height: 180px;
    padding: 14px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
    color: inherit;
    text-decoration: none;
  }

  .post-card:hover {
    border-color: rgba(107, 133, 201, 0.45);
  }

  .post-card span {
    color: var(--admin-secondary);
    font-size: 0.7rem;
    font-weight: 700;
  }

  .post-card strong {
    display: block;
    margin: 7px 0;
    font-size: 0.9rem;
  }

  .post-card p {
    margin: 0 0 10px;
  }

  @media (max-width: 920px) {
    .hero-panel,
    .grid,
    .ask-grid {
      grid-template-columns: 1fr;
    }

    .doc-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .demo-roadmap {
      grid-template-columns: 1fr;
    }

    .source-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .doc-grid {
      grid-template-columns: 1fr;
    }

    .knowledge-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
