---
import Layout from '../layouts/Layout.astro';

// ===== データ定義 =====
type CommonCase = {
  id: string;
  num: string;
  icon: string;
  title: string;
  summary: string;
  desc: string;
  tags: string[];
  self: string;
  demo?: { label: string; href: string; note?: string };
};

type Industry = {
  id: string;
  image: string;
  title: string;
  shortTitle: string;
  summary: string;
  metric: string;
  href: string;
  demo?: { label: string; href: string; note?: string };
};

const commonCases: CommonCase[] = [
  {
    id: 'case-inquiry',
    num: '01',
    icon: 'fa-route',
    title: '問い合わせ自動振り分け・一次返信下書き',
    summary: '問い合わせを分類し、優先度・担当者・返信案まで自動生成',
    desc: 'Webフォーム・メール・LINE・SNSなど、複数の窓口に届く問い合わせをAIが読み取り、内容分類、優先度判定、推奨対応者、一次返信案までまとめます。夜間や休日の取りこぼしを減らし、緊急度が高いものだけを担当者へ通知できます。完全自動返信ではなく、送信前に人が確認する設計なので、顧客対応の品質も保ちやすい仕組みです。',
    tags: ['宿泊業', 'EC', '士業', 'サービス業', 'BtoB'],
    self: '問い合わせ・診断申込・補助金情報の確認を、内容別に整理して次アクションへ回す運用を行っています。',
    demo: { label: '問い合わせ自動振り分けデモを試す', href: '/inquiry-routing' },
  },
  {
    id: 'case-quote',
    num: '02',
    icon: 'fa-file-signature',
    title: '見積書ドラフト自動生成',
    summary: '案件情報から、見積書の初稿をその場で作成',
    desc: '顧客名・案件概要・金額・納期・特記事項を入力すると、AIが見積書の下書きを生成します。御社専用版では、過去案件、標準価格表、社内テンプレート、承認ワークフローまで連携し、営業担当がゼロから文面を作る時間を削減できます。金額・条件・送付可否は人が最終確認する前提です。',
    tags: ['工務店', '制作会社', '士業', '導入支援', 'BtoB'],
    self: '提案書・見積条件・診断レポートの雛形を、案件情報に合わせて生成する運用を進めています。',
    demo: { label: '見積書ドラフト生成デモを試す', href: '/quote-generator' },
  },
  {
    id: 'case-search',
    num: '03',
    icon: 'fa-magnifying-glass-chart',
    title: '社内データ・社内ドキュメント検索',
    summary: '「先月の売上は？」「経費精算は？」に根拠付きで回答',
    desc: '売上・顧客・問い合わせ履歴などの数値データと、規程・マニュアル・連絡網などの社内文書に、自然な日本語で質問できます。回答には該当データや引用元を併せて表示するため、AIの回答を確認しながら使えます。新人教育、経営判断の数字確認、社内問い合わせ削減に向いた実用度の高い自動化です。',
    tags: ['全業種', '管理部門', '営業', '新人教育', '経営者'],
    self: '水耕栽培の収穫データ・電力消費データ、社内ドキュメント検索の運用検証を進めています。',
    demo: { label: 'データ検索＋社内ドキュメント検索デモを試す', href: '/data-search' },
  },
  {
    id: 'case-approval',
    num: '04',
    icon: 'fa-clipboard-check',
    title: '承認ワークフロー',
    summary: '申請者と承認者で画面が切り替わる承認フロー',
    desc: '経費精算・休暇申請・稟議・発注承認など、社内の承認業務を一元管理する仕組みです。申請者は専用画面から申請を提出し、承認者は自分宛の案件だけを確認・承認・却下します。金額や申請種類による承認ルート切替、承認後の会計・人事・スプレッドシート連携にも拡張できます。',
    tags: ['全業種', '管理部門', '建設業', '製造業', '複数拠点'],
    self: '稟議・経費・発注の承認を、Supabase + AI 駆動 UI で自動化する構成を運用しています。',
    demo: { label: '承認ワークフローのデモを試す', href: '/approval-workflow' },
  },
  {
    id: 'case-management',
    num: '05',
    icon: 'fa-table-columns',
    title: 'カスタム業務管理画面',
    summary: 'リードから納品・保守まで、御社専用画面で一元管理',
    desc: '汎用SaaSの「項目が多すぎて使われない」「複数サービスを行き来して二重入力」を避け、御社の業務フローに合わせた専用画面を構築します。経営者、営業パートナー、現場担当で表示項目を切り替え、必要な情報だけを扱えるようにします。',
    tags: ['小規模事業者', '営業組織', '外注先管理', '保守運用', '全業種'],
    self: 'CRM・コンテンツ運用・小説推敲ツールなど、用途ごとに専用画面を作って社内運用しています。',
    demo: { label: 'カスタム業務管理画面のデモを試す', href: '/custom-management' },
  },
  {
    id: 'case-review',
    num: '06',
    icon: 'fa-star-half-stroke',
    title: '口コミ監視・返信下書き',
    summary: '新着口コミを監視し、低評価アラートと返信案を生成',
    desc: 'Googleマップ、食べログ、SNSなどの新着口コミを定期的に確認し、低評価や対応が必要な投稿を見つけます。AIが内容を分類し、店舗のトーンに合わせた返信下書きと改善ポイントを提示します。公開返信は店舗責任者が確認するため、炎上リスクを抑えながら対応速度を上げられます。',
    tags: ['飲食店', '宿泊業', '観光事業', '店舗運営'],
    self: '外部情報の定期モニタリングと要約通知を、社内の情報収集業務で活用しています。',
    demo: { label: '口コミ監視＋返信下書きデモを試す', href: '/review-monitor' },
  },
  {
    id: 'case-document',
    num: '07',
    icon: 'fa-file-circle-check',
    title: '契約書・社内文書レビュー支援',
    summary: '契約条件・社内運用・顧客説明の抜け漏れを確認',
    desc: '契約書、料金改定案内、社内規程変更通知などを読み、業務上の影響、修正方針、確認先、修正文案まで整理します。御社専用版では、社内テンプレート、禁止表現、責任範囲、期限、金額、承認ルートなどの確認観点を組み込めます。法的判断や最終提出は専門家・責任者が確認する前提で、レビューの抜け漏れを減らします。',
    tags: ['士業', '管理部門', '営業', '経営者'],
    self: '公開文書・診断レポート・提案資料のレビュー観点をAIで整理し、人間が最終確認する運用を行っています。',
    demo: { label: '契約書・社内文書レビュー支援デモを試す', href: '/document-review' },
  },
];

const industries: Industry[] = [
  { id: 'ind-legal', image: '/images/industries/legal.png', title: '士業（税理士・行政書士）', shortTitle: '士業', summary: '期限管理・書類作成・顧客対応', metric: '月30時間削減', href: '/service/sample-legal' },
  { id: 'ind-pension', image: '/images/industries/pension.png', title: 'ペンション・宿泊業', shortTitle: 'ペンション・宿泊', summary: '予約対応・口コミ返信・多言語対応', metric: '月25時間削減', href: '/service/sample-pension' },
  { id: 'ind-restaurant', image: '/images/industries/restaurant.png', title: 'カフェ＆レストラン', shortTitle: 'カフェ・レストラン', summary: 'SNS投稿・口コミ対応・LINE配信', metric: '月18時間削減＋売上増', href: '/service/sample-restaurant', demo: { label: '口コミ監視＋返信下書きデモを試す', href: '/review-monitor', note: 'Googleマップ・食べログ・SNS の新着口コミを監視し、低評価アラートと返信下書きを確認できるデモです。' } },
  { id: 'ind-ec', image: '/images/industries/ec.png', title: 'EC事業者・ネットショップ', shortTitle: 'EC・ネットショップ', summary: '商品登録・受注対応・問い合わせ分類', metric: '月25時間削減', href: '/service/sample-ec' },
  { id: 'ind-construction', image: '/images/industries/construction.png', title: '工務店・建設業', shortTitle: '工務店・建設', summary: '見積書作成・報告書効率化・承認管理', metric: '月35時間削減', href: '/service/sample-construction' },
  { id: 'ind-winery', image: '/images/industries/winery.png', title: 'ワイナリー・醸造所', shortTitle: 'ワイナリー', summary: '醸造記録・在庫管理・卸先提案書', metric: '月30時間削減', href: '/service/sample-winery' },
];

---

<Layout
  title={`AI業務自動化デモ | 実用デモ${commonCases.length}件 + 業種別${industries.length}業種 | Optiens`}
  description={`問い合わせ振り分け、見積書作成、社内データ検索、承認ワークフローなど、実際に操作できるAI業務自動化デモを${commonCases.length}件公開しています。業種別シナリオと合わせてご覧ください。`}
  canonical="https://optiens.com/ai-examples"
>
  <main>
    <!-- 事例エクスプローラ（ヒーローは削除し直接表示） -->
    <section class="ax-explorer light-section">
      <div class="container">
        <!-- カテゴリタブ -->
        <div class="ax-tabs reveal" role="tablist" aria-label="事例カテゴリ">
          <button class="ax-tab active" data-cat="common" role="tab" aria-selected="true">
            <span class="ax-tab-label">実用デモ</span>
            <span class="ax-tab-count">{commonCases.length}</span>
          </button>
          <button class="ax-tab" data-cat="industry" role="tab" aria-selected="false">
            <span class="ax-tab-label">業種別資料</span>
            <span class="ax-tab-count">{industries.length}</span>
          </button>
        </div>

        <!-- セレクタ + 詳細 -->
        <div class="ax-explorer-grid">
          <!-- 左：セレクタリスト -->
          <aside class="ax-selector" aria-label="事例選択リスト">
            <!-- 共通事例 -->
            <ul class="ax-selector-group" data-cat-group="common">
              {commonCases.map((c, idx) => (
                <li>
                  <button class={`ax-sel-item ax-sel-item--common-no-icon ${idx === 0 ? 'active' : ''}`} data-id={c.id}>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">{c.title}</span>
                      <span class="ax-sel-summary">{c.summary}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
            <!-- 業種別 -->
            <ul class="ax-selector-group hidden" data-cat-group="industry">
              {industries.map((i) => (
                <li>
                  <button class="ax-sel-item" data-id={i.id}>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">{i.shortTitle}</span>
                      <span class="ax-sel-summary">{i.metric}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
          </aside>

          <!-- 右：詳細パネル -->
          <div class="ax-detail" aria-live="polite">
            <!-- 共通事例の詳細 -->
            {commonCases.map((c, idx) => (
              <article class={`ax-detail-card ${idx === 0 ? 'active' : ''}`} data-id={c.id} data-cat="common">
                <header class="ax-detail-head">
                  <h2 class="ax-detail-title">{c.title}</h2>
                </header>
                <p class="ax-detail-desc">{c.desc}</p>
                <div class="ax-detail-tags">
                  <span class="ax-detail-tags-label">適用業種：</span>
                  {c.tags.map((t: string) => <span class="ax-tag">{t}</span>)}
                </div>
                <div class="ax-detail-self">
                  <i class="fa-solid fa-flask"></i>
                  <p><strong>弊社での運用</strong>: {c.self}</p>
                </div>
                {c.demo ? (
                  <>
                    <a href={c.demo.href} class="btn-primary ax-detail-cta">
                      <i class="fa-solid fa-circle-play"></i>
                      {c.demo.label}
                      <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    {c.demo.note ? (
                      <p class="ax-detail-demo-note">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>{c.demo.note}</span>
                      </p>
                    ) : null}
                  </>
                ) : null}
              </article>
            ))}
            <!-- 業種別の詳細 -->
            {industries.map((i) => (
              <article class="ax-detail-card" data-id={i.id} data-cat="industry">
                <header class="ax-detail-head">
                  <h2 class="ax-detail-title">{i.title}</h2>
                </header>
                <p class="ax-detail-desc">{i.summary}を含む業務全体を、御社の現場に合わせて再設計します。業種特化の活用シナリオ・想定削減時間・導入ロードマップを、活用シナリオページでご覧いただけます。</p>
                <div class="ax-detail-metric">
                  <span class="ax-metric-label">想定削減時間</span>
                  <span class="ax-metric-value">{i.metric}</span>
                </div>
                <a href={i.href} class="btn-primary ax-detail-cta">
                  活用シナリオを見る
                  <i class="fa-solid fa-arrow-right"></i>
                </a>
                {i.demo && (
                  <>
                    <a href={i.demo.href} class="btn-secondary ax-detail-cta ax-detail-cta--demo">
                      <i class="fa-solid fa-circle-play"></i>
                      {i.demo.label}
                      <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    {i.demo.note && (
                      <p class="ax-detail-demo-note">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>{i.demo.note}</span>
                      </p>
                    )}
                  </>
                )}
              </article>
            ))}
          </div>
        </div>

        <p class="ax-bridge-note reveal">
          掲載デモはすべて、入力・判定・出力・人間の確認ポイントを確認できるものに絞っています。サービス内容は <a href="/service">AI支援ページ</a> をご確認ください。
        </p>
      </div>
    </section>

    <!-- ファイナルCTA -->
    <section class="ax-cta-section">
      <div class="container text-center">
        <h2 class="reveal">御社で使うなら、どのデモから着手すべきかを診断します</h2>
        <p class="reveal">
          上記のデモのうち、どれが御社で効きやすいか。<br />
          無料活用診断レポートで数値とともにご提案します。
        </p>
        <div class="cta-buttons reveal">
          <a href="/free-diagnosis" class="btn-primary">無料活用診断を受ける</a>
          <a href="/service" class="btn-secondary">サービス内容を見る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
(function() {
  const tabs = document.querySelectorAll('.ax-tab');
  const groups = document.querySelectorAll('.ax-selector-group');
  const detailCards = document.querySelectorAll('.ax-detail-card');
  const selItems = document.querySelectorAll('.ax-sel-item');

  function selectCategory(cat) {
    // タブ更新
    tabs.forEach((t) => {
      const isActive = t.dataset.cat === cat;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    // セレクタグループ更新
    groups.forEach((g) => {
      g.classList.toggle('hidden', g.dataset.catGroup !== cat);
    });
    // そのカテゴリの最初の項目を選択
    const firstItem = document.querySelector(`.ax-selector-group[data-cat-group="${cat}"] .ax-sel-item`);
    if (firstItem) selectItem(firstItem.dataset.id);
  }

  function selectItem(id) {
    if (!id) return;
    selItems.forEach((b) => b.classList.toggle('active', b.dataset.id === id));
    detailCards.forEach((c) => c.classList.toggle('active', c.dataset.id === id));
    // 詳細パネルへスクロール（モバイル対応）
    if (window.innerWidth <= 900) {
      const target = document.querySelector(`.ax-detail-card.active`);
      if (target) {
        const offset = target.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: offset, behavior: 'smooth' });
      }
    }
    // URLハッシュ更新
    if (history.replaceState) history.replaceState(null, '', '#' + id);
  }

  tabs.forEach((t) => {
    t.addEventListener('click', () => selectCategory(t.dataset.cat));
  });
  selItems.forEach((b) => {
    b.addEventListener('click', () => selectItem(b.dataset.id));
  });

  // 初期表示：URLハッシュがあればそれを選択
  const hash = window.location.hash.replace('#', '');
  if (hash) {
    const target = document.querySelector(`.ax-sel-item[data-id="${hash}"]`);
    if (target) {
      const cat = target.closest('.ax-selector-group')?.dataset.catGroup;
      if (cat) {
        selectCategory(cat);
        selectItem(hash);
        return;
      }
    }
  }
  // ?cat=industry|common でカテゴリ初期選択
  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('cat');
  if (catParam && ['common', 'industry'].includes(catParam)) {
    selectCategory(catParam);
  }
})();
</script>

<style>
  /* ===== Hero ===== */
  .ax-hero {
    position: relative;
    color: var(--text);
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(90px, 11vw, 140px) 0;
    background: #ffffff;
    overflow: hidden;
  }
  .ax-hero h1 {
    color: var(--heading);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    margin-bottom: 20px;
    line-height: 1.4;
  }
  .hero-sub {
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 32px;
  }
  .ax-hero .btn-primary.hero-cta {
    margin-top: clamp(20px, 3vw, 32px);
  }

  /* ===== Explorer Section ===== */
  .ax-explorer {
    background: #ffffff;
    padding: clamp(48px, 8vw, 80px) 0;
  }

  /* ===== Category Tabs ===== */
  .ax-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: clamp(28px, 4vw, 40px);
    background: rgba(31, 58, 147, .04);
    padding: 6px;
    border-radius: 999px;
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }
  .ax-tab {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 18px;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: clamp(.82rem, 1.4vw, .92rem);
    font-weight: 600;
    cursor: pointer;
    transition: all .2s ease;
  }
  .ax-tab:hover {
    color: var(--brand);
  }
  .ax-tab.active {
    background: linear-gradient(135deg, #1F3A93 0%, #6B85C9 100%);
    color: #fff;
    box-shadow: 0 6px 18px rgba(31, 58, 147, .35);
  }
  .ax-tab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: 999px;
    background: rgba(0, 0, 0, .08);
    color: inherit;
    font-size: .72rem;
    font-weight: 700;
  }
  .ax-tab.active .ax-tab-count {
    background: rgba(255, 255, 255, .25);
  }

  /* ===== Master-Detail Grid ===== */
  .ax-explorer-grid {
    display: grid;
    grid-template-columns: minmax(280px, 360px) 1fr;
    gap: clamp(20px, 3vw, 32px);
    align-items: start;
  }
  @media (max-width: 900px) {
    .ax-explorer-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Selector List ===== */
  .ax-selector {
    position: sticky;
    top: 90px;
    max-height: calc(100vh - 110px);
    overflow-y: auto;
    padding-right: 4px;
  }
  @media (max-width: 900px) {
    .ax-selector {
      position: static;
      max-height: none;
      overflow: visible;
    }
  }
  .ax-selector-group {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ax-selector-group.hidden {
    display: none;
  }
  .ax-sel-item {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 12px;
    cursor: pointer;
    text-align: left;
    transition: all .2s ease;
    color: inherit;
    font: inherit;
  }
  .ax-sel-item:hover {
