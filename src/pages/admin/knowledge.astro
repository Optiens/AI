---
import { getCollection } from 'astro:content';
import AdminLayout from '../../layouts/AdminLayout.astro';
import {
  knowledgeCategoryLabels,
  knowledgeDocs,
  knowledgeMaturityLabels,
  knowledgeVisibilityLabels,
  mergeKnowledgeDocs,
} from '../../lib/optiens-knowledge';
import { dbKnowledgeEntryToDoc, listKnowledgeEntries } from '../../lib/admin-ops';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => String(b.data.date).localeCompare(String(a.data.date)));

const publicCategoryLabels: Record<string, string> = {
  AI: 'AI支援',
  business: '経営',
  technology: '技術',
  agriculture: '水耕栽培',
  welfare: '福祉',
  social: '社会',
  announcement: 'お知らせ',
};

const latestPosts = posts.slice(0, 8);
const { entries: editableKnowledgeEntries, error: editableKnowledgeError } = await listKnowledgeEntries();
const editableKnowledgeDocs = editableKnowledgeEntries.map(dbKnowledgeEntryToDoc);
const allKnowledgeDocs = mergeKnowledgeDocs(knowledgeDocs, editableKnowledgeDocs)
  .sort((a, b) => String(b.updatedAt).localeCompare(String(a.updatedAt)) || a.title.localeCompare(b.title, 'ja'));

const draftInstruction = Astro.url.searchParams.get('draft') || '';
const demoSafeCount = allKnowledgeDocs.filter((doc) => doc.visibility === 'demo-safe').length;
const demoReadyCount = allKnowledgeDocs.filter((doc) => doc.maturity === 'demo-ready').length;
const operationalCount = allKnowledgeDocs.filter((doc) => doc.maturity === 'operational').length;
const categoryRows = Object.entries(
  allKnowledgeDocs.reduce<Record<string, number>>((acc, doc) => {
    acc[doc.category] = (acc[doc.category] || 0) + 1;
    return acc;
  }, {})
).map(([category, count]) => ({ category, count })).sort((a, b) => b.count - a.count);

const knowledgeSources = [
  {
    title: 'AI支援事業の案件運用',
    status: '稼働中',
    owner: 'CEO / COO',
    source: 'diagnosis_leads, ai_api_events',
    action: '案件、API障害、日次アラートへ接続済み',
  },
  {
    title: '無料診断・詳細診断のSOP',
    status: '整備中',
    owner: 'CMO / CSO',
    source: 'executive/ai-consulting, scripts/generate-*',
    action: '見積、納品、メール文面、レポート生成手順をSOP化',
  },
  {
    title: 'ブログ/公開ナレッジ',
    status: '素材あり',
    owner: 'CMO',
    source: 'src/content/blog',
    action: '業種別・論点別に営業資料へ再利用',
  },
  {
    title: '水耕栽培H1/H2判断材料',
    status: '未統合',
    owner: 'CFO / CRO',
    source: 'unit economics, sensor_data, cycles',
    action: '1株コスト、CV、kWh/kgを別ダッシュボード化',
  },
  {
    title: '補助金・期限・会計',
    status: '未統合',
    owner: 'CFO',
    source: 'Google Tasks, freee, executive/research',
    action: '月次/期限レポートとして日次メールに接続',
  },
];

function detailHref(id: string) {
  return `/admin/knowledge/${encodeURIComponent(id)}`;
}
---

<AdminLayout title="ナレッジ" active="knowledge">
  <section class="hero-panel">
    <div>
      <span>Optiens Knowledge Base</span>
      <h2>タイトルで探し、詳細ページでHTMLとして読む社内ナレッジ</h2>
      <p>人間はリストビューとHTMLビューで確認し、追加・編集はAIへの指示としてキュー化します。</p>
    </div>
    <strong>{allKnowledgeDocs.length}<small>社内ナレッジ</small></strong>
  </section>

  {editableKnowledgeError && (
    <div class="alert-box">
      <i class="fas fa-circle-exclamation"></i>
      <span>{editableKnowledgeError}</span>
    </div>
  )}

  <section class="panel ask-panel">
    <div class="panel-head">
      <div>
        <span>Ask Optiens</span>
        <h3>業務について質問する</h3>
      </div>
    </div>
    <div class="ask-grid">
      <label>
        <span>質問</span>
        <textarea id="knowledge-question" rows="4" placeholder="例: 詳細レポートの入金後は何をすればいいですか？"></textarea>
      </label>
      <div class="ask-actions">
        <button type="button" id="knowledge-ask-button"><i class="fas fa-message"></i> 質問する</button>
        <small>回答は社内ナレッジを根拠に生成します。不足があれば不足キューへ自動登録されます。</small>
      </div>
    </div>
    <div class="answer-box" id="knowledge-answer">まだ質問していません。</div>
  </section>

  <section class="panel instruction-panel">
    <div class="panel-head">
      <div>
        <span>Ask Codex</span>
        <h3>ナレッジ追加・編集をAIに依頼する</h3>
      </div>
      <a href="/admin/knowledge-gaps" class="panel-link">不足キューへ</a>
    </div>
    <div class="instruction-grid">
      <label class="instruction-main">
        <span>AIへの依頼内容</span>
        <textarea id="knowledge-instruction" rows="5" placeholder="例: 有償診断の返金条件と、手動復旧SOPへのリンクをナレッジに追加して。">{draftInstruction}</textarea>
      </label>
      <div class="instruction-options">
        <label>
          <span>カテゴリ候補</span>
          <select id="knowledge-instruction-category">
            <option value="operations">運用</option>
            <option value="sales">営業</option>
            <option value="ai">AI/API</option>
            <option value="brand">ブランド</option>
            <option value="business">事業</option>
            <option value="governance">ガバナンス</option>
            <option value="hydroponics">水耕栽培</option>
          </select>
        </label>
        <label>
          <span>優先度</span>
          <select id="knowledge-instruction-priority">
            <option value="medium">中</option>
            <option value="high">高</option>
            <option value="low">低</option>
          </select>
        </label>
        <button type="button" id="knowledge-instruction-button"><i class="fas fa-wand-magic-sparkles"></i> AI依頼を作る</button>
      </div>
    </div>
    <div class="prompt-box" id="knowledge-instruction-result">
      ここにCodexへ渡す依頼文と、不足キューへの登録結果が表示されます。
    </div>
  </section>

  <section class="list-view-shell">
    <div class="list-view-header">
      <div>
        <span class="object-label">Knowledge</span>
        <h2><i class="fas fa-table-list"></i> ナレッジ一覧</h2>
        <p>タイトルをクリックすると、人間が読みやすいHTMLビューで詳細を確認できます。</p>
      </div>
      <div class="list-view-actions">
        <a class="ghost-btn" href="/admin/knowledge-gaps"><i class="fas fa-circle-question"></i> 不足キュー</a>
        <a class="ghost-btn" href="/admin/reports#report-library"><i class="fas fa-chart-simple"></i> レポート</a>
      </div>
    </div>

    <div class="list-view-summary" aria-label="ナレッジ概要">
      <span><b>{allKnowledgeDocs.length}</b> 登録ナレッジ</span>
      <span><b>{operationalCount}</b> 運用中</span>
      <span><b>{demoSafeCount}</b> デモ公開候補</span>
      <span><b>{demoReadyCount}</b> デモ準備済み</span>
    </div>

    <div class="lead-toolbar">
      <label class="search-box">
        <i class="fas fa-search"></i>
        <input id="knowledge-search" type="search" placeholder="タイトル、要約、タグで検索" />
      </label>
      <select id="knowledge-category-filter" aria-label="カテゴリ">
        <option value="all">すべてのカテゴリ</option>
        {Object.entries(knowledgeCategoryLabels).map(([id, label]) => <option value={id}>{label}</option>)}
      </select>
      <select id="knowledge-maturity-filter" aria-label="成熟度">
        <option value="all">すべての成熟度</option>
        {Object.entries(knowledgeMaturityLabels).map(([id, label]) => <option value={id}>{label}</option>)}
      </select>
    </div>

    <div class="list-view-meta">
      <span><span id="visible-count">{allKnowledgeDocs.length}</span>件を表示中</span>
      <span>追加・編集はフォームではなく、上のAI依頼欄から不足キュー化します。</span>
    </div>

    <div class="table-wrap">
      <table class="knowledge-table">
        <thead>
          <tr>
            <th class="select-col"></th>
            <th>タイトル</th>
            <th>カテゴリ</th>
            <th>状態</th>
            <th>責任者</th>
            <th>更新日</th>
            <th>タグ</th>
            <th class="open-col"></th>
          </tr>
        </thead>
        <tbody>
          {allKnowledgeDocs.map((doc) => (
            <tr
              class="knowledge-row"
              data-href={detailHref(doc.id)}
              data-category={doc.category}
              data-maturity={doc.maturity}
              data-search={`${doc.title} ${doc.summary} ${doc.tags.join(' ')}`.toLowerCase()}
              tabindex="0"
            >
              <td class="select-col"><span class="row-dot" aria-hidden="true"></span></td>
              <td class="td-title">
                <a href={detailHref(doc.id)}>{doc.title}</a>
                <span>{doc.summary}</span>
              </td>
              <td>{knowledgeCategoryLabels[doc.category]}</td>
              <td>
                <span class={`state-pill state-pill--${doc.maturity}`}>{knowledgeMaturityLabels[doc.maturity]}</span>
                <small>{knowledgeVisibilityLabels[doc.visibility]}</small>
              </td>
              <td>{doc.owner}</td>
              <td>{doc.updatedAt}</td>
              <td class="tag-cell">{doc.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}</td>
              <td class="open-col"><i class="fas fa-chevron-right"></i></td>
            </tr>
          ))}
          {allKnowledgeDocs.length === 0 && <tr><td colspan="8" class="td-empty">ナレッジがありません</td></tr>}
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid">
    <section class="panel panel-wide">
      <div class="panel-head">
        <div>
          <span>Inventory</span>
          <h3>ナレッジ資産の現在地</h3>
        </div>
      </div>
      <div class="source-list">
        {knowledgeSources.map((source) => (
          <article class="source-row">
            <div>
              <strong>{source.title}</strong>
              <p>{source.source}</p>
            </div>
            <span>{source.status}</span>
            <small>{source.owner}</small>
            <em>{source.action}</em>
          </article>
        ))}
      </div>
    </section>

    <section class="panel">
      <div class="panel-head">
        <div>
          <span>Categories</span>
          <h3>社内ナレッジ分類</h3>
        </div>
      </div>
      <ul class="bar-list">
        {categoryRows.map((row) => (
          <li>
            <span>{knowledgeCategoryLabels[row.category as keyof typeof knowledgeCategoryLabels] || row.category}</span>
            <b>{row.count}</b>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Sales Demo</span>
        <h3>販売デモ化の方針</h3>
      </div>
    </div>
    <div class="demo-roadmap">
      <article>
        <strong>1. 社内で使う</strong>
        <p>毎日の質問、引き継ぎ、手順確認に使い、不足した回答をAI依頼として蓄積します。</p>
      </article>
      <article>
        <strong>2. 公開可能な形へ分離する</strong>
        <p>顧客情報、APIキー、未公開財務、内部メモを除き、業務SOPと判断基準だけをデモ候補にします。</p>
      </article>
      <article>
        <strong>3. 主力販売ツールにする</strong>
        <p>「質問すると会社の標準回答が返る」体験を、属人化解消・新人教育・問い合わせ対応の提案に使います。</p>
      </article>
    </div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Recent</span>
        <h3>最近の公開記事</h3>
      </div>
      <a href="/blog" class="panel-link">サイト側で見る</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => (
        <a class="post-card" href={`/blog/${post.slug}`}>
          <span>{publicCategoryLabels[post.data.category] || post.data.category}</span>
          <strong>{post.data.title}</strong>
          <p>{post.data.excerpt}</p>
          <small>{post.data.date}</small>
        </a>
      ))}
    </div>
  </section>
</AdminLayout>

<script is:inline>
  (function() {
    const textarea = document.getElementById('knowledge-question');
    const button = document.getElementById('knowledge-ask-button');
    const answer = document.getElementById('knowledge-answer');

    button?.addEventListener('click', async () => {
      if (!textarea || !answer || !button) return;
      const question = textarea.value.trim();
      if (!question) {
        answer.textContent = '質問を入力してください。';
        return;
      }

      button.disabled = true;
      answer.textContent = 'ナレッジを検索して回答を生成しています...';
      try {
        const res = await fetch('/api/admin/knowledge-query', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
        const sourceText = (data.sources || []).map((source) => `・${source.title}`).join('\n');
        answer.textContent = `${data.answer || '回答がありませんでした。'}${sourceText ? `\n\n参照:\n${sourceText}` : ''}`;
      } catch (error) {
        answer.textContent = error instanceof Error ? error.message : '回答生成に失敗しました。';
      } finally {
        button.disabled = false;
      }
    });

    const instruction = document.getElementById('knowledge-instruction');
    const instructionCategory = document.getElementById('knowledge-instruction-category');
    const instructionPriority = document.getElementById('knowledge-instruction-priority');
    const instructionButton = document.getElementById('knowledge-instruction-button');
    const instructionResult = document.getElementById('knowledge-instruction-result');

    function buildCodexPrompt(text, category) {
      return [
        'Codexへ依頼:',
        'C:\\workspace\\Optiens の社内ナレッジを更新してください。',
        '',
        `依頼内容: ${text}`,
        `カテゴリ候補: ${category}`,
        '',
        '要件:',
        '- ナレッジ一覧でタイトルだけ見ても内容が分かるように整理する',
        '- 詳細ページのHTMLビューで読みやすいよう、見出し、箇条書き、短い段落で構成する',
        '- 必要に応じて src/lib/optiens-knowledge.ts または knowledge_entries 用 migration を更新する',
        '- Optiensの禁止事項に反する記述を追加しない',
        '- 型チェックとビルドを確認し、管理画面関連の差分だけコミット・プッシュする',
      ].join('\n');
    }

    instructionButton?.addEventListener('click', async () => {
      if (!instruction || !instructionResult || !instructionButton) return;
      const text = instruction.value.trim();
      if (!text) {
        instructionResult.textContent = 'AIに依頼したい内容を入力してください。';
        return;
      }
      const category = instructionCategory?.value || 'operations';
      const priority = instructionPriority?.value || 'medium';
      const prompt = buildCodexPrompt(text, category);

      instructionButton.disabled = true;
      instructionResult.textContent = '不足キューへ登録しています...';
      try {
        const res = await fetch('/api/admin/knowledge-gaps', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'create',
            question: `ナレッジ追加・編集依頼: ${text}`,
            suggested_category: category,
            priority,
            source: 'knowledge_instruction',
            answer_excerpt: prompt,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || data.error) throw new Error(data.error || `HTTP ${res.status}`);
        instructionResult.textContent = `${data.duplicate ? '既に不足キューに登録済みです。' : '不足キューへ登録しました。'}\n\n${prompt}`;
      } catch (error) {
        instructionResult.textContent = `${error instanceof Error ? error.message : '登録に失敗しました。'}\n\n${prompt}`;
      } finally {
        instructionButton.disabled = false;
      }
    });

    const rows = Array.from(document.querySelectorAll('.knowledge-row'));
    const search = document.getElementById('knowledge-search');
    const categoryFilter = document.getElementById('knowledge-category-filter');
    const maturityFilter = document.getElementById('knowledge-maturity-filter');
    const visibleCount = document.getElementById('visible-count');

    function applyFilters() {
      const q = (search?.value || '').trim().toLowerCase();
      const category = categoryFilter?.value || 'all';
      const maturity = maturityFilter?.value || 'all';
      let count = 0;
      rows.forEach((row) => {
        const ok = (!q || (row.dataset.search || '').includes(q))
          && (category === 'all' || row.dataset.category === category)
          && (maturity === 'all' || row.dataset.maturity === maturity);
        row.hidden = !ok;
        if (ok) count++;
      });
      if (visibleCount) visibleCount.textContent = String(count);
    }

    search?.addEventListener('input', applyFilters);
    categoryFilter?.addEventListener('change', applyFilters);
    maturityFilter?.addEventListener('change', applyFilters);
    rows.forEach((row) => {
      row.addEventListener('click', (event) => {
        if (event.target.closest('a, button, input, select')) return;
        if (row.dataset.href) window.location.href = row.dataset.href;
      });
      row.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        if (!row.dataset.href || event.target.closest('a, button, input, select')) return;
        event.preventDefault();
        window.location.href = row.dataset.href;
      });
    });
    applyFilters();
  })();
</script>

<style>
  .hero-panel,
  .panel,
  .list-view-shell {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
  }

  .hero-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 150px;
    gap: 18px;
    align-items: center;
    padding: 22px 24px;
    margin-bottom: 18px;
  }

  .hero-panel span,
  .panel-head span,
  .object-label {
    color: var(--admin-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-panel h2,
  .panel-head h3,
  .list-view-header h2 {
    color: #fff;
    letter-spacing: 0;
  }

  .hero-panel h2 {
    margin: 8px 0;
    font-size: 1.2rem;
  }

  .hero-panel p,
  .list-view-header p,
  .ask-actions small,
  .answer-box,
  .prompt-box,
  .source-row p,
  .source-row small,
  .source-row em,
  .post-card p,
  .post-card small,
  .list-view-meta {
    color: var(--admin-muted);
    font-size: 0.82rem;
  }

  .hero-panel strong {
    display: grid;
    place-items: center;
    min-height: 110px;
    border-radius: 8px;
    background: var(--admin-surface-2);
    color: #fff;
    font-size: 2rem;
  }

  .hero-panel small {
    display: block;
    color: var(--admin-muted);
    font-size: 0.72rem;
  }

  .alert-box {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 18px;
    padding: 12px;
    border: 1px solid rgba(228, 138, 149, 0.36);
    border-radius: 8px;
    background: rgba(228, 138, 149, 0.1);
    color: var(--admin-accent-soft);
    font-size: 0.84rem;
  }

  .panel {
    padding: 18px;
    margin-bottom: 18px;
  }

  .panel-head,
  .list-view-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 14px;
  }

  .panel-head h3 {
    margin: 3px 0 0;
    font-size: 1rem;
  }

  .panel-link,
  .list-view-actions a {
    color: var(--admin-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .ask-grid,
  .instruction-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 230px;
    gap: 14px;
    align-items: end;
  }

  label span {
    display: block;
    margin-bottom: 6px;
    color: var(--admin-muted);
    font-size: 0.76rem;
    font-weight: 800;
  }

  textarea,
  input,
  select {
    width: 100%;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
    color: var(--admin-text);
    font: inherit;
  }

  textarea {
    min-height: 110px;
    padding: 12px;
    resize: vertical;
  }

  input,
  select {
    min-height: 38px;
    padding: 0 10px;
  }

  .ask-actions,
  .instruction-options {
    display: grid;
    gap: 8px;
  }

  button,
  .ghost-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 38px;
    padding: 0 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-primary);
    color: #fff;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 800;
    cursor: pointer;
  }

  button:disabled {
    cursor: wait;
    opacity: 0.68;
  }

  .ghost-btn {
    background: var(--admin-surface-2);
    color: var(--admin-muted);
  }

  .answer-box,
  .prompt-box {
    margin-top: 14px;
    padding: 14px;
    min-height: 92px;
    white-space: pre-wrap;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .list-view-shell {
    margin-bottom: 18px;
    overflow: hidden;
  }

  .list-view-header {
    margin: 0;
    padding: 18px 20px 14px;
    border-bottom: 1px solid var(--admin-border);
    background: linear-gradient(180deg, rgba(107, 133, 201, 0.10), transparent);
  }

  .list-view-header h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 5px 0 6px;
    font-size: 1.18rem;
  }

