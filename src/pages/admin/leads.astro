    </div>

    <div class="lane-grid">
      {laneRows.map((lane) => (
        <article class="lane">
          <header>
            <div>
              <strong>{lane.label}</strong>
              <small>{lane.note}</small>
            </div>
            <span>{lane.count}</span>
          </header>
          <div class="lane-body">
            {lane.leads.slice(0, 6).map((lead) => {
              const status = getStatus(lead.status);
              const action = nextActionFor(lead);
              return (
                <a href={`/admin/leads/${lead.id}`} class="lead-mini">
                  <div>
                    <strong>{lead.company_name || '企業名未設定'}</strong>
                    <span>{timeAgo(lead.updated_at || lead.created_at)}</span>
                  </div>
