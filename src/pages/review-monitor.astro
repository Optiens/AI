---
import Layout from '../layouts/Layout.astro';

// モック口コミデータ（カフェ・レストラン業種特化デモ）
type Review = {
  id: string;
  source: 'tabelog' | 'google_map' | 'instagram';
  shop_name: string;
  reviewer: string;
  rating: number;
  title?: string;
  body: string;
  posted_at: string;       // 表示用相対時刻
  iso_at: string;          // 並べ替え用 ISO
  category: 'high' | 'mid' | 'low';
};

const reviews: Review[] = [
  {
    id: 'R-2003',
    source: 'tabelog',
    shop_name: '清里カフェ Verde',
    reviewer: 'k_takano',
    rating: 2,
    title: '料理は美味しいが提供が遅い',
