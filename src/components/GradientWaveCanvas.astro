---
/**
 * 案1: CSSグラデーション波
 * Figmaパレット4色のブラー済みブロブが、ゆっくり移動・拡縮を繰り返す。
 * Three.js / Canvas を使わない純CSSアニメーションで最軽量。
 *
 * 親要素は position: relative; 必須。
 */
interface Props {
  id?: string;
}
const { id = 'gradient-wave' } = Astro.props;
---

<div id={id} class="gradient-wave" aria-hidden="true">
  <span class="blob blob--purple"></span>
  <span class="blob blob--blue"></span>
  <span class="blob blob--green"></span>
  <span class="blob blob--orange"></span>
</div>

<style>
  .gradient-wave {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .blob {
    position: absolute;
    width: 55vmax;
    height: 55vmax;
    max-width: 900px;
    max-height: 900px;
    border-radius: 50%;
    filter: blur(90px);
    will-change: transform, opacity;
    mix-blend-mode: multiply;
  }

  .blob--purple {
    background: radial-gradient(circle, #3D6FA0 0%, rgba(61, 111, 160, 0) 70%);
    top: -25%;
    left: -15%;
    opacity: 0.55;
    animation: drift1 24s ease-in-out infinite alternate;
  }

  .blob--blue {
    background: radial-gradient(circle, #C0C0C0 0%, rgba(192, 192, 192, 0) 70%);
    top: 5%;
    right: -20%;
    opacity: 0.5;
    animation: drift2 28s ease-in-out infinite alternate;
    animation-delay: -7s;
  }

  .blob--green {
    background: radial-gradient(circle, #FFCED0 0%, rgba(255, 206, 208, 0) 70%);
    bottom: -25%;
    left: 25%;
    opacity: 0.45;
    animation: drift3 32s ease-in-out infinite alternate;
    animation-delay: -12s;
  }

  .blob--orange {
    background: radial-gradient(circle, #f24e1e 0%, rgba(242, 78, 30, 0) 70%);
    top: 35%;
    left: 40%;
    opacity: 0.3;
    animation: drift4 36s ease-in-out infinite alternate;
    animation-delay: -18s;
  }

  @keyframes drift1 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(15%, 12%) scale(1.15);
    }
    100% {
      transform: translate(-8%, 18%) scale(0.95);
    }
  }

  @keyframes drift2 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-18%, 10%) scale(0.9);
    }
    100% {
      transform: translate(-10%, 25%) scale(1.1);
    }
  }

  @keyframes drift3 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(20%, -15%) scale(1.08);
    }
    100% {
      transform: translate(-12%, -10%) scale(0.92);
    }
  }

  @keyframes drift4 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-15%, 20%) scale(1.2);
    }
    100% {
      transform: translate(20%, -10%) scale(0.85);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none !important;
    }
  }

  /* 暗い背景の Hero（深紺など）の場合、multiply は逆効果なので screen に切替 */
  /* 必要なら呼び出し側で .gradient-wave--on-dark を追加 */
  .gradient-wave--on-dark .blob {
    mix-blend-mode: screen;
  }
</style>
