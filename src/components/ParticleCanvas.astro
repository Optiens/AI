---
interface Props {
  id?: string;
}
const { id = 'particle-net' } = Astro.props;
---

<canvas id={id} class="particle-canvas" data-particle-canvas></canvas>

<script is:inline define:vars={{ canvasId: id }}>
  (function () {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth < 768;

    const PARTICLE_COUNT = isMobile ? 60 : 90;
    const CONNECT_DIST = isMobile ? 120 : 150;
    const MOUSE_DIST = 180;
    // アテンションイベントの最大同時数
    const MAX_ATTENTIONS = isMobile ? 2 : 3;
    // フレームごとのアテンション発生確率 → 約3〜4秒に1回
    const ATTENTION_SPAWN_RATE = 0.005;
    // ターゲット数（attention map の "head" 数のメタファー）
    const TARGETS_MIN = 4;
    const TARGETS_MAX = 9;
    // 1イベントの寿命（フレーム単位）
    const EVENT_DURATION = 110; // 約1.8秒（60fps）

    let w = 0;
    let h = 0;
    let dpr = 1;
    let particles = [];
    let attentions = [];
    let mouse = { x: -1000, y: -1000 };
    let animId = null;

    // Figma 4色パレット
    const COLORS = [
      'rgba(162, 89, 255, ', // purple
      'rgba(26, 188, 254, ', // blue
      'rgba(10, 207, 131, ', // green
      'rgba(242, 78, 30, ',  // orange
    ];
    const ATTENTION_COLORS = [
      { rgb: '162, 89, 255', hex: '#A259FF' },
      { rgb: '26, 188, 254', hex: '#1ABCFE' },
      { rgb: '10, 207, 131', hex: '#0ACF83' },
      { rgb: '242, 78, 30',  hex: '#F24E1E' },
    ];

    function resize() {
      const rect = canvas.parentElement.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function createParticles() {
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const colorIdx = i % COLORS.length;
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.4 + 0.6,
          colorIdx,
          color: COLORS[colorIdx],
        });
      }
      attentions = [];
    }

    function spawnAttention() {
      if (attentions.length >= MAX_ATTENTIONS) return;
      // ソースをランダムに選ぶ
      const sourceIdx = Math.floor(Math.random() * particles.length);
      const source = particles[sourceIdx];
      // ターゲット候補（ある程度近いノードに限る = 接続範囲の2.5倍まで）
      const candidateRange = CONNECT_DIST * 2.5;
      const candidates = [];
      for (let i = 0; i < particles.length; i++) {
        if (i === sourceIdx) continue;
        const dx = particles[i].x - source.x;
        const dy = particles[i].y - source.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < candidateRange) {
          candidates.push({ idx: i, dist });
        }
      }
      if (candidates.length < TARGETS_MIN) return;
      // ランダムにシャッフルして上位から取り出す
      candidates.sort(() => Math.random() - 0.5);
      const targetCount = TARGETS_MIN + Math.floor(Math.random() * (TARGETS_MAX - TARGETS_MIN + 1));
      const picked = candidates.slice(0, Math.min(targetCount, candidates.length));
      // 各ターゲットの attention weight をランダム生成（0.25〜1.0）→ softmax風に正規化
      const rawWeights = picked.map(() => 0.25 + Math.random() * 0.75);
      const maxWeight = Math.max(...rawWeights);
      const targets = picked.map((p, i) => ({
        idx: p.idx,
        weight: rawWeights[i] / maxWeight, // 0-1正規化
      }));

      const palette = ATTENTION_COLORS[source.colorIdx];
      attentions.push({
        source: sourceIdx,
        targets,
        t: 0,
        rgb: palette.rgb,
        hex: palette.hex,
      });
    }

    const heroEl = canvas.parentElement;
    heroEl.addEventListener('mousemove', function (e) {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    heroEl.addEventListener('mouseleave', function () {
      mouse.x = -1000;
      mouse.y = -1000;
    });

    function draw() {
      ctx.clearRect(0, 0, w, h);

      // ===== 1. ベースの線（粒子間） =====
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONNECT_DIST) {
            const alpha = (1 - dist / CONNECT_DIST) * 0.12;
            ctx.strokeStyle = particles[i].color + alpha + ')';
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }

        // ===== 2. マウスインタラクション =====
        const pp = particles[i];
        const mdx = pp.x - mouse.x;
        const mdy = pp.y - mouse.y;
        const mDist = Math.sqrt(mdx * mdx + mdy * mdy);
        if (mDist < MOUSE_DIST) {
          const mOpacity = (1 - mDist / MOUSE_DIST) * 0.4;
          ctx.beginPath();
          ctx.moveTo(pp.x, pp.y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = pp.color + mOpacity + ')';
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }

      // ===== 3. アテンションイベント =====
      // 新規発生
      if (!reducedMotion && Math.random() < ATTENTION_SPAWN_RATE) {
        spawnAttention();
      }

      // 既存イベント更新+描画
      for (let a = attentions.length - 1; a >= 0; a--) {
        const ev = attentions[a];
        if (!reducedMotion) ev.t += 1 / EVENT_DURATION;
        if (ev.t >= 1) {
          attentions.splice(a, 1);
          continue;
        }
        const source = particles[ev.source];
        if (!source) {
          attentions.splice(a, 1);
          continue;
        }
        // sinカーブで両端フェード
        const intensity = Math.sin(ev.t * Math.PI);

        // ソースから各ターゲットへの線
        for (let k = 0; k < ev.targets.length; k++) {
          const tgt = ev.targets[k];
          const target = particles[tgt.idx];
          if (!target) continue;
          // attention weight が太さ・透明度に比例
          const lineAlpha = 0.15 + tgt.weight * 0.6 * intensity;
          const lineWidth = 0.5 + tgt.weight * 2.2 * intensity;
          ctx.strokeStyle = `rgba(${ev.rgb}, ${lineAlpha})`;
          ctx.lineWidth = lineWidth;
          ctx.beginPath();
          ctx.moveTo(source.x, source.y);
          ctx.lineTo(target.x, target.y);
          ctx.stroke();
          // ターゲット側のグロー（attention weight が高いほど目立つ）
          ctx.save();
          ctx.shadowColor = ev.hex;
          ctx.shadowBlur = 10 * tgt.weight * intensity;
          ctx.fillStyle = `rgba(${ev.rgb}, ${0.7 * tgt.weight * intensity})`;
          ctx.beginPath();
          ctx.arc(target.x, target.y, 2 + tgt.weight * 2, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }

        // ソースノードのグロー（中心ノードを目立たせる）
        ctx.save();
        ctx.shadowColor = ev.hex;
        ctx.shadowBlur = 18 * intensity;
        ctx.fillStyle = `rgba(${ev.rgb}, ${0.9 * intensity})`;
        ctx.beginPath();
        ctx.arc(source.x, source.y, 3.6, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
        // 中心の白色コア
        ctx.fillStyle = `rgba(255, 255, 255, ${0.95 * intensity})`;
        ctx.beginPath();
        ctx.arc(source.x, source.y, 1.4, 0, Math.PI * 2);
        ctx.fill();
      }

      // ===== 4. 粒子本体 =====
      for (let k = 0; k < particles.length; k++) {
        const q = particles[k];
        ctx.beginPath();
        ctx.arc(q.x, q.y, q.r, 0, Math.PI * 2);
        ctx.fillStyle = q.color + '0.55)';
        ctx.fill();
      }

      // ===== 5. 粒子の動き =====
      if (!reducedMotion) {
        for (let m = 0; m < particles.length; m++) {
          const r = particles[m];
          r.x += r.vx;
          r.y += r.vy;
          if (r.x < 0 || r.x > w) r.vx *= -1;
          if (r.y < 0 || r.y > h) r.vy *= -1;
        }
      }

      animId = requestAnimationFrame(draw);
    }

    resize();
    createParticles();
    draw();

    function onResize() {
      resize();
    }
    window.addEventListener('resize', onResize);
  })();
</script>

<style>
  .particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    display: block;
  }
</style>
