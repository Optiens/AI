  // 流入元の自動補助（任意項目の初期値）
  (function() {
    var referrerField = document.getElementById('entry_referrer');
    var leadSource = document.getElementById('lead_source');
    var leadSourceDetail = document.getElementById('lead_source_detail');
    if (referrerField) referrerField.value = document.referrer || '';
    if (!leadSource || leadSource.value) return;

    var params = new URLSearchParams(window.location.search);
    var sourceParam = params.get('lead_source') || params.get('source');
    var detailParam = params.get('lead_source_detail') || params.get('source_detail');
    var allowed = ['url-file-demo', 'public-demo', 'ai-examples', 'role-demo', 'blog', 'search', 'referral', 'business-group', 'other'];
    function setDetail(value) {
      if (leadSourceDetail && value && !leadSourceDetail.value) {
        leadSourceDetail.value = String(value).slice(0, 300);
      }
    }
    if (sourceParam && allowed.indexOf(sourceParam) !== -1) {
      leadSource.value = sourceParam;
      setDetail(detailParam);
      return;
    }

    var ref = document.referrer || '';
    var demoPaths = ['/data-search', '/document-editor', '/document-review', '/approval-workflow', '/inquiry-routing', '/quote-generator', '/review-monitor', '/custom-management'];
    try {
      var refUrl = ref ? new URL(ref) : null;
      var path = refUrl ? refUrl.pathname : '';
      if (path.indexOf('/role-demo/') === 0) {
        leadSource.value = 'role-demo';
        setDetail(path.replace('/role-demo/', 'ロール別デモ: '));
      } else if (path.indexOf('/ai-examples') === 0) {
        leadSource.value = 'ai-examples';
        setDetail('AI活用サンプル一覧');
      } else if (path.indexOf('/service/sample-') === 0) {
        leadSource.value = 'ai-examples';
        setDetail('業種別サンプル: ' + path.replace('/service/sample-', ''));
      } else if (path.indexOf('/blog/') === 0) {
        leadSource.value = 'blog';
        setDetail('ブログ: ' + path.replace('/blog/', '').replace(/\/$/, ''));
      } else if (demoPaths.some(function(p) { return path.indexOf(p) === 0; })) {
        leadSource.value = 'public-demo';
        setDetail('公開デモ: ' + path.replace('/', ''));
      } else if (/google\.|bing\.|yahoo\./i.test(ref)) {
        leadSource.value = 'search';
      }
    } catch (_) {
      if (ref.indexOf('/role-demo/') !== -1) leadSource.value = 'role-demo';
      else if (ref.indexOf('/ai-examples') !== -1) leadSource.value = 'ai-examples';
      else if (ref.indexOf('/blog/') !== -1) leadSource.value = 'blog';
      else if (/google\.|bing\.|yahoo\./i.test(ref)) leadSource.value = 'search';
    }
  })();

