---
---
<header class="main-header">
  <a href="/" class="header-logo-link">
    <video autoplay muted playsinline loop class="header-logo">
      <source src="/videos/optiens-logo-wave.webm" type="video/webm" />
      <source src="/videos/optiens-logo-wave.mp4" type="video/mp4" />
    </video>
  </a>

  <nav class="desktop-nav">
    <ul>
      <li><a href="/service">サービス</a></li>
      <li><a href="/ai-examples">活用事例</a></li>
      <li class="has-dropdown">
        <span class="nav-trigger nav-trigger--label">私たちについて <span class="nav-caret" aria-hidden="true">▾</span></span>
        <ul class="nav-dropdown">
          <li><a href="/message">メッセージ</a></li>
          <li><a href="/company-profile">会社概要</a></li>
        </ul>
      </li>
      <li><a href="/blog">ブログ</a></li>
      <li><a href="/contact">お問い合わせ</a></li>
    </ul>
  </nav>

  <button id="menu-toggle" class="menu-button" aria-label="メニューを開く">
    <span></span><span></span><span></span>
  </button>

  <nav id="sidebar-menu" class="sidebar-menu" aria-label="モバイルメニュー">
    <ul>
      <li><a href="/service">サービス</a></li>
      <li><a href="/ai-examples">活用事例</a></li>
      <li class="mobile-group">
        <p class="mobile-group-label">私たちについて</p>
        <ul class="mobile-sub">
          <li><a href="/message">メッセージ</a></li>
          <li><a href="/company-profile">会社概要</a></li>
        </ul>
      </li>
      <li><a href="/blog">ブログ</a></li>
      <li><a href="/contact">お問い合わせ</a></li>
    </ul>
  </nav>
</header>

<script is:inline>
  const menuToggle  = document.getElementById('menu-toggle');
  const sidebarMenu = document.getElementById('sidebar-menu');

  if (menuToggle && sidebarMenu) {
    menuToggle.addEventListener('click', () => {
      sidebarMenu.classList.toggle('is-open');
      menuToggle.classList.toggle('is-active');
    });

    sidebarMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        sidebarMenu.classList.remove('is-open');
        menuToggle.classList.remove('is-active');
      });
    });
  }
</script>

<style>
.main-header {
  width: 100%;
  background: rgba(255, 255, 255, .88);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  color: #0f172a;
  padding: 14px 40px;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9900;
  border-bottom: 1px solid rgba(15, 23, 42, .06);
  box-shadow: 0 1px 4px rgba(15, 23, 42, .04), 0 4px 12px rgba(15, 23, 42, .03);
}
.header-logo {
  height: 44px;
  max-width: none;
  display: block;
  /* webm版は alpha チャンネル付き（chromakey で白を透明化済） */
}

@media (min-width: 769px) {
  .main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .header-logo-link {
    display: block;
    flex-shrink: 0;
  }
  .desktop-nav {
    margin-left: auto;
  }
  .desktop-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 36px;
  }
  .desktop-nav a {
    color: #475569;
    text-decoration: none;
    font-size: .88rem;
    font-weight: 500;
    letter-spacing: .02em;
    transition: color .2s ease;
  }
  .desktop-nav a:hover {
    color: #0f172a;
  }

  /* Dropdown */
  .desktop-nav .has-dropdown {
    position: relative;
  }
  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .nav-trigger--label {
    color: #475569;
    font-size: .88rem;
    font-weight: 500;
    letter-spacing: .02em;
    cursor: default;
    user-select: none;
    padding: 4px 0;
  }
  .has-dropdown:hover .nav-trigger--label {
    color: #0f172a;
  }
  .nav-caret {
    font-size: .65rem;
    opacity: .6;
    transition: transform .2s ease;
  }
  .has-dropdown:hover .nav-caret {
    transform: rotate(180deg);
  }
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    min-width: 180px;
    padding: 10px 0;
    margin: 12px 0 0;
    background: rgba(255, 255, 255, .98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(15, 23, 42, .08);
    border-radius: 10px;
    box-shadow: 0 12px 32px rgba(15, 23, 42, .1);
    list-style: none;
    display: flex !important;
    flex-direction: column;
    gap: 0 !important;
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease, transform .2s ease;
  }
  .has-dropdown:hover .nav-dropdown,
  .has-dropdown:focus-within .nav-dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nav-dropdown li {
    width: 100%;
  }
  .nav-dropdown a {
    display: block;
    padding: 10px 18px;
    font-size: .85rem;
    color: #334155;
    white-space: nowrap;
  }
  .nav-dropdown a:hover {
    background: rgba(14, 42, 71, .08);
    color: var(--brand);
  }

  .menu-button, .sidebar-menu { display: none; }
}

@media (max-width: 768px) {
  .main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
  }
  .header-logo-link { position: static; display: block; }
  .header-logo { height: 36px; }

  .menu-button {
    position: static;
    z-index: 10001;
    width: 32px;
    height: 24px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    padding: 0;
  }
  .menu-button span {
    display: block;
    width: 100%;
    height: 2px;
    background: #0f172a;
    transition: all .3s ease-in-out;
    border-radius: 2px;
  }
  .menu-button.is-active span:nth-child(1) { transform: translateY(11px) rotate(45deg); }
  .menu-button.is-active span:nth-child(2) { opacity: 0; }
  .menu-button.is-active span:nth-child(3) { transform: translateY(-11px) rotate(-45deg); }

  .sidebar-menu {
    position: fixed;
    top: 0;
    right: -280px;
    width: 280px;
    height: 100vh;
    background: rgba(255, 255, 255, .98);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    color: #0f172a;
    transition: right .3s ease-out;
    z-index: 10000;
    padding-top: 80px;
    border-left: 1px solid rgba(15, 23, 42, .08);
    box-shadow: -8px 0 24px rgba(15, 23, 42, .08);
    overflow-y: auto;
  }
  .sidebar-menu.is-open { right: 0; }

  .sidebar-menu ul { list-style: none; padding: 0; margin: 0; }
  .sidebar-menu li { border-bottom: 1px solid rgba(15, 23, 42, .06); }
  .sidebar-menu a {
    display: block;
    padding: 16px 24px;
    color: #334155;
    font-size: .98rem;
    font-weight: 500;
    letter-spacing: .02em;
    text-decoration: none;
    transition: background-color .2s ease, color .2s ease;
  }
  .sidebar-menu a:hover,
  .sidebar-menu a:active {
    background-color: rgba(14, 42, 71, .08);
    color: var(--brand);
  }

  /* Mobile dropdown group */
  .mobile-group-label {
    display: block;
    padding: 16px 24px 6px;
    font-size: .78rem;
    font-weight: 700;
    color: #94a3b8;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin: 0;
  }
  .mobile-sub {
    list-style: none;
    padding: 0 0 8px;
    margin: 0;
  }
  .mobile-sub li {
    border-bottom: none;
  }
  .mobile-sub a {
    padding-left: 36px;
    font-size: .92rem;
  }

  .desktop-nav { display: none; }
}

/* Progress bar / line fix */
#nprogress, #nprogress .bar,
.pace, .pace .pace-progress,
.top-loader, .top-progress, .router-progress-bar,
progress[role="progressbar"] { display: none !important; }

.main-header::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 2px;
  background: rgba(255, 255, 255, .88);
  pointer-events: none;
  z-index: 9800;
}
.main-header, .main-header::before {
  transform: translateZ(0);
  -webkit-font-smoothing: antialiased;
}
</style>
