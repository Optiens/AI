---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Optiensについて | AIエージェント業務自動化・全国オンライン対応"
  description="合同会社Optiens（オプティエンス）の会社情報。AIを業務の中心に置き、人間にしかできない判断と創造に集中する仕組みづくりを、全国の中小企業・小規模事業者へ届けます。"
  canonical="https://optiens.com/about"
>
  <main>
    <!-- ===== Header（ABOUT専用） ===== -->
    <section class="about-page-header">
      <div class="container" style="position:relative; z-index:1;">
        <h1 class="about-page-title">Optiensについて</h1>
        <p class="about-page-sub">
          AIを業務の中心に置き、人間にしか出来ない判断と創造に集中する。<br class="pc-only" />
          その仕組みづくりを支援します。
        </p>
      </div>
    </section>

    <!-- ===== Content ===== -->
    <section class="about-content-section"><div class="container">

        <!-- 事業内容 -->
        <section class="about-section about-businesses reveal">
          <h2 class="section-heading">事業内容</h2>
          <article class="business-feature">
            <div class="business-feature-img">
              <img src="/images/businesses/ai-consulting.png" alt="AI支援事業を表すイラスト" loading="lazy" />
            </div>
            <div class="business-feature-body">
              <h3 class="business-feature-title">AI支援事業</h3>
              <blockquote class="business-feature-philosophy">
                AIを<em>中心に</em>、働き方を変える時代へ。
              </blockquote>
              <p class="business-feature-desc">
                中小企業・小規模事業者のAI活用を、無料診断から導入・保守まで一貫して伴走します。エンタープライズ大規模CRM経験10年超を、御社の規模に最適化。これからAIに触れる方も、すでに活用されている方も、御社のペースで進められます。
              </p>
              <a href="/service" class="business-feature-link">サービス詳細を見る <span aria-hidden="true">→</span></a>
            </div>
          </article>
        </section>

        <!-- もっと知る: メッセージ・会社概要 -->
        <section class="about-section about-more reveal">
          <h2 class="section-heading">もっと知る</h2>
          <div class="more-grid">
            <a href="/message" class="more-card">
              <p class="more-eyebrow">MESSAGE</p>
              <h3>メッセージ</h3>
              <p class="more-desc">ミッション・ビジョン・代表メッセージ。私たちが大切にしている2つの考え方（最適化と円相）。</p>
              <span class="more-link">詳しく見る <span aria-hidden="true">→</span></span>
            </a>
            <a href="/company-profile" class="more-card">
              <p class="more-eyebrow">COMPANY</p>
              <h3>会社概要</h3>
              <p class="more-desc">商号・所在地・代表社員・法人番号など、合同会社Optiensの基本情報。</p>
              <span class="more-link">詳しく見る <span aria-hidden="true">→</span></span>
            </a>
          </div>
        </section>

      </div>
    </section>
  </main>
</Layout>

<script is:inline>
(function() {
  const canvas = document.getElementById('hero-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let w, h, particles, mouse;
  const PARTICLE_COUNT = 80;
  const CONNECT_DIST = 140;
  const MOUSE_DIST = 180;

  // Modern Vibrant パレット（Figma 4色：紫・青・緑・オレンジ）
  const COLORS = [
    { r: 162, g: 89,  b: 255 },  // #A259FF Figma purple（メイン）
    { r: 26,  g: 188, b: 254 },  // #1ABCFE Figma blue
    { r: 10,  g: 207, b: 131 },  // #0ACF83 Figma green
    { r: 242, g: 78,  b: 30 },   // #F24E1E Figma orange/red
  ];

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = rect.width;
    h = rect.height;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function createParticles() {
    particles = [];
    const count = Math.min(PARTICLE_COUNT, Math.floor((w * h) / 8000));
    for (let i = 0; i < count; i++) {
      const c = COLORS[Math.floor(Math.random() * COLORS.length)];
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 1.8 + 0.8,
        color: c,
        alpha: Math.random() * 0.5 + 0.3,
      });
    }
  }

  mouse = { x: -1000, y: -1000 };
  canvas.addEventListener('mousemove', function(e) {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });
  canvas.addEventListener('mouseleave', function() {
    mouse.x = -1000;
    mouse.y = -1000;
  });

  function draw() {
    ctx.clearRect(0, 0, w, h);

    // Update & draw particles
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      p.x += p.vx;
      p.y += p.vy;

      // Wrap around edges
      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;
      if (p.y < -10) p.y = h + 10;
      if (p.y > h + 10) p.y = -10;

      // Draw particle
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + p.color.r + ',' + p.color.g + ',' + p.color.b + ',' + p.alpha + ')';
      ctx.fill();

      // Connect to nearby particles
      for (let j = i + 1; j < particles.length; j++) {
        const q = particles[j];
        const dx = p.x - q.x;
        const dy = p.y - q.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          const opacity = (1 - dist / CONNECT_DIST) * 0.15;
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = 'rgba(' + p.color.r + ',' + p.color.g + ',' + p.color.b + ',' + opacity + ')';
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }

      // Mouse interaction — glow nearby lines
      const mdx = p.x - mouse.x;
      const mdy = p.y - mouse.y;
      const mDist = Math.sqrt(mdx * mdx + mdy * mdy);
      if (mDist < MOUSE_DIST) {
        const opacity = (1 - mDist / MOUSE_DIST) * 0.4;
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(mouse.x, mouse.y);
        // マウスへの線は各パーティクルの色に追従（Figmaカラー）
        ctx.strokeStyle = 'rgba(' + p.color.r + ',' + p.color.g + ',' + p.color.b + ',' + opacity + ')';
        ctx.lineWidth = 0.8;
        ctx.stroke();
      }
    }

    if (!prefersReducedMotion) {
      requestAnimationFrame(draw);
    }
  }

  resize();
  createParticles();
  if (prefersReducedMotion) {
    draw(); // single frame
  } else {
    draw();
  }

  let resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      resize();
      createParticles();
    }, 200);
  });
})();
</script>

<style>
/* =========================================================
   ABOUT専用ヘッダ（HOMEと同じ100vh + パーティクル）
   ========================================================= */
.about-page-header{
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(90px, 11vw, 140px) 20px;
  background: #ffffff;
  color: #334155;
  text-align: center;
}
.about-page-header > .container{
  max-width: 800px;
}
.about-page-eyebrow{
  font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
  font-size: 12px;
  letter-spacing: .35em;
  font-weight: 700;
  color: #A259FF;
  margin: 0 0 14px;
}
.about-page-title{
  font-size: clamp(28px, 4.4vw, 48px);
  font-weight: 800;
  letter-spacing: -.01em;
  color: #0f172a;
  margin: 0 0 20px;
  line-height: 1.25;
}
.about-page-sub{
  font-size: clamp(14px, 1.6vw, 16px);
  color: #64748b;
  line-height: 1.95;
  margin: 0 auto;
  max-width: 640px;
}
.about-page-header .pc-only { display: inline; }
@media (max-width: 768px){
  .about-page-header .pc-only { display: none; }
}

/* =========================================================
   About 上部のパーティクルヒーロー（旧・現在は未使用）
   ========================================================= */
.about-hero-section{
  position: relative;
  overflow: hidden;
  padding: clamp(100px, 14vw, 160px) 0 clamp(56px, 8vw, 80px);
  background: var(--surface);
  color: var(--text);
}
#hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.about-hero-section .hero-content{
  position:relative;
  z-index:2;
  width: min(900px, 100% - 6rem);
  margin-inline: auto;
  padding: 20px;
}
.about-hero-section .hero-text-block{
  width: fit-content;
  margin: 0 auto;
}
.about-hero-section .hero-eyebrow{
  display: block;
  margin: 0 0 1rem;
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--brand);
  font-weight: 500;
  text-align: left;
}
.about-hero-section .hero-title{
  font-size: clamp(30px, 5vw, 60px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -.02em;
  color: var(--heading);
  margin: 0 0 1rem;
  text-align: left;
}
.about-hero-section .hero-sub{
  font-size: clamp(15px, 2vw, 18px);
  color: var(--muted);
  margin: 0;
  font-weight: 600;
  text-align: right;
}
.sp-only{ display: none; }
@media (max-width: 640px){
  .sp-only{ display: inline; }
}

/* =========================================================
   About 本文 — ライト基調へ転換（ヒーローのダークと対比させる）
   ローカルでCSS変数をオーバーライドし、配下のすべての要素を
   ライトテーマに変換する
   ========================================================= */
.about-content-section{
  /* ライトテーマ変数オーバーライド */
  --surface: #ffffff;
  --surface-2: #f8fafc;
  --surface-card: #ffffff;
  --surface-3: #f1f5f9;
  --heading: #0f172a;
  --text: #334155;
  --muted: #64748b;
  --border: #e2e8f0;
  --border-hover: #cbd5e1;
  --glow: 0 4px 24px rgba(91, 127, 255, 0.08);

  padding: clamp(64px, 10vw, 120px) 20px clamp(80px, 12vw, 140px);
  background: var(--surface);
  color: var(--text);
  line-height: 1.8;
}
.about-content-section .container{ width: min(1000px, 100% - 2rem); margin-inline: auto; }

/* =========================================================
   セクション共通（余白・見出し）
   ========================================================= */
.about-section{
  margin-bottom: clamp(80px, 12vw, 140px);
}
.about-section:last-of-type{
  margin-bottom: 0;
}
.section-eyebrow{
  font-size: clamp(10px, 1vw, 12px);
  letter-spacing: .35em;
  font-weight: 500;
  color: var(--brand);
  margin: 0 0 12px;
  text-transform: uppercase;
}

/* もっと知るカード */
.about-more {
  margin-top: clamp(40px, 5vw, 60px);
}
.more-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
  max-width: 880px;
  margin: 0 auto;
}
.more-card {
  display: block;
  padding: clamp(24px, 3vw, 32px);
  background: linear-gradient(180deg, #fff 0%, rgba(91, 127, 255, 0.02) 100%);
  border: 1px solid var(--border);
  border-radius: 14px;
  text-decoration: none;
  color: inherit;
  transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
}
.more-card:hover {
  transform: translateY(-2px);
  border-color: rgba(162, 89, 255, 0.35);
  box-shadow: 0 12px 32px rgba(162, 89, 255, 0.08);
}
.more-eyebrow {
  font-family: 'SF Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.25em;
  font-weight: 700;
  color: var(--brand);
  margin: 0 0 10px;
  text-transform: uppercase;
}
.more-card h3 {
  font-size: clamp(1.1rem, 1.8vw, 1.3rem);
  font-weight: 700;
  color: var(--heading);
  margin: 0 0 12px;
}
.more-desc {
  color: var(--muted);
  line-height: 1.85;
  font-size: 0.92rem;
  margin: 0 0 18px;
}
.more-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--brand);
  font-weight: 700;
  font-size: 0.88rem;
  letter-spacing: 0.04em;
}

.section-heading{
  font-size: clamp(24px, 3.4vw, 34px);
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -.01em;
  color: var(--heading);
  margin: 0 0 clamp(28px, 4vw, 48px);
}
.section-lead{
  font-size: clamp(15px, 1.8vw, 17px);
  line-height: 1.9;
  color: var(--text);
  margin: clamp(-12px, -1vw, -8px) 0 clamp(28px, 4vw, 40px);
  max-width: 720px;
}
/* ===== Why AI section ===== */
.about-why-ai .why-ai-eyebrow{
  text-align: center;
  color: var(--brand);
  font-size: clamp(11px, 1.2vw, 13px);
  font-weight: 600;
  letter-spacing: .3em;
  text-transform: uppercase;
  margin: 0 0 12px;
}
.about-why-ai .section-heading{
  text-align: center;
}
.about-why-ai .why-ai-reasons{
  display: flex;
  flex-direction: column;
  gap: clamp(20px, 3vw, 28px);
  max-width: 800px;
  margin: 0 auto;
}
.about-why-ai .why-ai-reason{
  display: flex;
  gap: clamp(16px, 2.5vw, 24px);
  align-items: flex-start;
  padding: clamp(20px, 3vw, 28px);
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}
.about-why-ai .why-ai-num{
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 800;
  color: var(--brand);
  letter-spacing: -.02em;
  line-height: 1;
  flex-shrink: 0;
  font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
}
.about-why-ai .why-ai-content h3{
  font-size: clamp(1rem, 1.6vw, 1.15rem);
  font-weight: 700;
  color: var(--heading);
  margin: 0 0 8px;
  line-height: 1.5;
}
.about-why-ai .why-ai-content p{
  font-size: clamp(.88rem, 1.3vw, .95rem);
  color: var(--muted);
  line-height: 1.85;
  margin: 0;
}
.about-why-ai .why-ai-conclusion{
  max-width: 720px;
  margin: clamp(40px, 6vw, 64px) auto 0;
  text-align: center;
}
.about-why-ai .why-ai-bridge{
  color: var(--muted);
  font-size: 0.95rem;
  margin: 0 0 16px;
  letter-spacing: .03em;
}
.about-why-ai .why-ai-quote{
  font-size: clamp(1.1rem, 2.2vw, 1.5rem);
  font-weight: 700;
  line-height: 1.7;
  color: var(--heading);
  margin: 0 auto clamp(24px, 3.5vw, 32px);
  padding: clamp(16px, 2vw, 24px) clamp(20px, 3vw, 32px);
  border-left: 3px solid var(--brand);
  text-align: left;
  max-width: fit-content;
}
.about-why-ai .why-ai-cta{
  color: var(--text);
  font-size: clamp(.95rem, 1.5vw, 1.05rem);
  line-height: 1.85;
  margin: 0;
}
.about-why-ai .pc-only { display: inline; }
@media (max-width: 768px) {
  .about-why-ai .pc-only { display: none; }
}

.section-lead strong{
  color: var(--brand);
  font-weight: 700;
}

/* =========================================================
   ミニ・ヒーロー（カード）
   ========================================================= */
.about-content-section .hero-container--inline{
  position: relative;
  container-type: inline-size;
  --pad-x: clamp(24px, 4vw, 40px);
  padding: var(--pad-x);
  margin-bottom: 48px;
  background: var(--surface-3);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text); text-shadow: none;
  --inner-w: calc(100% - (var(--pad-x) * 2));
  --col-w: min(56rem, var(--inner-w));
}
.about-content-section .hero-container--inline::before{ display:none; }
.about-content-section .hero-container--inline .hero-block{ display:grid; gap:.75rem; box-sizing:border-box; }
.about-content-section .hero-container--inline .hero-title{ width: var(--col-w); max-width: 100%; margin-inline: auto; }
.about-content-section .hero-container--inline .eyebrow{
  margin:0 0 .75rem; text-align:left; font-size: clamp(11px, 1vw, 13px);
  letter-spacing:.18em; text-transform:uppercase; color: var(--brand); opacity:.95;
}
.about-content-section .hero-container--inline .hero-lead{ margin:0 0 1em; line-height:1.2; letter-spacing:.02em; color: var(--heading); }
.about-content-section .hero-container--inline .hero-lead--xl{ text-align:left; font-size: clamp(28px, 3.6vw, 44px); text-wrap: balance; }
.about-content-section .hero-container--inline .hero-lead--sm{
  width: var(--col-w); max-width: 100%; margin-inline: auto;
  text-align: right; font-size: clamp(14px, 1.8vw, 18px);
  color: var(--muted); font-weight:600;
}
@media (max-width: 640px){
  .about-content-section .hero-container--inline{ --col-w: calc(100% - (var(--pad-x) * 2)); }
  .about-content-section .hero-container--inline .hero-lead--xl{ font-size: clamp(18px, 5.2vw, 26px); }
  .about-content-section .hero-container--inline .hero-lead--sm{
    width: var(--col-w); margin-inline:auto;
    text-align: left;
    white-space: nowrap;
    font-size: min(16px, calc((100cqw - (var(--pad-x) * 2) - 36px) / 22));
    line-height: 1.35; letter-spacing: 0;
  }
}
@supports not (width: 1cqw){
  @media (max-width: 640px){
    .about-content-section .hero-container--inline .hero-lead--sm{
      font-size: clamp(12px, 3.6vw, 16px);
      white-space: nowrap;
    }
  }
}

/* =========================================================
   Name Roots（最適化 × 円相）
   ========================================================= */
.roots-grid{
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
.root-card{
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: clamp(28px, 4vw, 44px);
  text-align: center;
  transition: border-color .3s, box-shadow .3s, transform .3s;
}
.root-card:hover{
  border-color: var(--border-hover);
  box-shadow: var(--glow);
  transform: translateY(-2px);
}
.root-visual{
  width: clamp(140px, 22vw, 200px);
  height: clamp(140px, 22vw, 200px);
  margin: 0 auto 24px;
}
.root-visual svg{
  width: 100%;
  height: 100%;
  display: block;
}
.root-eng{
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .35em;
  text-transform: uppercase;
  font-weight: 500;
  color: var(--brand);
  margin: 0 0 8px;
}
.root-jp{
  font-size: clamp(20px, 2.6vw, 28px);
  font-weight: 800;
  color: var(--heading);
  margin: 0 0 16px;
  letter-spacing: .04em;
}
.root-desc{
  font-size: .92rem;
  line-height: 1.85;
  color: var(--muted);
  margin: 0;
  max-width: 380px;
  margin-inline: auto;
}
@media (max-width: 720px){
  .roots-grid{
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}

/* =========================================================
   About Values（調和・最適化・循環）
   ========================================================= */
.values-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
.value-card {
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2rem 1.5rem;
  text-align: center;
  transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
}
.value-card:hover {
  border-color: var(--border-hover);
  box-shadow: var(--glow);
  transform: translateY(-2px);
}
.value-img-wrap {
  width: 100%;
  max-width: 180px;
  aspect-ratio: 1;
  margin: 0 auto 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform .35s ease;
}
.value-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}
.value-card:hover .value-img-wrap {
  transform: scale(1.04);
}
.value-card h3 {
  font-size: 1.1rem;
  color: var(--heading);
  margin: 0 0 0.7rem;
  font-weight: 700;
  letter-spacing: 0.05em;
}
.value-card p {
  font-size: 0.9rem;
  color: var(--muted);
  line-height: 1.75;
  margin: 0;
}
@media (max-width: 768px) {
  .values-grid {
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
