---
import Layout from '../../layouts/Layout.astro';

type Scenario = {
  id: string;
  label: string;
  title: string;
  summary: string;
  items: string[];
  output: { label: string; value: string }[];
  humanCheck: string;
};

type RoleDemo = {
  role: string;
  tag: string;
  icon: string;
  title: string;
  description: string;
  persona: string;
  primaryMetric: string;
  backHash: string;
  scenarios: Scenario[];
};

export const roleDemos: Record<string, RoleDemo> = {
  executive: {
    role: '経営者・代表者',
    tag: 'FOR EXECUTIVES',
    icon: 'fa-user-tie',
    title: '経営者向けAIブリーフィング',
    description: '朝の短時間で、売上見込、未対応リスク、承認待ち、AI自動化の稼働状況を確認するデモです。',
    persona: '代表者・事業責任者',
    primaryMetric: '事業状況把握 5時間 → 30分',
    backHash: 'role-executive',
    scenarios: [
      {
        id: 'morning',
        label: '朝の確認',
        title: '本日見るべき経営情報',
