---
interface Props {
  id?: string;
}
const { id = 'particle-net' } = Astro.props;
---

<canvas id={id} class="particle-canvas" data-particle-canvas></canvas>

<script is:inline define:vars={{ canvasId: id }}>
  (function () {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth < 768;

    const PARTICLE_COUNT = isMobile ? 60 : 90;
    const CONNECT_DIST = isMobile ? 120 : 150;
    const MOUSE_DIST = 180;
    // パルス（シナプス発火）の最大同時数
    const MAX_PULSES = isMobile ? 6 : 12;
    // 1フレームあたりの新規パルス発生確率
    const PULSE_SPAWN_RATE = 0.06;

    let w = 0;
    let h = 0;
    let dpr = 1;
    let particles = [];
    let pulses = [];
    let connections = [];
    let mouse = { x: -1000, y: -1000 };
    let animId = null;

    // Figma 4色パレット
    const COLORS = [
      'rgba(162, 89, 255, ', // purple
      'rgba(26, 188, 254, ', // blue
      'rgba(10, 207, 131, ', // green
      'rgba(242, 78, 30, ',  // orange
    ];
    // パルス用の発光色（より鮮やか）
    const PULSE_COLORS = [
      '#C68DFF', // bright purple
      '#5DD0FF', // bright blue
      '#5EE0AA', // bright green
      '#FF8B5E', // bright orange
    ];

    function resize() {
      const rect = canvas.parentElement.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function createParticles() {
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const colorIdx = i % COLORS.length;
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.4 + 0.6,
          colorIdx,
          color: COLORS[colorIdx],
          pulseColor: PULSE_COLORS[colorIdx],
        });
      }
      pulses = [];
    }

    function spawnPulse() {
      if (pulses.length >= MAX_PULSES) return;
      if (connections.length === 0) return;
      const conn = connections[Math.floor(Math.random() * connections.length)];
      const speedBase = 0.012 + Math.random() * 0.018;
      pulses.push({
        i: conn.i,
        j: conn.j,
        t: 0,
        speed: speedBase,
        color: particles[conn.i].pulseColor,
      });
    }

    const heroEl = canvas.parentElement;
    heroEl.addEventListener('mousemove', function (e) {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    heroEl.addEventListener('mouseleave', function () {
      mouse.x = -1000;
      mouse.y = -1000;
    });

    function draw() {
      ctx.clearRect(0, 0, w, h);

      // 接続情報を毎フレーム再構築（パルス先選びに使う）
      connections = [];

      // ===== 1. ベースの線（粒子間） =====
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONNECT_DIST) {
            const alpha = (1 - dist / CONNECT_DIST) * 0.13;
            ctx.strokeStyle = particles[i].color + alpha + ')';
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
            connections.push({ i, j });
          }
        }

        // ===== 2. マウスインタラクション =====
        const pp = particles[i];
        const mdx = pp.x - mouse.x;
        const mdy = pp.y - mouse.y;
        const mDist = Math.sqrt(mdx * mdx + mdy * mdy);
        if (mDist < MOUSE_DIST) {
          const mOpacity = (1 - mDist / MOUSE_DIST) * 0.4;
          ctx.beginPath();
          ctx.moveTo(pp.x, pp.y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = pp.color + mOpacity + ')';
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }

      // ===== 3. シナプス発火パルス =====
      // 新規パルス確率発生
      if (!reducedMotion && Math.random() < PULSE_SPAWN_RATE) {
        spawnPulse();
      }

      // パルス更新 + 描画
      for (let p = pulses.length - 1; p >= 0; p--) {
        const pulse = pulses[p];
        if (!reducedMotion) {
          pulse.t += pulse.speed;
        }
        if (pulse.t >= 1) {
          pulses.splice(p, 1);
          continue;
        }
        const a = particles[pulse.i];
        const b = particles[pulse.j];
        if (!a || !b) {
          pulses.splice(p, 1);
          continue;
        }
        const x = a.x + (b.x - a.x) * pulse.t;
        const y = a.y + (b.y - a.y) * pulse.t;

        // sinカーブで両端フェード（中央で最大輝度）
        const intensity = Math.sin(pulse.t * Math.PI);

        // グロー（外側）
        ctx.save();
        ctx.shadowColor = pulse.color;
        ctx.shadowBlur = 14 * intensity;
        ctx.fillStyle = pulse.color;
        ctx.globalAlpha = 0.85 * intensity;
        ctx.beginPath();
        ctx.arc(x, y, 2.4, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();

        // コア（内側の明るい点）
        ctx.fillStyle = '#FFFFFF';
        ctx.globalAlpha = 0.95 * intensity;
        ctx.beginPath();
        ctx.arc(x, y, 1.1, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      // ===== 4. 粒子本体 =====
      for (let k = 0; k < particles.length; k++) {
        const q = particles[k];
        ctx.beginPath();
        ctx.arc(q.x, q.y, q.r, 0, Math.PI * 2);
        ctx.fillStyle = q.color + '0.55)';
        ctx.fill();
      }

      // ===== 5. 粒子の動き =====
      if (!reducedMotion) {
        for (let m = 0; m < particles.length; m++) {
          const r = particles[m];
          r.x += r.vx;
          r.y += r.vy;
          if (r.x < 0 || r.x > w) r.vx *= -1;
          if (r.y < 0 || r.y > h) r.vy *= -1;
        }
      }

      animId = requestAnimationFrame(draw);
    }

    resize();
    createParticles();
    draw();

    function onResize() {
      resize();
    }
    window.addEventListener('resize', onResize);
  })();
</script>

<style>
  .particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    display: block;
  }
</style>
