      employee_count: '従業員数',
      business_description: '事業内容',
      daily_tasks: '日常業務',
      current_tools: '使用ITツール',
      business_age: '創業・設立',
      service_area: '営業エリア',
      target_customer: '主要顧客層',
      annual_revenue_range: '売上規模感',
      decision_timeline: 'ご検討時期',
      past_it_experience: '過去のIT導入経験',
    };

    var EXTRAS_LABELS = {
