export const prerender = true;

export function getStaticPaths() {
  return Object.entries(roleDemos).map(([role, demo]) => ({
    params: { role },
    props: { demo },
  }));
}

const { demo } = Astro.props as { demo: RoleDemo };
const initialScenario = demo.scenarios[0];
const diagnosisHref = `/free-diagnosis?lead_source=role-demo&lead_source_detail=${encodeURIComponent(demo.title)}`;
---

<Layout
  title={`${demo.title}（デモ） | Optiens`}
  description={`${demo.persona}向けに、AIが業務情報を整理して次の確認ポイントを提示するロール別デモです。`}
  canonical={`https://optiens.com/role-demo/${demo.backHash.replace('role-', '')}`}
>
  <main class="rd-main light-section">
    <section class="rd-hero">
      <div class="container rd-hero-grid">
        <div>
          <p class="rd-eyebrow">{demo.tag}</p>
          <h1>{demo.title}</h1>
          <p class="rd-lede">{demo.description}</p>
          <div class="rd-meta">
            <span><i class="fa-solid fa-user"></i>{demo.persona}</span>
            <span><i class="fa-solid fa-chart-line"></i>{demo.primaryMetric}</span>
          </div>
        </div>
        <div class="rd-hero-card" aria-label="デモの前提">
          <i class={`fa-solid ${demo.icon}`}></i>
          <strong>サンプルデータで動く公開デモ</strong>
          <p>このページ上ではAPI通信や外部送信は発生しません。実案件では、利用するデータと業務リスクに合わせてAPI利用、権限、確認フローを設計します。</p>
        </div>
      </div>
    </section>

    <section class="rd-section">
      <div class="container rd-workbench">
        <aside class="rd-scenarios" aria-label="確認シナリオ">
          <h2>確認シナリオ</h2>
          <div class="rd-scenario-buttons">
            {demo.scenarios.map((scenario, index) => (
              <button class={`rd-scenario-btn ${index === 0 ? 'active' : ''}`} type="button" data-scenario={scenario.id}>
                <span>{scenario.label}</span>
                <i class="fa-solid fa-chevron-right"></i>
              </button>
            ))}
          </div>
        </aside>

        <section class="rd-panel" aria-live="polite">
          <header class="rd-panel-head">
            <span id="scenario-label">{initialScenario.label}</span>
            <h2 id="scenario-title">{initialScenario.title}</h2>
            <p id="scenario-summary">{initialScenario.summary}</p>
          </header>

          <div class="rd-output-grid" id="scenario-output">
            {initialScenario.output.map((item) => (
              <article>
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </article>
            ))}
          </div>

          <div class="rd-controls" aria-label="デモ条件の切り替え">
            <div class="rd-controls-head">
              <h3>条件を切り替えて確認</h3>
              <p>表示優先度、人の確認範囲、参照データを変えたときの見え方を確認できます。切り替えはブラウザ内のサンプル表示だけで動作します。</p>
            </div>
            <div class="rd-control-groups">
              <div class="rd-control-group">
                <span>表示優先度</span>
                <button type="button" class="rd-control-btn active" data-control="priority" data-value="通常" data-description="期限順と影響度順を組み合わせて表示します。">通常</button>
                <button type="button" class="rd-control-btn" data-control="priority" data-value="高" data-description="本日中に判断が必要な項目を上に寄せて表示します。">高</button>
              </div>
              <div class="rd-control-group">
                <span>人の確認</span>
                <button type="button" class="rd-control-btn active" data-control="approval" data-value="下書きまで" data-description="AIは整理と下書きまで行い、送信や承認は人が確認します。">下書きまで</button>
                <button type="button" class="rd-control-btn" data-control="approval" data-value="承認必須" data-description="金額、契約、顧客連絡に関わる項目は承認待ちとして止めます。">承認必須</button>
              </div>
              <div class="rd-control-group">
                <span>参照データ</span>
                <button type="button" class="rd-control-btn active" data-control="scope" data-value="自分の範囲" data-description="自分が担当する案件、承認、問い合わせを中心に表示します。">自分の範囲</button>
                <button type="button" class="rd-control-btn" data-control="scope" data-value="チーム全体" data-description="チーム全体の詰まりや未対応を横断して表示します。">チーム全体</button>
              </div>
            </div>
            <div class="rd-control-summary" aria-live="polite">
              <article>
                <span>表示優先度</span>
                <strong id="control-priority">通常</strong>
                <p id="control-priority-desc">期限順と影響度順を組み合わせて表示します。</p>
              </article>
              <article>
                <span>人の確認</span>
                <strong id="control-approval">下書きまで</strong>
                <p id="control-approval-desc">AIは整理と下書きまで行い、送信や承認は人が確認します。</p>
              </article>
              <article>
                <span>参照データ</span>
                <strong id="control-scope">自分の範囲</strong>
                <p id="control-scope-desc">自分が担当する案件、承認、問い合わせを中心に表示します。</p>
              </article>
            </div>
          </div>

          <div class="rd-item-list">
            <h3>AIが整理した確認項目</h3>
            <ul id="scenario-items">
              {initialScenario.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>

          <div class="rd-human-check">
            <i class="fa-solid fa-user-check"></i>
            <p><strong>人間の確認ポイント</strong><span id="scenario-human">{initialScenario.humanCheck}</span></p>
          </div>
        </section>
      </div>
    </section>

    <section class="rd-section rd-next">
      <div class="container">
        <div class="rd-next-grid">
          <article>
            <h2>実案件で調整すること</h2>
            <ul>
              <li>見るべきデータ元、通知先、承認者、閲覧権限</li>
              <li>AIが自動化してよい範囲と、人が必ず確認する範囲</li>
              <li>既存ツールとの連携方法、API利用の有無、保守方法</li>
            </ul>
          </article>
          <article>
            <h2>次の進め方</h2>
            <p>御社の業務で同じ画面が必要かは、業務量、既存ツール、扱う情報の機密性を見て判断します。無料診断で、どのロールから始めるべきかを整理できます。</p>
            <div class="rd-actions">
              <a href={`/ai-examples?cat=role#${demo.backHash}`} class="btn-secondary">ロール別一覧に戻る</a>
              <a href={diagnosisHref} class="btn-primary">無料診断を受ける</a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline define:vars={{ scenarios: demo.scenarios }}>
(function() {
  const buttons = document.querySelectorAll('.rd-scenario-btn');
  const label = document.getElementById('scenario-label');
  const title = document.getElementById('scenario-title');
  const summary = document.getElementById('scenario-summary');
  const output = document.getElementById('scenario-output');
  const items = document.getElementById('scenario-items');
  const human = document.getElementById('scenario-human');
  const controlButtons = document.querySelectorAll('.rd-control-btn');

  function renderScenario(id) {
    const scenario = scenarios.find((item) => item.id === id) || scenarios[0];
    label.textContent = scenario.label;
    title.textContent = scenario.title;
    summary.textContent = scenario.summary;
    output.innerHTML = scenario.output.map((item) => (
      `<article><span>${item.label}</span><strong>${item.value}</strong></article>`
    )).join('');
    items.innerHTML = scenario.items.map((item) => `<li>${item}</li>`).join('');
    human.textContent = scenario.humanCheck;
    buttons.forEach((button) => button.classList.toggle('active', button.dataset.scenario === scenario.id));
  }

  buttons.forEach((button) => {
    button.addEventListener('click', () => renderScenario(button.dataset.scenario));
  });

  function updateControl(button) {
    const control = button.dataset.control;
    if (!control) return;
    const value = document.getElementById(`control-${control}`);
    const description = document.getElementById(`control-${control}-desc`);
    if (!value || !description) return;
    document.querySelectorAll(`.rd-control-btn[data-control="${control}"]`).forEach((item) => {
      item.classList.toggle('active', item === button);
    });
    value.textContent = button.dataset.value || button.textContent?.trim() || '';
    description.textContent = button.dataset.description || '';
  }

  controlButtons.forEach((button) => {
    button.addEventListener('click', () => updateControl(button));
  });
})();
</script>

