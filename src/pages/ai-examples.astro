// ===== データ定義 =====
type CommonCase = {
  id: string;
  num: string;
  icon: string;
  title: string;
  summary: string;
  desc: string;
  tags: string[];
  self: string;
  implementation: {
    dailyFlow: string;
    requiredData: string;
    humanCheck: string;
    firstBuild: string;
  };
  demo?: { label: string; href: string; note?: string };
};

type Industry = {
  id: string;
  image: string;
  title: string;
  shortTitle: string;
  summary: string;
  metric: string;
  basis: string;
  href: string;
  relatedDemos: { label: string; href: string }[];
  demo?: { label: string; href: string; note?: string };
};

type RoleDemo = {
  id: string;
  tag: string;
  icon: string;
  title: string;
  shortTitle: string;
  summary: string;
  metric: string;
  basis: string;
  href: string;
  cta: string;
  note: string;
};

type NearbyIndustry = {
  title: string;
  summary: string;
  demos: { label: string; href: string }[];
};

