---
import Layout from '../../layouts/Layout.astro';
import precisionCultivationImg from '~/assets/precision-cultivation-model.png';

export const solutionData = {
  title: '【R&D】AI駆動型 水耕栽培キットの提供',
  overview: 'AI駆動型の次世代型栽培キット。光・温度・湿度・CO2などの環境データをAIが制御し、安定した収穫と品質を実現します。',
  image: precisionCultivationImg,
};
---

<Layout title={`${solutionData.title} | Optiens`}>
  <main>
    <section class="solution-detail-container">
      <div class="container">
        <h1 class="solution-title">{solutionData.title}</h1>

        <div class="solution-thumbnail-wrapper">
          <img src={solutionData.image.src} alt={solutionData.title} class="solution-thumbnail" />
        </div>

        <div class="solution-body prose">
          <section>
            <h2>AIによる制御</h2>
            <p>光、温度、湿度、CO2、養液成分など、植物の生育に不可欠な要素をAIがリアルタイムで制御します。成長段階に合わせた最適な環境を自動で構築し、植物のポテンシャルを最大限に引き出します。直感的な操作とAIによるサポートにより、次のアクションに迷いません。</p>
          </section>

          <section>
            <h2>無農薬で安全・安心・美味しい</h2>
            <p>閉鎖空間で栽培するため、虫害の心配がなく、農薬を一切必要としません。また、虫が嫌がる苦み成分が出ないため子供たちの食育に最適です。AIが溶液を監視し、衛生的な環境を保つことが可能です。</p>
          </section>

          <section>
            <h2>設置場所を選ばない汎用性</h2>
            <p>環境に左右されない設計のため、都市部のオフィスビルや学校、さらには地下空間など、あらゆる場所での設置が可能です。食糧生産の場を身近にすることで、フードマイレージの削減にも貢献します。</p>
          </section>

          <section>
            <h2>AIモデルのライセンス供与</h2>
            <p>当社の独自AIモデルの利用権をご提供します。継続的なアップデートにより、常に最新かつ最適な栽培ロジックをご活用いただけます。</p>
          </section>

          <section>
            <h2>導入支援</h2>
            <p>キットの設置から初期設定、運用指導まで、専門スタッフが丁寧にサポートいたします。初めて水耕栽培に取り組むお客様も安心してご利用いただけます。</p>
          </section>
        </div>
      </div>
    </section>
  </main>
</Layout>
