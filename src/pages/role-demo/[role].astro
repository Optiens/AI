    persona: '営業・事務・現場担当者',
    primaryMetric: '定型業務 月20時間削減',
    backHash: 'role-staff',
    scenarios: [
      {
        id: 'today',
        label: '今日の作業',
        title: '優先順位つきタスクリスト',
        summary: 'メール、申請、見積、社内依頼をまとめ、先に処理すべき順に並べます。',
        items: ['本日返信が必要な問い合わせ2件', '見積条件の確認待ち1件', '経費精算の領収書不足1件'],
