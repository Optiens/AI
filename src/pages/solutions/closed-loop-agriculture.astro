---
import Layout from '../../layouts/Layout.astro';
import closedLoopImg from '~/assets/closed-loop-agriculture.png'; // 画像差し替え可

export const solutionData = {
  title: '【R&D】宇宙対応クローズドループ栽培（Dual-Use）',
  overview:
    '衛生・冗長・自律・省資源の宇宙要件を満たす閉鎖循環型モジュール。地上でも同仕様で“閉鎖空間の食料自給”を実証できます。',
  image: closedLoopImg,
};
---

<Layout title={`${solutionData.title} | Optiens`}>
  <main>
    <section class="solution-detail-container">
      <div class="container">
        <h1 class="solution-title">{solutionData.title}</h1>

        <div class="solution-thumbnail-wrapper">
          <img src={solutionData.image.src} alt={solutionData.title} class="solution-thumbnail" />
        </div>

        <div class="solution-body prose">
          <section>
            <h2>クローズドループ設計（衛生・洗浄性・交換性）</h2>
            <p>
              密閉系の給排液・空調・照明を統合し、バイオバリアと洗浄性（CIP/SIP想定）を重視。
              ユニット交換・モジュール化により、汚染時もダウンタイムを最小化します。
            </p>
          </section>

          <section>
            <h2>AI制御 × 遠隔運用SaaS</h2>
            <p>
              光・温度・湿度・CO₂・流量・EC/pH・カメラ等のデータをAIが最適化。
              フェイルセーフ運転、アラート、履歴解析、SLA準拠のレポーティングまで一体提供します。
            </p>
          </section>

          <section>
            <h2>宇宙要件の適合（Dual-Use）</h2>
            <ul>
              <li>低電力：kWh/kg 指標の段階的改善</li>
              <li>冗長化：センサー/ポンプ/制御系の二重化方針</li>
              <li>環境試験：振動/温度/真空/EMCのプリ評価（パートナー連携）</li>
            </ul>
          </section>

          <section>
            <h2>主なユースケース</h2>
            <ul>
              <li>宇宙機関・大学のライフサポート研究、閉鎖空間の食料自給検証</li>
              <li>地上の防災拠点・病院・離島・船舶・地下施設での自給運用</li>
            </ul>
          </section>

          <section>
            <h2>ポリシー（法的・倫理）</h2>
            <p>
              固定種/オープンソース種子を基本に自家循環を設計。登録品種等の権利には配慮し、合法かつ再現性の高い運用を追求します。
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
</Layout>
