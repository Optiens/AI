---
import Layout from '../layouts/Layout.astro';
import VideoBackgroundCanvas from '../components/VideoBackgroundCanvas.astro';
import { getCollection } from 'astro:content';

// 最新ブログ3件（水耕系除外）
const hydroCategories = ['agriculture', 'welfare', 'social'];
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter((p) => !hydroCategories.includes(p.data.category as string))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const fmtDate = (d: string) => {
  const date = new Date(d);
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
};

// HOME 専用 JSON-LD: WebSite + サービス
const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Optiens',
    url: 'https://optiens.com',
    inLanguage: 'ja',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'AI業務自動化支援',
    provider: { '@type': 'Organization', name: '合同会社Optiens' },
    areaServed: { '@type': 'Country', name: '日本' },
    audience: { '@type': 'BusinessAudience', name: '中小企業・小規模事業者' },
    description: 'AIエージェントによる業務自動化を、無料診断から導入・保守まで一貫提供。全国オンライン対応。',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'JPY',
      name: 'AI活用診断（無料）',
      url: 'https://optiens.com/free-diagnosis',
    },
  },
];
---

<Layout
  title="Optiens | 中小企業のAI業務自動化・AIエージェント導入支援（全国オンライン対応）"
  description="合同会社OptiensはAIエージェントによる業務自動化を、無料診断から導入・保守まで一貫提供。全国オンライン対応で、中小企業・小規模事業者の業務効率化を支援します。"
  canonical="https://optiens.com/"
  structuredData={homeSchema}
>
  <main class="home">

    <!-- ===== Hero（変更禁止のコピーを保持） ===== -->
    <section class="home-hero light-section">
      <VideoBackgroundCanvas
        id="home-hero-video"
        src="/videos/hero-bg.mp4"
        srcWebm="/videos/hero-bg.webm"
        srcAv1="/videos/hero-bg-av1.webm"
        poster="/images/hero-poster.jpg"
        overlay="brand"
      />
      <div class="hero-content">
        <div class="hero-text-block">
          <p class="hero-eyebrow">NEXT STEP WITH AI</p>
          <h1 class="hero-title">
            MAKE AI NATIVE<br/>
            TO YOUR BUSINESS.
          </h1>
          <p class="hero-sub">判断と創造に集中できる経営へ。</p>
        </div>
      </div>
    </section>

    <!-- ===== MAIN: AI支援事業（リード+CTAのみ） ===== -->
    <section class="home-main-service light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">
          AIを事業の中心に。<br class="pc-only" />
          AX（AI Transformation）で業務を再設計しませんか？
        </h2>

        <div class="home-service-cta">
          <a href="/service" class="home-service-btn home-service-btn--primary">
            サービスを見る <span aria-hidden="true">→</span>
          </a>
          <a href="/ai-examples" class="home-service-btn home-service-btn--ghost">
            活用事例を見る <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== なぜ、いまAIなのか ===== -->
    <section class="home-why-section light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">なぜ、いまAIなのか</h2>
        <p class="home-why-lead">低コストで自動化できる時代がきています。</p>
        <div class="home-why-grid">
          <div class="home-why-item">
            <span class="home-why-num">01</span>
            <h3>AIエージェントの台頭で、業務の在り方が変わる</h3>
            <p>チャットに答えるだけでなく、業務を自律的にこなす<strong>AIエージェント</strong>が実用段階に到達しました。業務プロセスをAIが理解できる形に<strong>最適化</strong>することが、これからの設計思想です。</p>
          </div>
          <div class="home-why-item">
            <span class="home-why-num">02</span>
            <h3>中小企業でも、大企業の仕組みを持てる</h3>
            <p>クラウド × AIエージェントの構成で、かつては大企業しか持てなかった業務システムが小規模事業者にも実装可能になりました。テクノロジーの恩恵が規模を超えて<strong>循環</strong>する時代です。</p>
          </div>
          <div class="home-why-item">
            <span class="home-why-num">03</span>
            <h3>人手だけで回す時代は終わった</h3>
            <p>労働人口の減少が続く中、人とAIが<strong>調和</strong>しながら業務を回す形が新しいスタンダードです。「人がやるべきこと」と「AIに任せること」の境界を引き直す段階に来ています。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 中小企業にAXはなぜ大切か ===== -->
    <section class="home-ax-section light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">中小企業にAXはなぜ大切か</h2>
        <p class="home-lead home-ax-lead">
          大企業と比べて人手や資金が限られている中小企業では、<br class="pc-only" />
          毎日の業務を効率よく進める工夫が必要です。<br />
          AXは、従来の業務を根本から変革および高度化するため、<br class="pc-only" />
          限られたリソースの中でも成果を出すための効果的な手段になります。
        </p>
        <div class="home-ax-grid">
          <div class="home-ax-card">
            <div class="home-ax-icon"><i class="fa-solid fa-comments"></i></div>
            <h3>問い合わせ対応の自動化</h3>
            <p>顧客からの問い合わせが多い企業では、AIチャットボットを導入することで、よくある質問への対応を自動化できます。負担軽減により、担当者は個別対応や改善施策に集中できます。</p>
          </div>
          <div class="home-ax-card">
            <div class="home-ax-icon"><i class="fa-solid fa-receipt"></i></div>
            <h3>事務作業の自動処理</h3>
            <p>経費精算や勤怠管理などもAIを使って自動処理することで、事務作業にかかる時間を削減できます。本来やるべき業務に時間を取り戻せます。</p>
          </div>
          <div class="home-ax-card">
            <div class="home-ax-icon"><i class="fa-solid fa-chart-line"></i></div>
            <h3>データに基づく経営判断</h3>
            <p>売上データや在庫情報をAIで分析すれば、「どの商品がよく売れているか」「どの時間帯に顧客が多いか」を視覚的に把握。経験や勘に頼らず、数字に基づく予測や判断ができます。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 最新ブログ3件 ===== -->
    {latestPosts.length > 0 && (
      <section class="home-blog-section light-section">
        <div class="container">
          <div class="home-blog-head">
            <h2 class="home-section-heading home-section-heading--center">最新記事</h2>
            <a href="/blog" class="home-blog-all">記事一覧を見る <span aria-hidden="true">→</span></a>
          </div>
          <div class="home-blog-list">
            {latestPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="home-blog-row">
                <div class="home-blog-meta">
                  <time class="home-blog-date">{fmtDate(post.data.date)}</time>
                </div>
                <div class="home-blog-body">
                  <h3 class="home-blog-title">{post.data.title}</h3>
                  <p class="home-blog-excerpt">{post.data.excerpt}</p>
                </div>
                <span class="home-blog-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ===== Final CTA ===== -->
    <section class="home-final-cta">
      <div class="container text-center" style="position:relative; z-index:1;">
        <h2 class="reveal">まずは気軽に、無料AI診断から</h2>
        <p class="reveal final-cta-text">
          「うちの業務にAIって使えるの？」<br/>
          「何から始めればいいか分からない」<br/>
          そんな状態からで大丈夫です。<br class="pc-only" />
          フォーム入力だけで、御社向けの簡易レポートをお届けします。
        </p>
        <div class="final-cta-row reveal">
          <a href="/free-diagnosis" class="btn-primary">無料AI診断を受ける</a>
          <a href="/contact" class="btn-secondary">お問い合わせ</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
/* =========================================================
   HOME 専用スタイル（シンプル & かっこいい）
   ========================================================= */
.home {
  --home-text: #334155;
  --home-heading: #0f172a;
  --home-muted: #64748b;
  --home-border: #e2e8f0;
  --home-surface: #ffffff;
  --home-surface-2: #f8fafc;
  --home-surface-3: #f1f5f9;
  --home-brand: #0E2A47;
  --home-brand-2: #C0C0C0;
}

.home .pc-only { display: inline; }
@media (max-width: 768px) {
  .home .pc-only { display: none; }
}

.home .container {
  width: min(1100px, 100% - 2rem);
  margin-inline: auto;
}

.home-eyebrow {
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--home-brand);
  font-weight: 600;
  margin: 0 0 12px;
}
.home-eyebrow--accent {
  text-align: center;
}

.home-section-eyebrow {
  text-align: center;
  font-size: clamp(13px, 1.4vw, 15px);
  font-weight: 700;
  letter-spacing: .08em;
  color: var(--brand);
  margin: 0 0 14px;
  text-transform: none;
}

.home-section-heading {
  font-size: clamp(26px, 3.6vw, 38px);
  font-weight: 800;
  letter-spacing: -.01em;
  color: var(--home-heading);
  margin: 0 0 clamp(28px, 4vw, 44px);
  line-height: 1.3;
}
.home-section-heading--center {
  text-align: center;
}

.home-why-lead {
  text-align: center;
  font-size: clamp(15px, 1.7vw, 18px);
  line-height: 1.8;
  color: var(--home-heading);
  font-weight: 600;
  margin: -20px auto clamp(36px, 5vw, 48px);
  max-width: 760px;
  letter-spacing: .01em;
}

.home-lead {
  font-size: clamp(15px, 1.7vw, 17px);
  line-height: 1.9;
  color: var(--home-text);
  text-align: center;
  margin: 0 auto clamp(36px, 5vw, 56px);
  max-width: 780px;
}
.home-lead--small {
  font-size: clamp(14px, 1.5vw, 15px);
  margin-bottom: clamp(28px, 4vw, 40px);
}

/* =========================================================
   Hero（ファーストビュー全画面・センタリング）
   ========================================================= */
.home-hero {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  min-height: 100dvh; /* モバイルでアドレスバー等を考慮 */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(90px, 11vw, 140px) 0;
  background: var(--home-surface);
  color: var(--home-text);
}
.home-hero .hero-content {
  position: relative;
  z-index: 2;
  width: min(900px, 100% - 6rem);
  margin-inline: auto;
  padding: 20px;
}
.home-hero .hero-text-block {
  width: fit-content;
  margin: 0 auto;
}
.home-hero .hero-eyebrow {
  display: block;
  margin: 0 0 1rem;
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: #6E2BC9; /* 濃い紫で動画背景上でもコントラスト確保 */
  font-weight: 700;
  text-align: left;
  text-shadow: 0 1px 6px rgba(255, 255, 255, 0.65), 0 0 18px rgba(255, 255, 255, 0.4);
}
.home-hero .hero-title {
  font-size: clamp(30px, 5vw, 60px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -.02em;
  color: var(--home-heading);
  margin: 0 0 1rem;
  text-align: left;
  text-shadow: 0 2px 10px rgba(255, 255, 255, 0.45);
}
.home-hero .hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  color: #0f172a; /* 黒に近い濃グレーで可読性確保 */
  margin: 0;
  font-weight: 700;
  text-align: right;
  text-shadow: 0 1px 6px rgba(255, 255, 255, 0.65), 0 0 18px rgba(255, 255, 255, 0.4);
}

@media (max-width: 640px) {
  .home-hero .hero-content {
    width: 100%;
    padding: 16px;
  }
}

/* =========================================================
   Main Service（AI支援：リード+CTAのみ）
   ========================================================= */
.home-main-service {
  padding: clamp(80px, 11vw, 130px) 0;
  background: var(--home-surface);
  text-align: center;
}
.home-service-cta {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
  margin-top: clamp(8px, 1.5vw, 16px);
}
.home-service-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: clamp(14px, 1.5vw, 15px);
  font-weight: 700;
  letter-spacing: .04em;
  padding: 14px 30px;
  border-radius: 999px;
  text-decoration: none;
  transition: transform .2s ease, box-shadow .2s ease, background-color .2s ease, border-color .2s ease, color .2s ease;
  white-space: nowrap;
}
.home-service-btn--primary {
  background: linear-gradient(135deg, #0E2A47 0%, #C0C0C0 100%);
  color: #fff;
  box-shadow: 0 10px 30px rgba(14, 42, 71, .35);
}
.home-service-btn--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 36px rgba(14, 42, 71, .45);
}
.home-service-btn--ghost {
  background: rgba(255, 255, 255, .8);
  border: 1px solid var(--home-border);
  color: var(--home-heading);
  backdrop-filter: blur(8px);
}
.home-service-btn--ghost:hover {
  background: #fff;
  border-color: var(--home-brand);
  color: var(--home-brand);
}
@media (max-width: 640px) {
  .home-service-cta { flex-direction: column; align-items: stretch; }
  .home-service-btn { width: 100%; justify-content: center; }
}

/* =========================================================
   なぜ、いまAIなのか
   ========================================================= */
.home-why-section {
  padding: clamp(60px, 8vw, 100px) 20px;
  background: var(--home-surface-2);
}
.home-why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  max-width: 1100px;
  margin: 0 auto;
}
.home-why-item {
  background: #fff;
  border: 1px solid var(--home-border);
  border-radius: 16px;
  padding: clamp(28px, 3.2vw, 36px);
  position: relative;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}
.home-why-item::before {
  content: attr(data-num);
  position: absolute;
  top: -28px;
  right: -8px;
  font-family: 'Inter', 'SF Pro Display', sans-serif;
  font-size: clamp(7rem, 12vw, 10rem);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.06em;
  color: var(--home-brand);
  opacity: 0.05;
  pointer-events: none;
  user-select: none;
}
.home-why-item:hover {
  transform: translateY(-4px);
  box-shadow: 0 18px 40px -22px rgba(14, 42, 71, 0.28);
  border-color: rgba(14, 42, 71, 0.2);
}
.home-why-num {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  font-family: 'Inter', 'SF Pro Display', 'Helvetica Neue', sans-serif;
  font-size: clamp(2.6rem, 4.2vw, 3.4rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1;
  background: linear-gradient(135deg, var(--home-brand) 0%, #4a7ba8 60%, var(--home-brand-2) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
.home-why-num::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--home-brand-2) 0%, rgba(192, 192, 192, 0) 100%);
  align-self: center;
  border-radius: 2px;
}
.home-why-item h3 {
  font-size: clamp(1.05rem, 1.7vw, 1.2rem);
  font-weight: 700;
  color: var(--home-heading);
  margin: 0 0 16px;
  line-height: 1.55;
  position: relative;
  z-index: 1;
}
.home-why-item p {
  color: var(--home-text);
  font-size: 0.93rem;
  line-height: 1.95;
  margin: 0;
  position: relative;
  z-index: 1;
}

/* =========================================================
   中小企業にAXはなぜ大切か
   ========================================================= */
.home-ax-section {
  padding: clamp(60px, 8vw, 100px) 20px;
  background: var(--home-surface);
}
.home-ax-lead {
  margin-bottom: clamp(36px, 5vw, 56px) !important;
}
.home-ax-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  max-width: 1100px;
  margin: 0 auto clamp(36px, 5vw, 56px);
}
.home-ax-card {
  background: linear-gradient(180deg, var(--home-surface-2) 0%, #fff 100%);
  border: 1px solid var(--home-border);
  border-radius: 18px;
  padding: clamp(32px, 4vw, 44px) clamp(24px, 3vw, 32px);
  text-align: center;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}
.home-ax-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 44px -22px rgba(14, 42, 71, 0.32);
  border-color: rgba(14, 42, 71, 0.18);
}
.home-ax-icon {
  width: clamp(96px, 11vw, 120px);
  height: clamp(96px, 11vw, 120px);
  margin: 0 auto clamp(20px, 2.5vw, 28px);
  border-radius: 26px;
  background: linear-gradient(135deg, #0E2A47 0%, #2c5282 50%, #C0C0C0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: clamp(2.2rem, 3.4vw, 2.8rem);
  position: relative;
  box-shadow:
    0 14px 36px -16px rgba(14, 42, 71, 0.55),
    inset 0 1px 0 rgba(255, 255, 255, 0.25);
}
.home-ax-icon::before {
  content: '';
  position: absolute;
  inset: -8px;
  border-radius: 32px;
  background: linear-gradient(135deg, rgba(14, 42, 71, 0.08) 0%, rgba(192, 192, 192, 0.06) 100%);
  z-index: -1;
}
.home-ax-card h3 {
  font-size: clamp(1.05rem, 1.7vw, 1.2rem);
  font-weight: 700;
  color: var(--home-heading);
  margin: 0 0 16px;
  letter-spacing: 0.01em;
}
.home-ax-card p {
  color: var(--home-text);
  font-size: 0.9rem;
  line-height: 1.95;
  margin: 0;
  text-align: left;
}
.home-ax-closing {
  text-align: center;
  color: var(--home-muted);
  font-size: clamp(13px, 1.5vw, 14px);
  line-height: 1.95;
  max-width: 760px;
  margin: 0 auto;
}

.home-section-heading-ax {
  display: block;
  font-size: clamp(11px, 1.2vw, 13px);
  font-weight: 500;
  color: var(--home-muted);
  letter-spacing: 0.08em;
  margin-top: 8px;
  text-transform: none;
}

/* =========================================================
   最新ブログ3件
   ========================================================= */
.home-blog-section {
  padding: clamp(60px, 8vw, 100px) 20px;
  background: var(--home-surface-2);
}
.home-blog-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: clamp(28px, 4vw, 40px);
  max-width: 880px;
  margin-inline: auto;
  flex-wrap: wrap;
  gap: 12px;
}
.home-blog-head .home-section-heading {
  margin: 0;
}
.home-blog-all {
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--home-brand);
  text-decoration: none;
  letter-spacing: 0.04em;
}
.home-blog-all:hover {
  color: var(--home-brand-2);
}
.home-blog-list {
  max-width: 880px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.home-blog-row {
  display: grid;
  grid-template-columns: 110px 1fr 24px;
  gap: 24px;
  align-items: center;
  padding: 24px 28px;
  background: #fff;
  border: 1px solid var(--home-border);
  border-bottom: none;
  text-decoration: none;
  color: inherit;
  transition: background 0.2s ease;
}
.home-blog-row:first-child {
  border-radius: 12px 12px 0 0;
}
.home-blog-row:last-child {
  border-bottom: 1px solid var(--home-border);
  border-radius: 0 0 12px 12px;
}
.home-blog-row:only-child {
  border-radius: 12px;
}
.home-blog-row:hover {
