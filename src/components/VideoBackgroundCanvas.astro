---
/**
 * 案6: 動画背景（mp4/webm）
 *
 * <video autoplay muted loop> で動画を全画面再生し、上に
 * ブランド色のグラデーションオーバーレイを重ねて文字の可読性を確保。
 *
 * 動画ファイルは public/videos/ 等に置いて src で参照する。
 * src 未指定時は CSS グラデーションのフォールバックを表示。
 *
 * 推奨スペック:
 *   - 解像度: 1920x1080 以下（モバイル考慮）
 *   - 長さ: 8〜20秒のループ
 *   - 形式: mp4 (H.264) + webm (VP9) の併用が理想
 *   - サイズ: 2〜5MB 以内
 *
 * 推奨無料素材サイト:
 *   - Pexels Videos: https://www.pexels.com/videos/
 *   - Coverr: https://coverr.co/
 *   - Mixkit: https://mixkit.co/free-stock-video/
 *   検索キーワード例: "abstract", "particles", "neural", "ai", "tech"
 */
interface Props {
  id?: string;
  /** 動画URL (mp4) - フォールバック用 */
  src?: string;
  /** 動画URL (webm VP9) - 中間ブラウザ向け */
  srcWebm?: string;
  /** 動画URL (webm AV1) - 最新ブラウザ向け（最軽量） */
  srcAv1?: string;
  /** 動画読み込み中に表示するポスター画像 */
  poster?: string;
  /** オーバーレイの種類 */
  overlay?: 'brand' | 'dark' | 'light' | 'none';
}
const {
  id = 'video-bg',
  src,
  srcWebm,
  srcAv1,
  poster,
  overlay = 'brand',
} = Astro.props;
---

<div id={id} class="video-bg" data-overlay={overlay} aria-hidden="true">
  {src ? (
    <video
      class="video-bg-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={poster}
      disableRemotePlayback
    >
      {srcAv1 && <source src={srcAv1} type='video/webm; codecs="av01.0.05M.08"' />}
      {srcWebm && <source src={srcWebm} type='video/webm; codecs="vp9"' />}
      <source src={src} type="video/mp4" />
    </video>
  ) : (
    <div class="video-bg-fallback"></div>
  )}
  <div class="video-bg-overlay"></div>
</div>

<style>
  .video-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .video-bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-bg-fallback {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(31, 58, 147, 0.5), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(192, 192, 192, 0.45), transparent 50%),
      radial-gradient(circle at 50% 80%, rgba(255, 206, 208, 0.35), transparent 50%),
      radial-gradient(circle at 70% 20%, rgba(242, 78, 30, 0.25), transparent 50%);
    filter: blur(40px);
    animation: fallback-drift 20s ease-in-out infinite alternate;
  }
  @keyframes fallback-drift {
    0% {
      transform: scale(1) translate(0, 0);
    }
    100% {
      transform: scale(1.1) translate(-3%, 2%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .video-bg-fallback {
      animation: none;
    }
  }

  .video-bg-overlay {
    position: absolute;
    inset: 0;
  }
  [data-overlay='brand'] .video-bg-overlay {
    background: linear-gradient(
      135deg,
      rgba(31, 58, 147, 0.18) 0%,
      rgba(192, 192, 192, 0.12) 50%,
      rgba(255, 206, 208, 0.12) 100%
    );
    mix-blend-mode: screen;
  }
  [data-overlay='dark'] .video-bg-overlay {
    background: rgba(0, 0, 0, 0.45);
  }
  [data-overlay='light'] .video-bg-overlay {
    background: rgba(255, 255, 255, 0.55);
  }
  /* overlay='none' は overlay div は残るが透明 */
</style>
