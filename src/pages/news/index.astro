---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import bgUrl from '~/assets/ai-nature-city.webp?url';

const limit = 5;
const currentPage = Number(Astro.url.searchParams.get('page') ?? 1);
const offset = (currentPage - 1) * limit;

const allArticles = await getCollection('news');
const sorted = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const paged = sorted.slice(offset, offset + limit);
const totalPages = Math.ceil(sorted.length / limit);
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
---

<Layout title="ニュース | Optiens">
  <main>
    <!-- 共通 Hero セクション -->
    <section class="hero-section news-list-hero-section" style={`--hero-bg: url(${bgUrl});`}>
      <div class="container text-center">
        <h1>ニュース</h1>
      </div>
    </section>

    <!-- ニュース記事一覧 -->
    <section class="news-articles-section">
      <div class="container news-list-container">
        {paged.length > 0 ? (
          paged.map((item) => (
            <a href={`/news/${item.id}`} class="news-item-long-link" aria-label={`${item.data.title} の詳細`}>
              <article class="card news-item-long">
                <div class="card-content news-content-long">
                  <p class="news-date">{item.data.date.replace(/-/g, '.')}</p>
                  <h2 class="card-title">{item.data.title}</h2>
                </div>
                <span class="card-icon-container" aria-hidden="true">
                  <i class="fa-solid fa-arrow-up-right-from-square"></i>
                </span>
              </article>
            </a>
          ))
        ) : (
          <p class="text-center">現在、ニュースはありません。</p>
        )}
      </div>
    </section>

    {totalPages > 1 && (
      <nav class="pagination-container" aria-label="ニュースページネーション">
        <ul class="pagination">
          {hasPrev ? (
            <li class="pagination-item">
              <a href={`?page=${currentPage - 1}`} class="pagination-link">前へ</a>
            </li>
          ) : (
            <li class="pagination-item disabled">
              <span class="pagination-link">前へ</span>
            </li>
          )}
          <li class="pagination-item current">
            <span class="pagination-link">{currentPage} / {totalPages}</span>
          </li>
          {hasNext ? (
            <li class="pagination-item">
              <a href={`?page=${currentPage + 1}`} class="pagination-link">次へ</a>
            </li>
          ) : (
            <li class="pagination-item disabled">
              <span class="pagination-link">次へ</span>
            </li>
          )}
        </ul>
      </nav>
    )}
  </main>
</Layout>

<style>
  /* ========== News List ========== */
  .news-articles-section {
    padding: clamp(32px, 6vw, 60px) 0;
  }
  .news-list-container {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .news-item-long-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .news-item-long {
    display: flex;
    flex-direction: column;
  }
  .news-content-long {
    gap: 8px;
  }
  .news-date {
    font-size: .9em;
    color: var(--muted);
    margin: 0;
  }

  /* ========== Pagination ========== */
  .pagination-container {
    display: flex;
    justify-content: center;
    padding: 30px 0;
  }
  .pagination {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid #ddd;
    border-radius: 5px;
  }
  .pagination-link {
    display: block;
    padding: 10px 15px;
    text-decoration: none;
    color: var(--text);
    transition: background-color .2s;
    font-weight: bold;
  }
  .pagination-link:hover {
    background-color: var(--surface-2);
  }
  .pagination-item.disabled .pagination-link {
    color: #ccc;
    cursor: not-allowed;
    background: transparent;
  }
  .pagination-item.current .pagination-link {
    background: var(--brand);
    color: #fff;
  }
</style>
