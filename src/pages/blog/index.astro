---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

type BlogCategory = 'AI' | 'agriculture' | 'business' | 'technology' | 'welfare' | 'social' | 'announcement';

const categoryLabel: Partial<Record<BlogCategory, string>> = {
  AI: 'AI・機械学習',
  business: '経営・業務',
  technology: 'テクノロジー',
  announcement: 'お知らせ',
};

// 水耕栽培関連カテゴリはブログ一覧から除外（hydroponicsページで掲載）
const hydroCategories: BlogCategory[] = ['agriculture', 'welfare', 'social'];

const DEFAULT_LIMIT = 18;
const showAll = Astro.url.searchParams.get('all') === '1';
const limit = showAll ? Infinity : DEFAULT_LIMIT;
const currentPage = Number(Astro.url.searchParams.get('page') ?? 1);
const selectedCategory = (Astro.url.searchParams.get('category') ?? '') as BlogCategory | '';

const allPosts = await getCollection('blog');
const mainPosts = allPosts.filter((p) => !hydroCategories.includes(p.data.category as BlogCategory));
const sorted = mainPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const filtered = selectedCategory
  ? sorted.filter((p) => p.data.category === selectedCategory)
  : sorted;

const offset = showAll ? 0 : (currentPage - 1) * DEFAULT_LIMIT;
const paged = showAll ? filtered : filtered.slice(offset, offset + DEFAULT_LIMIT);
const totalPages = showAll ? 1 : Math.ceil(filtered.length / DEFAULT_LIMIT);
const hasPrev = !showAll && currentPage > 1;
const hasNext = !showAll && currentPage < totalPages;

// 表示用ページ番号配列（最大10ページ表示）
const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);

const categories = Object.entries(categoryLabel) as [BlogCategory, string][];

function pageUrl(page: number) {
  const params = new URLSearchParams();
  params.set('page', String(page));
  if (selectedCategory) params.set('category', selectedCategory);
  return `?${params.toString()}`;
}
function categoryUrl(cat: BlogCategory | '') {
  return cat ? `?category=${cat}` : '?';
}
function showAllUrl() {
  const params = new URLSearchParams();
  params.set('all', '1');
  if (selectedCategory) params.set('category', selectedCategory);
  return `?${params.toString()}`;
}
function paginatedUrl() {
  const params = new URLSearchParams();
  if (selectedCategory) params.set('category', selectedCategory);
  return params.toString() ? `?${params.toString()}` : '?';
}
---

<Layout title="ブログ | Optiens">
  <main>
    <!-- カテゴリフィルター -->
    <section class="filter-section filter-section--top light-section">
      <div class="container">
        <ul class="category-list" role="list">
          <li>
            <a href={categoryUrl('')} class={`category-tag ${!selectedCategory ? 'active' : ''}`}>
              すべて
            </a>
          </li>
          {categories.map(([key, label]) => (
            <li>
              <a
                href={categoryUrl(key)}
                class={`category-tag category-tag--${key} ${selectedCategory === key ? 'active' : ''}`}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 記事一覧 -->
    <section class="blog-articles-section light-section">
      <div class="container blog-grid">
        {paged.length > 0 ? (
          paged.map((post) => (
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="blog-card-link" aria-label={`${post.data.title} の詳細`}>
              <article class="card blog-card">
                {post.data.image && (
                  <div class="card-thumbnail">
                    <img src={post.data.image} alt={post.data.title} loading="lazy" />
                  </div>
                )}
                <div class="card-content">
                  <div class="blog-meta">
                    <span class={`category-badge category-badge--${post.data.category}`}>
                      {categoryLabel[post.data.category]}
                    </span>
                    <time class="blog-date" datetime={post.data.date}>
                      {post.data.date.replace(/-/g, '.')}
                    </time>
                  </div>
                  <h2 class="card-title blog-title">{post.data.title}</h2>
                  <p class="card-text blog-excerpt">{post.data.excerpt}</p>
                </div>
                <span class="card-icon-container" aria-hidden="true">
                  <i class="fa-solid fa-arrow-up-right-from-square"></i>
                </span>
              </article>
            </a>
          ))
        ) : (
          <p class="text-center no-posts">該当する記事がありません。</p>
        )}
      </div>
    </section>

    <!-- ページネーション -->
    {(totalPages > 1 || showAll) && (
      <nav class="pagination-container" aria-label="ブログページネーション">
        {showAll ? (
          <div class="pagination-mode">
            <span class="pagination-info">全 {filtered.length} 件を表示中</span>
            <a href={paginatedUrl()} class="pagination-link pagination-link--mode">ページ表示に戻す</a>
          </div>
        ) : (
          <div class="pagination-mode">
            <ul class="pagination">
              {hasPrev ? (
                <li class="pagination-item">
                  <a href={pageUrl(currentPage - 1)} class="pagination-link">前へ</a>
                </li>
              ) : (
                <li class="pagination-item disabled">
                  <span class="pagination-link">前へ</span>
                </li>
              )}
              {pageNumbers.map((n) => (
                <li class={`pagination-item pagination-item--num ${n === currentPage ? 'current' : ''}`}>
                  {n === currentPage ? (
                    <span class="pagination-link">{n}</span>
                  ) : (
                    <a href={pageUrl(n)} class="pagination-link">{n}</a>
                  )}
                </li>
              ))}
              {hasNext ? (
                <li class="pagination-item">
                  <a href={pageUrl(currentPage + 1)} class="pagination-link">次へ</a>
                </li>
              ) : (
                <li class="pagination-item disabled">
                  <span class="pagination-link">次へ</span>
                </li>
              )}
            </ul>
            <a href={showAllUrl()} class="pagination-link pagination-link--mode">全 {filtered.length} 件を一度に見る</a>
          </div>
        )}
      </nav>
    )}
  </main>
</Layout>

<style>
  .blog-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(90px, 11vw, 140px) 0;
    background: #ffffff;
    overflow: hidden;
    color: var(--text);
  }
  .blog-hero h1 {
    color: var(--heading);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    margin-bottom: 12px;
  }
  .hero-sub {
    margin: .75rem 0 0;
    font-size: clamp(.9rem, 2vw, 1.1rem);
    color: var(--muted);
  }

  /* ========== カテゴリフィルター ========== */
  .filter-section {
    padding: 28px 0 0;
  }
  .filter-section--top {
    padding-top: clamp(110px, 14vw, 150px);
  }
  .category-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .category-tag {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: .85rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--border);
    color: var(--muted);
    background: var(--surface-card);
    transition: all .2s;
  }
  .category-tag:hover,
  .category-tag.active {
    background: var(--brand);
    color: #fff;
    border-color: var(--brand);
  }

  /* ========== 記事グリッド ========== */
  .blog-articles-section {
    padding: clamp(28px, 5vw, 48px) 0 clamp(32px, 6vw, 60px);
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 28px;
  }
  .blog-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .blog-card {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .blog-card:has(.card-thumbnail) .card-content {
    padding-top: 10px;
  }

  .card-thumbnail {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .card-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .3s ease;
  }
  .blog-card:hover .card-thumbnail img {
    transform: scale(1.04);
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .blog-date {
    font-size: .85rem;
    color: var(--muted);
  }

  .category-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: .75rem;
    font-weight: 700;
    color: #fff;
  }
  .category-badge--AI           { background: #4A6CF7; }
  .category-badge--agriculture  { background: #2E7D4F; }
  .category-badge--business     { background: #B08825; }
  .category-badge--technology   { background: #7B4FA0; }
  .category-badge--welfare      { background: #D45D5D; }
  .category-badge--social       { background: #C0632B; }
  .category-badge--announcement { background: #3D5CC7; }

  .blog-title {
    font-size: clamp(1rem, 2vw, 1.15rem);
    margin: 0 0 .6rem;
    line-height: 1.5;
  }
  .blog-excerpt {
    font-size: .9rem;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .no-posts {
    grid-column: 1 / -1;
    padding: 40px 0;
    color: var(--muted);
  }

  /* ========== ページネーション ========== */
  .pagination-container {
    display: flex;
    justify-content: center;
    padding: 0 0 60px;
  }
  .pagination-mode {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .pagination {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pagination-item {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .pagination-link {
    display: block;
    padding: 9px 14px;
    text-decoration: none;
    color: var(--text);
    transition: background-color .2s, color .2s;
    font-weight: 600;
    font-size: .9rem;
    min-width: 40px;
    text-align: center;
  }
  .pagination-link:hover { background-color: var(--surface-3); color: var(--brand); }
  .pagination-item.disabled .pagination-link {
    color: rgba(0,0,0,.25);
    cursor: not-allowed;
    background: transparent;
  }
  .pagination-item.current {
    border-color: var(--brand);
  }
  .pagination-item.current .pagination-link {
    background: var(--brand);
    color: #fff;
  }
  .pagination-link--mode {
    border: 1px dashed var(--border);
    border-radius: 6px;
    padding: 8px 18px;
    color: var(--muted);
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .pagination-link--mode:hover {
    color: var(--brand);
    border-color: var(--brand);
  }
  .pagination-info {
    color: var(--muted);
    font-size: 0.9rem;
  }
  @media (max-width: 640px) {
    .pagination-link {
      padding: 8px 10px;
      font-size: 0.85rem;
      min-width: 32px;
    }
  }
</style>
