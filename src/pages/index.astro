---
import Layout from '../layouts/Layout.astro';
import VideoBackgroundCanvas from '../components/VideoBackgroundCanvas.astro';
import { getCollection } from 'astro:content';
import { filterPublishedPosts } from '../lib/blog-filters';

// 最新ブログ3件（水耕系除外）
const hydroCategories = ['agriculture', 'welfare', 'social'];
const allPosts = filterPublishedPosts(await getCollection('blog'));
const latestPosts = allPosts
  .filter((p) => !hydroCategories.includes(p.data.category as string))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const fmtDate = (d: string) => {
  const date = new Date(d);
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
};

// HOME 専用 JSON-LD: WebSite + サービス
const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Optiens',
    url: 'https://optiens.com',
    inLanguage: 'ja',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'AI業務自動化支援',
    provider: { '@type': 'Organization', name: '合同会社Optiens' },
    areaServed: { '@type': 'Country', name: '日本' },
    audience: { '@type': 'BusinessAudience', name: '中小企業・小規模事業者' },
    description: 'AIエージェントによる業務自動化を、AI活用診断から導入・保守まで一貫提供。全国オンライン対応。',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'JPY',
      name: 'AI活用診断（無料）',
      url: 'https://optiens.com/free-diagnosis',
    },
  },
];
---

<Layout
  title="Optiens | 中小企業のAI業務自動化・AIエージェント導入支援（全国オンライン対応）"
  description="合同会社OptiensはAIエージェントによる業務自動化を、AI活用診断から導入・保守まで一貫提供。全国オンライン対応で、中小企業・小規模事業者の業務効率化を支援します。"
  canonical="https://optiens.com/"
  ogTitle="Optiens | 中小企業のAI業務自動化"
  ogDescription="AI活用診断から導入・保守まで。CRM・問い合わせ・見積・営業事務の自動化を支援します。"
  ogImage="https://optiens.com/images/og-home-firstview-20260516.png"
  ogImageAlt="Optiens 中小企業のAI業務自動化"
  structuredData={homeSchema}
>
  <main class="home">

    <!-- ===== Hero（変更禁止のコピーを保持） ===== -->
    <section class="home-hero light-section">
      <VideoBackgroundCanvas
        id="home-hero-video"
        src="/videos/hero-bg.mp4"
        srcWebm="/videos/hero-bg.webm"
        srcAv1="/videos/hero-bg-av1.webm"
        poster="/images/hero-poster.jpg"
        overlay="brand"
      />
      <div class="hero-content">
        <div class="hero-text-block">
          <p class="hero-eyebrow">NEXT STEP WITH AI</p>
          <h1 class="hero-title">
            MAKE AI NATIVE<br/>
            TO YOUR BUSINESS.
          </h1>
          <p class="hero-sub">判断と創造に集中できる経営へ。</p>
        </div>
      </div>
    </section>

    <!-- ===== MAIN: AI支援事業（リード+CTAのみ） ===== -->
    <section class="home-main-service light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">
          AXで業務を再設計しませんか？
        </h2>
        <p class="home-ax-core-copy">
          中小企業の問い合わせ対応・見積作成・社内検索を、AIで自動化します。
        </p>
        <p class="home-ax-note">
          <strong>AX</strong>（AI Transformation）— 業務プロセスを AI が理解できる形に再設計し、人と AI が協働する仕組みへ移行する取り組み。DX の次のフェーズとして注目されています。
        </p>

        <div class="home-service-cta">
          <a href="/free-diagnosis" class="home-service-btn home-service-btn--primary">
            AI活用診断（無料） <span aria-hidden="true">→</span>
          </a>
          <a href="/ai-examples" class="home-service-btn home-service-btn--ghost">
            活用事例を見る <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== サービスチケット ===== -->
    <section class="home-ticket-section light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">
          相談から小さな実装まで、チケットで始められます
        </h2>
        <p class="home-ticket-lead">
          小さな相談はスポット相談チケット、大きな導入は個別見積、導入後の継続改善は保守チケット。入口を軽くしつつ、責任範囲が広い案件は無理にチケットへ押し込みません。
        </p>

        <div class="home-ticket-grid">
          <article class="home-ticket-card home-ticket-card--spot">
            <span class="home-ticket-label">Spot Consultation Ticket</span>
            <h3>スポット相談チケット</h3>
            <p class="home-ticket-price">¥33,000<span> / 1枚・税込</span></p>
            <p class="home-ticket-copy">1枚で診断後の相談または導入支援前の要件整理を行います。購入後はチケット番号で利用申請できます。</p>
            <ul>
              <li><strong>レビュー面談</strong> 診断結果と優先順位を整理</li>
              <li><strong>有償要件定義</strong> 導入支援成約時に初期費用へ充当</li>
              <li><strong>3枚から</strong> 簡易実装・軽微な自動化対応</li>
            </ul>
            <a href="/spot-ticket" class="home-ticket-link">チケットを見る <span aria-hidden="true">→</span></a>
          </article>

          <article class="home-ticket-card">
            <span class="home-ticket-label">Implementation</span>
            <h3>導入支援</h3>
            <p class="home-ticket-price">個別見積</p>
            <p class="home-ticket-copy">外部API連携、認証、個人情報、本番運用、継続保守が絡むものは、設計範囲を切って見積します。</p>
            <ul>
              <li>1業務MVPから段階導入</li>
              <li>契約書・工程表・検収基準を整理</li>
              <li>スポット要件定義費は成約時に充当</li>
            </ul>
            <a href="/implementation" class="home-ticket-link">導入支援を見る <span aria-hidden="true">→</span></a>
          </article>

          <article class="home-ticket-card">
            <span class="home-ticket-label">Maintenance</span>
            <h3>保守チケット</h3>
            <p class="home-ticket-price">¥45,000<span> / 月・税抜〜</span></p>
            <p class="home-ticket-copy">導入後の相談、軽微な調整、トラブル調査、ワークフロー改善を月次チケットで進めます。</p>
            <ul>
              <li>ライト: 月3チケット</li>
              <li>スタンダード: 月8チケット</li>
              <li>不足時は追加チケット購入も可能</li>
            </ul>
            <a href="/maintenance" class="home-ticket-link">保守を見る <span aria-hidden="true">→</span></a>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== なぜ、いまAIなのか ===== -->
    <section class="home-why-section light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">なぜ、いまAIなのか</h2>
        <div class="home-why-grid">
          <div class="home-why-item">
            <span class="home-why-num">01</span>
            <h3>AIエージェントの台頭で、業務の在り方が変わる</h3>
            <p>質問に答えるだけでなく、業務を自律的にこなす<strong>AIエージェント</strong>が実用段階に到達しました。業務プロセスや会社資産をAIが理解できる形に<strong>最適化</strong>することが、AI時代に生き残るために必要な取り組みになります。</p>
          </div>
          <div class="home-why-item">
            <span class="home-why-num">02</span>
            <h3>高額なSaaSではなく、自社専用の仕組みを持てる</h3>
            <p>AIエージェントは登場したばかりで、大企業もまだ手探りです。鍵は<strong>AI駆動開発</strong> — 月数十万円の既製SaaSに頼らず、<strong>自社専用システム</strong>を低コストで持てる時代になりました。</p>
          </div>
          <div class="home-why-item">
            <span class="home-why-num">03</span>
            <h3>人手だけで回す時代は終わった</h3>
            <p>労働人口は減り続け、AIは<strong>人間を超える頭脳</strong>を持ちはじめました。ジュニア層の業務はすでに代替されつつあります。「人がやるべきこと」と「AIに任せること」を<strong>再設計</strong>する段階にきています。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== なぜ、中小企業にAXか ===== -->
    <section class="home-ax-section light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">なぜ、中小企業にAXか</h2>
        <div class="home-ax-statement">
          <p>
            大企業と比べて<strong>人手や資金が限られる</strong>中小企業では、毎日の業務を効率よく進める工夫が常に求められます。
            AXは従来の業務を<strong>根本から変革・高度化</strong>するため、限られたリソースの中でも成果を出す効果的な手段になります。
          </p>
        </div>
      </div>
    </section>

    <!-- ===== 最新ブログ3件 ===== -->
    {latestPosts.length > 0 && (
      <section class="home-blog-section light-section">
        <div class="container">
          <div class="home-blog-head">
            <h2 class="home-section-heading home-section-heading--center">最新記事</h2>
            <a href="/blog" class="home-blog-all">記事一覧を見る <span aria-hidden="true">→</span></a>
          </div>
          <div class="home-blog-list">
            {latestPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="home-blog-row">
                <div class="home-blog-meta">
                  <time class="home-blog-date">{fmtDate(post.data.date)}</time>
                </div>
                <div class="home-blog-body">
                  <h3 class="home-blog-title">{post.data.title}</h3>
                  <p class="home-blog-excerpt">{post.data.excerpt}</p>
                </div>
                <span class="home-blog-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ===== Final CTA ===== -->
    <section class="home-final-cta">
      <div class="container text-center" style="position:relative; z-index:1;">
        <h2 class="reveal">まずは気軽に、AI活用診断から</h2>
        <p class="reveal final-cta-text">
          「うちの業務にAIって使えるの？」<br/>
          「何から始めればいいか分からない」<br/>
          そんな状態からで大丈夫です。<br class="pc-only" />
          フォーム入力だけで、御社専用の簡易レポートをお届けします。
        </p>
        <div class="final-cta-row reveal">
          <a href="/free-diagnosis" class="btn-primary">AI活用診断を受ける（無料）</a>
          <a href="/contact" class="btn-secondary">お問い合わせ</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
/* =========================================================
   HOME 専用スタイル（シンプル & かっこいい）
   ========================================================= */
.home {
  --home-text: #334155;
  --home-heading: #0f172a;
  --home-muted: #64748b;
  --home-border: #e2e8f0;
  --home-surface: #ffffff;
  --home-surface-2: #f8fafc;
  --home-surface-3: #f1f5f9;
  --home-brand: #1F3A93;
  --home-brand-2: #6B85C9;
}

.home .pc-only { display: inline; }
@media (max-width: 768px) {
  .home .pc-only { display: none; }
}

.home .container {
  width: min(1100px, 100% - 2rem);
  margin-inline: auto;
}

.home-eyebrow {
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--home-brand);
  font-weight: 600;
  margin: 0 0 12px;
}
.home-eyebrow--accent {
  text-align: center;
}

.home-section-eyebrow {
  text-align: center;
  font-size: clamp(13px, 1.4vw, 15px);
  font-weight: 700;
  letter-spacing: .08em;
  color: var(--brand);
  margin: 0 0 14px;
  text-transform: none;
}

.home-section-heading {
  font-size: clamp(26px, 3.6vw, 38px);
  font-weight: 800;
  letter-spacing: -.01em;
  color: var(--home-heading);
  margin: 0 0 clamp(28px, 4vw, 44px);
  line-height: 1.3;
}
.home-section-heading--center {
  text-align: center;
}

.home-why-lead {
  text-align: center;
  font-size: clamp(15px, 1.7vw, 18px);
  line-height: 1.8;
  color: var(--home-heading);
  font-weight: 600;
  margin: -20px auto clamp(36px, 5vw, 48px);
  max-width: 760px;
  letter-spacing: .01em;
}

.home-ax-core-copy {
  text-align: center;
  font-size: clamp(17px, 2.1vw, 22px);
  line-height: 1.65;
  color: var(--home-heading);
  font-weight: 800;
  margin: -20px auto clamp(18px, 3vw, 24px);
  max-width: 760px;
}

.home-ax-note {
  text-align: center;
  /* 最終行がポツンと残らないようブラウザに行末バランス調整を任せる
     （Chrome 117+ / Firefox 121+ / Safari 17.5+。非対応ブラウザはデフォルト動作） */
  text-wrap: pretty;
  font-size: clamp(12px, 1.2vw, 13px);
  line-height: 1.85;
  color: var(--muted, #64748b);
  margin: 0 auto clamp(28px, 4vw, 36px);
  max-width: 640px;
  letter-spacing: .01em;
  /* 単語境界を意識した日本語折り返し（句読点が行頭に来るのを抑制） */
  word-break: auto-phrase;
  overflow-wrap: anywhere;
}
@media (max-width: 640px) {
  .home-ax-note {
    text-align: left;
    max-width: 100%;
    padding: 0 8px;
  }
}
.home-ax-note strong {
  color: var(--home-brand, #1F3A93);
  font-weight: 700;
}

.home-lead {
  font-size: clamp(15px, 1.7vw, 17px);
  line-height: 1.9;
  color: var(--home-text);
  text-align: center;
  margin: 0 auto clamp(36px, 5vw, 56px);
  max-width: 780px;
}
.home-lead--small {
  font-size: clamp(14px, 1.5vw, 15px);
  margin-bottom: clamp(28px, 4vw, 40px);
}

/* =========================================================
   Hero（ファーストビュー全画面・センタリング）
   ========================================================= */
.home-hero {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  min-height: 100dvh; /* モバイルでアドレスバー等を考慮 */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(90px, 11vw, 140px) 0;
  background: var(--home-surface);
  color: var(--home-text);
}
.home-hero .hero-content {
  position: relative;
  z-index: 2;
  width: min(900px, 100% - 6rem);
  margin-inline: auto;
  padding: 20px;
}
.home-hero .hero-text-block {
  /* 半透明カードで背景動画を透かしつつ可読性を確保 */
  width: fit-content;
  max-width: 100%;
  margin: 0 auto;
  padding: clamp(28px, 4vw, 48px) clamp(28px, 4vw, 56px);
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10px) saturate(130%);
  -webkit-backdrop-filter: blur(10px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 24px;
  box-shadow: 0 24px 60px -20px rgba(15, 23, 42, 0.18);
}
.home-hero .hero-eyebrow {
  display: block;
  margin: 0 0 1rem;
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--home-brand, #1F3A93);
  font-weight: 700;
  text-align: left;
}
.home-hero .hero-title {
  font-size: clamp(30px, 5vw, 60px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -.02em;
  color: var(--home-heading);
  margin: 0 0 1rem;
  text-align: left;
}
.home-hero .hero-title-accent {
  color: #E48A95;
}
.home-hero .hero-title-lapis {
  color: #1F3A93;
}
.home-hero .hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  color: #0f172a;
  margin: 0;
  font-weight: 700;
  text-align: right;
}

@media (max-width: 640px) {
  .home-hero .hero-content {
    width: 100%;
    padding: 16px;
  }
  .home-hero .hero-text-block {
    padding: 24px 20px;
  }
}

/* =========================================================
   Main Service（AI支援：リード+CTAのみ）
   ========================================================= */
.home-main-service {
  padding: clamp(80px, 11vw, 130px) 0;
  background: var(--home-surface);
  text-align: center;
}
.home-service-cta {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
  margin-top: clamp(8px, 1.5vw, 16px);
}
.home-service-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: clamp(14px, 1.5vw, 15px);
  font-weight: 700;
  letter-spacing: .04em;
  padding: 14px 30px;
  border-radius: 999px;
  text-decoration: none;
  transition: transform .2s ease, box-shadow .2s ease, background-color .2s ease, border-color .2s ease, color .2s ease;
  white-space: nowrap;
}
.home-service-btn--primary {
  background: linear-gradient(135deg, #1F3A93 0%, #6B85C9 100%);
  color: #fff;
  box-shadow: 0 10px 30px rgba(31, 58, 147, .35);
}
.home-service-btn--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 36px rgba(31, 58, 147, .45);
}
.home-service-btn--ghost {
  background: rgba(255, 255, 255, .8);
  border: 1px solid var(--home-border);
  color: var(--home-heading);
  backdrop-filter: blur(8px);
}
.home-service-btn--ghost:hover {
  background: #fff;
  border-color: var(--home-brand);
  color: var(--home-brand);
}
@media (max-width: 640px) {
  .home-service-cta { flex-direction: column; align-items: stretch; }
  .home-service-btn { width: 100%; justify-content: center; }
}

/* =========================================================
   Service Tickets
   ========================================================= */
.home-ticket-section {
  padding: clamp(64px, 9vw, 110px) 0;
  background: var(--home-surface-2);
}
.home-ticket-lead {
  max-width: 760px;
  margin: -18px auto clamp(32px, 5vw, 48px);
  color: var(--home-text);
  font-size: clamp(14px, 1.6vw, 16px);
  line-height: 1.9;
  text-align: center;
}
.home-ticket-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: clamp(16px, 2.4vw, 24px);
}
.home-ticket-card {
  display: flex;
  flex-direction: column;
  min-height: 430px;
  padding: clamp(24px, 3vw, 32px);
  border: 1px solid rgba(31, 58, 147, 0.12);
  border-radius: 18px;
  background: #fff;
  box-shadow: 0 18px 44px -34px rgba(31, 58, 147, 0.32);
}
.home-ticket-card--spot {
  border-color: rgba(31, 58, 147, 0.24);
  background:
    linear-gradient(135deg, rgba(31, 58, 147, 0.055) 0%, rgba(255, 255, 255, 0) 54%, rgba(228, 138, 149, 0.07) 100%),
    #ffffff;
}
.home-ticket-label {
  color: var(--home-brand);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.home-ticket-card h3 {
  margin: 10px 0 12px;
  color: var(--home-heading);
  font-size: clamp(1.12rem, 1.8vw, 1.35rem);
  line-height: 1.45;
}
.home-ticket-price {
  margin: 0 0 14px;
  color: var(--home-brand);
  font-size: clamp(1.45rem, 2.5vw, 1.9rem);
  font-weight: 800;
  line-height: 1.2;
}
.home-ticket-price span {
  color: var(--home-muted);
  font-size: 0.82rem;
  font-weight: 600;
}
.home-ticket-copy {
  margin: 0 0 18px;
  color: var(--home-text);
  font-size: 0.92rem;
  line-height: 1.8;
}
.home-ticket-card ul {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin: 0 0 22px;
  padding: 0;
  list-style: none;
}
.home-ticket-card li {
  color: var(--home-text);
  font-size: 0.88rem;
  line-height: 1.7;
}
.home-ticket-card li::before {
  content: '';
  display: inline-block;
  width: 7px;
  height: 7px;
  margin-right: 9px;
  border-radius: 50%;
  background: var(--home-brand-2);
  transform: translateY(-1px);
}
.home-ticket-card li strong {
  color: var(--home-heading);
}
.home-ticket-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: auto;
  color: var(--home-brand);
