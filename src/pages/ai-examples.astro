---

<Layout
  title={`AI業務自動化デモ | 実用デモ${commonCases.length}件 + 業種別${industries.length}業種 + ロール別${roleDemos.length}件 | Optiens`}
  description={`問い合わせ振り分け、見積書作成、社内データ検索、承認ワークフローなど、実際に操作できるAI業務自動化デモを${commonCases.length}件公開しています。業種別デモとロール別デモも合わせてご覧ください。`}
  canonical="https://optiens.com/ai-examples"
>
  <main>
    <!-- 事例エクスプローラ -->
    <section class="ax-explorer light-section">
      <div class="container">
        <div class="ax-page-intro reveal">
          <p class="ax-page-kicker">AI業務自動化デモ</p>
          <h1>業務・業種・役割から、触れるAIデモを選べます</h1>
          <p>
            問い合わせ対応、見積書作成、社内検索、承認、文書レビューなど、
            中小企業の現場で検討しやすいAI活用例をサンプルデータで確認できます。
          </p>
          <div class="ax-page-badges" aria-label="公開デモの前提">
            <span><i class="fa-solid fa-database"></i>サンプルデータで動作</span>
            <span><i class="fa-solid fa-shield-halved"></i>外部AI API・第三者送信なし</span>
            <span><i class="fa-solid fa-route"></i>導入判断の情報まで確認</span>
          </div>
        </div>

        <!-- カテゴリタブ -->
        <div class="ax-tabs reveal" role="tablist" aria-label="事例カテゴリ">
          <button class="ax-tab active" data-cat="common" role="tab" aria-selected="true">
            <span class="ax-tab-label">実用デモ</span>
            <span class="ax-tab-count">{commonCases.length}</span>
          </button>
          <button class="ax-tab" data-cat="industry" role="tab" aria-selected="false">
            <span class="ax-tab-label">業種別デモ</span>
            <span class="ax-tab-count">{industries.length}</span>
          </button>
          <button class="ax-tab" data-cat="role" role="tab" aria-selected="false">
            <span class="ax-tab-label">ロール別デモ</span>
            <span class="ax-tab-count">{roleDemos.length}</span>
          </button>
        </div>

        <div class="ax-choice-guide reveal" aria-label="デモの選び方">
          <article>
            <span class="ax-choice-kicker">業務から選ぶ</span>
            <strong>すぐ試したい場合</strong>
            <p>問い合わせ、見積書、社内検索など、課題が見えている場合は実用デモから確認できます。</p>
          </article>
          <article>
            <span class="ax-choice-kicker">業種から選ぶ</span>
            <strong>自社に近い例を見たい場合</strong>
            <p>士業、宿泊、飲食、EC、建設、ベーカリー、自治体、観光などの業務文脈に近いデモへ進めます。</p>
          </article>
          <article>
            <span class="ax-choice-kicker">役割から選ぶ</span>
            <strong>誰が使うかを確認したい場合</strong>
            <p>経営者、役員、管理職、実務担当、バックオフィスの画面イメージを確認できます。</p>
          </article>
        </div>

        <!-- セレクタ + 詳細 -->
        <div class="ax-explorer-grid">
          <!-- 左：セレクタリスト -->
          <aside class="ax-selector" aria-label="事例選択リスト">
            <!-- 共通事例 -->
            <ul class="ax-selector-group" data-cat-group="common">
              {commonCases.map((c, idx) => (
                <li>
                  <button class={`ax-sel-item ax-sel-item--common-no-icon ${idx === 0 ? 'active' : ''}`} data-id={c.id}>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">{c.title}</span>
                      <span class="ax-sel-summary">{c.summary}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
            <!-- 業種別 -->
            <ul class="ax-selector-group hidden" data-cat-group="industry">
              {industries.map((i) => (
                <li>
                  <button class="ax-sel-item" data-id={i.id}>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">{i.shortTitle}</span>
                      <span class="ax-sel-summary">{i.metric}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
            <!-- ロール別 -->
            <ul class="ax-selector-group hidden" data-cat-group="role">
              {roleDemos.map((r) => (
                <li>
                  <button class="ax-sel-item" data-id={r.id}>
                    <span class="ax-sel-role-icon">
                      <i class={`fa-solid ${r.icon}`}></i>
                    </span>
                    <span class="ax-sel-body">
                      <span class="ax-sel-title">{r.shortTitle}</span>
                      <span class="ax-sel-summary">{r.metric}</span>
                    </span>
                    <i class="fa-solid fa-chevron-right ax-sel-chevron"></i>
                  </button>
                </li>
              ))}
            </ul>
          </aside>

          <!-- 右：詳細パネル -->
          <div class="ax-detail" aria-live="polite">
            <!-- 共通事例の詳細 -->
            {commonCases.map((c, idx) => (
              <article class={`ax-detail-card ${idx === 0 ? 'active' : ''}`} data-id={c.id} data-cat="common">
                <header class="ax-detail-head">
                  <h2 class="ax-detail-title">{c.title}</h2>
                </header>
                <p class="ax-detail-desc">{c.desc}</p>
                <div class="ax-detail-tags">
                  <span class="ax-detail-tags-label">適用業種：</span>
                  {c.tags.map((t: string) => <span class="ax-tag">{t}</span>)}
                </div>
                <div class="ax-detail-self">
                  <i class="fa-solid fa-flask"></i>
                  <p><strong>弊社での運用</strong>: {c.self}</p>
                </div>
                <div class="ax-implementation-notes" aria-label={`${c.title}の実案件化で確認すること`}>
                  <span class="ax-implementation-label">実案件化すると確認すること</span>
                  <dl class="ax-implementation-list">
                    <div>
                      <dt>1日の流れ</dt>
                      <dd>{c.implementation.dailyFlow}</dd>
                    </div>
                    <div>
                      <dt>必要なデータ</dt>
                      <dd>{c.implementation.requiredData}</dd>
                    </div>
                    <div>
                      <dt>人が確認する箇所</dt>
                      <dd>{c.implementation.humanCheck}</dd>
                    </div>
                    <div>
                      <dt>初回導入で作るもの</dt>
                      <dd>{c.implementation.firstBuild}</dd>
                    </div>
                  </dl>
                </div>
                <p class="ax-demo-safety-note">
                  <i class="fa-solid fa-lock"></i>
                  <span>公開デモはサンプルデータで動作します。一部デモは同一サイト内のデモAPIでテンプレート応答を返しますが、外部AI APIや第三者送信は発生しません。</span>
                </p>
                {c.demo ? (
                  <>
                    <a href={c.demo.href} class="btn-primary ax-detail-cta">
                      <i class="fa-solid fa-circle-play"></i>
                      {c.demo.label}
                      <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    {c.demo.note ? (
                      <p class="ax-detail-demo-note">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>{c.demo.note}</span>
                      </p>
                    ) : null}
                  </>
                ) : null}
              </article>
            ))}
            <!-- 業種別の詳細 -->
            {industries.map((i) => (
              <article class="ax-detail-card" data-id={i.id} data-cat="industry">
                <header class="ax-detail-head">
                  <h2 class="ax-detail-title">{i.title}</h2>
                </header>
                <p class="ax-detail-desc">{i.summary}を含む業務全体を、御社の現場に合わせて再設計します。業種別ページでは、課題、導入手順、想定削減時間に加えて、関連する実機デモも確認できます。</p>
                <div class="ax-detail-metric">
                  <span class="ax-metric-label">想定削減時間</span>
                  <span class="ax-metric-value">{i.metric}</span>
                  <p class="ax-basis-note">
                    <i class="fa-solid fa-calculator"></i>
                    <span>{i.basis}</span>
                  </p>
                </div>
                <div class="ax-related-demos" aria-label={`${i.shortTitle}で試しやすいデモ`}>
                  <span class="ax-related-label">この業種で試しやすいデモ</span>
                  <div class="ax-related-links">
                    {i.relatedDemos.map((demo, index) => (
                      <a class={`ax-related-demo-link ${index === 0 ? 'ax-related-demo-link--primary' : ''}`} href={demo.href}>
                        <span>{index === 0 ? 'まず試す' : '関連デモ'}</span>
                        <strong>{demo.label}</strong>
                        <i class="fa-solid fa-arrow-right"></i>
                      </a>
                    ))}
                  </div>
                </div>
                <p class="ax-demo-safety-note">
                  <i class="fa-solid fa-lock"></i>
                  <span>関連する実機デモはサンプルデータで確認できます。一部デモは同一サイト内のデモAPIでテンプレート応答を返しますが、外部AI APIや第三者送信は発生しません。</span>
                </p>
                <div class="ax-industry-actions">
                  {i.relatedDemos[0] && (
                    <a href={i.relatedDemos[0].href} class="btn-primary ax-detail-cta">
                      <i class="fa-solid fa-circle-play"></i>
                      {i.shortTitle}向けの実機デモを試す
                      <i class="fa-solid fa-arrow-right"></i>
                    </a>
                  )}
                  <a href={i.href} class="btn-secondary ax-detail-cta">
                    業種別資料を見る
                    <i class="fa-solid fa-arrow-right"></i>
                  </a>
                </div>
                {i.demo?.note && (
                  <p class="ax-detail-demo-note">
                    <i class="fa-solid fa-circle-info"></i>
                    <span>{i.demo.note}</span>
                  </p>
                )}
              </article>
            ))}
            <!-- ロール別の詳細 -->
            {roleDemos.map((r) => (
              <article class="ax-detail-card" data-id={r.id} data-cat="role">
                <header class="ax-detail-head">
                  <span class="ax-detail-eyebrow">{r.tag}</span>
                  <div class="ax-detail-icon ax-detail-icon--role">
                    <i class={`fa-solid ${r.icon}`}></i>
                  </div>
                  <h2 class="ax-detail-title">{r.title}</h2>
                </header>
                <p class="ax-detail-desc">{r.summary}。役割ごとに必要な情報、操作権限、確認ポイントを分けた状態で、実際の画面遷移を確認できます。</p>
                <div class="ax-detail-metric">
                  <span class="ax-metric-label">想定効果</span>
                  <span class="ax-metric-value">{r.metric}</span>
                  <p class="ax-basis-note">
                    <i class="fa-solid fa-calculator"></i>
                    <span>{r.basis}</span>
                  </p>
                </div>
                <p class="ax-demo-safety-note">
                  <i class="fa-solid fa-lock"></i>
                  <span>ロール別デモはブラウザ内のサンプル表示で動作し、外部AI APIや第三者送信は発生しません。</span>
                </p>
                <a href={r.href} class="btn-primary ax-detail-cta">
                  <i class="fa-solid fa-circle-play"></i>
                  {r.cta}
                  <i class="fa-solid fa-arrow-right"></i>
                </a>
                <p class="ax-detail-demo-note">
                  <i class="fa-solid fa-circle-info"></i>
                  <span>{r.note}</span>
                </p>
              </article>
            ))}
          </div>
        </div>

        <section class="ax-adjacent-industries reveal" aria-labelledby="ax-adjacent-title">
          <div class="ax-adjacent-head">
            <span>近い業種から探す</span>
            <h2 id="ax-adjacent-title">一覧にない業種でも、近いデモから確認できます</h2>
            <p>業種別資料をまだ用意していない業種でも、業務の構造が近いデモを組み合わせて導入イメージを確認できます。</p>
          </div>
          <div class="ax-adjacent-grid">
            {nearbyIndustries.map((industry) => (
              <article>
                <h3>{industry.title}</h3>
                <p>{industry.summary}</p>
                <div class="ax-adjacent-links">
                  {industry.demos.map((demo) => (
                    <a href={demo.href}>
                      {demo.label}
                      <i class="fa-solid fa-arrow-right"></i>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>

        <p class="ax-bridge-note reveal">
          掲載デモは、単機能の紹介ではなく、既存SaaS・スプレッドシート・メール・手作業のうち、どこを残し、どこをつなぎ、どこをAIで置き換えるかを検討するためのサンプルです。業種別・ロール別の入り口からも、実際に触れるデモへ進めます。サービス内容は <a href="/service">AI支援ページ</a> をご確認ください。
        </p>
      </div>
    </section>

    <!-- ファイナルCTA -->
    <section class="ax-decision-section">
      <div class="container">
        <div class="ax-decision-head reveal">
          <h2>導入判断に必要な情報</h2>
          <p>デモで動きを確認したあと、実際に検討する際に見られるポイントをまとめています。削減余地、自動化候補、回収期間の目安は、診断で業務量と既存ツールを確認して整理します。</p>
        </div>
        <div class="ax-decision-grid">
          <article class="reveal">
            <i class="fa-solid fa-yen-sign"></i>
            <h3>費用感</h3>
            <p>AI活用診断簡易版は無料、詳細診断は¥5,500税込です。導入支援は、残すSaaS・つなぐSaaS・専用化する範囲を見て個別に見積もります。</p>
          </article>
          <article class="reveal">
            <i class="fa-solid fa-calendar-check"></i>
            <h3>導入期間</h3>
            <p>小さな自動化は数週間、本格導入は要件範囲により数ヶ月を目安に、段階的に動かします。</p>
          </article>
          <article class="reveal">
            <i class="fa-solid fa-folder-open"></i>
            <h3>必要な資料</h3>
            <p>業務フロー、帳票、マニュアル、よくある問い合わせ、既存ツールの項目があると精度を上げやすくなります。</p>
          </article>
          <article class="reveal">
            <i class="fa-solid fa-plug-circle-bolt"></i>
            <h3>デモの前提</h3>
            <p>公開デモはサンプルデータで確認できます。実案件ではAI APIや既存ツール連携の有無を、扱う情報と業務リスクに合わせて設計します。</p>
          </article>
          <article class="reveal">
            <i class="fa-solid fa-shield-halved"></i>
            <h3>セキュリティ</h3>
            <p>外部送信したくない情報は、ローカルLLMや権限分離を含めて扱い方を分けます。</p>
          </article>
          <article class="reveal">
            <i class="fa-solid fa-route"></i>
            <h3>次の進め方</h3>
            <p>まず無料診断で効果が出やすい業務、残すSaaS、つなぐSaaS、AI化候補を整理し、必要に応じて詳細レポートや導入支援へ進みます。</p>
          </article>
        </div>
        <div class="ax-decision-links reveal">
          <a href="/service">サービス内容を見る</a>
          <a href="/security">情報セキュリティ方針を見る</a>
          <a href="/free-diagnosis?lead_source=ai-examples&lead_source_detail=AI活用サンプル一覧">無料診断へ進む</a>
        </div>
      </div>
    </section>

    <section class="ax-cta-section">
      <div class="container text-center">
        <h2 class="reveal">御社で使うなら、どの業務から着手すべきかを診断します</h2>
        <p class="reveal">
          既存SaaSや手作業を見たうえで、どこを残し、どこをAI化すべきか。<br />
          AI活用診断簡易版のレポートで数値とともにご提案します。
        </p>
        <div class="cta-buttons reveal">
          <a href="/free-diagnosis?lead_source=ai-examples&lead_source_detail=AI活用サンプル一覧" class="btn-primary">AI活用診断簡易版を受ける</a>
          <a href="/service" class="btn-secondary">サービス内容を見る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
(function() {
  const tabs = document.querySelectorAll('.ax-tab');
  const groups = document.querySelectorAll('.ax-selector-group');
  const detailCards = document.querySelectorAll('.ax-detail-card');
  const selItems = document.querySelectorAll('.ax-sel-item');

  function selectCategory(cat) {
    // タブ更新
    tabs.forEach((t) => {
      const isActive = t.dataset.cat === cat;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    // セレクタグループ更新
    groups.forEach((g) => {
      g.classList.toggle('hidden', g.dataset.catGroup !== cat);
    });
    // そのカテゴリの最初の項目を選択
    const firstItem = document.querySelector(`.ax-selector-group[data-cat-group="${cat}"] .ax-sel-item`);
    if (firstItem) selectItem(firstItem.dataset.id);
  }

  function selectItem(id) {
    if (!id) return;
    selItems.forEach((b) => b.classList.toggle('active', b.dataset.id === id));
    detailCards.forEach((c) => c.classList.toggle('active', c.dataset.id === id));
    // 詳細パネルへスクロール（モバイル対応）
    if (window.innerWidth <= 900) {
      const target = document.querySelector(`.ax-detail-card.active`);
      if (target) {
        const offset = target.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: offset, behavior: 'smooth' });
      }
    }
    // URLハッシュ更新
    if (history.replaceState) history.replaceState(null, '', '#' + id);
  }

  tabs.forEach((t) => {
    t.addEventListener('click', () => selectCategory(t.dataset.cat));
  });
  selItems.forEach((b) => {
    b.addEventListener('click', () => selectItem(b.dataset.id));
  });

  // 初期表示：URLハッシュがあればそれを選択
  const hash = window.location.hash.replace('#', '');
  if (hash) {
    const target = document.querySelector(`.ax-sel-item[data-id="${hash}"]`);
    if (target) {
      const cat = target.closest('.ax-selector-group')?.dataset.catGroup;
      if (cat) {
        selectCategory(cat);
        selectItem(hash);
        return;
      }
    }
  }
  // ?cat=industry|common|role でカテゴリ初期選択
  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('cat');
  if (catParam && ['common', 'industry', 'role'].includes(catParam)) {
    selectCategory(catParam);
  }
})();
</script>

