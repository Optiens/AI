---
import Layout from '../layouts/Layout.astro';

import bgUrl from '~/assets/ai-nature-city.webp?url';
---

<Layout title="ロードマップ | Optiens">
  <main>

    <!-- ===== Hero ===== -->
    <section class="hero-section" style={`--hero-bg: url(${bgUrl});`}>
      <div class="container text-center">
        <h1>ロードマップ</h1>
        <p class="hero-sub">IoT×AI水耕栽培ハーブ生産の段階的な実行計画</p>
      </div>
    </section>

    <!-- ===== 概要 ===== -->
    <section class="section-intro container prose">
      <h2>実行計画の概要</h2>
      <p>
        Optiensは自宅でのテスト栽培から始め、IoT×AIによる自動化水耕栽培システムを段階的に拡大します。センサーデータの蓄積と栽培レシピの確立を最優先し、仕組みが安定してから生産規模を拡大。テクノロジーの力で、1人でもスケールできる農業モデルを実証します。
      </p>
    </section>

    <!-- ===== タイムライン ===== -->
    <section class="section-timeline container">
      <ol class="timeline" aria-label="実行ロードマップ">

        <!-- Phase 1 ★現在フェーズ -->
        <li class="phase phase--current" id="phase1">
          <div class="phase-header">
            <span class="phase-badge phase-badge--current">Phase 1</span>
            <span class="phase-status">進行中</span>
          </div>
          <h2 class="phase-title">自宅テスト栽培・IoTシステム構築</h2>
          <p class="phase-period">～2026年9月</p>
          <ul class="phase-items">
            <li>メタルラック1台で循環式水耕栽培開始（バジル＋マイクログリーン）</li>
            <li>RPi×2+センサー群でIoT環境モニタリング構築</li>
            <li>Claude Code×MCPによるAI制御システム安定化</li>
            <li>栽培データ蓄積・品種別レシピ構築</li>
            <li>販売なし（自家消費でノウハウ蓄積）</li>
          </ul>
          <p class="phase-goal"><strong>目標：</strong>IoTシステム稼働率99%、栽培成功率90%以上</p>
        </li>

        <!-- Phase 2 -->
        <li class="phase phase--upcoming" id="phase2">
          <div class="phase-header">
            <span class="phase-badge">Phase 2</span>
            <span class="phase-status">次フェーズ</span>
          </div>
          <h2 class="phase-title">廃校教室で生産開始</h2>
          <p class="phase-period">2026年10月～2027年3月</p>
          <ul class="phase-items">
            <li>北杜市の廃校教室（20m²）に移転</li>
            <li>パート1名雇用（週3日×4時間）</li>
            <li>レストラン・道の駅・ECへの販売開始</li>
            <li>作業者はマニュアル+AIアプリの指示で運営</li>
            <li>補助金申請（チャレンジ農業・ものづくり補助金）</li>
          </ul>
          <p class="phase-goal"><strong>目標：</strong>レストラン3-5店舗と取引確立、月間売上8万円</p>
        </li>

        <!-- Phase 3 -->
        <li class="phase phase--future" id="phase3">
          <div class="phase-header">
            <span class="phase-badge">Phase 3</span>
            <span class="phase-status">計画</span>
          </div>
          <h2 class="phase-title">拡大・横展開</h2>
          <p class="phase-period">2027年4月～</p>
          <ul class="phase-items">
            <li>教室2-3室に拡大（60m²）</li>
            <li>EC定期便サービス開始</li>
            <li>栽培品目の拡充</li>
            <li>仕組みの横展開（他拠点 or フランチャイズ的展開）</li>
          </ul>
          <p class="phase-goal"><strong>目標：</strong>月間売上30-50万円、月間利益10-20万円</p>
        </li>

      </ol>
    </section>

    <!-- ===== 主要指標 ===== -->
    <section class="section-kpis container prose">
      <h2>主要指標と目標値</h2>
      <ul class="ticks">
        <li><strong>栽培成功率：</strong>Phase 1完了時に90%以上</li>
        <li><strong>IoTシステム稼働率：</strong>24時間無人運転99%以上</li>
        <li><strong>販路：</strong>Phase 2でレストラン3-5店舗</li>
        <li><strong>月間売上：</strong>Phase 2で月8万円、Phase 3で月30-50万円</li>
        <li><strong>生産効率：</strong>1m²あたり収穫量の継続的改善</li>
      </ul>
    </section>

    <!-- ===== CTA ===== -->
    <section class="section-cta container">
      <h2>お問い合わせ</h2>
      <p>協業・販路パートナーシップに関するご相談は下記よりご連絡ください。</p>
      <div class="cta-btns">
        <a href="/contact" class="btn-primary">お問い合わせ</a>
        <a href="/investors" class="btn-secondary">投資家情報を見る</a>
      </div>
    </section>

    <!-- ===== 注記 ===== -->
    <section class="section-notes container">
      <p class="note-text">※ 本ページのスケジュール・数値目標・ロードマップは将来予測を含み、変更される可能性があります。</p>
    </section>

  </main>
</Layout>

<style>
/* ========== Layout ========== */
:root {
  --maxw: 860px;
  --header-offset-mobile: 84px;
  --header-offset-desktop: 104px;
}

main {
  padding-top: calc(env(safe-area-inset-top, 0px) + var(--header-offset-desktop));
}
@media (max-width: 768px) {
  main { padding-top: calc(env(safe-area-inset-top, 0px) + var(--header-offset-mobile)); }
}

section { padding: clamp(48px, 8vw, 80px) 0; }

.container { width: min(var(--maxw), 100% - 2rem); margin-inline: auto; }

/* ========== Hero sub ========== */
.hero-sub {
  font-size: clamp(14px, 1.8vw, 17px);
  margin-top: .75rem;
  opacity: .9;
  line-height: 1.7;
}

/* ========== Intro ========== */
.section-intro { padding-bottom: 0; }

/* ========== Timeline ========== */
.section-timeline { padding-top: clamp(32px, 5vw, 56px); }

.timeline {
  list-style: none;
  padding: 0;
  margin: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* 縦線 */
.timeline::before {
  content: '';
  position: absolute;
  left: 28px;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--brand), var(--brand-2) 60%, #ccc);
  border-radius: 2px;
  z-index: 0;
}

/* ========== Phase カード ========== */
.phase {
  position: relative;
  padding: 28px 28px 28px 76px;
  border-radius: 12px;
  margin-bottom: 24px;
  transition: box-shadow .2s ease, transform .2s ease;
}
.phase:last-child { margin-bottom: 0; }

/* 縦線上の丸 */
.phase::before {
  content: '';
  position: absolute;
  left: 20px;
  top: 32px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 3px solid var(--brand);
  background: var(--surface);
  z-index: 1;
}

/* ---- 現在フェーズ ---- */
.phase--current {
  background: color-mix(in srgb, var(--brand) 8%, transparent);
  border: 2px solid var(--brand);
  box-shadow: 0 6px 20px rgba(46,87,76,.14);
}
.phase--current::before {
  background: var(--brand);
  border-color: var(--brand);
  box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand) 20%, transparent);
}
.phase--current:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(46,87,76,.18);
}

/* ---- 次フェーズ ---- */
.phase--upcoming {
  background: color-mix(in srgb, var(--brand-2) 6%, transparent);
  border: 1.5px solid color-mix(in srgb, var(--brand-2) 40%, transparent);
}
.phase--upcoming::before {
  border-color: var(--brand-2);
}

/* ---- 将来フェーズ ---- */
.phase--future {
  background: var(--surface-2, #f7f7f7);
  border: 1.5px solid #e0e0e0;
}
.phase--future::before {
  border-color: #bbb;
}

/* ========== Phase ヘッダー ========== */
.phase-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.phase-badge {
  display: inline-block;
  padding: 3px 12px;
  border-radius: 9999px;
  font-size: .82rem;
  font-weight: 700;
  background: var(--brand);
  color: #fff;
  letter-spacing: .04em;
}
.phase-badge--current {
  background: var(--brand);
  box-shadow: 0 2px 8px rgba(46,87,76,.3);
}
.phase--upcoming .phase-badge { background: var(--brand-2); }
.phase--future .phase-badge {
  background: #999;
}

.phase-status {
  font-size: .8rem;
  color: var(--muted);
  font-weight: 500;
}
.phase--current .phase-status {
  color: var(--brand);
  font-weight: 700;
}

/* ========== Phase コンテンツ ========== */
.phase-title {
  font-size: clamp(18px, 2.4vw, 22px);
  font-weight: 800;
  color: var(--heading);
  margin: 0 0 4px;
  line-height: 1.3;
}

.phase-period {
  font-size: .88rem;
  color: var(--muted);
  margin: 0 0 16px;
  font-weight: 500;
}
.phase--current .phase-period { color: var(--brand); font-weight: 700; }

.phase-items {
  list-style: none;
  padding: 0;
  margin: 0 0 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.phase-items li {
  position: relative;
  padding-left: 1.4em;
  font-size: .95rem;
  line-height: 1.7;
  color: var(--text);
}
.phase-items li::before {
  content: '›';
  position: absolute;
  left: 0;
  top: 0;
  color: var(--brand-2);
  font-weight: 700;
  font-size: 1.1em;
  line-height: 1.5;
}
.phase--future .phase-items li { color: var(--muted); }

.phase-goal {
  font-size: .9rem;
  color: var(--text);
  background: color-mix(in srgb, var(--brand) 6%, transparent);
  border-left: 3px solid var(--brand);
  padding: 8px 12px;
  border-radius: 0 6px 6px 0;
  margin: 0;
  line-height: 1.6;
}
.phase--future .phase-goal {
  background: rgba(0,0,0,.03);
  border-left-color: #bbb;
  color: var(--muted);
}

/* ========== KPIs ========== */
.section-kpis {
  background: var(--surface-2, #f7f7f7);
  border-radius: 16px;
  padding: clamp(32px, 5vw, 56px) clamp(20px, 4vw, 40px);
}
.ticks { list-style: none; padding: 0; margin: 0; }
.ticks li {
  position: relative;
  padding-left: 1.6rem;
  margin: .6rem 0;
  line-height: 1.7;
  font-size: .97rem;
  color: var(--text);
}
.ticks li::before {
  content: '✔';
  position: absolute;
  left: 0;
  top: 0;
  line-height: 1.4;
  color: var(--brand);
  font-size: .9em;
}

/* ========== CTA ========== */
.section-cta {
  text-align: center;
}
.section-cta h2 {
  font-size: clamp(20px, 2.8vw, 26px);
  color: var(--heading);
  margin: 0 0 .75rem;
}
.section-cta p {
  color: var(--muted);
  margin: 0 0 1.5rem;
  font-size: .97rem;
}
.cta-btns {
  display: flex;
  gap: .9rem;
  flex-wrap: wrap;
  justify-content: center;
}
.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: .75rem 1.25rem;
  min-height: 44px;
  font-size: clamp(14px, 1.6vw, 16px);
  font-weight: 700;
  cursor: pointer;
  color: var(--brand);
  background: transparent;
  border: 2px solid var(--brand);
  border-radius: 9999px;
  transition: background .2s ease, color .2s ease, transform .2s ease;
  text-decoration: none;
}
.btn-secondary:hover {
  background: color-mix(in srgb, var(--brand) 8%, transparent);
  transform: translateY(-1px);
}

/* ========== Notes ========== */
.section-notes { padding-top: 0; }
.note-text {
  font-size: .88rem;
  color: var(--muted);
  text-align: center;
}

/* ========== Responsive ========== */
@media (max-width: 640px) {
  .timeline::before { left: 20px; }
  .phase { padding: 20px 16px 20px 56px; }
  .phase::before { left: 12px; top: 24px; width: 16px; height: 16px; }
  .phase-title { font-size: clamp(17px, 4.5vw, 20px); }
  .cta-btns { flex-direction: column; align-items: stretch; }
  .cta-btns .btn-primary,
  .cta-btns .btn-secondary { text-align: center; }
}
</style>
