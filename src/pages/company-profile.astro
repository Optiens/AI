---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="会社概要 | 合同会社Optiens"
  description="合同会社Optiens（オプティエンス）の会社概要。山梨県北杜市を拠点に、AI活用支援とIoT水耕栽培の自社実証を組み合わせた事業を運営しています。"
  canonical="https://optiens.com/company-profile"
>
  <main class="cp-main">

    <!-- ヒーロー -->
    <section class="cp-hero light-section">
      <div class="container">
        <p class="cp-eyebrow">COMPANY PROFILE</p>
        <h1>会社概要</h1>
        <p class="cp-sub">合同会社Optiens（オプティエンス）<br/>山梨県北杜市を拠点に、AI活用支援を全国オンラインで提供しています。</p>
        <p class="cp-meta">最終更新日: 2026年5月5日</p>
      </div>
    </section>

    <!-- ハイライトカード -->
    <section class="cp-highlight-section light-section">
      <div class="container">
        <div class="cp-highlight-grid">
          <div class="cp-highlight-card">
            <span class="cp-highlight-label">設立</span>
            <p class="cp-highlight-value">2026.04.06</p>
            <p class="cp-highlight-note">合同会社として登記</p>
          </div>
          <div class="cp-highlight-card">
            <span class="cp-highlight-label">拠点</span>
            <p class="cp-highlight-value">山梨県北杜市</p>
            <p class="cp-highlight-note">全国オンライン対応</p>
          </div>
          <div class="cp-highlight-card">
            <span class="cp-highlight-label">事業</span>
            <p class="cp-highlight-value">AI 支援 / IoT 実証</p>
            <p class="cp-highlight-note">自社で使い、自社で改善</p>
          </div>
          <div class="cp-highlight-card">
            <span class="cp-highlight-label">体制</span>
            <p class="cp-highlight-value">代表 1 名 + AI</p>
            <p class="cp-highlight-note">AIエージェント連携で運営</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 法人情報 -->
    <section class="cp-section light-section">
      <div class="container cp-container">
        <article class="cp-block">
          <table class="cp-table">
            <tbody>
              <tr><th>商号</th><td>合同会社Optiens（オプティエンス）</td></tr>
              <tr><th>英字表記</th><td>Optiens LLC</td></tr>
              <tr><th>設立</th><td>2026年4月6日</td></tr>
              <tr><th>代表社員</th><td>髙橋 大地</td></tr>
              <tr><th>所在地</th><td>〒407-0301 山梨県北杜市高根町清里3545番地2483</td></tr>
              <tr><th>資本金</th><td>100,000円</td></tr>
              <tr><th>法人番号</th><td>9090003003025</td></tr>
              <tr><th>事業内容</th><td>AI活用支援、IoT水耕栽培の自社実証</td></tr>
              <tr><th>インボイス登録</th><td>適格請求書発行事業者 申請中</td></tr>
              <tr><th>取引銀行</th><td>GMOあおぞらネット銀行 フリー支店</td></tr>
              <tr><th>連絡先</th><td><a href="mailto:info@optiens.com">info@optiens.com</a></td></tr>
            </tbody>
          </table>

          <p class="cp-related-links">
            関連:
            <a href="/message">メッセージ</a>
            <span aria-hidden="true">·</span>
            <a href="/service">サービス</a>
            <span aria-hidden="true">·</span>
            <a href="/contact">お問い合わせ</a>
          </p>
        </article>
      </div>
    </section>

  </main>
</Layout>

<style>
  .cp-main {
    color: var(--text);
    background: #ffffff;
  }

  /* ===== Hero ===== */
  .cp-hero {
    padding: clamp(110px, 14vw, 160px) 0 clamp(48px, 7vw, 72px);
    background: #ffffff;
    border-bottom: 1px solid var(--border);
  }
  .cp-eyebrow {
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .25em;
    color: var(--brand);
    margin: 0 0 14px;
  }
  .cp-hero h1 {
    color: var(--heading);
    font-size: clamp(1.7rem, 4.4vw, 2.6rem);
    margin: 0 0 18px;
    letter-spacing: -.01em;
  }
  .cp-sub {
    font-size: clamp(.94rem, 1.7vw, 1.05rem);
    color: var(--muted);
    line-height: 1.85;
    margin: 0 0 12px;
  }
  .cp-meta {
    font-size: .78rem;
    color: var(--muted);
    margin: 0;
    letter-spacing: .04em;
  }

  /* ===== Highlight ===== */
  .cp-highlight-section {
    padding: clamp(36px, 6vw, 56px) 0;
    background: #ffffff;
  }
  .cp-highlight-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(12px, 1.6vw, 18px);
    max-width: 980px;
    margin: 0 auto;
  }
  .cp-highlight-card {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: clamp(18px, 2.4vw, 24px) clamp(16px, 2vw, 22px);
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .cp-highlight-card:hover {
    transform: translateY(-2px);
    border-color: rgba(162, 89, 255, .35);
    box-shadow: 0 10px 28px rgba(15, 23, 42, .06);
  }
  .cp-highlight-label {
    display: inline-block;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .14em;
    color: var(--brand);
    margin-bottom: 10px;
  }
  .cp-highlight-value {
    font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
    font-size: clamp(1.1rem, 1.9vw, 1.35rem);
    font-weight: 700;
    color: var(--heading);
    margin: 0 0 6px;
    letter-spacing: -.01em;
    line-height: 1.3;
  }
  .cp-highlight-note {
    font-size: .78rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }
  @media (max-width: 768px) {
    .cp-highlight-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ===== Section ===== */
  .cp-section {
    padding: clamp(48px, 7vw, 72px) 0 clamp(64px, 10vw, 100px);
    background: #ffffff;
  }
  .cp-container {
    max-width: 760px;
  }
  .cp-block {
    background: transparent;
  }

  /* ===== Table ===== */
  .cp-table {
    width: 100%;
    border-collapse: collapse;
    border-top: 1px solid var(--border);
  }
  .cp-table th,
  .cp-table td {
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
    font-size: .92rem;
    line-height: 1.7;
  }
  .cp-table th {
    width: 32%;
    color: var(--muted);
    font-weight: 600;
    white-space: nowrap;
    font-size: .85rem;
    letter-spacing: .02em;
    background: #fafbfc;
  }
  .cp-table td {
    color: var(--text);
    font-weight: 500;
  }
  .cp-table a {
    color: var(--brand);
    text-decoration: underline;
  }

  .cp-related-links {
    margin: 28px 0 0;
    font-size: .82rem;
    color: var(--muted);
    line-height: 1.8;
  }
  .cp-related-links a {
    color: var(--brand);
    text-decoration: none;
    margin: 0 4px;
  }
  .cp-related-links a:hover {
    text-decoration: underline;
  }
  .cp-related-links span {
    color: var(--border);
    margin: 0 2px;
  }

  @media (max-width: 768px) {
    .cp-table th {
      width: 38%;
      font-size: .8rem;
      padding: 12px 12px;
    }
    .cp-table td {
      font-size: .88rem;
      padding: 12px 12px;
    }
  }

  @media print {
    .cp-section,
    .cp-hero,
    .cp-highlight-section {
      background: #fff;
    }
    .cp-block {
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }
</style>
