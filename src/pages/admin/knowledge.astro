---
import { getCollection } from 'astro:content';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { knowledgeDocs } from '../../lib/optiens-knowledge';
import { dbKnowledgeEntryToDoc, listKnowledgeEntries } from '../../lib/admin-ops';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => String(b.data.date).localeCompare(String(a.data.date)));

const categoryLabels: Record<string, string> = {
  AI: 'AI支援',
  business: '経営',
  technology: '技術',
  agriculture: '水耕栽培',
  welfare: '福祉',
  social: '社会',
  announcement: 'お知らせ',
};

const categoryRows = Object.entries(
  posts.reduce<Record<string, number>>((acc, post) => {
    const key = post.data.category || 'unknown';
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  }, {})
)
  .map(([id, count]) => ({ id, label: categoryLabels[id] || id, count }))
  .sort((a, b) => b.count - a.count);

const latestPosts = posts.slice(0, 12);
const { entries: editableKnowledgeEntries, error: editableKnowledgeError } = await listKnowledgeEntries();
const editableKnowledgeDocs = editableKnowledgeEntries.map(dbKnowledgeEntryToDoc);
const allKnowledgeDocs = [...knowledgeDocs, ...editableKnowledgeDocs];

const knowledgeSources = [
  {
    title: 'AI支援事業の案件運用',
    status: '稼働中',
    owner: 'CEO / COO',
    source: 'diagnosis_leads, ai_api_events',
    action: '案件、API障害、日次アラートへ接続済み',
  },
  {
    title: '無料診断・詳細診断のSOP',
    status: '整備中',
    owner: 'CMO / CSO',
    source: 'executive/ai-consulting, scripts/generate-*',
    action: '見積、納品、メール文面、レポート生成手順をSOP化',
  },
  {
    title: 'ブログ/公開ナレッジ',
    status: '素材あり',
    owner: 'CMO',
    source: 'src/content/blog',
    action: '業種別・論点別に営業資料へ再利用',
  },
  {
    title: '水耕栽培H1/H2判断材料',
    status: '未統合',
    owner: 'CFO / CRO',
    source: 'unit economics, sensor_data, cycles',
    action: '1株コスト、CV、kWh/kgを別ダッシュボード化',
  },
  {
    title: '補助金・期限・会計',
    status: '未統合',
    owner: 'CFO',
    source: 'Google Tasks, freee, executive/research',
    action: '月次/期限レポートとして日次メールに接続',
  },
];

const buildItems = [
  '質問して答えが不足した内容は、SOPまたはナレッジ本文へ追記する',
  '顧客別の提案・MTGメモ・次回アクションは、リード詳細から紐づける',
  '価格、ターゲット、禁止方針、Phase移行条件は決定ログとして残す',
  'プロンプト、メール、Slides、提案書テンプレはバージョンと変更理由を管理する',
  'ナレッジごとに責任者、最終更新日、次回見直し日を持たせる',
];

const categoryDocRows = Object.entries(
  allKnowledgeDocs.reduce<Record<string, number>>((acc, doc) => {
    acc[doc.category] = (acc[doc.category] || 0) + 1;
    return acc;
  }, {})
).map(([category, count]) => ({ category, count })).sort((a, b) => b.count - a.count);

const demoSafeCount = allKnowledgeDocs.filter((doc) => doc.visibility === 'demo-safe').length;
const demoReadyCount = allKnowledgeDocs.filter((doc) => doc.maturity === 'demo-ready').length;

function visibilityLabel(value: string) {
  return value === 'demo-safe' ? 'デモ可' : '社内限定';
}

function maturityLabel(value: string) {
  if (value === 'demo-ready') return 'デモ準備済み';
  if (value === 'operational') return '運用中';
  return '追加中';
}
---

<AdminLayout title="ナレッジ" active="knowledge">
  <section class="hero-panel">
    <div>
      <span>Optiens Knowledge Base</span>
      <h2>人が入った時に、Optiensの仕事を質問できる社内ナレッジにする</h2>
      <p>事業方針、営業SOP、AI/API運用、毎朝の確認、水耕栽培KPI、禁止表現を同じ棚に置き、質問欄から回答できる形にします。</p>
    </div>
    <strong>{allKnowledgeDocs.length}<small>社内ナレッジ</small></strong>
  </section>

  {editableKnowledgeError && (
    <div class="alert-box">
      <i class="fas fa-circle-exclamation"></i>
      <span>{editableKnowledgeError}</span>
    </div>
  )}

  <section class="panel ask-panel">
    <div class="panel-head">
      <div>
        <span>Ask Optiens</span>
        <h3>業務について質問する</h3>
      </div>
    </div>
    <div class="ask-grid">
      <label>
        <span>質問</span>
        <textarea id="knowledge-question" rows="4" placeholder="例: 詳細レポートの入金後は何をすればいいですか？"></textarea>
      </label>
      <div class="ask-actions">
        <button type="button" id="knowledge-ask-button"><i class="fas fa-message"></i> 質問する</button>
        <small>回答は社内ナレッジを根拠に生成します。不足が出た内容はナレッジ化候補です。</small>
      </div>
    </div>
    <div class="answer-box" id="knowledge-answer">まだ質問していません。</div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Internal DB</span>
        <h3>Optiens標準業務ナレッジ</h3>
      </div>
    </div>
    <div class="knowledge-stats">
      <div>
        <b>{allKnowledgeDocs.length}</b>
        <span>登録ナレッジ</span>
      </div>
      <div>
        <b>{demoSafeCount}</b>
        <span>デモ公開候補</span>
      </div>
      <div>
        <b>{demoReadyCount}</b>
        <span>デモ準備済み</span>
      </div>
    </div>
    <div class="doc-grid">
      {allKnowledgeDocs.map((doc) => (
        <article class="doc-card">
          <div class="doc-badges">
            <span>{doc.category}</span>
            <span class={doc.visibility === 'demo-safe' ? 'badge-ok' : 'badge-warn'}>{visibilityLabel(doc.visibility)}</span>
          </div>
          <strong>{doc.title}</strong>
          <p>{doc.summary}</p>
          <small>{doc.owner} / {doc.updatedAt} / {maturityLabel(doc.maturity)}</small>
        </article>
      ))}
    </div>
  </section>

  <section class="panel edit-panel">
    <div class="panel-head">
      <div>
        <span>Editable DB</span>
        <h3>ナレッジを追加・編集する</h3>
      </div>
      <a href="/admin/audit" class="panel-link">監査ログへ</a>
    </div>
    <form class="knowledge-form" id="knowledge-entry-form">
      <input type="hidden" name="id" id="knowledge-entry-id" />
      <label>
        <span>タイトル</span>
        <input name="title" id="knowledge-entry-title" required />
      </label>
      <label>
        <span>カテゴリ</span>
        <select name="category" id="knowledge-entry-category">
          <option value="business">business</option>
          <option value="sales">sales</option>
          <option value="operations" selected>operations</option>
          <option value="ai">ai</option>
          <option value="hydroponics">hydroponics</option>
          <option value="brand">brand</option>
          <option value="governance">governance</option>
        </select>
      </label>
      <label>
        <span>責任者</span>
        <input name="owner" id="knowledge-entry-owner" value="COO" />
      </label>
      <label>
        <span>公開区分</span>
        <select name="visibility" id="knowledge-entry-visibility">
          <option value="internal">internal</option>
          <option value="demo-safe">demo-safe</option>
        </select>
      </label>
      <label>
        <span>成熟度</span>
        <select name="maturity" id="knowledge-entry-maturity">
          <option value="seed">seed</option>
          <option value="operational">operational</option>
          <option value="demo-ready">demo-ready</option>
        </select>
      </label>
      <label>
        <span>タグ</span>
        <input name="tags" id="knowledge-entry-tags" placeholder="SOP, 営業, 引き継ぎ" />
      </label>
      <label class="field-wide">
        <span>要約</span>
        <textarea name="summary" id="knowledge-entry-summary" rows="3" required></textarea>
      </label>
      <label class="field-wide">
        <span>本文</span>
        <textarea name="body" id="knowledge-entry-body" rows="7" required></textarea>
      </label>
      <div class="form-actions">
        <button type="submit" id="knowledge-entry-save"><i class="fas fa-floppy-disk"></i> 保存する</button>
        <button type="button" id="knowledge-entry-reset" class="ghost-button">新規入力に戻す</button>
        <small id="knowledge-entry-result">保存すると監査ログにも記録されます。</small>
      </div>
    </form>

    <div class="editable-list">
      {editableKnowledgeEntries.length === 0 ? (
        <p class="empty-state">DB管理ナレッジはまだありません。上のフォームから追加できます。</p>
      ) : (
        editableKnowledgeEntries.map((entry) => (
          <article class="editable-row">
            <div>
              <strong>{entry.title}</strong>
              <p>{entry.summary}</p>
              <small>{entry.category} / {entry.visibility} / {entry.maturity}</small>
            </div>
            <button
              type="button"
              class="edit-knowledge-button"
              data-id={entry.id}
              data-title={entry.title}
              data-category={entry.category}
              data-owner={entry.owner}
              data-visibility={entry.visibility}
              data-maturity={entry.maturity}
              data-summary={entry.summary}
              data-body={entry.body}
              data-tags={(entry.tags || []).join(', ')}
            >
              編集
            </button>
          </article>
        ))
      )}
    </div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Sales Demo</span>
        <h3>販売デモ化の方針</h3>
      </div>
    </div>
    <div class="demo-roadmap">
      <article>
        <strong>1. 社内で使う</strong>
        <p>毎日の質問、引き継ぎ、手順確認に使い、不足した回答をナレッジ化します。</p>
      </article>
      <article>
        <strong>2. 公開可能な形へ分離する</strong>
        <p>顧客情報、APIキー、未公開財務、内部メモを除き、業務SOPと判断基準だけをデモ候補にします。</p>
      </article>
      <article>
        <strong>3. 主力販売ツールにする</strong>
        <p>「質問すると会社の標準回答が返る」体験を、属人化解消・新人教育・問い合わせ対応の提案に使います。</p>
      </article>
    </div>
  </section>

  <div class="grid">
    <section class="panel panel-wide">
      <div class="panel-head">
        <div>
          <span>Inventory</span>
          <h3>ナレッジ資産の現在地</h3>
        </div>
      </div>
      <div class="source-list">
        {knowledgeSources.map((source) => (
          <article class="source-row">
            <div>
              <strong>{source.title}</strong>
              <p>{source.source}</p>
            </div>
            <span>{source.status}</span>
            <small>{source.owner}</small>
            <em>{source.action}</em>
          </article>
        ))}
      </div>
    </section>

    <section class="panel">
      <div class="panel-head">
        <div>
          <span>Categories</span>
          <h3>公開ナレッジ分類</h3>
        </div>
      </div>
      <ul class="bar-list">
        {categoryDocRows.map((row) => (
          <li>
            <span>{row.category}</span>
            <b>{row.count}</b>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Next Build</span>
        <h3>実装すべきナレッジ機能</h3>
      </div>
    </div>
    <div class="build-list">
      {buildItems.map((item, index) => (
        <div class="build-item">
          <b>{index + 1}</b>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <span>Recent</span>
        <h3>最近の公開記事</h3>
      </div>
      <a href="/blog" class="panel-link">サイト側で見る</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => (
        <a class="post-card" href={`/blog/${post.slug}`}>
          <span>{categoryLabels[post.data.category] || post.data.category}</span>
          <strong>{post.data.title}</strong>
          <p>{post.data.excerpt}</p>
          <small>{post.data.date}</small>
        </a>
      ))}
    </div>
  </section>
</AdminLayout>

<script is:inline>
  (function() {
    const textarea = document.getElementById('knowledge-question');
    const button = document.getElementById('knowledge-ask-button');
    const answer = document.getElementById('knowledge-answer');

    button?.addEventListener('click', async () => {
      if (!textarea || !answer || !button) return;
      const question = textarea.value.trim();
      if (!question) {
        answer.textContent = '質問を入力してください。';
        return;
      }

      button.disabled = true;
      answer.textContent = 'ナレッジを検索して回答を生成しています...';
      try {
        const res = await fetch('/api/admin/knowledge-query', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
        const sourceText = (data.sources || []).map((source) => `・${source.title}`).join('\n');
        answer.textContent = `${data.answer || '回答がありませんでした。'}${sourceText ? `\n\n参照:\n${sourceText}` : ''}`;
      } catch (error) {
        answer.textContent = error instanceof Error ? error.message : '回答生成に失敗しました。';
      } finally {
        button.disabled = false;
      }
    });

    const entryForm = document.getElementById('knowledge-entry-form');
    const entryResult = document.getElementById('knowledge-entry-result');
    const entrySave = document.getElementById('knowledge-entry-save');
    const entryReset = document.getElementById('knowledge-entry-reset');
    const fields = {
      id: document.getElementById('knowledge-entry-id'),
      title: document.getElementById('knowledge-entry-title'),
      category: document.getElementById('knowledge-entry-category'),
      owner: document.getElementById('knowledge-entry-owner'),
      visibility: document.getElementById('knowledge-entry-visibility'),
      maturity: document.getElementById('knowledge-entry-maturity'),
      tags: document.getElementById('knowledge-entry-tags'),
      summary: document.getElementById('knowledge-entry-summary'),
      body: document.getElementById('knowledge-entry-body'),
    };

    function setField(name, value) {
      if (fields[name]) fields[name].value = value || '';
    }

    document.querySelectorAll('.edit-knowledge-button').forEach((editButton) => {
      editButton.addEventListener('click', () => {
        setField('id', editButton.dataset.id);
        setField('title', editButton.dataset.title);
        setField('category', editButton.dataset.category);
        setField('owner', editButton.dataset.owner);
        setField('visibility', editButton.dataset.visibility);
        setField('maturity', editButton.dataset.maturity);
        setField('summary', editButton.dataset.summary);
        setField('body', editButton.dataset.body);
        setField('tags', editButton.dataset.tags);
        entryResult.textContent = '既存ナレッジを編集中です。';
        entryForm?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    entryReset?.addEventListener('click', () => {
      entryForm?.reset();
      setField('id', '');
      entryResult.textContent = '新規入力に戻しました。';
    });

    entryForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!entryForm || !entrySave || !entryResult) return;
      const formData = new FormData(entryForm);
      const payload = {};
      for (const [key, value] of formData.entries()) {
        payload[key] = value;
      }

      entrySave.disabled = true;
      entryResult.textContent = '保存中...';
      try {
        const res = await fetch('/api/admin/knowledge-docs', {
          method: payload.id ? 'PUT' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || data.ok === false) {
          throw new Error(data.error || `HTTP ${res.status}`);
        }
        entryResult.textContent = '保存しました。画面を更新します...';
        window.location.reload();
      } catch (error) {
        entryResult.textContent = error instanceof Error ? error.message : '保存に失敗しました。';
      } finally {
        entrySave.disabled = false;
      }
    });
  })();
</script>

<style>
  .hero-panel,
  .panel,
  .doc-card {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
  }

  .hero-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 150px;
    gap: 18px;
    align-items: center;
    padding: 22px 24px;
    margin-bottom: 18px;
  }

  .hero-panel span,
  .panel-head span {
    color: var(--admin-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-panel h2,
  .panel-head h3 {
    color: #fff;
    letter-spacing: 0;
  }

  .hero-panel h2 {
    margin: 8px 0;
    font-size: 1.2rem;
  }

  .hero-panel p {
    margin: 0;
    color: var(--admin-muted);
    font-size: 0.9rem;
  }

  .ask-panel {
    margin-bottom: 18px;
  }

  .ask-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 14px;
    align-items: end;
  }

  .ask-grid label span {
    display: block;
    margin-bottom: 6px;
    color: var(--admin-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .ask-grid textarea {
    width: 100%;
    resize: vertical;
    min-height: 110px;
    padding: 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
    color: var(--admin-text);
    font: inherit;
  }

  .ask-actions {
    display: grid;
    gap: 8px;
  }

  .ask-actions button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 40px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-primary);
    color: #fff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .ask-actions button:disabled {
    cursor: wait;
    opacity: 0.68;
  }

  .ask-actions small,
  .answer-box,
  .doc-card p,
  .doc-card small {
    color: var(--admin-muted);
    font-size: 0.82rem;
  }

  .answer-box {
    margin-top: 14px;
    padding: 14px;
    min-height: 92px;
    white-space: pre-wrap;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .alert-box {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 18px;
    padding: 12px;
    border: 1px solid rgba(228, 138, 149, 0.36);
    border-radius: 8px;
    background: rgba(228, 138, 149, 0.1);
    color: var(--admin-accent-soft);
    font-size: 0.84rem;
  }

  .knowledge-form {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }

  .knowledge-form label {
    display: grid;
    gap: 7px;
  }

  .knowledge-form label span {
    color: var(--admin-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .knowledge-form input,
  .knowledge-form select,
  .knowledge-form textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
    color: var(--admin-text);
    font: inherit;
  }

  .knowledge-form textarea {
    resize: vertical;
  }

  .field-wide,
  .form-actions {
    grid-column: 1 / -1;
  }

  .form-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .form-actions button,
  .editable-row button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 36px;
    padding: 0 13px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-primary);
    color: #fff;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
  }

  .form-actions button:disabled {
    cursor: wait;
    opacity: 0.68;
  }

  .form-actions .ghost-button,
  .editable-row button {
    background: var(--admin-surface-2);
    color: var(--admin-muted);
  }

  .form-actions small,
  .editable-row p,
  .editable-row small,
  .empty-state {
    color: var(--admin-muted);
    font-size: 0.8rem;
  }

  .editable-list {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .editable-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 78px;
    gap: 12px;
    align-items: center;
    padding: 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .editable-row strong {
    color: #fff;
  }

  .editable-row p {
    margin: 4px 0;
  }

  .knowledge-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 14px;
  }

  .knowledge-stats div {
    padding: 12px;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    background: var(--admin-bg);
  }

  .knowledge-stats b {
    display: block;
    color: #fff;
    font-size: 1.35rem;
  }

  .knowledge-stats span {
    color: var(--admin-muted);
    font-size: 0.76rem;
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
