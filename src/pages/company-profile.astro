---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="会社概要 | 合同会社Optiens"
  description="合同会社Optiens（オプティエンス）の会社概要。山梨県北杜市を拠点に、AI活用支援とIoT水耕栽培の自社実証を組み合わせた事業を運営しています。"
  canonical="https://optiens.com/company-profile"
>
  <main class="cp-main">

    <!-- 法人情報 -->
    <section class="cp-section light-section">
      <div class="container cp-container">
        <h1 class="cp-title">会社概要</h1>
        <table class="cp-table">
          <tbody>
            <tr><th>商号</th><td>合同会社Optiens（オプティエンス）</td></tr>
            <tr><th>英字表記</th><td>Optiens LLC</td></tr>
            <tr><th>設立</th><td>2026年4月6日</td></tr>
            <tr><th>代表社員</th><td>髙橋 大地</td></tr>
            <tr><th>所在地</th><td>〒407-0301 山梨県北杜市高根町清里3545番地2483</td></tr>
            <tr><th>資本金</th><td>100,000円</td></tr>
            <tr><th>法人番号</th><td>9090003003025</td></tr>
            <tr><th>事業内容</th><td>AI活用支援、IoT水耕栽培の自社実証</td></tr>
            <tr><th>インボイス登録</th><td>適格請求書発行事業者 申請中</td></tr>
            <tr><th>取引銀行</th><td>GMOあおぞらネット銀行 フリー支店</td></tr>
            <tr><th>連絡先</th><td><a href="mailto:info@optiens.com">info@optiens.com</a></td></tr>
          </tbody>
        </table>
      </div>
    </section>

  </main>
</Layout>

<style>
  .cp-main {
    color: var(--text);
    background: #ffffff;
  }

  /* ===== Section ===== */
  .cp-section {
    padding: clamp(110px, 14vw, 160px) 0 clamp(64px, 10vw, 100px);
    background: #ffffff;
  }
  .cp-container {
    max-width: 760px;
  }

  .cp-title {
    font-size: clamp(1.5rem, 3.4vw, 2rem);
    font-weight: 700;
    color: var(--heading);
    margin: 0 0 28px;
    letter-spacing: -.01em;
  }

  /* ===== Table ===== */
  .cp-table {
    width: 100%;
    border-collapse: collapse;
    border-top: 1px solid var(--border);
  }
  .cp-table th,
  .cp-table td {
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
    font-size: .92rem;
    line-height: 1.7;
  }
  .cp-table th {
    width: 32%;
    color: var(--muted);
    font-weight: 600;
    white-space: nowrap;
    font-size: .85rem;
    letter-spacing: .02em;
    background: #fafbfc;
  }
  .cp-table td {
    color: var(--text);
    font-weight: 500;
  }
  .cp-table a {
    color: var(--brand);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .cp-table th {
      width: 38%;
      font-size: .8rem;
      padding: 12px 12px;
    }
    .cp-table td {
      font-size: .88rem;
      padding: 12px 12px;
    }
  }

  @media print {
    .cp-section {
      background: #fff;
    }
  }
</style>
