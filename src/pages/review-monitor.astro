---
import Layout from '../layouts/Layout.astro';

// モック口コミデータ（カフェ・レストラン業種特化デモ）
type Review = {
  id: string;
  source: 'tabelog' | 'google_map' | 'instagram';
  shop_name: string;
  reviewer: string;
  rating: number;
  title?: string;
  body: string;
  posted_at: string;       // 表示用相対時刻
  iso_at: string;          // 並べ替え用 ISO
  category: 'high' | 'mid' | 'low';
};

const reviews: Review[] = [
  {
    id: 'R-2003',
    source: 'tabelog',
    shop_name: '清里カフェ Verde',
    reviewer: 'k_takano',
    rating: 2,
    title: '料理は美味しいが提供が遅い',
    body: '土曜の昼に伺いました。注文してからオムライスが出てくるまで45分。子供が飽きてしまい大変でした。料理自体は美味しかったので、ピーク時のオペレーションを改善してほしいです。',
    posted_at: '8 分前',
    iso_at: new Date(Date.now() - 8 * 60 * 1000).toISOString(),
    category: 'low',
  },
  {
    id: 'R-2002',
    source: 'google_map',
    shop_name: '清里カフェ Verde',
    reviewer: 'Yuki S.',
    rating: 5,
    body: '八ヶ岳の眺めが最高でした！ハーブティーの香りに癒され、季節のサラダプレートも野菜の鮮度が抜群。スタッフの方の接客も気持ちよく、また絶対に行きたいです。',
    posted_at: '34 分前',
    iso_at: new Date(Date.now() - 34 * 60 * 1000).toISOString(),
    category: 'high',
  },
  {
    id: 'R-2001',
    source: 'google_map',
    shop_name: '清里カフェ Verde',
    reviewer: 'Hannah K.',
    rating: 4,
    body: 'Lovely cafe with a great view of Mt. Yatsugatake! The basil pasta was fresh and aromatic. A bit busy on weekends but worth visiting.',
    posted_at: '1 時間前',
    iso_at: new Date(Date.now() - 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
  {
    id: 'R-1999',
    source: 'instagram',
    shop_name: '清里カフェ Verde',
    reviewer: '@coffee_walker_jp',
    rating: 4,
    body: '清里に来たら必ず寄るカフェ。今日のキッシュ、しっかりめの塩味で美味しかった！次は朝の時間帯に行きたい。',
    posted_at: '2 時間前',
    iso_at: new Date(Date.now() - 2 * 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
  {
    id: 'R-1998',
    source: 'tabelog',
    shop_name: '清里カフェ Verde',
    reviewer: 'morimoto_3',
    rating: 3,
    title: 'デザートは良かった',
    body: 'メイン料理（ハンバーグ）はちょっと味付けが強めで好みではなかったですが、デザートのバスクチーズケーキは絶品でした。立地は最高なので雰囲気目当てで再訪します。',
    posted_at: '5 時間前',
    iso_at: new Date(Date.now() - 5 * 60 * 60 * 1000).toISOString(),
    category: 'mid',
  },
  {
    id: 'R-1997',
    source: 'google_map',
    shop_name: '清里カフェ Verde',
    reviewer: 'まるちゃん',
    rating: 5,
    body: '駐車場から店内まで段差がほぼなく、ベビーカーでも入りやすかったです。お子様メニューもあり助かりました。',
    posted_at: '8 時間前',
    iso_at: new Date(Date.now() - 8 * 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
  {
    id: 'R-1996',
    source: 'tabelog',
    shop_name: '清里カフェ Verde',
    reviewer: 'gourmet_eye_99',
    rating: 1,
    title: '予約していたのに席がなかった',
    body: '予約していたのに着いたら席がないと言われ、30分待たされました。予約システムをきちんと運用してほしい。料理云々の前に、お客様への対応がなっていないと感じました。',
    posted_at: '13 時間前',
    iso_at: new Date(Date.now() - 13 * 60 * 60 * 1000).toISOString(),
    category: 'low',
  },
  {
    id: 'R-1995',
    source: 'google_map',
    shop_name: '清里カフェ Verde',
    reviewer: '田中 健一',
    rating: 4,
    body: '清里の自然に囲まれた素敵なカフェでした。コーヒーの香りも良く、ゆっくりとした時間を過ごせました。',
    posted_at: '昨日',
    iso_at: new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
  {
    id: 'R-1994',
    source: 'instagram',
    shop_name: '清里カフェ Verde',
    reviewer: '@brunch_diary',
    rating: 5,
    body: '朝のテラス席が本当に気持ちよかった！コーヒーと焼きたてマフィンで完璧な朝食。',
    posted_at: '昨日',
    iso_at: new Date(Date.now() - 25 * 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
  {
    id: 'R-1993',
    source: 'tabelog',
    shop_name: '清里カフェ Verde',
    reviewer: 'cafe_lover_2026',
    rating: 4,
    title: '雰囲気は最高',
    body: '雰囲気は本当に良いカフェ。料理もハーブが効いていて美味しいです。値段はやや高めですが立地と眺めを考えれば妥当かな。',
    posted_at: '2 日前',
    iso_at: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
];

const last24h = reviews.filter((r) => new Date(r.iso_at).getTime() > Date.now() - 24 * 60 * 60 * 1000);
const stats = {
  total24h: last24h.length,
  low24h: last24h.filter((r) => r.category === 'low').length,
  highAvgRating: (last24h.reduce((s, r) => s + r.rating, 0) / Math.max(last24h.length, 1)).toFixed(1),
};

const sourceLabel = {
  tabelog: '食べログ',
  google_map: 'Googleマップ',
  instagram: 'Instagram',
};
const sourceIcon = {
  tabelog: 'fa-utensils',
  google_map: 'fa-map-location-dot',
  instagram: 'fa-square-instagram',
};
---

<Layout
  title="口コミ自動監視 + AI返信下書き（デモ）| Optiens"
  description="食べログ・Google マップ・Instagram の新着口コミを 24h 監視し、AI が分類・低評価アラート・返信下書きを行うデモ。中小カフェ・レストラン向け業種特化AI事例。"
  noindex={true}
>
  <main class="rm-main">
    <section class="rm-hero">
      <div class="container">
        <h1 class="rm-title">口コミ 24h 自動監視＋AI返信下書き</h1>
        <p class="rm-lede">
          食べログ・Google マップ・Instagram の新着口コミを<strong>裏で 24h 監視</strong>し、
          内容を AI が分類、<strong>低評価は即時通知</strong>、<strong>返信下書きは即生成</strong>する仕組みのデモです。
        </p>
      </div>
    </section>

    <section class="rm-section">
      <div class="container">

        <!-- 透明性バナー -->
        <div class="transparency-banner">
          <div class="tb-item">
            <i class="fa-solid fa-circle-check"></i>
            <div>
              <strong>本デモは AI API を呼びません（事前用意のサンプル応答を表示）</strong>
              <p>「AI で返信下書きを生成」ボタンを押すと、各レビュー × 口調 × 言語の組合せで <strong>事前用意した応答</strong> を表示します。実運用時は <strong>Claude Opus 4.7</strong> または <strong>GPT-5.5</strong> 等の最新フラッグシップで動的生成し、<strong>利用量に応じた従量課金</strong>が発生します（1 件あたり約 ¥2〜3）。</p>
            </div>
          </div>
          <div class="tb-item">
            <i class="fa-solid fa-database"></i>
            <div>
              <strong>口コミ・店舗・投稿者は架空のサンプルデータ</strong>
              <p>食べログには公式 API がないため、実運用では「店舗管理画面の通知メールを IMAP 受信→AI 解析」の合法的な方式を採用します。Google Maps は公式 API、Instagram は Facebook Business 経由の Graph API で実装可能。<strong>本デモ画面からは実際の取得・投稿は行いません</strong>。</p>
            </div>
          </div>
          <div class="tb-item">
            <i class="fa-solid fa-vial"></i>
            <div>
              <strong>本番導入前のテスト環境（サンドボックス）も用意可能です</strong>
              <p>御社専用版では、本番チャネルとは切り離した <strong>ステージング環境（Vercel Preview + Supabase の別 schema / branch）</strong> を立てて、実データの一部を流して挙動を確認した上で本番接続に切り替えます。Instagram Graph API は <strong>Development mode</strong> での自社検証から始めることが可能です（実運用には Meta の <strong>App Review 承認（2〜4 週間）</strong>が別途必要）。</p>
            </div>
          </div>
        </div>

        <!-- 監視ヘッダ -->
        <div class="monitor-bar">
          <div class="monitor-status">
            <span class="status-dot"></span>
            <span class="status-text"><strong>監視中</strong> ・ 最終チェック 2 分前</span>
          </div>
          <div class="monitor-channels">
            <span class="ch-tag"><i class="fa-solid fa-utensils"></i> 食べログ</span>
            <span class="ch-tag"><i class="fa-solid fa-map-location-dot"></i> Googleマップ</span>
            <span class="ch-tag"><i class="fa-brands fa-square-instagram"></i> Instagram</span>
          </div>
        </div>

        <!-- KPI -->
        <div class="kpi-grid">
          <div class="kpi-card">
            <div class="kpi-label">直近 24h 新着レビュー</div>
            <div class="kpi-value">{stats.total24h}<span class="kpi-unit">件</span></div>
          </div>
          <div class={`kpi-card ${stats.low24h > 0 ? 'kpi-card--alert' : ''}`}>
            <div class="kpi-label">直近 24h 低評価（★1〜2）</div>
            <div class="kpi-value">{stats.low24h}<span class="kpi-unit">件</span></div>
            {stats.low24h > 0 && <div class="kpi-sub kpi-sub--alert">即時返信を推奨</div>}
          </div>
          <div class="kpi-card">
            <div class="kpi-label">直近 24h 平均評価</div>
            <div class="kpi-value">{stats.highAvgRating}<span class="kpi-unit">/ 5</span></div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">監視チャネル数</div>
            <div class="kpi-value">3<span class="kpi-unit">本</span></div>
            <div class="kpi-sub">食べログ / Maps / IG</div>
          </div>
        </div>

        <!-- タイムライン -->
        <h2 class="section-title">新着レビュー タイムライン</h2>
        <div class="review-list">
          {reviews.map((r) => (
            <article class={`review-item review-${r.category}`} data-id={r.id} data-rating={r.rating} data-source={r.source} data-body={r.body} data-shop={r.shop_name} data-reviewer={r.reviewer} data-title={r.title || ''}>
              <header class="review-head">
                <span class={`review-source review-source--${r.source}`}>
                  <i class={`fa-solid ${sourceIcon[r.source]}`}></i> {sourceLabel[r.source]}
                </span>
                <span class="review-rating">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <i class={`fa-solid fa-star ${i < r.rating ? 'star-filled' : 'star-empty'}`}></i>
                  ))}
                </span>
                <span class="review-time">{r.posted_at}</span>
                {r.category === 'low' && (
                  <span class="review-alert"><i class="fa-solid fa-circle-exclamation"></i> 即時対応推奨</span>
                )}
              </header>
              {r.title && <h3 class="review-title">{r.title}</h3>}
              <p class="review-meta">投稿者: <strong>{r.reviewer}</strong></p>
              <p class="review-body">{r.body}</p>

              <div class="review-settings">
                <label class="setting-field">
                  <span class="setting-label">口調</span>
                  <select class="setting-select" data-setting="tone">
                    <option value="polite">最も丁寧（高級店向け）</option>
                    <option value="standard" selected>標準（丁寧でフレンドリー）</option>
                    <option value="friendly">カジュアル（親しみ寄り）</option>
                  </select>
                </label>
                <label class="setting-field">
                  <span class="setting-label">返信言語</span>
                  <select class="setting-select" data-setting="lang">
                    <option value="auto" selected>自動（口コミと同じ言語）</option>
                    <option value="ja">日本語固定</option>
                    <option value="en">英語固定</option>
                  </select>
                </label>
              </div>

              <div class="review-actions">
                <button class="btn-reply" data-action="reply" data-review-id={r.id}>
                  <i class="fa-solid fa-wand-magic-sparkles"></i> AI で返信下書きを生成
                </button>
                <button class="btn-skip" data-action="skip" data-review-id={r.id}>
                  <i class="fa-regular fa-circle"></i> スルー（対応不要）
                </button>
              </div>

              <div class="reply-area" data-reply-area={r.id} hidden>
                <div class="reply-loading" hidden>
                  <i class="fa-solid fa-spinner fa-spin"></i> AI が返信を作成中...
                </div>
                <div class="reply-result" hidden>
                  <div class="reply-meta">
                    <span class="reply-tone-badge"></span>
                    <span class="reply-key-points"></span>
                  </div>
                  <textarea class="reply-textarea" rows="5"></textarea>
                  <div class="reply-action-row">
                    <button class="btn-publish" data-action="publish">
                      <i class="fa-solid fa-paper-plane"></i> このまま投稿（モック）
                    </button>
                    <button class="btn-regen" data-action="regen">
                      <i class="fa-solid fa-rotate"></i> 再生成
                    </button>
                  </div>
                  <p class="reply-status"></p>
                </div>
                <div class="reply-error" hidden></div>
              </div>
            </article>
          ))}
        </div>

        <!-- 拡張可能性ハイライト -->
        <div class="rm-extension">
          <div class="rm-extension-head">
            <i class="fa-solid fa-arrows-turn-to-dots"></i>
            <h3>御社専用版なら、ここまで全自動化</h3>
          </div>
          <p class="rm-extension-lede">
            このデモは「監視→分類→返信下書き生成」までを画面で再現していますが、御社専用版では下記まで <strong>裏で動き続けて、必要な時だけ通知</strong> する構成にできます。
          </p>
          <div class="rm-extension-grid">
            <div class="rm-ext-card">
              <i class="fa-solid fa-bell"></i>
              <h4>低評価即時通知</h4>
              <p>★1〜2 の新着レビューを 5 分以内にオーナー LINE / Slack / メールへプッシュ通知。深夜帯も検知のみ、対応は朝。</p>
            </div>
            <div class="rm-ext-card">
              <i class="fa-solid fa-paper-plane"></i>
              <h4>高評価は予約自動投稿</h4>
              <p>★4〜5 の口コミは AI 返信下書きを自動生成 → 営業時間内（例 18:00）に自動投稿。投稿前に承認も可。</p>
            </div>
            <div class="rm-ext-card">
              <i class="fa-solid fa-chart-line"></i>
              <h4>月次傾向レポート</h4>
              <p>「どの料理が褒められたか」「どの時間帯にクレームが多いか」を月次集計し、改善の議論に使える資料を自動配信。</p>
            </div>
            <div class="rm-ext-card">
              <i class="fa-solid fa-shield-halved"></i>
              <h4>炎上検知アラート</h4>
              <p>同一店舗への低評価が短時間に複数件続いた場合、SNS 拡散リスクの可能性を経営者に即時通知。</p>
            </div>
          </div>
        </div>

        <!-- 仕組み・データソース -->
        <div class="rm-tech">
          <h2 class="section-title">仕組み・データソース（実運用時）</h2>
          <div class="rm-tech-grid">
            <div class="rm-tech-card">
              <div class="rm-tech-head">
                <i class="fa-solid fa-map-location-dot"></i>
                <strong>Google マップ</strong>
                <span class="rm-tech-badge rm-tech-badge--ok">公式 API</span>
              </div>
              <p>Google Business Profile API で 5〜30 分間隔の cron polling。自社店舗の新着口コミを合法的に取得・返信。<br /><small>※ Google への <strong>API アクセス申請（承認制）</strong>が必要。承認まで通常 1〜2 週間。</small></p>
            </div>
            <div class="rm-tech-card">
              <div class="rm-tech-head">
                <i class="fa-solid fa-utensils"></i>
                <strong>食べログ</strong>
                <span class="rm-tech-badge rm-tech-badge--alt">メール解析</span>
              </div>
              <p>公式 API は提供されていないため、店舗オーナーの管理画面通知メールを御社専用の受信ボックスに転送 → IMAP で AI が内容抽出する代替方式を採用します。<br /><small>※ 第三者スクレイピングではなく店舗オーナー本人の管理メールを使うため規約上問題なしですが、食べログ仕様変更による影響は避けられません。</small></p>
            </div>
            <div class="rm-tech-card">
              <div class="rm-tech-head">
                <i class="fa-brands fa-square-instagram"></i>
                <strong>Instagram コメント・メンション</strong>
                <span class="rm-tech-badge rm-tech-badge--ok">公式 API</span>
              </div>
              <p>Instagram Graph API（Facebook Business 経由）で公式に取得・返信が可能です。<br /><small>※ 実運用には Meta の <strong>App Review 承認</strong>が必要（通常 2〜4 週間）。</small></p>
            </div>
          </div>
        </div>

        <!-- ランニングコスト試算 -->
        <div class="rm-cost">
          <h2 class="section-title">ランニングコスト試算（月額・実運用時）</h2>
          <p class="rm-cost-lede">店舗 1 拠点・月 100 件の口コミ取得・うち 30 件に AI 返信下書きを生成する想定での目安です。実数量に応じて変動します。</p>
          <div class="rm-cost-table-wrap">
            <table class="rm-cost-table">
              <thead>
                <tr>
                  <th>項目</th>
                  <th>料金体系</th>
                  <th class="cost-amount-col">月額目安</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Google Business Profile API</strong><br /><small>取得・返信</small></td>
                  <td>無料<br /><small>※ Google への <strong>API アクセス申請承認</strong>が必要（承認制）</small></td>
                  <td class="cost-amount cost-amount--free">¥0</td>
                </tr>
                <tr>
                  <td><strong>Instagram Graph API</strong><br /><small>コメント・メンション取得・返信</small></td>
                  <td>無料（基本利用）<br /><small>※ 実運用には Meta の <strong>App Review 承認</strong>が必要（2〜4 週間）</small></td>
                  <td class="cost-amount cost-amount--free">¥0</td>
                </tr>
                <tr>
                  <td><strong>食べログ通知メール用 IMAP</strong><br /><small>専用メールアドレス・受信</small></td>
                  <td>Google Workspace Business Starter<br /><small>月 ¥800〜（年契約・税抜。既存契約があれば追加 ¥0）</small></td>
                  <td class="cost-amount">¥0〜800</td>
                </tr>
                <tr>
                  <td><strong>AI API（Claude Opus 4.7 または GPT-5.5）</strong><br /><small>返信下書き生成 30 件想定</small></td>
                  <td>従量課金<br /><small>1 件約 ¥2〜3（プロンプト＋応答 約 1,500 トークン・為替 ¥150/USD 想定）<br />※ バランス重視なら Sonnet 4.6 / GPT-5.4 で 1 件 ¥1〜2、コスト最優先なら gpt-4o-mini で 1 件 ¥0.05〜0.1 まで圧縮可能</small></td>
                  <td class="cost-amount">¥60〜100</td>
                </tr>
                <tr>
                  <td><strong>Supabase（DB・認証）</strong><br /><small>口コミ履歴・分析データ保管</small></td>
                  <td>Free 〜 Pro $25/月<br /><small>※ Free 枠: 8GB DB / 100K MAU / 100GB ストレージ</small></td>
                  <td class="cost-amount">¥0〜3,800</td>
                </tr>
                <tr>
                  <td><strong>Vercel（ホスティング）</strong><br /><small>cron polling 含む</small></td>
                  <td>Pro $20/月（必須）<br /><small>※ Hobby は cron 1 日 1 回のみ。5〜30 分 polling は <strong>Pro 必須</strong></small></td>
                  <td class="cost-amount">¥3,000</td>
                </tr>
                <tr>
                  <td><strong>通知連携</strong><br /><small>Slack / メール / LINE 公式（任意）</small></td>
                  <td>各サービスの基本枠は無料</td>
                  <td class="cost-amount cost-amount--free">¥0</td>
                </tr>
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="2"><strong>合計目安（月額）</strong></td>
                  <td class="cost-amount cost-amount--total">¥3,060〜7,700</td>
                </tr>
              </tfoot>
            </table>
          </div>
          <div class="rm-cost-notes">
            <p><strong>規模拡大時の試算例</strong>（Claude Opus 4.7 / GPT-5.5 想定）:</p>
            <ul>
