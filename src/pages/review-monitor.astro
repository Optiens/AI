    rating: 5,
    body: '朝のテラス席が本当に気持ちよかった！コーヒーと焼きたてマフィンで完璧な朝食。',
    posted_at: '昨日',
    iso_at: new Date(Date.now() - 25 * 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
  {
    id: 'R-1993',
    source: 'tabelog',
    shop_name: '清里カフェ Verde',
    reviewer: 'cafe_lover_2026',
    rating: 4,
    title: '雰囲気は最高',
    body: '雰囲気は本当に良いカフェ。料理もハーブが効いていて美味しいです。値段はやや高めですが立地と眺めを考えれば妥当かな。',
    posted_at: '2 日前',
    iso_at: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(),
    category: 'high',
  },
];

const last24h = reviews.filter((r) => new Date(r.iso_at).getTime() > Date.now() - 24 * 60 * 60 * 1000);
const stats = {
  total24h: last24h.length,
  low24h: last24h.filter((r) => r.category === 'low').length,
  highAvgRating: (last24h.reduce((s, r) => s + r.rating, 0) / Math.max(last24h.length, 1)).toFixed(1),
};

const sourceLabel = {
  tabelog: '食べログ',
  google_map: 'Googleマップ',
  instagram: 'Instagram',
};
const sourceIcon = {
  tabelog: 'fa-utensils',
  google_map: 'fa-map-location-dot',
  instagram: 'fa-square-instagram',
};
---

<Layout
  title="口コミ自動監視 + AI返信下書き（デモ）| Optiens"
  description="食べログ・Google マップ・Instagram の新着口コミを 24h 監視し、AI が分類・低評価アラート・返信下書きを行うデモ。中小カフェ・レストラン向け業種特化AI事例。"
  noindex={true}
>
  <main class="rm-main">
    <section class="rm-hero">
      <div class="container">
        <p class="rm-eyebrow">DEMO ／ Optiens 業種特化AI事例 ／ カフェ・レストラン</p>
        <h1 class="rm-title">口コミ 24h 自動監視＋AI返信下書き</h1>
        <p class="rm-lede">
          食べログ・Google マップ・Instagram の新着口コミを<strong>裏で 24h 監視</strong>し、
          内容を AI が分類、<strong>低評価は即時通知</strong>、<strong>返信下書きは即生成</strong>する仕組みのデモです。
        </p>
      </div>
    </section>

    <section class="rm-section">
      <div class="container">

        <!-- 透明性バナー -->
        <div class="transparency-banner">
          <div class="tb-item">
            <i class="fa-solid fa-bolt"></i>
            <div>
              <strong>「AI で返信下書きを生成」は実際に OpenAI API を呼び出します</strong>
              <p>1 回あたり数円（gpt-4o-mini）。本番運用時は御社の API キーを使う構成にできます。本デモは Optiens の API キーを使っており、<strong>1 IP あたり 1 時間 30 回まで</strong>に制限しています。</p>
            </div>
          </div>
          <div class="tb-item">
            <i class="fa-solid fa-database"></i>
            <div>
              <strong>口コミ・店舗・投稿者は架空のサンプルデータ</strong>
              <p>食べログには公式 API がないため、実運用では「店舗管理画面の通知メールを IMAP 受信→AI 解析」の合法的な方式を採用します。Google Maps は公式 API、Instagram は Facebook Business 経由の Graph API で実装可能。<strong>本デモ画面からは実際の取得・投稿は行いません</strong>。</p>
            </div>
          </div>
          <div class="tb-item">
            <i class="fa-solid fa-vial"></i>
            <div>
              <strong>本番導入前のテスト環境（サンドボックス）も用意可能です</strong>
              <p>御社専用版では、本番チャネルとは切り離した <strong>ステージング環境（Vercel Preview + Supabase の別 schema / branch）</strong> を立てて、実データの一部を流して挙動を確認した上で本番接続に切り替えます。Instagram Graph API はテストアプリモードでも動作可能。</p>
            </div>
          </div>
        </div>

        <!-- 監視ヘッダ -->
        <div class="monitor-bar">
          <div class="monitor-status">
            <span class="status-dot"></span>
            <span class="status-text"><strong>監視中</strong> ・ 最終チェック 2 分前</span>
          </div>
          <div class="monitor-channels">
            <span class="ch-tag"><i class="fa-solid fa-utensils"></i> 食べログ</span>
            <span class="ch-tag"><i class="fa-solid fa-map-location-dot"></i> Googleマップ</span>
            <span class="ch-tag"><i class="fa-brands fa-square-instagram"></i> Instagram</span>
          </div>
        </div>

        <!-- KPI -->
        <div class="kpi-grid">
          <div class="kpi-card">
            <div class="kpi-label">直近 24h 新着レビュー</div>
            <div class="kpi-value">{stats.total24h}<span class="kpi-unit">件</span></div>
          </div>
          <div class={`kpi-card ${stats.low24h > 0 ? 'kpi-card--alert' : ''}`}>
            <div class="kpi-label">直近 24h 低評価（★1〜2）</div>
            <div class="kpi-value">{stats.low24h}<span class="kpi-unit">件</span></div>
            {stats.low24h > 0 && <div class="kpi-sub kpi-sub--alert">即時返信を推奨</div>}
          </div>
          <div class="kpi-card">
            <div class="kpi-label">直近 24h 平均評価</div>
            <div class="kpi-value">{stats.highAvgRating}<span class="kpi-unit">/ 5</span></div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">監視チャネル数</div>
            <div class="kpi-value">3<span class="kpi-unit">本</span></div>
            <div class="kpi-sub">食べログ / Maps / IG</div>
          </div>
        </div>

        <!-- タイムライン -->
        <h2 class="section-title">新着レビュー タイムライン</h2>
        <div class="review-list">
          {reviews.map((r) => (
            <article class={`review-item review-${r.category}`} data-id={r.id} data-rating={r.rating} data-source={r.source} data-body={r.body} data-shop={r.shop_name} data-reviewer={r.reviewer} data-title={r.title || ''}>
              <header class="review-head">
                <span class={`review-source review-source--${r.source}`}>
                  <i class={`fa-solid ${sourceIcon[r.source]}`}></i> {sourceLabel[r.source]}
                </span>
                <span class="review-rating">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <i class={`fa-solid fa-star ${i < r.rating ? 'star-filled' : 'star-empty'}`}></i>
                  ))}
                </span>
                <span class="review-time">{r.posted_at}</span>
                {r.category === 'low' && (
                  <span class="review-alert"><i class="fa-solid fa-circle-exclamation"></i> 即時対応推奨</span>
                )}
              </header>
              {r.title && <h3 class="review-title">{r.title}</h3>}
              <p class="review-meta">投稿者: <strong>{r.reviewer}</strong></p>
              <p class="review-body">{r.body}</p>

              <div class="review-settings">
                <label class="setting-field">
                  <span class="setting-label">口調</span>
                  <select class="setting-select" data-setting="tone">
                    <option value="polite">最も丁寧（高級店向け）</option>
                    <option value="standard" selected>標準（丁寧でフレンドリー）</option>
                    <option value="friendly">カジュアル（親しみ寄り）</option>
                  </select>
                </label>
                <label class="setting-field">
                  <span class="setting-label">返信言語</span>
                  <select class="setting-select" data-setting="lang">
                    <option value="auto" selected>自動（口コミと同じ言語）</option>
                    <option value="ja">日本語固定</option>
                    <option value="en">英語固定</option>
                  </select>
                </label>
              </div>

              <div class="review-actions">
                <button class="btn-reply" data-action="reply" data-review-id={r.id}>
                  <i class="fa-solid fa-wand-magic-sparkles"></i> AI で返信下書きを生成
                </button>
                <button class="btn-skip" data-action="skip" data-review-id={r.id}>
                  <i class="fa-regular fa-circle"></i> スルー（対応不要）
                </button>
              </div>

              <div class="reply-area" data-reply-area={r.id} hidden>
                <div class="reply-loading" hidden>
                  <i class="fa-solid fa-spinner fa-spin"></i> AI が返信を作成中...
                </div>
                <div class="reply-result" hidden>
                  <div class="reply-meta">
                    <span class="reply-tone-badge"></span>
                    <span class="reply-key-points"></span>
                  </div>
                  <textarea class="reply-textarea" rows="5"></textarea>
                  <div class="reply-action-row">
                    <button class="btn-publish" data-action="publish">
                      <i class="fa-solid fa-paper-plane"></i> このまま投稿（モック）
                    </button>
                    <button class="btn-regen" data-action="regen">
                      <i class="fa-solid fa-rotate"></i> 再生成
                    </button>
                  </div>
                  <p class="reply-status"></p>
                </div>
                <div class="reply-error" hidden></div>
              </div>
            </article>
          ))}
        </div>

        <!-- 拡張可能性ハイライト -->
        <div class="rm-extension">
          <div class="rm-extension-head">
            <i class="fa-solid fa-arrows-turn-to-dots"></i>
            <h3>御社専用版なら、ここまで全自動化</h3>
          </div>
          <p class="rm-extension-lede">
            このデモは「監視→分類→返信下書き生成」までを画面で再現していますが、御社専用版では下記まで <strong>裏で動き続けて、必要な時だけ通知</strong> する構成にできます。
          </p>
          <div class="rm-extension-grid">
            <div class="rm-ext-card">
              <i class="fa-solid fa-bell"></i>
              <h4>低評価即時通知</h4>
              <p>★1〜2 の新着レビューを 5 分以内にオーナー LINE / Slack / メールへプッシュ通知。深夜帯も検知のみ、対応は朝。</p>
            </div>
            <div class="rm-ext-card">
              <i class="fa-solid fa-paper-plane"></i>
              <h4>高評価は予約自動投稿</h4>
              <p>★4〜5 の口コミは AI 返信下書きを自動生成 → 営業時間内（例 18:00）に自動投稿。投稿前に承認も可。</p>
            </div>
            <div class="rm-ext-card">
              <i class="fa-solid fa-chart-line"></i>
              <h4>月次傾向レポート</h4>
              <p>「どの料理が褒められたか」「どの時間帯にクレームが多いか」を月次集計し、改善の議論に使える資料を自動配信。</p>
            </div>
            <div class="rm-ext-card">
              <i class="fa-solid fa-shield-halved"></i>
              <h4>炎上検知アラート</h4>
              <p>同一店舗への低評価が短時間に複数件続いた場合、SNS 拡散リスクの可能性を経営者に即時通知。</p>
            </div>
          </div>
        </div>

        <!-- 仕組み・データソース -->
        <div class="rm-tech">
          <h2 class="section-title">仕組み・データソース（本番運用時）</h2>
          <div class="rm-tech-grid">
            <div class="rm-tech-card">
              <div class="rm-tech-head">
                <i class="fa-solid fa-map-location-dot"></i>
                <strong>Google マップ</strong>
                <span class="rm-tech-badge rm-tech-badge--ok">公式 API</span>
              </div>
              <p>Google Business Profile API で 5〜30 分間隔の cron polling。自社店舗の新着口コミを合法的に取得・返信。</p>
            </div>
            <div class="rm-tech-card">
              <div class="rm-tech-head">
                <i class="fa-solid fa-utensils"></i>
                <strong>食べログ</strong>
                <span class="rm-tech-badge rm-tech-badge--alt">メール解析</span>
              </div>
              <p>公式 API は提供されていないため、店舗管理画面の通知メールを IMAP で受信→AI で内容抽出する合法的な代替方式を採用します。</p>
            </div>
            <div class="rm-tech-card">
              <div class="rm-tech-head">
                <i class="fa-brands fa-square-instagram"></i>
                <strong>Instagram コメント・メンション</strong>
                <span class="rm-tech-badge rm-tech-badge--ok">公式 API</span>
              </div>
              <p>Instagram Graph API（Facebook Business 経由）で公式に取得・返信が可能です。</p>
            </div>
          </div>
        </div>

        <!-- 注記 -->
        <div class="rm-footnote">
          <p><strong>このデモについて</strong>: 表示している店舗・口コミ・投稿者はすべて<strong>架空のサンプルデータ</strong>です。実際のお客様向けには、御社の実店舗データ（Google ビジネスプロフィール / 食べログ管理画面 / Instagram Graph API）に接続して構築します。</p>
          <p><strong>弊社での運用</strong>: 同型の「外部チャネル定期監視＋AI 一次対応」構成を、Optiens 社内では補助金公募モニタリング・市場ニュース定期チェックに使っています。</p>
          <a href="/ai-examples?cat=industry" class="rm-back">← 業種別 活用シナリオに戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
type Review = {
  id: string
  source: 'tabelog' | 'google_map' | 'instagram'
  shop_name: string
  reviewer: string
  rating: number
  title?: string
  body: string
}

document.addEventListener('click', async (e) => {
  const target = e.target as HTMLElement
  const replyBtn = target.closest<HTMLButtonElement>('[data-action="reply"]')
  const skipBtn = target.closest<HTMLButtonElement>('[data-action="skip"]')
  const regenBtn = target.closest<HTMLButtonElement>('[data-action="regen"]')
  const publishBtn = target.closest<HTMLButtonElement>('[data-action="publish"]')

  if (replyBtn) await handleReply(replyBtn)
  if (regenBtn) {
    const item = regenBtn.closest('.review-item')!
    const replyBtnInItem = item.querySelector<HTMLButtonElement>('[data-action="reply"]')!
    await handleReply(replyBtnInItem)
  }
  if (skipBtn) {
    const item = skipBtn.closest('.review-item')!
    item.classList.add('review-skipped')
    skipBtn.disabled = true
    skipBtn.innerHTML = '<i class="fa-solid fa-check"></i> スルー済み'
  }
  if (publishBtn) {
    const status = publishBtn.closest('.reply-result')!.querySelector('.reply-status') as HTMLElement
    status.textContent = '✓ 投稿予約しました（営業時間内 18:00 に自動投稿予定 / モック表示）'
    status.classList.add('reply-status--success')
    publishBtn.disabled = true
  }
})

async function handleReply(btn: HTMLButtonElement) {
  const item = btn.closest('.review-item') as HTMLElement
  if (!item) return
  const id = item.dataset.id!
  const review: Review = {
    id,
    source: item.dataset.source as Review['source'],
    shop_name: item.dataset.shop || '',
    reviewer: item.dataset.reviewer || '',
    rating: Number(item.dataset.rating || 0),
    title: item.dataset.title || undefined,
    body: item.dataset.body || '',
  }

  // 口調・言語の選択値を取得
  const toneSelect = item.querySelector<HTMLSelectElement>('[data-setting="tone"]')
  const langSelect = item.querySelector<HTMLSelectElement>('[data-setting="lang"]')
  const tone = toneSelect?.value || 'standard'
  const language = langSelect?.value || 'auto'

  const area = item.querySelector(`[data-reply-area="${id}"]`) as HTMLElement
  const loading = area.querySelector('.reply-loading') as HTMLElement
  const result = area.querySelector('.reply-result') as HTMLElement
  const errorBox = area.querySelector('.reply-error') as HTMLElement

  area.hidden = false
  loading.hidden = false
  result.hidden = true
  errorBox.hidden = true
  btn.disabled = true

  try {
    const res = await fetch('/api/review-reply-demo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ review, tone, language }),
    })
    const data = await res.json()
    if (!res.ok) {
      errorBox.textContent = data?.error || '生成に失敗しました'
      errorBox.hidden = false
      loading.hidden = true
      return
    }

    const ta = result.querySelector('.reply-textarea') as HTMLTextAreaElement
    ta.value = data.reply_text || ''
    const toneBadge = result.querySelector('.reply-tone-badge') as HTMLElement
    const toneMap: Record<string, string> = {
      low_rating: '低評価対応',
      mid_rating: '通常返信',
      high_rating: '高評価返信',
    }
    toneBadge.textContent = toneMap[data.tone] || '通常返信'
    toneBadge.className = `reply-tone-badge tone-${data.tone}`

    const kpEl = result.querySelector('.reply-key-points') as HTMLElement
    kpEl.textContent =
      Array.isArray(data.key_points) && data.key_points.length
        ? `触れた要素: ${data.key_points.join(' / ')}`
        : ''

    if (data.mock) {
      const status = result.querySelector('.reply-status') as HTMLElement
      status.textContent = '※ モック応答（API キー未設定環境）'
      status.classList.add('reply-status--note')
    }

    loading.hidden = true
    result.hidden = false
    btn.innerHTML = '<i class="fa-solid fa-rotate"></i> 再生成（編集後も可）'
    btn.disabled = false
  } catch (err) {
    errorBox.textContent = '通信エラーが発生しました'
    errorBox.hidden = false
    loading.hidden = true
    btn.disabled = false
  }
}
</script>

