---
import Layout from '../layouts/Layout.astro';
import IsoGridCanvas from '../components/IsoGridCanvas.astro';
---

<Layout
  title="無料AI活用診断 | 中小企業・小規模事業者向けROIレポート | Optiens"
  description="かんたんなフォーム入力で、あなたの事業のどこにAIが効くか、ROI（投資利益率）を含む簡易レポートを無料でお届け。全国オンライン対応・契約不要・しつこい営業なし。"
  canonical="https://optiens.com/free-diagnosis"
>
  <main>
    <section class="diag-hero light-section">
      <IsoGridCanvas id="diag-bg" />
      <div class="container text-center" style="position:relative;z-index:1;">
        <p class="diag-eyebrow">AI DIAGNOSIS</p>
        <h1>AI活用診断</h1>

        <!-- プラン切替トグル -->
        <div class="plan-switcher" role="tablist" aria-label="診断プランの切替">
          <button type="button" class="plan-switch-btn is-active" data-plan="free" role="tab" aria-selected="true">
            <span class="plan-switch-name">無料・簡易版</span>
            <span class="plan-switch-price">0円</span>
          </button>
          <button type="button" class="plan-switch-btn" data-plan="paid" role="tab" aria-selected="false">
            <span class="plan-switch-name">有償・詳細版</span>
            <span class="plan-switch-price">¥5,500 税込</span>
          </button>
        </div>

        <p class="diag-sub" data-plan-show="free">
          かんたんなフォーム入力で、あなたの事業に合った<br/>
          AI活用ポイントを簡易レポートとしてお届けします。
        </p>
        <p class="diag-sub" data-plan-show="paid" hidden>
          御社のIT環境に合わせた<strong>5〜8ページの詳細レポート</strong>と<br/>
          <strong>60分のオンラインMTG</strong>で、AI活用の道筋を具体的にお届けします。
        </p>

        <!-- 無料版のお約束 -->
        <div class="diag-promise" data-plan-show="free">
          <div class="diag-promise-item">
            <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
            <p>詳細版と同じ仕組みで作成。無料版は<strong>要点に絞った2〜3ページ</strong>のレポートをお届けします。</p>
          </div>
          <div class="diag-promise-item">
            <i class="fa-solid fa-list-check" aria-hidden="true"></i>
            <p>AI活用ポイントを<strong>最低3つ</strong>ご提示することをお約束します。</p>
          </div>
          <div class="diag-promise-item">
            <i class="fa-solid fa-handshake-simple" aria-hidden="true"></i>
            <p>契約は不要です。詳細レポートやご相談をご希望の場合のみ、こちらからご案内します。</p>
          </div>
        </div>

        <!-- 有償版のお約束 -->
        <div class="diag-promise" data-plan-show="paid" hidden>
          <div class="diag-promise-item">
            <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
            <p><strong>5〜8ページの詳細レポート</strong>。御社のIT環境に合わせた個別提案・アーキテクチャ図・導入支援の具体額までを記載します。</p>
          </div>
          <div class="diag-promise-item">
            <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
            <p><strong>AI事業者ガイドライン整合性チェック</strong>付き。経産省・総務省のガイドラインに照らして、御社の現状と次の一手を整理します。</p>
          </div>
          <div class="diag-promise-item">
            <i class="fa-solid fa-comments" aria-hidden="true"></i>
            <p><strong>60分のオンラインMTG</strong>を含みます。レポート内容の質疑応答・次の判断のすり合わせを行います。</p>
          </div>
          <div class="diag-promise-item">
            <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
            <p>導入支援にお進みになる場合、本費用は<strong>初期費用に充当</strong>します。</p>
          </div>
        </div>
      </div>
    </section>

    <section class="diag-form-section light-section">
      <div class="container">
        <!-- 無料版ステップ -->
        <div class="diag-steps" data-plan-show="free">
          <div class="step"><span class="step-num">1</span><span>フォーム入力<small>かんたん</small></span></div>
          <div class="step-arrow" aria-hidden="true"></div>
          <div class="step"><span class="step-num">2</span><span>分析<small>1〜2営業日</small></span></div>
          <div class="step-arrow" aria-hidden="true"></div>
          <div class="step"><span class="step-num">3</span><span>レポート送付<small>メールで届く</small></span></div>
        </div>

        <!-- 有償版ステップ -->
        <div class="diag-steps" data-plan-show="paid" hidden>
          <div class="step"><span class="step-num">1</span><span>申込フォーム<small>下記から</small></span></div>
          <div class="step-arrow" aria-hidden="true"></div>
          <div class="step"><span class="step-num">2</span><span>お支払い<small>銀行振込</small></span></div>
          <div class="step-arrow" aria-hidden="true"></div>
          <div class="step"><span class="step-num">3</span><span>業務分析・提案作成<small>5営業日以内</small></span></div>
          <div class="step-arrow" aria-hidden="true"></div>
          <div class="step"><span class="step-num">4</span><span>レポート + MTG<small>日程調整</small></span></div>
        </div>

        <form method="POST" action="/api/free-diagnosis" class="diag-form" id="diag-form">
          <!-- いたずら防止: ハニーポット -->
          <div style="position:absolute;left:-9999px;" aria-hidden="true">
            <label for="website">ウェブサイト</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <!-- いたずら防止: タイムスタンプ -->
          <input type="hidden" name="_t" id="_t" />
          <!-- 選択中プラン（free / paid） -->
          <input type="hidden" name="plan" id="plan-field" value="free" />

          <!-- ===== 業務資料から自動入力（任意） ===== -->
          <fieldset class="upload-fieldset">
            <legend>業務資料・自社サイトから自動入力（任意）</legend>
            <div class="upload-hint">
              <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
              <p>名刺・会社案内・業務報告書などのアップロード、または自社の会社案内ページのURL貼り付けで、AIが内容を読み取って下のフォームを自動入力します。<strong>抽出結果に「ご担当者名は手動でご記入ください」等の確認メッセージが出る場合があります</strong>ので、内容をご確認のうえ修正・追記してください。</p>
            </div>

            <div class="upload-tabs" role="tablist">
              <button type="button" class="upload-tab is-active" data-mode="file" role="tab" aria-selected="true">
                <i class="fa-solid fa-paperclip" aria-hidden="true"></i> ファイル添付
              </button>
              <button type="button" class="upload-tab" data-mode="url" role="tab" aria-selected="false">
                <i class="fa-solid fa-link" aria-hidden="true"></i> URLを貼り付け
              </button>
            </div>

            <div class="upload-mode-panel" data-panel="file">
              <p class="upload-mode-note"><small>対応形式: JPG / PNG / GIF / WebP（最大5MB）／ 名刺・会社案内・スクリーンショット等の画像</small></p>
              <div class="upload-controls">
                <label for="file-upload" class="upload-file-label">
                  <i class="fa-solid fa-paperclip" aria-hidden="true"></i>
                  <span id="upload-file-name">ファイルを選択</span>
                </label>
                <input type="file" id="file-upload" accept="image/jpeg,image/png,image/gif,image/webp" />
                <button type="button" id="extract-file-btn" class="upload-btn">
                  <i class="fa-solid fa-file-import" aria-hidden="true"></i> AIで読み取って反映
                </button>
              </div>
            </div>

            <div class="upload-mode-panel" data-panel="url" hidden>
              <p class="upload-mode-note"><small>会社案内ページなど、公開されているURLを指定してください（JavaScriptで描画されるサイトはご利用いただけない場合があります）</small></p>
              <div class="upload-controls upload-controls--url">
                <input type="url" id="url-input" class="upload-url-input" placeholder="https://example.co.jp/company" />
                <button type="button" id="extract-url-btn" class="upload-btn">
                  <i class="fa-solid fa-globe" aria-hidden="true"></i> URLから読み取って反映
                </button>
              </div>
            </div>

            <p id="extract-status" class="extract-status" hidden></p>

            <!-- ファクトチェック・抽出結果サマリー（読み取り後に表示） -->
            <div id="extract-factcheck" class="extract-factcheck" hidden>
              <div class="factcheck-head">
                <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                <h3>抽出内容の確認</h3>
              </div>
              <ul id="factcheck-notes" class="factcheck-notes"></ul>
              <div id="extract-extras-wrap" class="extract-extras" hidden>
                <p class="extras-title">参考情報（フォームには反映していません）</p>
                <dl id="extract-extras-list" class="extras-list"></dl>
              </div>
            </div>
          </fieldset>

          <fieldset>
            <legend>組織情報</legend>
            <div class="field">
              <label for="company_name">企業・団体名 <span class="req">*</span></label>
              <input type="text" id="company_name" name="company_name" required placeholder="例: 株式会社〇〇" />
            </div>
            <div class="field">
              <label for="person_name">ご担当者名 <span class="req">*</span></label>
              <input type="text" id="person_name" name="person_name" required placeholder="例: 山田 太郎" />
            </div>
            <div class="field">
              <label for="email">メールアドレス <span class="req">*</span></label>
              <input type="email" id="email" name="email" required placeholder="example@company.com" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="industry">業種 <span class="req">*</span></label>
                <select id="industry" name="industry" required>
                  <option value="">選択してください</option>
                  <option value="accommodation">宿泊業（ペンション・旅館・ホテル）</option>
                  <option value="restaurant">飲食業（カフェ・レストラン）</option>
                  <option value="construction">建設業（工務店・リフォーム）</option>
                  <option value="winery">醸造所（ワイナリー・ブルワリー）</option>
                  <option value="outdoor">アウトドア・観光ガイド</option>
                  <option value="bakery">パン屋・菓子製造</option>
                  <option value="agriculture">農業・畜産業</option>
                  <option value="retail">小売業</option>
                  <option value="service">サービス業</option>
                  <option value="manufacturing">製造業</option>
                  <option value="municipality">自治体・公共機関</option>
                  <option value="other">その他</option>
                </select>
              </div>
              <div class="field">
                <label for="employee_count">従業員数</label>
                <select id="employee_count" name="employee_count">
                  <option value="">選択してください</option>
                  <option value="1">1名（個人事業）</option>
                  <option value="2-5">2〜5名</option>
                  <option value="6-20">6〜20名</option>
                  <option value="21-50">21〜50名</option>
                  <option value="51-100">51〜100名</option>
                  <option value="101+">101名以上</option>
                </select>
              </div>
            </div>
          </fieldset>

          <fieldset>
            <legend>AI活用の現状</legend>
            <div class="field">
              <label for="ai_level">現在のAI活用度 <span class="req">*</span></label>
              <select id="ai_level" name="ai_level" required>
                <option value="">選択してください</option>
                <option value="none">まったく使っていない</option>
                <option value="interest">興味はあるが未導入</option>
                <option value="trial">個人的に試している程度</option>
                <option value="partial">一部業務で活用中</option>
                <option value="active">組織的に活用中</option>
              </select>
            </div>
            <div class="field">
              <label for="budget_range">想定予算（導入支援の初期費用）</label>
              <select id="budget_range" name="budget_range">
                <option value="">選択してください</option>
                <option value="under-30">〜30万円（小さく試したい）</option>
                <option value="30-60">30〜60万円（本格導入を検討）</option>
                <option value="60-100">60〜100万円（複数業務を一括）</option>
                <option value="100-plus">100万円以上（経営課題として取り組む）</option>
                <option value="undecided">まだ分からない・相談したい</option>
              </select>
              <p class="field-hint">予算をお知らせいただくと、レポートで「予算内で実現可能な範囲」を具体的にご提案できます。</p>
            </div>
            <div class="field">
              <p class="field-label">AI導入で感じている課題（複数可）</p>
              <div class="checkbox-group">
                <label class="checkbox-item">
                  <input type="checkbox" name="challenges" value="what-to-use" />
                  <span>何に使えるかわからない</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="challenges" value="cost" />
                  <span>コストが心配</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="challenges" value="security" />
                  <span>セキュリティが不安</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="challenges" value="skill" />
                  <span>社内にスキルがない</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="challenges" value="time" />
                  <span>導入する時間がない</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="challenges" value="effect" />
                  <span>効果が見えない</span>
                </label>
              </div>
            </div>
          </fieldset>

          <fieldset>
            <legend>業務の詳細（任意）</legend>
            <div class="detail-hint">
              <i class="fa-solid fa-lightbulb"></i>
              <p>以下の項目にご回答いただくほど、より具体的で精度の高い診断レポートをお届けできます。</p>
            </div>
            <div class="field">
              <label for="business_description">事業内容・主なサービス</label>
              <textarea id="business_description" name="business_description" rows="3" placeholder="例: 家族向けペンションを運営。宿泊・レストラン・アクティビティガイドの3事業"></textarea>
            </div>
            <div class="field">
              <label for="daily_tasks">日常業務で時間がかかっている作業</label>
              <textarea id="daily_tasks" name="daily_tasks" rows="3" placeholder="例: 予約メールの返信、SNS投稿の作成、月次の売上レポート作成、在庫の発注判断"></textarea>
            </div>
            <div class="field">
              <label for="current_tools">現在使っているITツール・ソフトウェア</label>
              <textarea id="current_tools" name="current_tools" rows="2" placeholder="例: じゃらん、LINE公式、Excel、freee会計、Instagram"></textarea>
            </div>
            <div class="field">
              <p class="field-label">AIを使ってみたい業務領域（複数可）</p>
              <div class="checkbox-group">
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="customer-support" />
                  <span>顧客対応・問い合わせ</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="marketing" />
                  <span>集客・マーケティング</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="accounting" />
                  <span>経理・事務作業</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="content" />
                  <span>SNS・コンテンツ作成</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="inventory" />
                  <span>在庫・仕入れ管理</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="scheduling" />
                  <span>予約・スケジュール管理</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="analysis" />
                  <span>データ分析・レポート</span>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="interests" value="training" />
                  <span>社員教育・マニュアル</span>
                </label>
              </div>
            </div>
            <div class="field">
              <label for="free_text">その他、気になっていること</label>
              <textarea id="free_text" name="free_text" rows="3" placeholder="「AIで作った文章をそのまま使って大丈夫？」「月額いくらくらいかかる？」など"></textarea>
            </div>
          </fieldset>

          <fieldset class="extra-fieldset">
            <legend>詳細レポート向けの追加情報（任意）</legend>
            <div class="detail-hint">
              <i class="fa-solid fa-stars"></i>
              <p>以下は<strong>詳細レポートをご希望の場合に役立つ情報</strong>です。記入が多いほど、ROI試算や提案の精度が向上します。すべて任意です。</p>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="business_age">創業・設立</label>
                <input type="text" id="business_age" name="business_age" placeholder="例: 2010年創業 / 創業30年" />
              </div>
              <div class="field">
                <label for="service_area">主な営業エリア・拠点</label>
                <input type="text" id="service_area" name="service_area" placeholder="例: 東京都中心 / 全国対応 / 関東エリア" />
              </div>
            </div>
            <div class="field">
              <label for="target_customer">主要顧客層・ターゲット</label>
              <input type="text" id="target_customer" name="target_customer" placeholder="例: 30〜50代女性 / 法人（中小企業） / 建設業界の現場監督" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="annual_revenue_range">売上規模感</label>
                <select id="annual_revenue_range" name="annual_revenue_range">
                  <option value="">選択してください</option>
                  <option value="under-10m">〜1,000万円</option>
                  <option value="10-30m">1,000万〜3,000万円</option>
                  <option value="30-50m">3,000万〜5,000万円</option>
                  <option value="50-100m">5,000万〜1億円</option>
                  <option value="100-300m">1億〜3億円</option>
                  <option value="300-1000m">3億〜10億円</option>
                  <option value="over-1000m">10億円以上</option>
                </select>
              </div>
              <div class="field">
                <label for="decision_timeline">AI導入のご検討時期</label>
                <select id="decision_timeline" name="decision_timeline">
                  <option value="">選択してください</option>
                  <option value="asap">できるだけ早く</option>
                  <option value="3m">3ヶ月以内</option>
                  <option value="6m">半年以内</option>
                  <option value="12m">1年以内</option>
                  <option value="undecided">未定（情報収集中）</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label for="past_it_experience">過去のIT・自動化導入の経験</label>
              <textarea id="past_it_experience" name="past_it_experience" rows="3" placeholder="例: 数年前にCRMを導入したが定着せず利用停止。Excel管理に戻った。"></textarea>
            </div>
          </fieldset>

          <!-- 有償版の支払い案内（paid時のみ表示） -->
          <div class="payment-note" data-plan-show="paid" hidden>
            <div class="payment-note-head">
              <i class="fa-solid fa-credit-card" aria-hidden="true"></i>
              <h3>お支払いの流れ（全自動）</h3>
            </div>
            <ol class="payment-note-steps">
              <li>このフォーム送信時に<strong>申込番号</strong>を自動採番し、振込先口座と併せて<strong>確認メールを即時お送り</strong>します。</li>
              <li>メール記載の銀行口座へ<strong>銀行振込</strong>（お振込期限：申込から7日以内）。<strong>振込人名義はご入力いただいた会社名のみでOK</strong>です（特別な番号併記は不要）。</li>
              <li>入金が<strong>自動検知</strong>され（通常1営業日以内）、「入金を確認しました」メールが自動送信されます。</li>
              <li>入金確認後 <strong>5営業日以内に詳細レポート＋60分MTG日程調整リンク</strong>をお届けします。</li>
            </ol>
            <p class="payment-note-foot">※ お振込手数料はお客様ご負担となります。<br />※ 領収書・適格請求書（インボイス）の発行に対応しています。<br />※ 導入支援契約に進まれた場合、本費用 ¥5,500（税込）は<strong>初期費用に全額充当</strong>します。</p>
          </div>

          <div class="form-note">
            <p>ご入力いただいた情報は診断レポート作成のみに使用します。</p>
            <p>レポート送付後、ご検討の負担になるような連絡はいたしません。</p>
            <p><a href="/privacy-policy">プライバシーポリシー</a>をご確認ください。</p>
          </div>

          <button type="submit" class="btn-primary diag-submit" id="diag-submit">
            <span data-plan-show="free">無料診断を受ける</span>
            <span data-plan-show="paid" hidden>詳細診断を申し込む（¥5,500 税込）</span>
          </button>
        </form>
      </div>
    </section>

  </main>
</Layout>

<script is:inline>
  // タイムスタンプ設定（いたずら防止）
  document.getElementById('_t').value = String(Date.now());

  // ===== プラン切替（free / paid） =====
  (function() {
    var planField = document.getElementById('plan-field');
    var planTargets = document.querySelectorAll('[data-plan-show]');
    var planButtons = document.querySelectorAll('.plan-switch-btn');

    function applyPlan(plan) {
      planButtons.forEach(function(btn) {
        var on = btn.getAttribute('data-plan') === plan;
        btn.classList.toggle('is-active', on);
        btn.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      planTargets.forEach(function(el) {
        var allowed = (el.getAttribute('data-plan-show') || '').split(',').map(function(s) { return s.trim(); });
        el.hidden = allowed.indexOf(plan) === -1;
      });
      if (planField) planField.value = plan;
      document.body.setAttribute('data-plan', plan);
    }

    planButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var plan = btn.getAttribute('data-plan');
        if (plan) applyPlan(plan);
      });
    });

    applyPlan('free');
  })();

  // 二重送信防止
  document.getElementById('diag-form').addEventListener('submit', function() {
    var btn = document.getElementById('diag-submit');
    btn.disabled = true;
    var plan = (document.getElementById('plan-field') || {}).value || 'free';
    btn.textContent = plan === 'paid' ? 'お申込中…' : '送信中…';
  });

  // ===== 業務資料・URLからの自動入力 =====
  (function() {
    var fileUpload = document.getElementById('file-upload');
    var fileNameLabel = document.getElementById('upload-file-name');
    var extractFileBtn = document.getElementById('extract-file-btn');
    var extractUrlBtn = document.getElementById('extract-url-btn');
    var urlInput = document.getElementById('url-input');
    var extractStatus = document.getElementById('extract-status');
    var tabs = document.querySelectorAll('.upload-tab');
    var panels = document.querySelectorAll('.upload-mode-panel');

    if (!extractStatus) return;

    function setStatus(text, kind) {
      extractStatus.textContent = text;
      extractStatus.className = 'extract-status ' + (kind || 'info');
      extractStatus.hidden = false;
    }

    var FIELD_LABELS = {
      company_name: '企業・団体名',
      person_name: 'ご担当者名',
      email: 'メールアドレス',
      industry: '業種',
      employee_count: '従業員数',
      business_description: '事業内容',
      daily_tasks: '日常業務',
      current_tools: '使用ITツール',
      business_age: '創業・設立',
      service_area: '営業エリア',
      target_customer: '主要顧客層',
      annual_revenue_range: '売上規模感',
      decision_timeline: 'ご検討時期',
      past_it_experience: '過去のIT導入経験',
    };

    var EXTRAS_LABELS = {
      representative_name: '代表者名',
      phone: '電話番号',
      address: '住所',
      fax: 'FAX番号',
      website: 'ウェブサイト',
    };

    function renderFactCheck(data) {
      var factWrap = document.getElementById('extract-factcheck');
      var notesUl = document.getElementById('factcheck-notes');
      var extrasWrap = document.getElementById('extract-extras-wrap');
      var extrasList = document.getElementById('extract-extras-list');
      if (!factWrap || !notesUl) return;

      notesUl.innerHTML = '';
      var notes = Array.isArray(data.notes) ? data.notes : [];
      if (notes.length === 0) {
        var li = document.createElement('li');
        li.className = 'factcheck-note factcheck-note--info';
        li.textContent = '抽出に対する注意事項はありません。各欄の内容をご確認ください。';
        notesUl.appendChild(li);
      } else {
        notes.forEach(function(n) {
          var li = document.createElement('li');
          var level = (n && n.level) === 'warn' ? 'warn' : 'info';
          li.className = 'factcheck-note factcheck-note--' + level;
          var fieldLabel = n.field && FIELD_LABELS[n.field] ? '【' + FIELD_LABELS[n.field] + '】' : '';
          li.textContent = fieldLabel + (n.message || '');
          notesUl.appendChild(li);
        });
      }

      // extras
      if (extrasList && extrasWrap) {
        extrasList.innerHTML = '';
        var extras = data.extracted_extras || {};
        var extraKeys = Object.keys(extras).filter(function(k) { return extras[k] && String(extras[k]).trim(); });
        if (extraKeys.length === 0) {
          extrasWrap.hidden = true;
        } else {
          extraKeys.forEach(function(k) {
            var dt = document.createElement('dt');
            dt.textContent = EXTRAS_LABELS[k] || k;
            var dd = document.createElement('dd');
            dd.textContent = extras[k];
            extrasList.appendChild(dt);
            extrasList.appendChild(dd);
          });
          extrasWrap.hidden = false;
        }
      }
      factWrap.hidden = false;
    }

    function applyFields(data) {
      var fields = data.fields || {};
      var setIf = function(id, val) {
        if (val) {
          var el = document.getElementById(id);
          if (el) {
            el.value = val;
            el.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
      };
      // 基本
      setIf('company_name', fields.company_name);
      setIf('person_name', fields.person_name);
      setIf('email', fields.email);
      setIf('industry', fields.industry);
      setIf('employee_count', fields.employee_count);
      setIf('business_description', fields.business_description);
      setIf('daily_tasks', fields.daily_tasks);
      setIf('current_tools', fields.current_tools);
      // 詳細レポート向け追加項目
      setIf('business_age', fields.business_age);
      setIf('service_area', fields.service_area);
      setIf('target_customer', fields.target_customer);
      setIf('annual_revenue_range', fields.annual_revenue_range);
      setIf('decision_timeline', fields.decision_timeline);
      setIf('past_it_experience', fields.past_it_experience);

      var filledCount = 0;
      Object.keys(fields).forEach(function(k) {
        if (fields[k] && String(fields[k]).trim()) filledCount++;
      });

      var msg;
      if (data.mock) {
        msg = 'モック応答（APIキー未設定）です。本番環境では実データから抽出されます。' + filledCount + '項目を反映しました。';
      } else if (filledCount === 0) {
        msg = '読み取り結果が空でした。情報源を変更して再度お試しください。';
      } else {
        msg = filledCount + '項目をフォームに反映しました。下記の確認内容と合わせてご確認・修正をお願いします。';
      }
      setStatus(msg, filledCount === 0 ? 'error' : 'info');

      // ファクトチェック表示
      renderFactCheck(data);
    }

    function postExtract(payload, btn, runningMsg) {
      btn.disabled = true;
      setStatus(runningMsg, 'info');
      fetch('/api/file-extract', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.error) {
            setStatus(data.error, 'error');
          } else {
            applyFields(data);
          }
          btn.disabled = false;
        })
        .catch(function(err) {
          console.error('[file-extract] fetch error:', err);
          setStatus('通信エラーが発生しました。時間をおいて再度お試しください。', 'error');
          btn.disabled = false;
        });
    }

    // タブ切替
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var mode = tab.getAttribute('data-mode');
        tabs.forEach(function(t) {
          var on = t === tab;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        panels.forEach(function(p) {
          p.hidden = p.getAttribute('data-panel') !== mode;
        });
      });
    });

    // ファイル選択時のラベル更新
    if (fileUpload && fileNameLabel) {
      fileUpload.addEventListener('change', function() {
        var file = fileUpload.files && fileUpload.files[0];
        fileNameLabel.textContent = file ? file.name : 'ファイルを選択';
      });
    }

    // ファイル → 抽出
    if (extractFileBtn && fileUpload) {
      extractFileBtn.addEventListener('click', function() {
        var file = fileUpload.files && fileUpload.files[0];
        if (!file) {
          setStatus('ファイルを選択してください。', 'error');
          return;
        }
        if (file.size > 5 * 1024 * 1024) {
          setStatus('ファイルサイズが上限（5MB）を超えています。', 'error');
          return;
        }
        var reader = new FileReader();
        reader.onload = function() {
          var dataUrl = String(reader.result || '');
          var match = dataUrl.match(/^data:([^;]+);base64,(.+)$/);
          if (!match) {
            setStatus('ファイルの読み込みに失敗しました。', 'error');
            return;
          }
          postExtract(
            { fileBase64: match[2], mediaType: match[1], fileName: file.name },
            extractFileBtn,
            'AIが書類を読み取り中… 通常10〜30秒かかります。'
          );
        };
        reader.onerror = function() {
          setStatus('ファイルの読み込みに失敗しました。', 'error');
        };
        reader.readAsDataURL(file);
      });
    }

    // URL → 抽出
    if (extractUrlBtn && urlInput) {
      extractUrlBtn.addEventListener('click', function() {
        var url = urlInput.value.trim();
        if (!url) {
          setStatus('URLを入力してください。', 'error');
          return;
        }
        if (!/^https?:\/\//i.test(url)) {
          setStatus('http:// または https:// で始まるURLを入力してください。', 'error');
          return;
        }
        postExtract(
          { url: url },
          extractUrlBtn,
          'ページを読み取り中… 通常10〜30秒かかります。'
        );
      });
    }
  })();

</script>

