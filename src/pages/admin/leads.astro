---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

type Lead = {
  id: number | string;
  created_at: string;
  updated_at?: string | null;
  application_id?: string | null;
  company_name?: string | null;
  person_name?: string | null;
  email?: string | null;
  industry?: string | null;
  employee_count?: string | null;
  ai_level?: string | null;
  challenges?: string[] | string | null;
  interests?: string[] | string | null;
  business_description?: string | null;
  daily_tasks?: string | null;
  current_tools?: string | null;
  lead_source?: string | null;
  lead_source_detail?: string | null;
  entry_referrer?: string | null;
  plan?: string | null;
  status?: string | null;
  amount_jpy?: number | null;
  paid_at?: string | null;
  verified_at?: string | null;
  sent_at?: string | null;
  report_sent_at?: string | null;
  slides_url?: string | null;
  business_age?: string | null;
  service_area?: string | null;
  target_customer?: string | null;
  annual_revenue_range?: string | null;
  decision_timeline?: string | null;
  past_it_experience?: string | null;
  admin_notes?: string | null;
  last_error?: string | null;
};

type StatusConfig = {
  id: string;
  label: string;
  shortLabel: string;
  color: string;
  group: 'intake' | 'automation' | 'sales' | 'delivery' | 'closed';
  actionable?: boolean;
};

type NextAction = {
  label: string;
  detail: string;
  urgency: 'critical' | 'high' | 'medium' | 'low' | 'none';
  due: string;
  score: number;
};

const adminColors = {
  primary: '#1F3A93',
  primaryDark: '#152870',
  secondary: '#6B85C9',
  accent: '#E48A95',
  accentSoft: '#FFCED0',
  muted: '#94a3b8',
};

const statusConfigs: StatusConfig[] = [
  { id: 'new', label: '新規受付', shortLabel: '新規', color: adminColors.secondary, group: 'intake', actionable: true },
  { id: 'pending_verification', label: 'メール認証待ち', shortLabel: '認証待ち', color: adminColors.muted, group: 'intake' },
  { id: 'verified', label: '認証完了・処理待ち', shortLabel: '処理待ち', color: adminColors.secondary, group: 'automation' },
  { id: 'processing', label: '自動生成中', shortLabel: '生成中', color: adminColors.primary, group: 'automation' },
  { id: 'completed', label: '簡易レポート送付済', shortLabel: '無料完了', color: adminColors.secondary, group: 'automation' },
  { id: 'quota_retry_pending', label: 'クォータ再試行待ち', shortLabel: '再試行', color: adminColors.accent, group: 'automation', actionable: true },
  { id: 'manual_review', label: '手動確認', shortLabel: '要確認', color: adminColors.accent, group: 'automation', actionable: true },
  { id: 'limit_exceeded', label: '月次上限到達', shortLabel: '上限', color: adminColors.accent, group: 'automation', actionable: true },
  { id: 'rejected', label: 'スパム・対象外', shortLabel: '対象外', color: adminColors.muted, group: 'closed' },
  { id: 'pending_payment', label: '入金待ち', shortLabel: '入金待ち', color: adminColors.accent, group: 'sales', actionable: true },
  { id: 'paid', label: '入金確認済み', shortLabel: '入金済', color: adminColors.secondary, group: 'sales', actionable: true },
  { id: 'report_created', label: '詳細レポート作成済', shortLabel: '作成済', color: adminColors.primary, group: 'sales', actionable: true },
  { id: 'report_sent', label: '詳細レポート送付済', shortLabel: '送付済', color: adminColors.accentSoft, group: 'sales', actionable: true },
  { id: 'sent', label: '詳細レポート送付済', shortLabel: '送付済', color: adminColors.accentSoft, group: 'sales', actionable: true },
  { id: 'mtg_scheduled', label: 'MTG予定', shortLabel: 'MTG', color: adminColors.secondary, group: 'sales', actionable: true },
  { id: 'paid_report', label: '有料レポート完了', shortLabel: '有料完了', color: adminColors.secondary, group: 'sales', actionable: true },
  { id: 'implementation', label: '導入支援', shortLabel: '導入', color: adminColors.accent, group: 'delivery', actionable: true },
  { id: 'maintenance', label: '保守契約', shortLabel: '保守', color: adminColors.secondary, group: 'delivery', actionable: true },
  { id: 'cancelled', label: 'キャンセル', shortLabel: '終了', color: adminColors.muted, group: 'closed' },
];

const statusMap = new Map(statusConfigs.map((s) => [s.id, s]));
const statusOptions = statusConfigs.map((s) => ({ id: s.id, label: s.label }));

const lanes = [
  { id: 'intake', label: '受付・認証', note: 'フォーム送信から診断開始まで', statuses: ['new', 'pending_verification'] },
  { id: 'automation', label: '自動生成・例外', note: '無料診断の処理状況', statuses: ['verified', 'processing', 'completed', 'quota_retry_pending', 'manual_review', 'limit_exceeded'] },
  { id: 'sales', label: '有償化・商談', note: '詳細版、MTG、提案化', statuses: ['pending_payment', 'paid', 'report_created', 'report_sent', 'sent', 'mtg_scheduled', 'paid_report'] },
  { id: 'delivery', label: '導入・保守', note: '導入案件と継続契約', statuses: ['implementation', 'maintenance'] },
  { id: 'closed', label: '終了・対象外', note: '追わないリード', statuses: ['cancelled', 'rejected'] },
];

const industryLabels: Record<string, string> = {
  accommodation: '宿泊業',
  restaurant: '飲食業',
  construction: '建設業',
  winery: '醸造所',
  outdoor: 'アウトドア・観光',
  bakery: 'パン屋・菓子',
  agriculture: '農業・畜産業',
  retail: '小売業',
  service: 'サービス業',
  manufacturing: '製造業',
  municipality: '自治体・公共機関',
  other: 'その他',
};

const employeeLabels: Record<string, string> = {
  '1': '1名',
  '2-5': '2〜5名',
  '6-20': '6〜20名',
  '21-50': '21〜50名',
  '51-100': '51〜100名',
  '101+': '101名以上',
};

const timelineLabels: Record<string, string> = {
  asap: 'できるだけ早く',
  '3m': '3ヶ月以内',
  '6m': '半年以内',
  '12m': '1年以内',
  undecided: '未定',
};

const revenueLabels: Record<string, string> = {
  'under-10m': '〜1,000万円',
  '10-30m': '1,000万〜3,000万円',
  '30-50m': '3,000万〜5,000万円',
  '50-100m': '5,000万〜1億円',
  '100-300m': '1億〜3億円',
  '300-1000m': '3億〜10億円',
  'over-1000m': '10億円以上',
};

const leadSourceLabels: Record<string, string> = {
  'url-file-demo': '自動入力デモ',
  'public-demo': '実機デモ',
  'ai-examples': '業種別サンプル',
  'role-demo': 'ロール別デモ',
  blog: 'ブログ',
  search: '検索',
  referral: '紹介',
  'business-group': '商工会・勉強会',
  other: 'その他',
};

let leads: Lead[] = [];
let error = '';

if (supabase) {
  const { data, error: dbError } = await supabase
    .from('diagnosis_leads')
    .select('*')
    .order('created_at', { ascending: false });

  if (dbError) {
    error = dbError.message;
  } else {
    leads = (data as Lead[]) || [];
  }

} else {
  error = 'Supabase が設定されていません';
}

const now = Date.now();
const oneHour = 60 * 60 * 1000;
const oneDay = 24 * oneHour;
const yen = new Intl.NumberFormat('ja-JP');
const tokyoDate = new Intl.DateTimeFormat('ja-JP', {
  timeZone: 'Asia/Tokyo',
  month: '2-digit',
  day: '2-digit',
});
const tokyoDayKeyFormatter = new Intl.DateTimeFormat('sv-SE', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
const tokyoMonthKeyFormatter = new Intl.DateTimeFormat('sv-SE', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: '2-digit',
});

function normalizeStatus(status?: string | null) {
  return status || 'new';
}

function getStatus(status?: string | null): StatusConfig {
  const id = normalizeStatus(status);
  return statusMap.get(id) || {
    id,
    label: id,
    shortLabel: id,
    color: adminColors.muted,
    group: 'closed',
  };
}

function parseTime(iso?: string | null) {
  if (!iso) return 0;
  const t = new Date(iso).getTime();
  return Number.isFinite(t) ? t : 0;
}

function ageDays(lead: Lead, from: 'created_at' | 'updated_at' = 'created_at') {
  const t = parseTime(from === 'updated_at' ? lead.updated_at || lead.created_at : lead.created_at);
  if (!t) return 0;
  return Math.max(0, Math.floor((now - t) / oneDay));
}

function ageHours(lead: Lead, from: 'created_at' | 'updated_at' = 'created_at') {
  const t = parseTime(from === 'updated_at' ? lead.updated_at || lead.created_at : lead.created_at);
  if (!t) return 0;
  return Math.max(0, Math.floor((now - t) / oneHour));
}

function formatDate(iso?: string | null) {
  return iso ? tokyoDate.format(new Date(iso)) : '-';
}

function truncate(value?: string | null, max = 90) {
  if (!value) return '';
  return value.length > max ? `${value.slice(0, max)}...` : value;
}

function tokyoDayKey(date: Date) {
  return tokyoDayKeyFormatter.format(date);
}

function tokyoMonthKey(date: Date) {
  return tokyoMonthKeyFormatter.format(date);
}

function timeAgo(iso?: string | null) {
  const t = parseTime(iso);
  if (!t) return '-';
  const diff = Math.max(0, now - t);
  const hours = Math.floor(diff / oneHour);
  const days = Math.floor(diff / oneDay);
  if (hours < 1) return '1時間未満';
  if (hours < 24) return `${hours}時間前`;
  if (days === 1) return '昨日';
  return `${days}日前`;
}

function normalizeList(value: Lead['challenges']) {
  if (!value) return [];
  if (Array.isArray(value)) return value;
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed : [value];
  } catch {
    return [value];
  }
}

function planLabel(plan?: string | null) {
  return plan === 'paid' ? '詳細版' : '簡易版';
}

function isPaidOpportunity(lead: Lead) {
  const status = normalizeStatus(lead.status);
  return lead.plan === 'paid'
    || ['pending_payment', 'paid', 'report_created', 'report_sent', 'sent', 'mtg_scheduled', 'paid_report', 'implementation', 'maintenance'].includes(status)
    || (lead.amount_jpy || 0) > 0;
}

function isRevenueConfirmed(lead: Lead) {
  return Boolean(lead.paid_at) && (lead.amount_jpy || 0) > 0;
}

function hasAiIssue(lead: Lead) {
  const status = normalizeStatus(lead.status);
  return Boolean(lead.last_error) || ['manual_review', 'quota_retry_pending', 'limit_exceeded'].includes(status);
}

function nextActionFor(lead: Lead): NextAction {
  const status = normalizeStatus(lead.status);
  const createdDays = ageDays(lead);
  const updatedHours = ageHours(lead, 'updated_at');

  if (status === 'manual_review') {
    return {
      label: '生成エラーを確認',
      detail: lead.last_error ? `原因: ${lead.last_error.slice(0, 80)}` : '入力不足・自動生成失敗の原因を確認',
      urgency: 'critical',
      due: '今日',
      score: 100,
    };
  }
  if (status === 'limit_exceeded') {
    return {
      label: '月次枠の扱いを判断',
      detail: '翌月案内、詳細版案内、個別対応のいずれかを決める',
      urgency: 'critical',
      due: '今日',
      score: 96,
    };
  }
  if (status === 'quota_retry_pending') {
    return {
      label: updatedHours >= 8 ? '再処理状況を確認' : '自動リトライ待ち',
      detail: updatedHours >= 8 ? 'cron 後も残っていれば手動再実行を検討' : '翌朝 7:00 JST の自動再処理対象',
      urgency: updatedHours >= 8 ? 'high' : 'medium',
      due: updatedHours >= 8 ? '今日' : '翌朝確認',
      score: updatedHours >= 8 ? 90 : 64,
    };
  }
  if (status === 'verified' || status === 'processing') {
    return {
      label: updatedHours >= 2 ? '自動生成の停滞確認' : '自動生成を待つ',
      detail: status === 'verified' ? 'Database Webhook 起動状況を確認' : 'Edge Function の進行状況を確認',
      urgency: updatedHours >= 2 ? 'high' : 'low',
      due: updatedHours >= 2 ? '今日' : '自動処理中',
      score: updatedHours >= 2 ? 86 : 28,
    };
  }
  if (status === 'pending_verification') {
    return {
      label: createdDays >= 1 ? '認証未完了を確認' : 'メール認証待ち',
      detail: createdDays >= 1 ? '認証メール未クリック。再送や個別連絡を検討' : '顧客のメール認証待ち',
      urgency: createdDays >= 2 ? 'medium' : 'low',
      due: createdDays >= 1 ? '様子見後フォロー' : '待機',
      score: createdDays >= 2 ? 54 : 20,
    };
  }
  if (status === 'pending_payment') {
    return {
      label: createdDays >= 3 ? '入金リマインド' : '入金確認',
      detail: `請求金額 ¥${yen.format(lead.amount_jpy || 0)}。freee 入金照合を確認`,
      urgency: createdDays >= 3 ? 'high' : 'medium',
      due: createdDays >= 3 ? '今日' : '入金待ち',
      score: createdDays >= 3 ? 88 : 70,
    };
  }
  if (status === 'paid') {
    return {
      label: '詳細レポート作成',
      detail: '5営業日以内の納品に向けて作成開始',
      urgency: createdDays >= 1 ? 'high' : 'medium',
      due: '5営業日以内',
      score: createdDays >= 1 ? 84 : 72,
    };
  }
  if (status === 'report_created') {
    return {
      label: 'レポート送付',
      detail: 'PDF と MTG 日程調整リンクを送付',
      urgency: 'high',
      due: '今日',
      score: 82,
    };
  }
  if (status === 'sent' || status === 'report_sent') {
    return {
      label: createdDays >= 2 ? 'MTG日程フォロー' : 'MTG日程待ち',
      detail: '日程確定後、導入支援の仮説を準備',
      urgency: createdDays >= 2 ? 'medium' : 'low',
      due: createdDays >= 2 ? '今日〜明日' : '待機',
      score: createdDays >= 2 ? 62 : 36,
    };
  }
  if (status === 'mtg_scheduled') {
    return {
      label: '商談準備',
      detail: '課題、ROI、次回提案の叩き台を整理',
      urgency: 'medium',
      due: 'MTG前',
      score: 68,
    };
  }
  if (status === 'paid_report') {
    return {
      label: '導入支援へ提案化',
      detail: '見積、スコープ、初回着手範囲を決める',
      urgency: 'medium',
      due: '次回接点',
      score: 66,
    };
  }
  if (status === 'implementation') {
    return {
      label: '週次進捗確認',
      detail: '納品物、未決事項、次回作業を確認',
      urgency: 'medium',
      due: '週次',
      score: 60,
    };
  }
  if (status === 'maintenance') {
    return {
      label: '継続改善ログ確認',
      detail: '改善要望、効果、次月提案を記録',
      urgency: 'low',
      due: '月次',
      score: 38,
    };
  }
  if (status === 'completed') {
    return {
      label: createdDays >= 3 ? '詳細版フォロー検討' : 'レポート到達確認',
      detail: '無料診断後の反応を見て、有償相談の導線を判断',
      urgency: createdDays >= 3 ? 'medium' : 'low',
      due: createdDays >= 3 ? '今週' : '待機',
      score: createdDays >= 3 ? 50 : 24,
    };
  }
  if (status === 'new') {
    return {
      label: '受付内容を確認',
      detail: '業種、課題、メール、重複を確認',
      urgency: 'medium',
      due: '今日',
      score: 58,
    };
  }
  return {
    label: '対応不要',
    detail: '終了または対象外',
    urgency: 'none',
    due: '-',
    score: 0,
  };
}

function leadScore(lead: Lead) {
  let score = 0;
  if (lead.plan === 'paid') score += 28;
  if (isRevenueConfirmed(lead)) score += 22;
  if (['paid', 'report_created', 'sent', 'report_sent', 'mtg_scheduled', 'paid_report', 'implementation', 'maintenance'].includes(normalizeStatus(lead.status))) score += 18;
  if (lead.decision_timeline === 'asap') score += 18;
  if (lead.decision_timeline === '3m') score += 14;
  if (lead.decision_timeline === '6m') score += 8;
  if (['6-20', '21-50', '51-100', '101+'].includes(lead.employee_count || '')) score += 10;
  if (['50-100m', '100-300m', '300-1000m', 'over-1000m'].includes(lead.annual_revenue_range || '')) score += 10;
  if ((lead.daily_tasks || '').length > 80) score += 8;
  if (normalizeList(lead.interests).length >= 2) score += 5;
  return Math.min(100, score);
}

function priorityLabel(score: number) {
  if (score >= 70) return '高';
  if (score >= 40) return '中';
  return '低';
}

function urgencyRank(urgency: NextAction['urgency']) {
  return { critical: 4, high: 3, medium: 2, low: 1, none: 0 }[urgency];
}

const actionRows = leads
  .map((lead) => ({ lead, action: nextActionFor(lead), score: leadScore(lead) }))
  .filter((row) => row.action.urgency !== 'none')
  .sort((a, b) => urgencyRank(b.action.urgency) - urgencyRank(a.action.urgency) || b.action.score - a.action.score || b.score - a.score)
  .slice(0, 10);

const total = leads.length;
const last7d = leads.filter((l) => parseTime(l.created_at) > now - 7 * oneDay).length;
const last30d = leads.filter((l) => parseTime(l.created_at) > now - 30 * oneDay).length;
const actionableCount = leads.filter((l) => nextActionFor(l).urgency !== 'none' && nextActionFor(l).score >= 50).length;
const criticalCount = leads.filter((l) => ['critical', 'high'].includes(nextActionFor(l).urgency)).length;
const paidOpportunityCount = leads.filter(isPaidOpportunity).length;
const confirmedRevenue = leads.filter(isRevenueConfirmed).reduce((sum, l) => sum + (l.amount_jpy || 0), 0);
const pendingRevenue = leads
  .filter((l) => normalizeStatus(l.status) === 'pending_payment')
  .reduce((sum, l) => sum + (l.amount_jpy || 0), 0);
const implementationCount = leads.filter((l) => ['implementation', 'maintenance'].includes(normalizeStatus(l.status))).length;
const currentMonthKey = tokyoMonthKey(new Date());
const monthlyVerified = leads.filter((l) => {
  const status = normalizeStatus(l.status);
  return l.verified_at
    && ['verified', 'processing', 'completed', 'manual_review', 'quota_retry_pending'].includes(status)
    && tokyoMonthKey(new Date(l.verified_at)) === currentMonthKey;
}).length;
const freeQuotaLimit = 30;
const freeQuotaPct = Math.min(100, Math.round((monthlyVerified / freeQuotaLimit) * 100));
const phaseA1PaidProgress = Math.min(100, Math.round((leads.filter(isRevenueConfirmed).length / 1) * 100));

const laneRows = lanes.map((lane) => {
  const laneLeads = leads.filter((lead) => lane.statuses.includes(normalizeStatus(lead.status)));
  return {
    ...lane,
    leads: laneLeads,
    count: laneLeads.length,
    attention: laneLeads.filter((lead) => nextActionFor(lead).score >= 50).length,
  };
});

const statusRows = statusConfigs.map((status) => ({
  ...status,
  count: leads.filter((lead) => normalizeStatus(lead.status) === status.id).length,
}));
const maxStatusCount = Math.max(1, ...statusRows.map((s) => s.count));

const industryRows = Object.entries(
  leads.reduce<Record<string, number>>((acc, lead) => {
    const key = lead.industry || 'unknown';
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  }, {})
)
  .map(([id, count]) => ({ id, label: industryLabels[id] || (id === 'unknown' ? '未設定' : id), count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 7);
const maxIndustryCount = Math.max(1, ...industryRows.map((row) => row.count));

const leadSourceRows = Object.entries(
  leads.reduce<Record<string, number>>((acc, lead) => {
    const key = lead.lead_source || 'unknown';
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  }, {})
)
  .map(([id, count]) => ({ id, label: leadSourceLabels[id] || (id === 'unknown' ? '未回答' : id), count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 7);
const maxLeadSourceCount = Math.max(1, ...leadSourceRows.map((row) => row.count));

const recentTrend = Array.from({ length: 14 }, (_, i) => {
  const date = new Date(now - (13 - i) * oneDay);
  const key = tokyoDayKey(date);
  return {
    key,
    label: tokyoDate.format(date),
    count: leads.filter((lead) => tokyoDayKey(new Date(lead.created_at)) === key).length,
  };
});
const maxTrendCount = Math.max(1, ...recentTrend.map((row) => row.count));

const funnelSteps = [
  { label: '申込', count: total, color: adminColors.secondary },
  {
    label: '認証・有効',
    count: leads.filter((l) => Boolean(l.verified_at) || isPaidOpportunity(l)).length,
    color: adminColors.secondary,
  },
  {
    label: '納品済',
    count: leads.filter((l) => ['completed', 'sent', 'report_sent', 'mtg_scheduled', 'paid_report', 'implementation', 'maintenance'].includes(normalizeStatus(l.status))).length,
    color: adminColors.primary,
  },
  { label: '有償接点', count: paidOpportunityCount, color: adminColors.accent },
  { label: '入金済', count: leads.filter(isRevenueConfirmed).length, color: adminColors.secondary },
  { label: '導入・保守', count: implementationCount, color: adminColors.accent },
];
const maxFunnelCount = Math.max(1, ...funnelSteps.map((step) => step.count));

const exportRows = leads.map((lead) => {
  const status = getStatus(lead.status);
  const action = nextActionFor(lead);
  const score = leadScore(lead);
  return {
    id: String(lead.id),
    application_id: lead.application_id || '',
    company_name: lead.company_name || '',
    person_name: lead.person_name || '',
    email: lead.email || '',
    industry: industryLabels[lead.industry || ''] || lead.industry || '',
    lead_source: leadSourceLabels[lead.lead_source || ''] || lead.lead_source || '',
    lead_source_detail: lead.lead_source_detail || '',
    entry_referrer: lead.entry_referrer || '',
    plan: planLabel(lead.plan),
    status: status.label,
    amount_jpy: lead.amount_jpy || 0,
    paid_at: lead.paid_at || '',
    created_at: lead.created_at || '',
    next_action: action.label,
    urgency: action.urgency,
    priority: priorityLabel(score),
    last_error: lead.last_error || '',
  };
});
const safeExportJson = JSON.stringify(exportRows).replace(/</g, '\\u003c');
---

<AdminLayout title="リード管理" active="leads">
  <Fragment slot="header-actions">
    <div class="header-actions">
      <button class="ghost-btn" id="export-csv" type="button"><i class="fas fa-download"></i> CSV</button>
      <span class="lead-count">{total}件</span>
    </div>
  </Fragment>

  {error && <div class="admin-error">{error}</div>}

  <section class="ops-hero">
    <div class="ops-hero__main">
      <span class="eyebrow">Optiens Operating Board</span>
      <h2>今日見るべきリードと、次に動かす数字</h2>
      <p>無料診断の自動生成、有償レポート、導入支援、保守契約までを同じ画面で追います。</p>
    </div>
    <div class="ops-hero__goal">
      <span class="goal-label">Phase A1 有償案件</span>
      <strong>{leads.filter(isRevenueConfirmed).length}/1</strong>
      <div class="goal-bar"><span style={`width: ${phaseA1PaidProgress}%`}></span></div>
    </div>
  </section>

  <section class="kpi-grid" aria-label="主要KPI">
    <article class="kpi-card kpi-card--attention">
      <span class="kpi-label">要対応</span>
      <strong>{actionableCount}<span>件</span></strong>
      <small>{criticalCount}件は今日確認</small>
    </article>
    <article class="kpi-card">
      <span class="kpi-label">直近流入</span>
      <strong>{last7d}<span>件</span></strong>
      <small>30日合計 {last30d}件</small>
    </article>
    <article class="kpi-card">
      <span class="kpi-label">有償接点</span>
      <strong>{paidOpportunityCount}<span>件</span></strong>
      <small>入金待ち ¥{yen.format(pendingRevenue)}</small>
    </article>
    <article class="kpi-card">
      <span class="kpi-label">入金済売上</span>
      <strong>¥{yen.format(confirmedRevenue)}</strong>
      <small>詳細版・有償対応の入金確認済</small>
    </article>
    <article class="kpi-card">
      <span class="kpi-label">導入・保守</span>
      <strong>{implementationCount}<span>件</span></strong>
      <small>導入支援/保守契約フェーズ</small>
    </article>
    <article class="kpi-card">
      <span class="kpi-label">無料診断 月次枠</span>
      <strong>{monthlyVerified}<span>/{freeQuotaLimit}</span></strong>
      <div class="mini-progress"><span style={`width: ${freeQuotaPct}%`}></span></div>
    </article>
  </section>

  <div class="dashboard-grid">
    <section class="panel panel--wide">
      <div class="panel-head">
        <div>
          <span class="section-kicker">Next Actions</span>
          <h3>今日の対応キュー</h3>
        </div>
        <span class="panel-count">{actionRows.length}件表示</span>
      </div>
      {actionRows.length === 0 ? (
        <p class="empty-state">緊急対応が必要なリードはありません。</p>
      ) : (
        <div class="action-list">
          {actionRows.map(({ lead, action, score }) => {
            const status = getStatus(lead.status);
            return (
              <a href={`/admin/leads/${lead.id}`} class={`action-item action-item--${action.urgency}`}>
                <div class="action-rank">{action.due}</div>
                <div class="action-body">
                  <div class="action-title">
                    <strong>{action.label}</strong>
                    <span class="status-pill" style={`--pill:${status.color}`}>{status.shortLabel}</span>
                    <span class="priority-pill">優先度 {priorityLabel(score)}</span>
                  </div>
