        <option value="all">すべてのステータス</option>
        {statusOptions.map((status) => <option value={status.id}>{status.label}</option>)}
      </select>
      <select id="plan-filter" aria-label="プラン">
        <option value="all">すべてのプラン</option>
        <option value="free">簡易版</option>
        <option value="paid">詳細版</option>
      </select>
      <div class="quick-filters" role="group" aria-label="クイックフィルタ">
        <button class="quick-filter active" type="button" data-filter="all">全件</button>
        <button class="quick-filter" type="button" data-filter="action">要対応</button>
        <button class="quick-filter" type="button" data-filter="ai-error">AIエラー</button>
        <button class="quick-filter" type="button" data-filter="paid">有償</button>
        <button class="quick-filter" type="button" data-filter="delivered">納品済</button>
      </div>
    </div>

    <div class="table-wrap">
      <table class="leads-table">
        <thead>
          <tr>
            <th>対応</th>
            <th>企業</th>
            <th>状態</th>
            <th>プラン</th>
            <th>優先度</th>
            <th>申込日</th>
            <th>金額</th>
            <th>詳細</th>
          </tr>
        </thead>
        <tbody id="lead-table-body">
          {leads.map((lead) => {
            const status = getStatus(lead.status);
            const action = nextActionFor(lead);
            const score = leadScore(lead);
            const delivered = ['completed', 'sent', 'report_sent', 'mtg_scheduled', 'paid_report', 'implementation', 'maintenance'].includes(normalizeStatus(lead.status));
            const searchText = [
              lead.application_id,
              lead.company_name,
              lead.person_name,
              lead.email,
              industryLabels[lead.industry || ''] || lead.industry,
              leadSourceLabels[lead.lead_source || ''] || lead.lead_source,
              lead.lead_source_detail,
              status.label,
              action.label,
            ].filter(Boolean).join(' ').toLowerCase();
            return (
              <tr
                class="lead-row"
                data-id={lead.id}
                data-href={`/admin/leads/${lead.id}`}
                data-search={searchText}
                data-status={normalizeStatus(lead.status)}
                data-plan={lead.plan || 'free'}
                data-actionable={action.score >= 50 ? 'true' : 'false'}
                data-ai-error={hasAiIssue(lead) ? 'true' : 'false'}
                data-paid={isPaidOpportunity(lead) ? 'true' : 'false'}
                data-delivered={delivered ? 'true' : 'false'}
              >
                <td>
                  <strong class={`urgency urgency--${action.urgency}`}>{action.label}</strong>
                  <small>{action.due}</small>
                  {lead.last_error && <small class="error-snippet">AI: {truncate(lead.last_error, 70)}</small>}
                </td>
                <td class="td-company">
                  <strong>{lead.company_name || '企業名未設定'}</strong>
                  <span>{lead.person_name || '担当者未設定'} / {industryLabels[lead.industry || ''] || '業種未設定'}</span>
                  {lead.lead_source && <span>きっかけ: {leadSourceLabels[lead.lead_source] || lead.lead_source}</span>}
                  <em>{lead.application_id || '申込番号なし'}</em>
                </td>
                <td><span class="status-pill" style={`--pill:${status.color}`}>{status.label}</span></td>
                <td><span class={`plan-pill plan-pill--${lead.plan === 'paid' ? 'paid' : 'free'}`}>{planLabel(lead.plan)}</span></td>
                <td>
                  <span class={`score-pill score-pill--${priorityLabel(score)}`}>{priorityLabel(score)}</span>
                  <small>{score}/100</small>
                </td>
                <td>{formatDate(lead.created_at)}</td>
                <td>¥{yen.format(lead.amount_jpy || 0)}</td>
                <td><a class="row-link" href={`/admin/leads/${lead.id}`}>開く</a></td>
              </tr>
            );
          })}
          {leads.length === 0 && <tr><td colspan="8" class="td-empty">リードがありません</td></tr>}
        </tbody>
      </table>
    </div>
  </section>

  <script type="application/json" id="lead-export-data" set:html={safeExportJson}></script>
</AdminLayout>

<script is:inline>
  (function() {
    const rows = Array.from(document.querySelectorAll('.lead-row'));
    const search = document.getElementById('lead-search');
    const statusFilter = document.getElementById('status-filter');
    const planFilter = document.getElementById('plan-filter');
    const visibleCount = document.getElementById('visible-count');
    const exportBtn = document.getElementById('export-csv');
    const quickButtons = Array.from(document.querySelectorAll('.quick-filter'));
    const rawData = document.getElementById('lead-export-data')?.textContent || '[]';
    let exportData = [];
    let quickFilter = 'all';

    try {
      exportData = JSON.parse(rawData);
    } catch {
      exportData = [];
    }

    function matchesQuick(row) {
      if (quickFilter === 'action') return row.dataset.actionable === 'true';
      if (quickFilter === 'ai-error') return row.dataset.aiError === 'true';
      if (quickFilter === 'paid') return row.dataset.paid === 'true';
      if (quickFilter === 'delivered') return row.dataset.delivered === 'true';
      return true;
    }

    function applyFilters() {
      const q = (search?.value || '').trim().toLowerCase();
      const status = statusFilter?.value || 'all';
      const plan = planFilter?.value || 'all';
      let count = 0;

      rows.forEach((row) => {
        const ok = (!q || (row.dataset.search || '').includes(q))
          && (status === 'all' || row.dataset.status === status)
          && (plan === 'all' || row.dataset.plan === plan)
          && matchesQuick(row);
        row.hidden = !ok;
        if (ok) count += 1;
      });

      if (visibleCount) visibleCount.textContent = String(count);
    }

    function csvCell(value) {
      const text = String(value ?? '');
      return `"${text.replaceAll('"', '""')}"`;
    }

    function exportVisibleCsv() {
      const visibleIds = new Set(rows.filter((row) => !row.hidden).map((row) => row.dataset.id));
      const filtered = exportData.filter((row) => visibleIds.has(String(row.id)));
      const headers = ['id', 'application_id', 'company_name', 'person_name', 'email', 'industry', 'lead_source', 'lead_source_detail', 'entry_referrer', 'plan', 'status', 'amount_jpy', 'paid_at', 'created_at', 'next_action', 'urgency', 'priority', 'last_error'];
      const lines = [
        headers.join(','),
        ...filtered.map((row) => headers.map((key) => csvCell(row[key])).join(',')),
      ];
      const blob = new Blob(['\ufeff' + lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `optiens-leads-${new Date().toISOString().slice(0, 10)}.csv`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    }

    search?.addEventListener('input', applyFilters);
    statusFilter?.addEventListener('change', applyFilters);
    planFilter?.addEventListener('change', applyFilters);
    exportBtn?.addEventListener('click', exportVisibleCsv);
    quickButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        quickButtons.forEach((item) => item.classList.remove('active'));
        btn.classList.add('active');
        quickFilter = btn.dataset.filter || 'all';
        applyFilters();
      });
    });

    rows.forEach((row) => {
      row.addEventListener('click', (event) => {
        if (event.target.closest('a, button, input, select')) return;
        window.location.href = row.dataset.href;
      });
    });

    applyFilters();
  })();
</script>

