---
import Layout from '../layouts/Layout.astro';
import poster from '../assets/about-poster.jpg?url';
---

<Layout title="会社情報 | Optiens">
  <main>
    <!-- ===== Hero（動画） ===== -->
    <section
      class="about-hero-section"
      style={`--hero-poster: url(${poster});`}
    >
      <video
        autoplay muted loop playsinline preload="metadata"
        poster={poster} aria-hidden="true"
      >
        <source src="/videos/about_compressed.webm" type="video/webm" />
        <source src="/videos/about_compressed.mp4" type="video/mp4" />
        お使いのブラウザは動画タグをサポートしていません。
      </video>

      <div class="hero-content">
        <div class="container text-center">
          <h1>ABOUT</h1>
          <p>持続可能な循環社会へ</p>
        </div>
      </div>
    </section>

    <!-- ===== Content ===== -->
    <section class="about-content-section">
      <div class="container">

        <!-- ミニ・ヒーロー（About専用の軽量版） -->
        <section class="hero-container hero-container--inline">
          <div class="hero-block">
            <div class="hero-title">
              <p class="eyebrow">GRAND VISION</p>
              <h2 class="hero-lead hero-lead--xl">
                DESIGNING A FUTURE WHERE PEOPLE<br/>
                AND THE PLANET THRIVE TOGETHER.
              </h2>
            </div>
            <p class="hero-lead hero-lead--sm">
              人と地球が共に豊かになる未来をデザインする。
            </p>
          </div>
        </section>

        <!-- 1) Optiensの由来 -->
        <section class="about-origin">
          <h2>Optiensについて</h2></p>
            <p>Optiens（オプティエンス） は <strong>Optimization（最適化）</strong> と <strong>Ensō（円相）</strong>を重ねた造語です。</p>
            <p>円は平面ではなく、<strong>新しい情報を取り入れて上昇し続ける立体の螺旋</strong>として捉えています。</p>
            <p>それは閉じて完結する形ではなく、<strong>次の世代へ繋ぐための象徴</strong>として考えています。</p>
            <p>既成概念を見直し、<strong>社会や暮らしの仕組みを最適化していく</strong>ことが私たちのミッションです。</p>
        </section>

        <!-- 2) 代表メッセージ -->
        <section class="founder-letter">
          <h2>代表メッセージ</h2>
          <p class="lede">クローズドループ農業で、宇宙と地上の食料自給を日常に。</p>

          <p>
            Optiensは、土壌・気候・水に強く依存する従来モデルを越え、低電力設計 × AI制御 × 運用SaaS を核にした閉鎖循環型の水耕モジュールを開発しています。<br/>
            エネルギー・水・栄養・CO₂・廃熱の循環を一体で設計し、どこでも再現性高く食料を生み出す――それが私たちの解く課題です。<br/>
            この技術は単なる栽培設備ではなく、孤立環境で人が生きるためのインフラです。<br/>
            病院や防災拠点、離島・船舶、砂漠地域から宇宙まで、同じアーキテクチャで拡張できるデュアルユースを前提にしています。
          </p>
          <p>
            私たちは、①低電力・高効率、②衛生性と冗長性、③モジュール化と保守性、④開かれたインターフェース、⑤LCAに基づく透明な評価を設計原則とし、現場を止めない遠隔監視と予防保全で運用を支えます。
          </p>
          <p>
            まずは地上MVPで電力・水・LCAを実証し、医療・防災・教育など公共性の高い領域から実装。<br/>
            その先に、軌道上の小型実験、月周回・月面での展開を段階的に進めます。各ステップでデータを公開し、検証と改善を積み重ねます。
          </p>
          <p>
            10年先、100年先も「安心して食べられる環境」を残すために。<br/>
            Optiensは、農業を環境に左右される営みから設計・運用できる社会的インフラへアップデートします。ともに実装を進めていきましょう。
          </p>
        </section>
      </div>
    </section>
  </main>
</Layout>

<style>
/* =========================================================
   About 上部の動画ヒーロー（既存の見た目を維持）
   ========================================================= */
.about-hero-section{
  position: relative;
  overflow: hidden;
  min-height: clamp(480px, 66svh, 80svh);
  display: flex; align-items: center; justify-content: center;
  background-image: var(--hero-poster),
                    var(--brand-gradient, linear-gradient(135deg,#2e574c,#5ea89a));
  background-size: cover; background-position: center; background-repeat: no-repeat;
  color: var(--on-hero, #fff);
}
.about-hero-section::before{ content:''; position:absolute; inset:0; background: rgba(0,0,0,.45); z-index:1; }
.about-hero-section video{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0; pointer-events:none; }
.about-hero-section .hero-content{ position:relative; z-index:2; padding: clamp(56px, 8vw, 112px) 20px; width:100%; text-align:center; }
.about-hero-section .hero-content h1{ font-size: clamp(28px, 6vw, 56px); line-height:1.15; margin:0 0 12px; color:#fff; }
.about-hero-section .hero-content p{ font-size: clamp(14px, 2vw, 18px); line-height:1.7; max-width: 900px; margin:0 auto; color:#fff; }

/* =========================================================
   About 本文
   ========================================================= */
.about-content-section{ padding: 64px 20px; background: var(--surface, #fff); line-height:1.8; }
.about-content-section .container{ width: min(1000px, 100% - 2rem); margin-inline: auto; }

/* =========================================================
   ミニ・ヒーロー（カード）
   “列（--col-w）”を全要素で共有して左起点を完全一致
   ========================================================= */
.about-content-section .hero-container--inline{
  position: relative;
  /* コンテナ化：子孫で cqw を使って実寸参照できるようにする */
  container-type: inline-size;

  --pad-x: clamp(24px, 4vw, 40px);
  padding: var(--pad-x);

  margin-bottom: 48px;
  background: var(--surface, #fff);
  border: 1px solid color-mix(in srgb, var(--brand-2, #5ea89a) 22%, transparent);
  border-radius: 10px;
  box-shadow: 0 8px 30px rgba(0,0,0,.06);
  color: #111; text-shadow: none;

  /* 列幅（常に内側幅以下） */
  --inner-w: calc(100% - (var(--pad-x) * 2));
  --col-w: min(56rem, var(--inner-w));
}
.about-content-section .hero-container--inline::before{ display:none; }

.about-content-section .hero-container--inline .hero-block{ display:grid; gap:.75rem; box-sizing:border-box; }
.about-content-section .hero-container--inline .hero-title{ width: var(--col-w); max-width: 100%; margin-inline: auto; }
.about-content-section .hero-container--inline .eyebrow{
  margin:0 0 .75rem; text-align:left; font-size: clamp(11px, 1vw, 13px);
  letter-spacing:.18em; text-transform:uppercase; color:#76b2a8; opacity:.95;
}
.about-content-section .hero-container--inline .hero-lead{ margin:0 0 1em; line-height:1.2; letter-spacing:.02em; }
.about-content-section .hero-container--inline .hero-lead--xl{ text-align:left; font-size: clamp(28px, 3.6vw, 44px); text-wrap: balance; }

/* 日本語サブコピー：PC は右寄せ */
.about-content-section .hero-container--inline .hero-lead--sm{
  width: var(--col-w); max-width: 100%; margin-inline: auto;
  text-align: right; font-size: clamp(14px, 1.8vw, 18px);
  color:#666; font-weight:600;
}

/* =========================================================
   モバイル（<=640px）
   - 実寸（100cqw）からフォントサイズを算出
   - 1 行固定だが overflow: hidden は使わない（切れ防止）
   - GRAND VISION と左起点を揃える
   ========================================================= */
@media (max-width: 640px){
  .about-content-section .hero-container--inline{
    /* 列幅は内側幅に厳密フィット */
    --col-w: calc(100% - (var(--pad-x) * 2));
  }
  .about-content-section .hero-container--inline .hero-lead--xl{
    font-size: clamp(18px, 5.2vw, 26px);
  }
  .about-content-section .hero-container--inline .hero-lead--sm{
    width: var(--col-w); margin-inline:auto;
    text-align: left;            /* ← eyebrow と同じ左起点 */
    white-space: nowrap;         /* 常に 1 行 */

    /* ★ポイント：コンテナ実寸 100cqw から左右パディングを引いて割る
       末尾切れを避けるため安全マージンを多めに（+ 32px） */
    font-size: min(16px, calc((100cqw - (var(--pad-x) * 2) - 32px) / 18));
    line-height: 1.35;
    letter-spacing: 0;
    overflow: visible;           /* 隠さない（サイズで必ず収める） */
  }
}

/* =========================================================
   その他セクション
   ========================================================= */
.about-origin{ margin-bottom: 64px; }
.about-origin h2{ font-size: clamp(24px, 3.2vw, 32px); margin: 0 0 12px; color: var(--heading, #111); }
.about-origin p{ margin: 0 0 12px; }

.founder-letter{
  max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem;
  background: var(--surface-2, #f9f9f9); border-radius: 10px; box-shadow: 0 8px 30px rgba(0,0,0,.06);
}
.founder-letter h2{ font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; text-align: center; margin-bottom: 2rem; color:#111; }
.founder-letter .lede{ font-size: 1.2rem; font-weight: 600; text-align: center; color: var(--brand, #2e574c); margin-bottom: 2.5rem; }
.founder-letter p{ margin-bottom: 1.5rem; line-height: 1.8; color: var(--text, #1a1a1a); }

/* a11y: 動画を無効化 */
@media (prefers-reduced-motion: reduce){
  .about-hero-section video{ display:none; }
}


</style>

