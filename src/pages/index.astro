---
import Layout from '../layouts/Layout.astro';
import VideoBackgroundCanvas from '../components/VideoBackgroundCanvas.astro';
import { getCollection } from 'astro:content';
import { filterPublishedPosts } from '../lib/blog-filters';

// 最新ブログ3件（水耕系除外）
const hydroCategories = ['agriculture', 'welfare', 'social'];
const allPosts = filterPublishedPosts(await getCollection('blog'));
const latestPosts = allPosts
  .filter((p) => !hydroCategories.includes(p.data.category as string))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const fmtDate = (d: string) => {
  const date = new Date(d);
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
};

// HOME 専用 JSON-LD: WebSite + サービス
const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Optiens',
    url: 'https://optiens.com',
    inLanguage: 'ja',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'AI業務自動化支援',
    provider: { '@type': 'Organization', name: '合同会社Optiens' },
    areaServed: { '@type': 'Country', name: '日本' },
    audience: { '@type': 'BusinessAudience', name: '中小企業・小規模事業者' },
    description: 'AIエージェントによる業務自動化を、AI活用診断から導入・保守まで一貫提供。全国オンライン対応。',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'JPY',
      name: 'AI活用診断（無料）',
      url: 'https://optiens.com/free-diagnosis',
    },
  },
];
---

<Layout
  title="Optiens | 中小企業のAI業務自動化・AIエージェント導入支援（全国オンライン対応）"
  description="合同会社OptiensはAIエージェントによる業務自動化を、AI活用診断から導入・保守まで一貫提供。全国オンライン対応で、中小企業・小規模事業者の業務効率化を支援します。"
  canonical="https://optiens.com/"
  structuredData={homeSchema}
>
  <main class="home">

    <!-- ===== Hero（変更禁止のコピーを保持） ===== -->
    <section class="home-hero light-section">
      <VideoBackgroundCanvas
        id="home-hero-video"
        src="/videos/hero-bg.mp4"
        srcWebm="/videos/hero-bg.webm"
        srcAv1="/videos/hero-bg-av1.webm"
        poster="/images/hero-poster.jpg"
        overlay="brand"
      />
      <div class="hero-content">
        <div class="hero-text-block">
          <p class="hero-eyebrow">NEXT STEP WITH AI</p>
          <h1 class="hero-title">
            MAKE AI NATIVE<br/>
            TO YOUR BUSINESS.
          </h1>
          <p class="hero-sub">判断と創造に集中できる経営へ。</p>
        </div>
      </div>
    </section>

    <!-- ===== MAIN: AI支援事業（リード+CTAのみ） ===== -->
    <section class="home-main-service light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">
          AXで業務を再設計しませんか？
        </h2>
        <p class="home-ax-note">
          <strong>AX</strong>（AI Transformation）— 業務プロセスを AI が理解できる形に再設計し、人と AI が協働する仕組みへ移行する取り組み。DX の次のフェーズとして注目されています。
        </p>

        <div class="home-service-cta">
          <a href="/service" class="home-service-btn home-service-btn--primary">
            サービスを見る <span aria-hidden="true">→</span>
          </a>
          <a href="/ai-examples" class="home-service-btn home-service-btn--ghost">
            活用事例を見る <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== なぜ、いまAIなのか ===== -->
    <section class="home-why-section light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">なぜ、いまAIなのか</h2>
        <div class="home-why-grid">
          <div class="home-why-item">
            <span class="home-why-num">01</span>
            <h3>AIエージェントの台頭で、業務の在り方が変わる</h3>
            <p>質問に答えるだけでなく、業務を自律的にこなす<strong>AIエージェント</strong>が実用段階に到達しました。業務プロセスや会社資産をAIが理解できる形に<strong>最適化</strong>することが、AI時代に生き残るために必要な取り組みになります。</p>
          </div>
          <div class="home-why-item">
            <span class="home-why-num">02</span>
            <h3>高額なSaaSではなく、自社専用の仕組みを持てる</h3>
            <p>AIエージェントは登場したばかりで、大企業もまだ手探りです。鍵は<strong>AI駆動開発</strong> — 月数十万円の既製SaaSに頼らず、<strong>自社専用システム</strong>を低コストで持てる時代になりました。むしろ大企業より、意思決定が速い中小企業の方が先に動けます。</p>
          </div>
          <div class="home-why-item">
            <span class="home-why-num">03</span>
            <h3>人手だけで回す時代は終わった</h3>
            <p>労働人口は減り続け、AIは<strong>人間を超える頭脳</strong>を持ちはじめました。ジュニア層の業務はすでに代替されつつあります。「人がやるべきこと」と「AIに任せること」を<strong>再設計</strong>する段階にきています。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== なぜ、中小企業にAXか ===== -->
    <section class="home-ax-section light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">なぜ、中小企業にAXか</h2>
        <div class="home-ax-statement">
          <p>
            大企業と比べて<strong>人手や資金が限られる</strong>中小企業では、毎日の業務を効率よく進める工夫が常に求められます。
            AXは従来の業務を<strong>根本から変革・高度化</strong>するため、限られたリソースの中でも成果を出す効果的な手段になります。
          </p>
        </div>
      </div>
    </section>

    <!-- ===== 最新ブログ3件 ===== -->
    {latestPosts.length > 0 && (
      <section class="home-blog-section light-section">
        <div class="container">
          <div class="home-blog-head">
            <h2 class="home-section-heading home-section-heading--center">最新記事</h2>
            <a href="/blog" class="home-blog-all">記事一覧を見る <span aria-hidden="true">→</span></a>
          </div>
          <div class="home-blog-list">
            {latestPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="home-blog-row">
                <div class="home-blog-meta">
                  <time class="home-blog-date">{fmtDate(post.data.date)}</time>
                </div>
                <div class="home-blog-body">
                  <h3 class="home-blog-title">{post.data.title}</h3>
                  <p class="home-blog-excerpt">{post.data.excerpt}</p>
                </div>
                <span class="home-blog-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ===== Final CTA ===== -->
    <section class="home-final-cta">
      <div class="container text-center" style="position:relative; z-index:1;">
        <h2 class="reveal">まずは気軽に、AI活用診断から</h2>
        <p class="reveal final-cta-text">
          「うちの業務にAIって使えるの？」<br/>
          「何から始めればいいか分からない」<br/>
          そんな状態からで大丈夫です。<br class="pc-only" />
          フォーム入力だけで、御社専用の簡易レポートをお届けします。
        </p>
        <div class="final-cta-row reveal">
          <a href="/free-diagnosis" class="btn-primary">AI活用診断を受ける（無料）</a>
          <a href="/contact" class="btn-secondary">お問い合わせ</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
/* =========================================================
   HOME 専用スタイル（シンプル & かっこいい）
   ========================================================= */
.home {
  --home-text: #334155;
  --home-heading: #0f172a;
  --home-muted: #64748b;
  --home-border: #e2e8f0;
  --home-surface: #ffffff;
  --home-surface-2: #f8fafc;
  --home-surface-3: #f1f5f9;
  --home-brand: #1F3A93;
  --home-brand-2: #6B85C9;
}

.home .pc-only { display: inline; }
@media (max-width: 768px) {
  .home .pc-only { display: none; }
}

.home .container {
  width: min(1100px, 100% - 2rem);
  margin-inline: auto;
}

.home-eyebrow {
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--home-brand);
  font-weight: 600;
  margin: 0 0 12px;
}
.home-eyebrow--accent {
  text-align: center;
}

.home-section-eyebrow {
  text-align: center;
  font-size: clamp(13px, 1.4vw, 15px);
  font-weight: 700;
  letter-spacing: .08em;
  color: var(--brand);
  margin: 0 0 14px;
  text-transform: none;
}

.home-section-heading {
  font-size: clamp(26px, 3.6vw, 38px);
  font-weight: 800;
  letter-spacing: -.01em;
  color: var(--home-heading);
  margin: 0 0 clamp(28px, 4vw, 44px);
  line-height: 1.3;
}
.home-section-heading--center {
  text-align: center;
}

.home-why-lead {
  text-align: center;
  font-size: clamp(15px, 1.7vw, 18px);
  line-height: 1.8;
  color: var(--home-heading);
  font-weight: 600;
  margin: -20px auto clamp(36px, 5vw, 48px);
  max-width: 760px;
  letter-spacing: .01em;
}

.home-ax-note {
  text-align: center;
  /* 最終行がポツンと残らないようブラウザに行末バランス調整を任せる
     （Chrome 117+ / Firefox 121+ / Safari 17.5+。非対応ブラウザはデフォルト動作） */
  text-wrap: pretty;
  font-size: clamp(12px, 1.2vw, 13px);
  line-height: 1.85;
  color: var(--muted, #64748b);
  margin: -16px auto clamp(28px, 4vw, 36px);
  max-width: 640px;
  letter-spacing: .01em;
  /* 単語境界を意識した日本語折り返し（句読点が行頭に来るのを抑制） */
  word-break: auto-phrase;
  overflow-wrap: anywhere;
}
@media (max-width: 640px) {
  .home-ax-note {
    text-align: left;
    max-width: 100%;
    padding: 0 8px;
  }
}
.home-ax-note strong {
  color: var(--home-brand, #1F3A93);
  font-weight: 700;
}

.home-lead {
  font-size: clamp(15px, 1.7vw, 17px);
  line-height: 1.9;
  color: var(--home-text);
  text-align: center;
  margin: 0 auto clamp(36px, 5vw, 56px);
  max-width: 780px;
}
.home-lead--small {
  font-size: clamp(14px, 1.5vw, 15px);
  margin-bottom: clamp(28px, 4vw, 40px);
}

/* =========================================================
   Hero（ファーストビュー全画面・センタリング）
   ========================================================= */
.home-hero {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  min-height: 100dvh; /* モバイルでアドレスバー等を考慮 */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(90px, 11vw, 140px) 0;
  background: var(--home-surface);
  color: var(--home-text);
}
.home-hero .hero-content {
  position: relative;
  z-index: 2;
  width: min(900px, 100% - 6rem);
  margin-inline: auto;
  padding: 20px;
}
.home-hero .hero-text-block {
  /* 半透明カードで背景動画を透かしつつ可読性を確保 */
  width: fit-content;
  max-width: 100%;
  margin: 0 auto;
  padding: clamp(28px, 4vw, 48px) clamp(28px, 4vw, 56px);
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10px) saturate(130%);
  -webkit-backdrop-filter: blur(10px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 24px;
  box-shadow: 0 24px 60px -20px rgba(15, 23, 42, 0.18);
}
.home-hero .hero-eyebrow {
  display: block;
  margin: 0 0 1rem;
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--home-brand, #1F3A93);
  font-weight: 700;
  text-align: left;
}
.home-hero .hero-title {
  font-size: clamp(30px, 5vw, 60px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -.02em;
  color: var(--home-heading);
  margin: 0 0 1rem;
  text-align: left;
}
.home-hero .hero-title-accent {
  color: #E48A95;
}
.home-hero .hero-title-lapis {
  color: #1F3A93;
}
.home-hero .hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  color: #0f172a;
  margin: 0;
  font-weight: 700;
  text-align: right;
}

@media (max-width: 640px) {
  .home-hero .hero-content {
    width: 100%;
    padding: 16px;
  }
  .home-hero .hero-text-block {
    padding: 24px 20px;
  }
}

/* =========================================================
   Main Service（AI支援：リード+CTAのみ）
   ========================================================= */
.home-main-service {
  padding: clamp(80px, 11vw, 130px) 0;
  background: var(--home-surface);
  text-align: center;
}
.home-service-cta {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
  margin-top: clamp(8px, 1.5vw, 16px);
}
.home-service-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: clamp(14px, 1.5vw, 15px);
  font-weight: 700;
  letter-spacing: .04em;
  padding: 14px 30px;
  border-radius: 999px;
  text-decoration: none;
  transition: transform .2s ease, box-shadow .2s ease, background-color .2s ease, border-color .2s ease, color .2s ease;
  white-space: nowrap;
}
.home-service-btn--primary {
  background: linear-gradient(135deg, #1F3A93 0%, #6B85C9 100%);
  color: #fff;
  box-shadow: 0 10px 30px rgba(31, 58, 147, .35);
}
.home-service-btn--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 36px rgba(31, 58, 147, .45);
}
.home-service-btn--ghost {
  background: rgba(255, 255, 255, .8);
  border: 1px solid var(--home-border);
  color: var(--home-heading);
  backdrop-filter: blur(8px);
}
.home-service-btn--ghost:hover {
  background: #fff;
  border-color: var(--home-brand);
  color: var(--home-brand);
}
@media (max-width: 640px) {
  .home-service-cta { flex-direction: column; align-items: stretch; }
  .home-service-btn { width: 100%; justify-content: center; }
}

/* =========================================================
   なぜ、いまAIなのか
   ========================================================= */
.home-why-section {
  padding: clamp(60px, 8vw, 100px) 20px;
  background: var(--home-surface-2);
}
.home-why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  max-width: 1100px;
  margin: 0 auto;
}
.home-why-item {
  background: #fff;
  border: 1px solid var(--home-border);
  border-radius: 16px;
  padding: clamp(28px, 3.2vw, 36px);
  position: relative;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}
.home-why-item::before {
  content: attr(data-num);
  position: absolute;
  top: -28px;
  right: -8px;
  font-family: 'Inter', 'SF Pro Display', sans-serif;
  font-size: clamp(7rem, 12vw, 10rem);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.06em;
  color: var(--home-brand);
  opacity: 0.05;
  pointer-events: none;
  user-select: none;
}
.home-why-item:hover {
  transform: translateY(-4px);
  box-shadow: 0 18px 40px -22px rgba(31, 58, 147, 0.28);
  border-color: rgba(31, 58, 147, 0.2);
}
.home-why-num {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  font-family: 'Inter', 'SF Pro Display', 'Helvetica Neue', sans-serif;
  font-size: clamp(2.6rem, 4.2vw, 3.4rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1;
  background: linear-gradient(135deg, var(--home-brand) 0%, #4a7ba8 60%, var(--home-brand-2) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
.home-why-num::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--home-brand-2) 0%, rgba(192, 192, 192, 0) 100%);
  align-self: center;
  border-radius: 2px;
}
.home-why-item h3 {
  font-size: clamp(1.05rem, 1.7vw, 1.2rem);
  font-weight: 700;
  color: var(--home-heading);
  margin: 0 0 16px;
  line-height: 1.55;
  position: relative;
  z-index: 1;
}
.home-why-item p {
  color: var(--home-text);
  font-size: 0.93rem;
  line-height: 1.95;
  margin: 0;
  position: relative;
  z-index: 1;
}

/* =========================================================
   なぜ、中小企業にAXか（課題→解決の2カードフロー）
   ========================================================= */
.home-ax-section {
  padding: clamp(60px, 8vw, 100px) 20px;
  background: var(--home-surface);
}
.home-ax-statement {
  position: relative;
  max-width: 960px;
  margin: clamp(36px, 5vw, 48px) auto 0;
  padding: clamp(44px, 5.5vw, 72px) clamp(32px, 4.5vw, 72px);
  border-radius: 28px;
  background:
    linear-gradient(135deg, rgba(31, 58, 147, 0.035) 0%, rgba(255, 255, 255, 0) 40%, rgba(228, 138, 149, 0.04) 100%),
    #ffffff;
  border: 1px solid rgba(31, 58, 147, 0.08);
  box-shadow:
    0 1px 2px rgba(15, 23, 42, 0.04),
    0 28px 56px -36px rgba(31, 58, 147, 0.22);
  overflow: hidden;
  isolation: isolate;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}
.home-ax-statement:hover {
  transform: translateY(-2px);
  box-shadow:
    0 1px 2px rgba(15, 23, 42, 0.04),
    0 36px 72px -36px rgba(31, 58, 147, 0.28);
}
.home-ax-statement::before {
  /* 右上の装飾円（桜・ぼかし） */
  content: '';
  position: absolute;
  top: -120px;
  right: -120px;
  width: 320px;
  height: 320px;
  background: radial-gradient(circle, rgba(228, 138, 149, 0.18) 0%, rgba(228, 138, 149, 0) 65%);
  border-radius: 50%;
  z-index: -1;
  pointer-events: none;
}
.home-ax-statement::after {
  /* 左下の装飾円（ラピス・ぼかし） */
  content: '';
  position: absolute;
  bottom: -140px;
  left: -100px;
  width: 360px;
  height: 360px;
  background: radial-gradient(circle, rgba(31, 58, 147, 0.10) 0%, rgba(31, 58, 147, 0) 65%);
  border-radius: 50%;
  z-index: -1;
  pointer-events: none;
}
.home-ax-statement p {
  font-size: clamp(17px, 2vw, 22px);
  line-height: 2.1;
  color: var(--home-text);
  margin: 0;
  text-align: left;
  position: relative;
  z-index: 1;
}
.home-ax-statement p strong {
  color: #1F3A93;
  font-weight: 700;
  background: linear-gradient(180deg, transparent 0%, transparent 65%, rgba(228, 138, 149, 0.22) 65%, rgba(228, 138, 149, 0.22) 100%);
  padding: 0 2px;
}

.home-section-heading-ax {
  display: block;
  font-size: clamp(11px, 1.2vw, 13px);
  font-weight: 500;
  color: var(--home-muted);
  letter-spacing: 0.08em;
  margin-top: 8px;
  text-transform: none;
}

/* =========================================================
   最新ブログ3件
   ========================================================= */
.home-blog-section {
  padding: clamp(60px, 8vw, 100px) 20px;
  background: var(--home-surface-2);
}
.home-blog-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: clamp(28px, 4vw, 40px);
  max-width: 880px;
  margin-inline: auto;
  flex-wrap: wrap;
  gap: 12px;
}
.home-blog-head .home-section-heading {
  margin: 0;
}
.home-blog-all {
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--home-brand);
  text-decoration: none;
  letter-spacing: 0.04em;
}
.home-blog-all:hover {
  color: var(--home-brand-2);
}
.home-blog-list {
  max-width: 880px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.home-blog-row {
  display: grid;
  grid-template-columns: 110px 1fr 24px;
  gap: 24px;
  align-items: center;
  padding: 24px 28px;
  background: #fff;
  border: 1px solid var(--home-border);
  border-bottom: none;
  text-decoration: none;
  color: inherit;
  transition: background 0.2s ease;
}
.home-blog-row:first-child {
  border-radius: 12px 12px 0 0;
}
.home-blog-row:last-child {
  border-bottom: 1px solid var(--home-border);
