---
import Layout from '../layouts/Layout.astro';
import VideoBackgroundCanvas from '../components/VideoBackgroundCanvas.astro';

// HOME 専用 JSON-LD: WebSite + サービス
const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Optiens',
    url: 'https://optiens.com',
    inLanguage: 'ja',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'AI業務自動化支援',
    provider: { '@type': 'Organization', name: '合同会社Optiens' },
    areaServed: { '@type': 'Country', name: '日本' },
    audience: { '@type': 'BusinessAudience', name: '中小企業・小規模事業者' },
    description: 'AIエージェントによる業務自動化を、無料診断から導入・保守まで一貫提供。全国オンライン対応。',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'JPY',
      name: 'AI活用診断（無料）',
      url: 'https://optiens.com/free-diagnosis',
    },
  },
];
---

<Layout
  title="Optiens | 中小企業のAI業務自動化・AIエージェント導入支援（全国オンライン対応）"
  description="合同会社OptiensはAIエージェントによる業務自動化を、無料診断から導入・保守まで一貫提供。全国オンライン対応で、中小企業・小規模事業者の業務効率化を支援します。"
  canonical="https://optiens.com/"
  structuredData={homeSchema}
>
  <main class="home">

    <!-- ===== Hero（変更禁止のコピーを保持） ===== -->
    <section class="home-hero light-section">
      <VideoBackgroundCanvas
        id="home-hero-video"
        src="/videos/hero-bg.mp4"
        srcWebm="/videos/hero-bg.webm"
        srcAv1="/videos/hero-bg-av1.webm"
        poster="/images/hero-poster.jpg"
        overlay="brand"
      />
      <div class="hero-content">
        <div class="hero-text-block">
          <p class="hero-eyebrow">NEXT STEP WITH AI</p>
          <h1 class="hero-title">
            MAKE AI NATIVE<br/>
            TO YOUR BUSINESS.
          </h1>
          <p class="hero-sub">AIを事業の中心に。</p>
        </div>
      </div>
    </section>

    <!-- ===== MAIN: AI支援事業（リード+CTAのみ） ===== -->
    <section class="home-main-service light-section">
      <div class="container">
        <h2 class="home-section-heading home-section-heading--center">
          AXで、業務を再設計する
          <span class="home-section-heading-ax">AX = AI Transformation（AIによる業務変革）</span>
        </h2>
        <p class="home-lead">
          <strong>従業員数50名以下の事業者の方へ。</strong><br class="pc-only" />
          AXで、業務を再設計しませんか？
        </p>

        <div class="home-service-cta">
          <a href="/service" class="home-service-btn home-service-btn--primary">
            サービスを見る <span aria-hidden="true">→</span>
          </a>
          <a href="/ai-examples" class="home-service-btn home-service-btn--ghost">
            活用事例を見る <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== Final CTA ===== -->
    <section class="home-final-cta">
      <div class="container text-center" style="position:relative; z-index:1;">
        <h2 class="reveal">まずは気軽に、無料AI診断から</h2>
        <p class="reveal final-cta-text">
          「うちの業務にAIって使えるの？」<br/>
          「何から始めればいいか分からない」<br/>
          そんな状態からで大丈夫です。<br class="pc-only" />
          フォーム入力だけで、御社向けの簡易レポートをお届けします。
        </p>
        <div class="final-cta-row reveal">
          <a href="/free-diagnosis" class="btn-primary">無料AI診断を受ける</a>
          <a href="/contact" class="btn-secondary">お問い合わせ</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
/* =========================================================
   HOME 専用スタイル（シンプル & かっこいい）
   ========================================================= */
.home {
  --home-text: #334155;
  --home-heading: #0f172a;
  --home-muted: #64748b;
  --home-border: #e2e8f0;
  --home-surface: #ffffff;
  --home-surface-2: #f8fafc;
  --home-surface-3: #f1f5f9;
  --home-brand: #A259FF;
  --home-brand-2: #1ABCFE;
}

.home .pc-only { display: inline; }
@media (max-width: 768px) {
  .home .pc-only { display: none; }
}

.home .container {
  width: min(1100px, 100% - 2rem);
  margin-inline: auto;
}

.home-eyebrow {
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--home-brand);
  font-weight: 600;
  margin: 0 0 12px;
}
.home-eyebrow--accent {
  text-align: center;
}

.home-section-heading {
  font-size: clamp(26px, 3.6vw, 38px);
  font-weight: 800;
  letter-spacing: -.01em;
  color: var(--home-heading);
  margin: 0 0 clamp(28px, 4vw, 44px);
  line-height: 1.3;
}
.home-section-heading--center {
  text-align: center;
}

.home-lead {
  font-size: clamp(15px, 1.7vw, 17px);
  line-height: 1.9;
  color: var(--home-text);
  text-align: center;
  margin: 0 auto clamp(36px, 5vw, 56px);
  max-width: 780px;
}
.home-lead--small {
  font-size: clamp(14px, 1.5vw, 15px);
  margin-bottom: clamp(28px, 4vw, 40px);
}

/* =========================================================
   Hero（ファーストビュー全画面・センタリング）
   ========================================================= */
.home-hero {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  min-height: 100dvh; /* モバイルでアドレスバー等を考慮 */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(90px, 11vw, 140px) 0;
  background: var(--home-surface);
  color: var(--home-text);
}
.home-hero .hero-content {
  position: relative;
  z-index: 2;
  width: min(900px, 100% - 6rem);
  margin-inline: auto;
  padding: 20px;
}
.home-hero .hero-text-block {
  width: fit-content;
  margin: 0 auto;
}
.home-hero .hero-eyebrow {
  display: block;
  margin: 0 0 1rem;
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: #6E2BC9; /* 濃い紫で動画背景上でもコントラスト確保 */
  font-weight: 700;
  text-align: left;
  text-shadow: 0 1px 6px rgba(255, 255, 255, 0.65), 0 0 18px rgba(255, 255, 255, 0.4);
}
.home-hero .hero-title {
  font-size: clamp(30px, 5vw, 60px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -.02em;
  color: var(--home-heading);
  margin: 0 0 1rem;
  text-align: left;
  text-shadow: 0 2px 10px rgba(255, 255, 255, 0.45);
}
.home-hero .hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  color: #0f172a; /* 黒に近い濃グレーで可読性確保 */
  margin: 0;
  font-weight: 700;
  text-align: right;
  text-shadow: 0 1px 6px rgba(255, 255, 255, 0.65), 0 0 18px rgba(255, 255, 255, 0.4);
}

@media (max-width: 640px) {
  .home-hero .hero-content {
    width: 100%;
    padding: 16px;
  }
}

/* =========================================================
   Main Service（AI支援：リード+CTAのみ）
   ========================================================= */
.home-main-service {
  padding: clamp(80px, 11vw, 130px) 0;
  background: var(--home-surface);
  text-align: center;
}
.home-service-cta {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
  margin-top: clamp(8px, 1.5vw, 16px);
}
.home-service-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: clamp(14px, 1.5vw, 15px);
  font-weight: 700;
  letter-spacing: .04em;
  padding: 14px 30px;
  border-radius: 999px;
  text-decoration: none;
  transition: transform .2s ease, box-shadow .2s ease, background-color .2s ease, border-color .2s ease, color .2s ease;
  white-space: nowrap;
}
.home-service-btn--primary {
  background: linear-gradient(135deg, #A259FF 0%, #1ABCFE 100%);
  color: #fff;
  box-shadow: 0 10px 30px rgba(162, 89, 255, .35);
}
.home-service-btn--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 36px rgba(162, 89, 255, .45);
}
.home-service-btn--ghost {
  background: rgba(255, 255, 255, .8);
  border: 1px solid var(--home-border);
  color: var(--home-heading);
  backdrop-filter: blur(8px);
}
.home-service-btn--ghost:hover {
  background: #fff;
  border-color: var(--home-brand);
  color: var(--home-brand);
}
@media (max-width: 640px) {
  .home-service-cta { flex-direction: column; align-items: stretch; }
  .home-service-btn { width: 100%; justify-content: center; }
}

/* =========================================================
   Final CTA
   ========================================================= */
.home-final-cta {
  position: relative;
  padding: clamp(80px, 11vw, 130px) 20px;
  background: var(--home-surface);
  color: var(--home-text);
  overflow: hidden;
}
.home-final-cta h2 {
  font-size: clamp(24px, 3.4vw, 36px);
  font-weight: 800;
  letter-spacing: -.01em;
  color: var(--home-heading);
  margin: 0 0 18px;
  line-height: 1.3;
}
.home-final-cta p {
  font-size: clamp(14px, 1.6vw, 16px);
  color: var(--home-muted);
  line-height: 1.9;
  margin: 0 0 32px;
  max-width: 680px;
  margin-inline: auto;
}
.final-cta-row {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
}
.final-cta-row .btn-primary {
  background: linear-gradient(135deg, #A259FF 0%, #1ABCFE 100%);
  color: #fff;
  box-shadow: 0 10px 30px rgba(162, 89, 255, .4);
  font-weight: 700;
  padding: 14px 30px;
  border-radius: 999px;
  text-decoration: none;
  letter-spacing: .04em;
  transition: transform .2s ease, box-shadow .2s ease;
}
.final-cta-row .btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 36px rgba(162, 89, 255, .5);
}
.final-cta-row .btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  padding: 14px 30px;
  border-radius: 999px;
  text-decoration: none;
  letter-spacing: .04em;
  background: rgba(255, 255, 255, .8);
  border: 1px solid var(--home-border);
  color: var(--home-heading);
  backdrop-filter: blur(8px);
  transition: background-color .2s ease, border-color .2s ease, color .2s ease, transform .2s ease;
}
.final-cta-row .btn-secondary:hover {
  background: #fff;
  border-color: var(--home-brand);
  color: var(--home-brand);
  transform: translateY(-1px);
}

/* Reveal helper（Layoutで実装済みのIntersectionObserverに反応） */
.reveal {
  opacity: 0;
  transform: translateY(12px);
  transition: opacity .6s ease, transform .6s ease;
}
.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
